<UserControl x:Class="Companion.App.Controls.CampaignTimelineStrip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Companion.ViewModels.Services;assembly=Companion.ViewModels"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <UserControl.Resources>
        <!-- the Dynasty locked-season tooltip: everything the pinned pack declares about itself
             (venues + teams), display-only. One shared implicit template for every slot. -->
        <DataTemplate DataType="{x:Type services:CampaignSeasonPreview}">
            <StackPanel MaxWidth="300">
                <TextBlock Text="COMING UP" Style="{StaticResource Eyebrow}" />
                <TextBlock FontWeight="SemiBold" Margin="0,3,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} · {1}">
                            <Binding Path="Year" />
                            <Binding Path="SeriesName" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
                <TextBlock Text="Venues" Style="{StaticResource Faint}" Margin="0,6,0,1" />
                <ItemsControl ItemsSource="{Binding Venues}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource Faint}"
                                       FontSize="9.5" Margin="0,0,8,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="Teams" Style="{StaticResource Faint}" Margin="0,5,0,1" />
                <ItemsControl ItemsSource="{Binding Teams}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource Faint}"
                                       FontSize="9.5" Margin="0,0,8,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <!-- The whole campaign arc as one horizontal strip of season slots (codex-gui-smgp300-brief.md
         §4): SMGP's 17 seasons, a bounded Dynasty horizon headed by its synthetic Formula Junior
         prologue, or only the played seasons of a legacy career. Session + RoundText are bridged
         from the live Hub, with the tagged tear-off Window as the established fallback; the
         converter re-reads ICareerSession.CampaignTimeline() whenever the MultiBinding invalidates.
         An empty timeline (no pinned horizon, no session) collapses the strip outright.
         Slot states: Completed shows the outcome (position / champion / honest injury absence),
         Current glows, Locked stays muted. SMGP locked slots arrive with no title, era or year
         (the backend's no-spoiler rule) and render as anonymous ordinal chips; Dynasty locked slots
         carry a pack-level Preview (historical years are real-world known) shown on the card, with
         venues + teams on the tooltip. The ordinal-0 prologue renders as a distinct coming-soon
         card, never a playable season. -->
    <Border x:Name="CampaignTimelinePanel"
            Padding="15,12"
            AutomationProperties.Name="Campaign season timeline">
        <Border.DataContext>
            <MultiBinding Converter="{StaticResource CampaignTimeline}">
                <Binding Path="DataContext.Home.Session"
                         RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                <Binding Path="DataContext.Home.RoundText"
                         RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                <Binding Path="Tag.Home.Session"
                         RelativeSource="{RelativeSource AncestorType=Window}" />
                <Binding Path="Tag.Home.RoundText"
                         RelativeSource="{RelativeSource AncestorType=Window}" />
            </MultiBinding>
        </Border.DataContext>
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource Panel}">
                <Setter Property="Visibility" Value="Visible" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Count}" Value="0">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel>
            <!-- the header text is set in code-behind: it counts real seasons only, never the
                 synthetic prologue slot -->
            <TextBlock x:Name="CampaignTimelineHeader" Style="{StaticResource Eyebrow}"
                       Foreground="{DynamicResource AccentTextBrush}" />
            <TextBlock Text="Every summer stays on the record, including seasons changed by injury."
                       Style="{StaticResource Muted}" Margin="0,3,0,9" TextWrapping="Wrap" />
            <ScrollViewer x:Name="CampaignTimelineScroll"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Focusable="True" IsTabStop="True"
                          AutomationProperties.Name="Campaign season timeline"
                          AutomationProperties.HelpText="Use the arrow keys to review every campaign season.">
                <ItemsControl x:Name="CampaignTimelineSlots" ItemsSource="{Binding}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="9,7" Margin="0,0,6,4"
                                    CornerRadius="7" VerticalAlignment="Top"
                                    ToolTip="{Binding Preview}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <!-- Locked/future seasons without a preview are anonymous
                                             placeholders: a compact chip, so many of them don't blow
                                             out the strip. Slots carrying real content (current,
                                             completed, previewed, prologue) get a full card. The
                                             BorderThickness lives in the style (never a local value)
                                             so the current slot's 2px accent border can land. -->
                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Opacity" Value="0.5" />
                                        <Setter Property="Width" Value="88" />
                                        <Setter Property="MinHeight" Value="46" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State}"
                                                         Value="{x:Static services:CampaignSeasonState.Current}">
                                                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="Width" Value="168" />
                                                <Setter Property="MinHeight" Value="104" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding State}"
                                                         Value="{x:Static services:CampaignSeasonState.Completed}">
                                                <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="Width" Value="168" />
                                                <Setter Property="MinHeight" Value="104" />
                                            </DataTrigger>
                                            <!-- Dynasty locked seasons carry a pack-level preview: the
                                                 slot grows to a full card to show it. -->
                                            <DataTrigger Binding="{Binding Preview, Converter={StaticResource NullCollapsed}}"
                                                         Value="Visible">
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="Width" Value="168" />
                                                <Setter Property="MinHeight" Value="104" />
                                            </DataTrigger>
                                            <!-- The synthetic ordinal-0 Formula Junior prologue is a
                                                 distinct coming-soon card, never a playable season. -->
                                            <DataTrigger Binding="{Binding IsPrologue}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="Width" Value="168" />
                                                <Setter Property="MinHeight" Value="104" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Year}"
                                                   Style="{StaticResource Mono}" FontSize="9.5"
                                                   Visibility="{Binding Year, Converter={StaticResource NullCollapsed}}" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Preview.Year}"
                                                   Style="{StaticResource Mono}" FontSize="9.5"
                                                   Visibility="{Binding Preview, Converter={StaticResource NullCollapsed}}" />
                                        <TextBlock Text="{Binding Ordinal, StringFormat=SEASON {0}}"
                                                   Style="{StaticResource PixelBadge}"
                                                   Visibility="{Binding IsPrologue, Converter={StaticResource BoolCollapsed}}" />
                                        <TextBlock Text="PROLOGUE" Style="{StaticResource PixelBadge}"
                                                   Foreground="{DynamicResource WarningBrush}"
                                                   Visibility="{Binding IsPrologue, Converter={StaticResource BoolVisible}}" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"
                                               TextWrapping="Wrap" TextTrimming="None" Margin="0,5,0,0"
                                               Visibility="{Binding Title, Converter={StaticResource StringVisible}}" />
                                    <TextBlock Text="{Binding Era}" Style="{StaticResource Faint}" FontSize="9.5"
                                               TextWrapping="Wrap" TextTrimming="None" Margin="0,2,0,0"
                                               Visibility="{Binding Era, Converter={StaticResource StringVisible}}" />
                                    <!-- Dynasty locked-season preview: the pack's identity, no play entry -->
                                    <TextBlock Text="{Binding Preview.SeriesName}" FontWeight="SemiBold" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,5,0,0"
                                               Visibility="{Binding Preview, Converter={StaticResource NullCollapsed}}" />
                                    <TextBlock Style="{StaticResource Faint}" FontSize="9.5" Margin="0,2,0,0"
                                               Visibility="{Binding Preview, Converter={StaticResource NullCollapsed}}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} · {1} rounds">
                                                <Binding Path="Preview.EraLabel" />
                                                <Binding Path="Preview.RoundCount" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <WrapPanel Margin="0,7,0,0">
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,5,4"
                                                Background="{DynamicResource AccentDimBrush}"
                                                BorderBrush="{DynamicResource AccentBrush}"
                                                Visibility="{Binding State, Converter={StaticResource EnumVisible},
                                                                     ConverterParameter={x:Static services:CampaignSeasonState.Current}}">
                                            <TextBlock Text="CURRENT" Style="{StaticResource PixelBadge}"
                                                       Foreground="{DynamicResource AccentTextBrush}" />
                                        </Border>
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,5,4"
                                                Visibility="{Binding PlayerPosition, Converter={StaticResource NullCollapsed}}">
                                            <TextBlock Text="{Binding PlayerPosition, StringFormat=P{0}}"
                                                       Style="{StaticResource Mono}" FontSize="9.5" />
                                        </Border>
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,5,4"
                                                Background="{DynamicResource SuccessDimBrush}"
                                                BorderBrush="{DynamicResource SuccessBrush}"
                                                Visibility="{Binding PlayerChampion, Converter={StaticResource BoolVisible}}">
                                            <TextBlock Text="CHAMPION" Style="{StaticResource PixelBadge}"
                                                       Foreground="{DynamicResource SuccessBrush}" />
                                        </Border>
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,5,4"
                                                Background="{DynamicResource WarningDimBrush}"
                                                BorderBrush="{DynamicResource WarningBrush}"
                                                Visibility="{Binding MissedRounds, Converter={StaticResource BoolVisible}}">
                                            <TextBlock Text="INJURY ABSENCE" Style="{StaticResource PixelBadge}"
                                                       Foreground="{DynamicResource WarningBrush}" />
                                        </Border>
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,5,4"
                                                Background="{DynamicResource WarningDimBrush}"
                                                BorderBrush="{DynamicResource WarningBrush}"
                                                Visibility="{Binding IsPrologue, Converter={StaticResource BoolVisible}}">
                                            <TextBlock Text="COMING SOON" Style="{StaticResource PixelBadge}"
                                                       Foreground="{DynamicResource WarningBrush}" />
                                        </Border>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
