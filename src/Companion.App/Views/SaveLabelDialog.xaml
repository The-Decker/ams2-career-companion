<Window x:Class="Companion.App.Views.SaveLabelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Companion.App"
        xmlns:audio="clr-namespace:Companion.App.Audio"
        Title="Name save point"
        Width="440" SizeToContent="Height" ResizeMode="NoResize" WindowStyle="None"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}" FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource SurfaceBrush}">
    <Grid Background="{StaticResource AppTextureBrush}">
        <Border Background="{StaticResource AppVignetteBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Height="38" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                        app:WindowChromeAssist.IsDragRegion="True">
                    <DockPanel Margin="12,3,4,3">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}"
                                audio:SoundAssist.Cue="Back"
                                app:WindowChromeAssist.IsCloseButton="True"
                                AutomationProperties.Name="Close save label dialog" />
                        <TextBlock Text="NAME THIS SAVE POINT" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <StackPanel Margin="22,20,22,22">
                    <TextBlock Text="SAVE LABEL" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                    <TextBox x:Name="LabelBox" FontSize="15" MaxLength="80"
                             AutomationProperties.Name="Save point label"
                             TextChanged="OnLabelChanged" />
                    <TextBlock Text="Use a short reminder such as Before Monaco or Season 2 opener."
                               Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,7,0,0" />
                    <TextBlock x:Name="ValidationText" Text="Enter a label for this save point."
                               Foreground="{DynamicResource ErrorBrush}" Margin="0,7,0,0"
                               Visibility="Collapsed" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button x:Name="SaveButton" Content="SAVE" Style="{StaticResource AccentButton}"
                                audio:SoundAssist.Cue="Confirm"
                                MinWidth="96" IsDefault="True" Click="OnSave" />
                        <Button Content="CANCEL" MinWidth="96" Margin="8,0,0,0" IsCancel="True"
                                audio:SoundAssist.Cue="Back" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
