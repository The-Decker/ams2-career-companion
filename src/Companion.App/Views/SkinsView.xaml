<UserControl x:Class="Companion.App.Views.SkinsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="GridStatusChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tone}" Value="Good">
                    <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="Warn">
                    <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="GridStatusText" TargetType="TextBlock" BasedOn="{StaticResource Faint}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tone}" Value="Good">
                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Tone}" Value="Warn">
                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PreviewFrame" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="GridSelectorItem" TargetType="ListBoxItem">
            <Setter Property="Width" Value="258" />
            <Setter Property="Height" Value="82" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="GridSelectorFrame" Padding="10,8" CornerRadius="9"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GridSelectorFrame" Property="Background"
                                        Value="{DynamicResource HoverBrush}" />
                                <Setter TargetName="GridSelectorFrame" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="GridSelectorFrame" Property="Background"
                                        Value="{DynamicResource AccentDimBrush}" />
                                <Setter TargetName="GridSelectorFrame" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="GridSelectorFrame" Property="BorderThickness"
                                        Value="2" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="GridSelectorFrame" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="SkinsScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Focusable="False">
        <Grid Margin="30,26,30,40" HorizontalAlignment="Stretch" MaxWidth="1420">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="PRE-QUALIFYING REFERENCE" Style="{StaticResource Eyebrow}"
                               Foreground="{DynamicResource AccentTextBrush}" />
                    <TextBlock x:Name="GridPreviewTitle" Text="Grid Preview"
                               Style="{StaticResource H1}" Margin="0,2,0,0" />
                    <TextBlock Text="{Binding Summary}" Style="{StaticResource Muted}"
                               TextWrapping="Wrap" Margin="0,3,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="20,0,0,0"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource CompactChip}"
                            Visibility="{Binding GridLabel, Converter={StaticResource StringVisible}}">
                        <TextBlock x:Name="GridPreviewMeta" Text="{Binding GridLabel}"
                                   Style="{StaticResource Mono}" />
                    </Border>
                    <TextBlock Text="PORTRAIT  •  TEAM  •  TOP  •  SIDE"
                               Style="{StaticResource Faint}" HorizontalAlignment="Right"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Grid>

            <Border x:Name="StagingOverridesNotice" Grid.Row="1" Style="{StaticResource WarningCallout}"
                    Margin="0,14,0,0" Padding="14,10"
                    Visibility="{Binding HasStagingOverrides, Converter={StaticResource BoolVisible}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="CLEAR LEGACY EDITS"
                            Style="{StaticResource SubtleButton}" Margin="14,0,0,0"
                            Foreground="{DynamicResource WarningBrush}"
                            Command="{Binding ClearStagingOverridesCommand}"
                            AutomationProperties.Name="Clear legacy grid staging overrides" />
                    <StackPanel>
                        <TextBlock Text="LEGACY GRID EDITS ARE ACTIVE" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource WarningBrush}" />
                        <TextBlock Text="{Binding StagingOverridesNote}" Style="{StaticResource Muted}"
                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border x:Name="SelectedCarPreview" Grid.Row="2" Margin="0,18,0,0" Padding="18"
                    CornerRadius="12" Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                    Visibility="{Binding HasSelectedCar, Converter={StaticResource BoolVisible}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="150" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="250" />
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Row="0" Grid.ColumnSpan="5">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="PreviewPreviousCarButton" Width="40" Height="34"
                                    Padding="0" Content="‹" FontSize="23"
                                    ToolTip="Previous grid car"
                                    AutomationProperties.Name="Previous grid car"
                                    audio:SoundAssist.Cue="Navigate"
                                    Command="{Binding PreviousCarCommand}" />
                            <Border Style="{StaticResource CompactChip}" Margin="7,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedPositionLabel}"
                                           Style="{StaticResource PixelBadge}" />
                            </Border>
                            <Button x:Name="PreviewNextCarButton" Width="40" Height="34"
                                    Padding="0" Content="›" FontSize="23"
                                    ToolTip="Next grid car"
                                    AutomationProperties.Name="Next grid car"
                                    audio:SoundAssist.Cue="Navigate"
                                    Command="{Binding NextCarCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCar.Number, StringFormat=CAR #{0}}"
                                       Style="{StaticResource Mono}" FontSize="13" Margin="0,0,10,0" />
                            <TextBlock Text="{Binding SelectedCar.DriverName}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold" FontSize="18" />
                            <TextBlock Text="  YOU" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       Visibility="{Binding SelectedCar.IsPlayer, Converter={StaticResource BoolVisible}}" />
                        </StackPanel>
                    </DockPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0">
                        <TextBlock Text="DRIVER PROFILE" Style="{StaticResource Eyebrow}" />
                        <Border Style="{StaticResource PreviewFrame}" Width="166" Height="166"
                                HorizontalAlignment="Left" Margin="0,7,0,0">
                            <Grid>
                                <TextBlock Text="&#xE77B;" Style="{StaticResource AssetPlaceholderGlyph}"
                                           FontSize="48" />
                                <Image x:Name="SelectedDriverPortraitPreview" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Source="{Binding SelectedCar.PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid Grid.Row="2" Grid.Column="2" VerticalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="108" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="TEAM" Style="{StaticResource Eyebrow}" />
                            <Border Style="{StaticResource PreviewFrame}" Width="94" Height="94"
                                    HorizontalAlignment="Left" Margin="0,7,0,0">
                                <Grid>
                                    <TextBlock Text="&#xE7C1;" Style="{StaticResource AssetPlaceholderGlyph}"
                                               FontSize="36" />
                                    <Image x:Name="SelectedTeamLogoPreview" Stretch="Uniform" Margin="8"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                                           Source="{Binding SelectedCar.TeamLogoKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/logos}"
                                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                </Grid>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedCar.TeamName}" Style="{StaticResource H2}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedCar.LiveryName}" Style="{StaticResource Mono}"
                                       FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Border Style="{StaticResource GridStatusChip}">
                                    <TextBlock Text="{Binding SelectedCar.StatusLabel}"
                                               Style="{StaticResource GridStatusText}" />
                                </Border>
                                <Border Style="{StaticResource CompactChip}" Margin="8,0,0,0"
                                        Visibility="{Binding SelectedCar.SkinSlot, Converter={StaticResource StringVisible}}">
                                    <TextBlock Text="{Binding SelectedCar.SkinSlot, StringFormat=SKIN SLOT {0}}"
                                               Style="{StaticResource PixelBadge}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedCar.Detail}" Style="{StaticResource Faint}"
                                       TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Grid.Column="4">
                        <TextBlock Text="TOP VIEW" Style="{StaticResource Eyebrow}" />
                        <Border Style="{StaticResource PreviewFrame}" Height="166" Margin="0,7,0,0">
                            <Grid>
                                <Image x:Name="SelectedTopCarPreview" Stretch="Uniform" Margin="14"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Source="{Binding SelectedCar.TopCarKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/grid-cars}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="5">
                        <TextBlock Text="SIDE VIEW" Style="{StaticResource Eyebrow}" />
                        <Border Style="{StaticResource PreviewFrame}" Height="128" Margin="0,7,0,0">
                            <Grid>
                                <Image x:Name="SelectedSideCarPreview" Stretch="Uniform" Margin="16,4"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       Source="{Binding SelectedCar.CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3" Margin="0,22,0,0">
                <DockPanel Margin="0,0,0,10">
                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                            VerticalAlignment="Bottom">
                        <TextBlock Text="{Binding Cars.Count, StringFormat={}{0} GRID CARS}"
                                   Style="{StaticResource PixelBadge}" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Choose a car to preview" Style="{StaticResource H2}" />
                        <TextBlock Text="Selection changes only the reference panel above."
                                   Style="{StaticResource Muted}" Margin="0,3,0,0" />
                    </StackPanel>
                </DockPanel>

                <ListBox x:Name="GridEntrySelector"
                         ItemsSource="{Binding Cars}"
                         SelectedItem="{Binding SelectedCar, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource GridSelectorItem}"
                         Background="Transparent" BorderThickness="0" Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="78" />
                                </Grid.ColumnDefinitions>
                                <Border Width="32" Height="32" CornerRadius="6"
                                        Background="{DynamicResource FieldBrush}"
                                        VerticalAlignment="Top">
                                    <Grid>
                                        <TextBlock Text="&#xE7C1;" Style="{StaticResource AssetPlaceholderGlyph}"
                                                   FontSize="16" />
                                        <Image Stretch="Uniform" Margin="3"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Source="{Binding TeamLogoKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/logos}"
                                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="7,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Number, StringFormat=#{0}}"
                                                   Style="{StaticResource Mono}" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding DriverName}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding TeamName}" Style="{StaticResource Faint}"
                                               TextTrimming="CharacterEllipsis" Margin="0,1,0,0" />
                                    <TextBlock Text="{Binding StatusLabel}" Style="{StaticResource Faint}"
                                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                                </StackPanel>
                                <Border Grid.Column="2" Background="Transparent">
                                    <Grid>
                                        <Image Stretch="Uniform" Margin="2"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               Source="{Binding CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Style="{StaticResource Panel}" Padding="16" Margin="0,2,0,0"
                        Visibility="{Binding Cars.Count, Converter={StaticResource CountCollapsed}}">
                    <TextBlock Text="No next-race grid is available to preview."
                               Style="{StaticResource Muted}" HorizontalAlignment="Center" />
                </Border>
            </StackPanel>

            <Border x:Name="DidNotQualifyStrip" Grid.Row="4" Style="{StaticResource Panel}"
                    Padding="14,11" Margin="0,14,0,0" Opacity="0.78"
                    Visibility="{Binding HasDnq, Converter={StaticResource BoolVisible}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding DnqHeader}" Style="{StaticResource Eyebrow}" />
                        <TextBlock Text="Outside this round's cut"
                                   Style="{StaticResource Faint}" Margin="0,2,0,0" />
                    </StackPanel>
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding DidNotQualify}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource FieldBrush}" CornerRadius="7"
                                        Padding="9,6" Margin="0,0,7,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding NumberLabel}" Style="{StaticResource Mono}"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding DriverName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding TeamName, StringFormat={}  •  {0}}"
                                                   Style="{StaticResource Faint}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
