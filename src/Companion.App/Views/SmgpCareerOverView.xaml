<UserControl x:Class="Companion.App.Views.SmgpCareerOverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- The Level-D floor ending. This is the fired/relegated-out voice of the same terminal
         surface used for fatal accidents; its DataContext is the already-projected Briefing VM. -->
    <DockPanel Background="{DynamicResource BgBrush}">
        <Border DockPanel.Dock="Bottom" Padding="24,14,24,20"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <Button x:Name="SmgpCareerOverReturnButton" DockPanel.Dock="Right"
                        Content="Return to main menu" Style="{StaticResource SubtleButton}"
                        MinWidth="180" Padding="14,9"
                        Command="{Binding DataContext.GoToStartCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                        AutomationProperties.Name="Return to main menu" />
                <TextBlock Text="THE PADDOCK MOVES ON" Style="{StaticResource Eyebrow}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Focusable="False">
            <Grid MaxWidth="940" MinHeight="620" Margin="28" HorizontalAlignment="Center">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                        CornerRadius="14" Effect="{StaticResource PanelElevationEffect}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Background="{DynamicResource ErrorBrush}" CornerRadius="14,14,0,0" />

                        <StackPanel Grid.Row="1" Margin="54,42,54,48"
                                    HorizontalAlignment="Center" MaxWidth="760">
                            <Border Padding="16,7" CornerRadius="5"
                                    Background="{DynamicResource ErrorDimBrush}"
                                    BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="C A R E E R   O V E R"
                                           Style="{StaticResource PixelBadge}" FontSize="9"
                                           Foreground="{DynamicResource ErrorBrush}" />
                            </Border>

                            <Border Width="104" Height="104" CornerRadius="52" Margin="0,24,0,0"
                                    Background="{DynamicResource ErrorDimBrush}"
                                    BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="2">
                                <TextBlock Text="&#xE8D7;" FontFamily="{StaticResource IconFont}"
                                           FontSize="46" Foreground="{DynamicResource ErrorBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <TextBlock Text="OUT OF FORMULA ONE"
                                       FontFamily="{StaticResource DisplayFont}" FontSize="38"
                                       FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,22,0,0" />
                            <TextBlock Text="KICKED OUT AT THE BOTTOM OF THE GRID"
                                       Style="{StaticResource Eyebrow}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" />

                            <Border Style="{StaticResource ErrorCallout}" Margin="0,24,0,0"
                                    Padding="22,17" MinWidth="600">
                                <StackPanel>
                                    <TextBlock Text="A rival took your Zeroforce seat. There is no team below to catch you."
                                               FontFamily="{StaticResource DisplayFont}" FontSize="17"
                                               FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" />
                                    <TextBlock Text="Four defeats at the floor end the SMGP climb. The career is finished; Senna and the rest of the field race on."
                                               Style="{StaticResource Body}" FontSize="15"
                                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource QuoteCard}" Margin="0,16,0,0" Padding="20,16">
                                <TextBlock Text="There was nowhere left to fall."
                                           Style="{StaticResource Body}" FontSize="17" FontStyle="Italic"
                                           TextAlignment="Center" />
                            </Border>

                            <WrapPanel HorizontalAlignment="Center" Margin="0,24,0,0">
                                <Border Style="{StaticResource CompactChip}" Margin="0,0,8,8"
                                        Visibility="{Binding SmgpRoundHeader, Converter={StaticResource StringVisible}}">
                                    <TextBlock Text="{Binding SmgpRoundHeader}" Style="{StaticResource Mono}" />
                                </Border>
                                <Border Style="{StaticResource CompactChip}" Margin="0,0,8,8"
                                        Visibility="{Binding SmgpCampaignLine, Converter={StaticResource StringVisible}}">
                                    <TextBlock Text="{Binding SmgpCampaignLine}" Style="{StaticResource Mono}" />
                                </Border>
                            </WrapPanel>

                            <TextBlock Text="This ending is final for this career file. Start again and fight your way off the floor before the fourth loss."
                                       Style="{StaticResource Muted}" TextAlignment="Center"
                                       TextWrapping="Wrap" Margin="0,18,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
