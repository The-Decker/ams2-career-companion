<UserControl x:Class="Companion.App.Views.EconomyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             xmlns:dynasty="clr-namespace:Companion.Core.Dynasty;assembly=Companion.Core"
             Focusable="False">
    <!-- The Dynasty owner-economy hub lens ("Team Ledger", economy §9): a read-mostly ledger over
         EconomyViewModel.Dashboard (replaced wholesale on every refresh) with the five decision
         commands down the right column. The session is the affordability/availability authority;
         a refused decision surfaces inline in EconomyActionErrorPanel, never a modal. After the
         team folds the tab stays open as a read-only final ledger (Dashboard.Bankrupt disables
         the whole decisions column). Codex GUI brief: docs/dev/codex-gui-dynasty-economy-brief.md. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalFirst"
                  Focusable="False">
        <StackPanel Margin="22,16,22,24">

            <!-- 1. header strip: balance, deficit state, the overdraft line, the BANKRUPT seal -->
            <Border x:Name="EconomyHeaderStrip" Style="{StaticResource Panel}" Padding="16,13">
                <DockPanel LastChildFill="False">
                    <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                        <Border x:Name="BankruptSeal" Padding="10,4" Margin="6,0,0,0"
                                Background="{DynamicResource ErrorDimBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Visibility="{Binding Dashboard.Bankrupt, Converter={StaticResource BoolVisible}}">
                            <TextBlock Text="BANKRUPT" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource ErrorBrush}" />
                        </Border>
                        <Border x:Name="DeficitChip" Padding="10,4" Margin="6,0,0,0"
                                Background="{DynamicResource WarningDimBrush}"
                                BorderBrush="{DynamicResource WarningBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Visibility="{Binding Dashboard.InDeficit, Converter={StaticResource BoolVisible}}">
                            <TextBlock Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource WarningBrush}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}DEFICIT ROUND {0} OF {1}">
                                        <Binding Path="Dashboard.DeficitRounds" />
                                        <Binding Path="Dashboard.GraceRounds" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                    </WrapPanel>
                    <StackPanel>
                        <TextBlock Text="TEAM LEDGER" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock x:Name="BalanceText" Text="{Binding Dashboard.Balance, FallbackValue=-}"
                                   FontFamily="{StaticResource DisplayFont}" FontSize="30" FontWeight="Bold"
                                   Margin="0,2,0,0"
                                   ToolTip="The folded team balance">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.InDeficit}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Style="{StaticResource Faint}" FontSize="10.5" Margin="0,3,0,0"
                                   ToolTip="At or below this balance the team folds immediately">
                            <Run Text="OVERDRAFT LINE  " />
                            <Run Text="{Binding Dashboard.HardFloor, Mode=OneWay, FallbackValue=-}" FontWeight="Bold" />
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- left column: the cash-flow statement + the locked-in plan -->
                <StackPanel>
                    <Border Style="{StaticResource Panel}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="CASH FLOW" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                            <ItemsControl x:Name="StatementList" ItemsSource="{Binding Dashboard.Statement}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="10,7">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource Callout}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsDeficit}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="92" />
                                                </Grid.ColumnDefinitions>
                                                <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                                    <Border Style="{StaticResource CompactChip}" Padding="6,1" Margin="0,0,8,0"
                                                            Visibility="{Binding Round, Converter={StaticResource NullCollapsed}}">
                                                        <TextBlock Text="{Binding Round, StringFormat={}R{0}}"
                                                                   Style="{StaticResource Mono}" FontSize="9.5" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Net}"
                                                           FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDeficit}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Text="{Binding BalanceAfter}"
                                                           Style="{StaticResource Mono}" FontSize="11"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           ToolTip="Balance after this line" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No settlements yet." Style="{StaticResource Faint}"
                                       Visibility="{Binding Dashboard.Statement.Count, Converter={StaticResource CountCollapsed}, FallbackValue=Visible}" />
                        </StackPanel>
                    </Border>

                    <!-- pending plan: declared, folded next round; decisions cannot be un-declared in v1,
                         so there is deliberately no remove affordance -->
                    <Border x:Name="PendingPanel" Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,0"
                            Visibility="{Binding Dashboard.HasPendingDecisions, Converter={StaticResource BoolVisible}}">
                        <StackPanel>
                            <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                <TextBlock DockPanel.Dock="Right" Style="{StaticResource Faint}" FontSize="10.5">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}Locked in when Round {0} runs.">
                                            <Binding Path="Dashboard.NextRound" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text="PENDING PLAN" Style="{StaticResource Eyebrow}" />
                            </DockPanel>
                            <ItemsControl x:Name="PendingList" ItemsSource="{Binding Dashboard.PendingDecisions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource AccentCallout}" Margin="0,0,0,6" Padding="10,7">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Amount}"
                                                           Style="{StaticResource Mono}" FontWeight="Bold"
                                                           Margin="10,0,0,0"
                                                           Visibility="{Binding Amount, Converter={StaticResource StringVisible}}" />
                                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" TextWrapping="Wrap" />
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- right column: the decisions. Read-only once the team has folded. -->
                <StackPanel Grid.Column="2">
                    <Border x:Name="FoldedNotice" Style="{StaticResource ErrorCallout}" Margin="0,0,0,12"
                            Visibility="{Binding Dashboard.Bankrupt, Converter={StaticResource BoolVisible}}">
                        <TextBlock Text="The team has folded. This ledger is read-only."
                                   Style="{StaticResource Body}" Foreground="{DynamicResource ErrorBrush}" />
                    </Border>

                    <!-- the refused decision's reason, inline beside the actions (the Dossier
                         SkillActionError pattern), cleared by the next accepted decision -->
                    <Border x:Name="EconomyActionErrorPanel" Style="{StaticResource ErrorCallout}" Margin="0,0,0,12"
                            Visibility="{Binding EconomyActionError, Converter={StaticResource StringVisible}}">
                        <TextBlock Text="{Binding EconomyActionError, Mode=OneWay}"
                                   TextWrapping="Wrap" Foreground="{DynamicResource ErrorBrush}" />
                    </Border>

                    <Grid x:Name="DecisionsColumn"
                          IsEnabled="{Binding Dashboard.Bankrupt, Converter={StaticResource InverseBool}, FallbackValue=False}">
                        <StackPanel>
                            <!-- 3. sponsor board -->
                            <Border Style="{StaticResource Panel}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="SPONSORS" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                                    <ItemsControl x:Name="ActiveSponsorList" ItemsSource="{Binding Dashboard.ActiveSponsors}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Callout}" Margin="0,0,0,6" Padding="10,7">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <Border Style="{StaticResource CompactChip}" Padding="6,1" Margin="0,0,8,0">
                                                                    <TextBlock Text="{Binding TierSlot}" Style="{StaticResource PixelBadge}"
                                                                               Foreground="{DynamicResource AccentTextBrush}" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </DockPanel>
                                                            <TextBlock Style="{StaticResource Faint}" Margin="0,3,0,0">
                                                                <Run Text="{Binding PerRace, Mode=OneWay}" /><Run Text=" / race  ·  " />
                                                                <Run Text="{Binding PerSeason, Mode=OneWay}" /><Run Text=" / season  ·  " />
                                                                <Run Text="{Binding SeasonsRemaining, Mode=OneWay}" /><Run Text=" season(s) left" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="DROP" Margin="12,0,0,0" Padding="10,6"
                                                                Style="{StaticResource SubtleButton}"
                                                                audio:SoundAssist.Cue="Destructive"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.DropSponsorCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Id}"
                                                                ToolTip="Drop this sponsor at the next round's settlement"
                                                                AutomationProperties.Name="Drop this sponsor" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No active sponsors." Style="{StaticResource Faint}"
                                               Visibility="{Binding Dashboard.ActiveSponsors.Count, Converter={StaticResource CountCollapsed}, FallbackValue=Visible}" />

                                    <TextBlock Text="THE BOARD" Style="{StaticResource Eyebrow}" Margin="0,12,0,7" />
                                    <ItemsControl x:Name="SponsorBoardList" ItemsSource="{Binding Dashboard.SponsorBoard}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- ineligible deals stay visible but dimmed, with the reason shown:
                                                     honest availability, not hidden options -->
                                                <Border Margin="0,0,0,6" Padding="10,7">
                                                    <Border.Style>
                                                        <Style TargetType="Border" BasedOn="{StaticResource Callout}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Eligible}" Value="False">
                                                                    <Setter Property="Opacity" Value="0.62" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <Border Style="{StaticResource CompactChip}" Padding="6,1" Margin="0,0,8,0">
                                                                    <TextBlock Text="{Binding TierSlot}" Style="{StaticResource PixelBadge}"
                                                                               Foreground="{DynamicResource AccentTextBrush}" />
                                                                </Border>
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </DockPanel>
                                                            <TextBlock Style="{StaticResource Faint}" Margin="0,3,0,0">
                                                                <Run Text="Signing " /><Run Text="{Binding SigningBonus, Mode=OneWay}" FontWeight="Bold" />
                                                                <Run Text="  ·  " /><Run Text="{Binding PerRace, Mode=OneWay}" /><Run Text=" / race  ·  " />
                                                                <Run Text="{Binding PerSeason, Mode=OneWay}" /><Run Text=" / season  ·  " />
                                                                <Run Text="{Binding ContractSeasons, Mode=OneWay}" /><Run Text=" season(s)" />
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding IneligibleReason}" Margin="0,3,0,0"
                                                                       FontSize="11" TextWrapping="Wrap"
                                                                       Foreground="{DynamicResource WarningBrush}"
                                                                       Visibility="{Binding IneligibleReason, Converter={StaticResource StringVisible}}" />
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="SIGN" Margin="12,0,0,0" Padding="10,6"
                                                                Style="{StaticResource AccentButton}"
                                                                audio:SoundAssist.Cue="Confirm"
                                                                VerticalAlignment="Center"
                                                                Command="{Binding DataContext.SignSponsorCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Id}"
                                                                Visibility="{Binding Eligible, Converter={StaticResource BoolVisible}}"
                                                                ToolTip="Sign this sponsor at the next round's settlement"
                                                                AutomationProperties.Name="Sign this sponsor" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="No offers on the board this season." Style="{StaticResource Faint}"
                                               Visibility="{Binding Dashboard.SponsorBoard.Count, Converter={StaticResource CountCollapsed}, FallbackValue=Visible}" />
                                </StackPanel>
                            </Border>

                            <!-- 4. development: the escalating, era-priced stage ladder -->
                            <Border Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <DockPanel LastChildFill="False" Margin="0,0,0,7">
                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}" FontSize="11"
                                                   Foreground="{DynamicResource TextMutedBrush}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}STAGE {0} OF {1}">
                                                    <Binding Path="Dashboard.DevelopmentLevel" />
                                                    <Binding Path="Dashboard.DevelopmentMaxLevel" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="DEVELOPMENT" Style="{StaticResource Eyebrow}" />
                                    </DockPanel>
                                    <ProgressBar x:Name="DevelopmentStageBar" Height="10"
                                                 Minimum="0"
                                                 Maximum="{Binding Dashboard.DevelopmentMaxLevel, FallbackValue=1}"
                                                 Value="{Binding Dashboard.DevelopmentLevel, FallbackValue=0}"
                                                 Background="{DynamicResource SurfaceAltBrush}"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 BorderThickness="0" />
                                    <DockPanel LastChildFill="False" Margin="0,9,0,0">
                                        <Button x:Name="BuyDevelopmentButton" DockPanel.Dock="Right"
                                                Style="{StaticResource AccentButton}" Padding="12,7"
                                                audio:SoundAssist.Cue="Confirm"
                                                Command="{Binding BuyDevelopmentCommand}"
                                                Visibility="{Binding Dashboard.DevelopmentAtCap, Converter={StaticResource BoolCollapsed}}"
                                                ToolTip="Buy the next development stage at the next round's settlement"
                                                AutomationProperties.Name="Buy the next development stage">
                                            <TextBlock>
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}BUY NEXT STAGE  {0}">
                                                        <Binding Path="Dashboard.NextDevelopmentCost" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Button>
                                        <TextBlock Text="PROGRAMME AT CAP" Style="{StaticResource PixelBadge}"
                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding Dashboard.DevelopmentAtCap, Converter={StaticResource BoolVisible}}" />
                                        <TextBlock Text="A bought stage is felt the very next round."
                                                   Style="{StaticResource Faint}" VerticalAlignment="Center" />
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- 5. engineering staff: single selection, tier 0 = no staff -->
                            <Border Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="ENGINEERING STAFF" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                                    <ItemsControl x:Name="StaffOptionsList" ItemsSource="{Binding Dashboard.StaffOptions}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,7,7" Padding="11,7"
                                                        audio:SoundAssist.Cue="Confirm"
                                                        Command="{Binding DataContext.SetStaffCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Tier}"
                                                        AutomationProperties.Name="Set staff tier">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="Bold" HorizontalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                    <Setter Property="Text" Value="{Binding Tier, StringFormat={}TIER {0}}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Tier}" Value="0">
                                                                            <Setter Property="Text" Value="NO STAFF" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding UpkeepPerSeason, StringFormat={}UPKEEP {0} / SEASON}"
                                                                   Style="{StaticResource Faint}" FontSize="9.5"
                                                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                                                   Visibility="{Binding UpkeepPerSeason, Converter={StaticResource StringVisible}}" />
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- 6. second seat: a two-way deal toggle -->
                            <Border Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="SECOND SEAT" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="SecondSeatRetainedButton" Padding="11,9"
                                                audio:SoundAssist.Cue="Confirm"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding SetSecondSeatCommand}"
                                                CommandParameter="{x:Static dynasty:SecondSeatDeal.Retained}"
                                                ToolTip="Pay the salary, keep the second car's prize money."
                                                AutomationProperties.Name="Second seat: retained deal">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Dashboard.SecondSeat}"
                                                                     Value="{x:Static dynasty:SecondSeatDeal.Retained}">
                                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock Text="RETAINED" FontWeight="Bold" HorizontalAlignment="Center" />
                                                <TextBlock HorizontalAlignment="Center" Margin="0,3,0,0"
                                                           Style="{StaticResource Mono}" FontSize="10.5">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}SALARY {0} / SEASON">
                                                            <Binding Path="Dashboard.SecondSeatSalaryPerSeason" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="Pay the salary, keep the second car's prize money."
                                                           Style="{StaticResource Faint}" FontSize="10" TextWrapping="Wrap"
                                                           TextAlignment="Center" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="SecondSeatPayDriverButton" Grid.Column="2" Padding="11,9"
                                                audio:SoundAssist.Cue="Confirm"
                                                HorizontalContentAlignment="Stretch"
                                                Command="{Binding SetSecondSeatCommand}"
                                                CommandParameter="{x:Static dynasty:SecondSeatDeal.PayDriver}"
                                                ToolTip="Their backers pay you; their prize money is theirs."
                                                AutomationProperties.Name="Second seat: pay-driver deal">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Dashboard.SecondSeat}"
                                                                     Value="{x:Static dynasty:SecondSeatDeal.PayDriver}">
                                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <StackPanel>
                                                <TextBlock Text="PAY DRIVER" FontWeight="Bold" HorizontalAlignment="Center" />
                                                <TextBlock HorizontalAlignment="Center" Margin="0,3,0,0"
                                                           Style="{StaticResource Mono}" FontSize="10.5">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}BACKING {0} / SEASON">
                                                            <Binding Path="Dashboard.PayDriverBackingPerSeason" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="Their backers pay you; their prize money is theirs."
                                                           Style="{StaticResource Faint}" FontSize="10" TextWrapping="Wrap"
                                                           TextAlignment="Center" Margin="0,3,0,0" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
