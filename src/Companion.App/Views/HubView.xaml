<UserControl x:Class="Companion.App.Views.HubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <DockPanel>
        <!-- the persistent left tab rail (career-hub-design.md §2.1) -->
        <Border DockPanel.Dock="Left" Width="140"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,10">
                <!-- era badge: the season + its period medium (telegram/fax/email) -->
                <StackPanel DockPanel.Dock="Top" Margin="14,2,12,12">
                    <TextBlock Text="{Binding Home.SeasonYearText}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding Era.Label}" Style="{StaticResource Faint}"
                               FontSize="10" Margin="1,1,0,0"
                               ToolTip="The period your career is skinned as — it ages telegram → fax → email across the decades" />
                </StackPanel>

                <!-- close-career sits at the bottom of the rail (also available on the Race header) -->
                <Button DockPanel.Dock="Bottom" Margin="10,10,10,0" Style="{StaticResource SubtleButton}"
                        HorizontalContentAlignment="Left"
                        ToolTip="Close this career and return to the start screen"
                        AutomationProperties.Name="Back to start screen"
                        Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="12"
                                   VerticalAlignment="Center" Margin="2,1,8,0" />
                        <TextBlock Text="Start" />
                    </StackPanel>
                </Button>

                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Tabs}" Margin="8,2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,2" Padding="12,9" HorizontalContentAlignment="Left"
                                    AutomationProperties.Name="{Binding Title}"
                                    ToolTip="{Binding Title}"
                                    Command="{Binding DataContext.SelectTabCommand,
                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding Title}" FontSize="14" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- the selected tab's content (Race = the re-homed loop, or a lens) -->
        <ContentControl Content="{Binding SelectedTab.Content}" Focusable="False" />
    </DockPanel>
</UserControl>
