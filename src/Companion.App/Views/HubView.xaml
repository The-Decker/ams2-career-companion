<UserControl x:Class="Companion.App.Views.HubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <Grid x:Name="HubStage">
    <!-- Remove the ordinary Hub from BOTH layout and binding scope for either terminal path.
         That matters in Hardcore: collapsed controls still keep WPF bindings alive, while clearing
         this subtree's DataContext guarantees no hidden lens/converter can query the disposed session. -->
    <Grid x:Name="LiveHubSurfaces">
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Visibility" Value="Collapsed" />
                <Setter Property="DataContext" Value="{x:Null}" />
                <Style.Triggers>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding DataContext.Home.CareerOver,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Value="{x:Null}" />
                            <Condition Binding="{Binding DataContext.Home.Briefing.SmgpCareerOver,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Value="False" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Visibility" Value="Visible" />
                        <Setter Property="DataContext"
                                Value="{Binding DataContext,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
    <DockPanel x:Name="HubContent">
        <!-- persistent global career header (glanceable from EVERY tab) -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DockPanel>
                    <!-- The reserved top-right now opens the read-only Team HQ / future tycoon mode. -->
                    <Button x:Name="TeamHqButton" DockPanel.Dock="Right"
                            Style="{StaticResource AccentButton}" Padding="13,8"
                            Click="OnToggleTycoonDashboard"
                            ToolTip="Open the read-only Team HQ dashboard preview"
                            AutomationProperties.Name="Open Team HQ dashboard"
                            Visibility="{Binding Paddock.HasPaddock, Converter={StaticResource BoolVisible}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7C1;" FontFamily="{StaticResource IconFont}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="TEAM HQ" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Normal mortality only. SaveManagerWindow performs whole-file snapshots and
                         reopens through the shell after restore, so this button owns no game logic. -->
                    <Button x:Name="ManageSavesButton" DockPanel.Dock="Right" Margin="0,0,8,0"
                            Style="{StaticResource SubtleButton}" Padding="13,8"
                            Click="OnManageSaves"
                            Visibility="{Binding Home.Session.SavesEnabled, Converter={StaticResource BoolVisible}}"
                            ToolTip="Create, restore, or delete whole-career save points"
                            AutomationProperties.Name="Manage career save points">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="SAVES" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- the season year (big + first) with its era medium beneath -->
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="{Binding Home.SeasonYearText}" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   ToolTip="The season your career is currently in" />
                        <TextBlock Text="{Binding Era.Label}" Style="{StaticResource Faint}" FontSize="10"
                                   Margin="2,-3,0,0"
                                   Visibility="{Binding EraThemingEnabled, Converter={StaticResource BoolVisible}}"
                                   ToolTip="The period your career is skinned as — it ages telegram → fax → email across the decades" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Home.HeaderTitle}" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Style="{StaticResource Muted}" FontSize="13" Margin="0,2,0,0">
                            <Run Text="{Binding Home.RoundText, Mode=OneWay}" /><Run Text="   ·   " /><Run Text="{Binding Home.StandingText, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="13" Margin="0,2,0,0" Foreground="{DynamicResource AccentTextBrush}"
                                   Text="{Binding Home.FormText}"
                                   ToolTip="Reputation and overperformance index after the last folded round"
                                   Visibility="{Binding Home.HasForm, Converter={StaticResource BoolVisible}}" />
                    </StackPanel>
                </DockPanel>

                <!-- Persistent live headline strip; the full dispatch cards remain in News. -->
                <Button Grid.Row="1" Padding="8,5" Margin="0,9,0,0"
                        HorizontalContentAlignment="Stretch" Click="OnOpenLatestNews"
                        ToolTip="Open the News desk and read the latest dispatch"
                        AutomationProperties.Name="Open latest paddock dispatch">
                    <Button.DataContext>
                        <!-- RoundText is a refresh token: it changes after every fold, causing the
                             public Task-4 session projection to be read again. The third value keeps
                             historical careers on their existing journal feed. -->
                        <MultiBinding Converter="{StaticResource LatestHubDispatch}">
                            <Binding Path="Home.Session" />
                            <Binding Path="Home.RoundText" />
                            <Binding Path="News.Items[0]" />
                        </MultiBinding>
                    </Button.DataContext>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Background="{DynamicResource ErrorDimBrush}" BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,9,0">
                            <TextBlock Text="LIVE WIRE" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource ErrorBrush}" />
                        </Border>
                        <TextBlock Grid.Column="1" Style="{StaticResource Mono}"
                                   FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0">
                            <TextBlock.Text>
                                <PriorityBinding FallbackValue="">
                                    <Binding Path="WhenLabel" />
                                    <Binding Path="Meta" />
                                </PriorityBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Grid.Column="2" Text="{Binding Headline}"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="&#xE76C;" FontFamily="{StaticResource IconFont}"
                                   Foreground="{DynamicResource AccentTextBrush}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </Grid>
        </Border>

        <!-- the persistent left tab rail (pure navigation); Auto width with the old 140 as the
             floor so long tab names never clip at 130% UI scale -->
        <Border DockPanel.Dock="Left" Width="Auto" MinWidth="140"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,12">
                <!-- close-career sits at the bottom of the rail -->
                <Button DockPanel.Dock="Bottom" Margin="10,10,10,0" Style="{StaticResource SubtleButton}"
                        HorizontalContentAlignment="Left"
                        ToolTip="Close this career and return to the start screen"
                        AutomationProperties.Name="Back to start screen"
                        Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE80F;" FontSize="12"
                                   VerticalAlignment="Center" Margin="2,1,8,0" />
                        <TextBlock Text="Start" />
                    </StackPanel>
                </Button>

                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Tabs}" Margin="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- the row = a full-width select button, with a small tear-off ⧉ on the
                                 read-only lenses (Standings/Driver/History/Skins) that pops the tab
                                 into an always-on-top companion window over AMS2. The Upcoming Race
                                 tab leads the rail; its loop is walked with its own Continue button. -->
                            <Grid Margin="0,2"
                                  Visibility="{Binding ShowInRail, Converter={StaticResource BoolVisible}}">
                                <Button Padding="12,9" HorizontalContentAlignment="Left"
                                        AutomationProperties.Name="{Binding Title}"
                                        ToolTip="{Binding Title}"
                                        Command="{Binding DataContext.SelectTabCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource RailNavButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Title}" FontSize="14" Margin="0,0,20,0" />
                                </Button>
                                <!-- tear-off affordance: a Button OVER the row button (WPF routes the
                                     click to the inner Button, so it never also selects the tab) -->
                                <Button Content="&#xE8A7;" Style="{StaticResource IconButton}" FontSize="12"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                        Padding="6,4"
                                        Click="OnPopOutTab"
                                        AutomationProperties.Name="Pop out this tab"
                                        ToolTip="Pop this tab into an always-on-top window (keep it over AMS2 on a second screen)"
                                        Visibility="{Binding CanPopOut, Converter={StaticResource BoolVisible}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- the selected tab's content (Race = the re-homed loop, or a lens) -->
        <ContentControl Content="{Binding SelectedTab.Content}" Focusable="False" />
    </DockPanel>

        <!-- Read-only Team HQ shell. The PriorityBinding uses Claude's future TeamDashboard first;
             until it lands, the selected Paddock team keeps the shell tangible without inventing
             management mechanics or fold inputs. -->
        <Border x:Name="TycoonDashboardBackdrop" Visibility="Collapsed"
                Background="{DynamicResource ScrimBrush}" Opacity="0.72"
                MouseLeftButtonDown="OnCloseTycoonDashboard" />
        <Border x:Name="TycoonDashboardPanel" Visibility="Collapsed" Margin="24"
                HorizontalAlignment="Right" VerticalAlignment="Stretch"
                KeyboardNavigation.TabNavigation="Cycle"
                KeyboardNavigation.ControlTabNavigation="Cycle"
                Width="{Binding ActualWidth, ElementName=HubStage,
                                Converter={StaticResource WidthFraction}, ConverterParameter=0.72|720|1220}"
                Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource EdgeStrongBrush}"
                BorderThickness="1" CornerRadius="12" Effect="{StaticResource PanelElevationEffect}"
                PreviewKeyDown="OnTycoonPreviewKeyDown" Focusable="True">
            <Border.DataContext>
                <MultiBinding Converter="{StaticResource SmgpPlayerTeam}">
                    <Binding Path="Home.Session" />
                    <Binding Path="Home.RoundText" />
                    <!-- Paddock selection is only the absent/off-SMGP preview fallback; the real
                         Task-5 dashboard projection above wins whenever the session provides it. -->
                    <Binding Path="Paddock.SelectedTeam" />
                </MultiBinding>
            </Border.DataContext>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <DockPanel Margin="20,18,18,12">
                    <Button x:Name="TycoonCloseButton" DockPanel.Dock="Right"
                            Style="{StaticResource CloseButton}" Click="OnCloseTycoonDashboard"
                            ToolTip="Close Team HQ (Esc)"
                            AutomationProperties.Name="Close Team HQ dashboard" />
                    <StackPanel>
                        <TextBlock Text="TYCOON TEAM MODE" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock Text="TEAM HQ" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="25" FontWeight="Bold" Margin="0,2,0,0" />
                        <TextBlock Text="READ-ONLY DASHBOARD SHELL" Style="{StaticResource Mono}"
                                   FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Focusable="False">
                    <StackPanel Margin="20,0,20,20">
                        <Border Style="{StaticResource Panel}" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid Width="210" Height="150">
                                    <Border Style="{StaticResource AssetPlaceholderFrame}">
                                        <TextBlock Text="&#xE7C1;" Style="{StaticResource AssetPlaceholderGlyph}"
                                                   FontSize="50" />
                                    </Border>
                                    <Image Stretch="Uniform" IsHitTestVisible="False"
                                           Source="{Binding TeamId, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}"
                                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                    <Border Width="58" Height="58" HorizontalAlignment="Left" VerticalAlignment="Top"
                                            Margin="8" Background="{DynamicResource SurfaceBrush}" CornerRadius="7"
                                            BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
                                        <Grid>
                                            <TextBlock Text="&#xE7C1;" Style="{StaticResource AssetPlaceholderGlyph}" FontSize="21" />
                                            <Image Stretch="Uniform" Margin="5" IsHitTestVisible="False"
                                                   Source="{Binding LogoKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/logos}"
                                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                    <TextBlock Text="{Binding Name, FallbackValue=YOUR TEAM}" Style="{StaticResource H1}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Motto, FallbackValue='Build the team. Write the era.'}"
                                               Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold"
                                               Margin="0,3,0,0" TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,10,0,0">
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,7,7">
                                            <TextBlock Text="{Binding Tier, FallbackValue='TIER —'}" Style="{StaticResource Eyebrow}" />
                                        </Border>
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,7,7">
                                            <TextBlock Style="{StaticResource Eyebrow}" FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0}  ·  {1} PTS">
                                                        <Binding Path="ChampionshipPosition" StringFormat="STANDING P{0}"
                                                                 TargetNullValue="STANDING —" FallbackValue="STANDING —" />
                                                        <Binding Path="ChampionshipPoints" FallbackValue="—" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Border>
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,7,7">
                                            <TextBlock Text="{Binding BudgetTier, StringFormat=BUDGET  {0}, FallbackValue='BUDGET  —'}"
                                                       Style="{StaticResource Eyebrow}" FontWeight="Bold" />
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Text="{Binding History[0], FallbackValue='The economy is not active yet—this is the read-only data spine for the future management mode.'}"
                                               Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource Panel}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="ROSTER" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                                    <ItemsControl ItemsSource="{Binding Roster, FallbackValue={x:Null}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Callout}" Margin="0,0,0,6" Padding="9,7">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding SeasonLine}"
                                                                   FontFamily="{StaticResource MonoFont}"
                                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding CareerLine}" Style="{StaticResource Faint}"
                                                                       FontSize="10.5" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Roster projection pending." Style="{StaticResource Faint}"
                                               Visibility="{Binding Roster.Count, Converter={StaticResource CountCollapsed}, FallbackValue=Visible}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="PARTNERS" Style="{StaticResource Eyebrow}" Margin="0,0,0,7" />
                                    <ItemsControl ItemsSource="{Binding Sponsors, FallbackValue={x:Null}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Callout}" Margin="0,0,0,6" Padding="9,7"
                                                        BorderBrush="{Binding BrandColorHex, Converter={StaticResource HexBrush}}">
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Tier}"
                                                                   Style="{StaticResource Eyebrow}" />
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Sponsor portfolio pending." Style="{StaticResource Faint}"
                                               Visibility="{Binding Sponsors.Count, Converter={StaticResource CountCollapsed}, FallbackValue=Visible}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Style="{StaticResource AccentCallout}" Margin="0,12,0,0" Padding="12,9">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="&#xE946;" FontFamily="{StaticResource IconFont}"
                                           FontSize="18" Foreground="{DynamicResource AccentTextBrush}"
                                           Margin="0,0,10,0" />
                                <TextBlock Text="Team management actions remain deliberately locked. This dashboard is a display-only preview over career state."
                                           Style="{StaticResource Body}" TextWrapping="Wrap" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>

        <!-- Fatal-career takeover. Its inner view binds only Home.DeathScreen/CareerOver, both
             captured before Hardcore deletes the database; the ordinary Hub is collapsed above. -->
        <views:DeathScreenView Panel.ZIndex="20" DataContext="{Binding Home}"
                               RestoreRequested="OnDeathRestoreRequested">
            <views:DeathScreenView.Style>
                <Style TargetType="views:DeathScreenView">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CareerOver}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:DeathScreenView.Style>
        </views:DeathScreenView>

        <!-- The SMGP Level-D floor uses the same terminal visual language, with a fired/out-of-F1
             voice instead of an obituary. This branch reads only the already-projected briefing. -->
        <views:SmgpCareerOverView x:Name="SmgpCareerOverSurface"
                                  Panel.ZIndex="20" DataContext="{Binding Home.Briefing}"
                                  Visibility="{Binding SmgpCareerOver,
                                                       Converter={StaticResource BoolVisible},
                                                       FallbackValue=Collapsed}" />
    </Grid>
</UserControl>
