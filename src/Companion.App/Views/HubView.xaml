<UserControl x:Class="Companion.App.Views.HubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <UserControl.Resources>
        <!-- header loop button: accent underline when its loop state is active -->
        <Style x:Key="HubLoopButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- persistent global career header (glanceable from EVERY tab) -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <DockPanel>
                <!-- always-visible primary loop actions (one click back to the loop from anywhere) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Race day" Command="{Binding GoToBriefingCommand}"
                            ToolTip="Go to the race-day briefing for the current round">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource HubLoopButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Home.IsBriefingState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Enter result" Command="{Binding GoToResultCommand}"
                            ToolTip="Enter this round's finishing order">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource HubLoopButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Home.IsResultEntryState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Home.IsConfirmState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- the season year (big + first) with its era medium beneath -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock Text="{Binding Home.SeasonYearText}" FontSize="32" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               ToolTip="The season your career is currently in" />
                    <TextBlock Text="{Binding Era.Label}" Style="{StaticResource Faint}" FontSize="10"
                               Margin="2,-3,0,0"
                               Visibility="{Binding EraThemingEnabled, Converter={StaticResource BoolVisible}}"
                               ToolTip="The period your career is skinned as — it ages telegram → fax → email across the decades" />
                </StackPanel>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Home.HeaderTitle}" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource Muted}" FontSize="13" Margin="0,2,0,0">
                        <Run Text="{Binding Home.RoundText, Mode=OneWay}" /><Run Text="   ·   " /><Run Text="{Binding Home.StandingText, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,2,0,0" Foreground="{StaticResource AccentBrush}"
                               Text="{Binding Home.FormText}"
                               ToolTip="Reputation and overperformance index after the last folded round"
                               Visibility="{Binding Home.HasForm, Converter={StaticResource BoolVisible}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- the persistent left tab rail (pure navigation) -->
        <Border DockPanel.Dock="Left" Width="140"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,12">
                <!-- close-career sits at the bottom of the rail -->
                <Button DockPanel.Dock="Bottom" Margin="10,10,10,0" Style="{StaticResource SubtleButton}"
                        HorizontalContentAlignment="Left"
                        ToolTip="Close this career and return to the start screen"
                        AutomationProperties.Name="Back to start screen"
                        Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="12"
                                   VerticalAlignment="Center" Margin="2,1,8,0" />
                        <TextBlock Text="Start" />
                    </StackPanel>
                </Button>

                <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Tabs}" Margin="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- the row = a full-width select button, with a small tear-off ⧉ on the
                                 read-only lenses (Standings/Driver/History/Skins) that pops the tab
                                 into an always-on-top companion window over AMS2. -->
                            <Grid Margin="0,2">
                                <Button Padding="12,9" HorizontalContentAlignment="Left"
                                        AutomationProperties.Name="{Binding Title}"
                                        ToolTip="{Binding Title}"
                                        Command="{Binding DataContext.SelectTabCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <TextBlock Text="{Binding Title}" FontSize="14" Margin="0,0,20,0" />
                                </Button>
                                <!-- tear-off affordance: a Button OVER the row button (WPF routes the
                                     click to the inner Button, so it never also selects the tab) -->
                                <Button Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                        Padding="6,4" Background="Transparent" BorderBrush="Transparent"
                                        Click="OnPopOutTab"
                                        AutomationProperties.Name="Pop out this tab"
                                        ToolTip="Pop this tab into an always-on-top window (keep it over AMS2 on a second screen)"
                                        Visibility="{Binding CanPopOut, Converter={StaticResource BoolVisible}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- the selected tab's content (Race = the re-homed loop, or a lens) -->
        <ContentControl Content="{Binding SelectedTab.Content}" Focusable="False" />
    </DockPanel>
</UserControl>
