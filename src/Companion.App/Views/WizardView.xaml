<UserControl x:Class="Companion.App.Views.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wizard="clr-namespace:Companion.ViewModels.Wizard;assembly=Companion.ViewModels"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <UserControl.Resources>
        <!-- step-indicator segment: accent when it IS the current step -->
        <Style x:Key="StepLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{StaticResource TextFaintBrush}" />
            <Setter Property="Margin" Value="0,0,22,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="40,32">
        <!-- header + step indicator -->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="New career" Style="{StaticResource H1}" />
            <StackPanel Orientation="Horizontal" Margin="0,10,0,20">
                <TextBlock Text="1 · Season">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.SeasonPick}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="2 · Verify content">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Verification}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="3 · Seat">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.SeatPick}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="4 · Grid">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Grid}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="5 · Driver"
                           Visibility="{Binding HasCharacterStep, Converter={StaticResource BoolVisible}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Character}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="6 · Confirm">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Confirm}">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </StackPanel>

        <!-- footer: cancel / back / next -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
            <Button DockPanel.Dock="Left" Content="Cancel"
                    Style="{StaticResource SubtleButton}"
                    Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="_Back" MinWidth="96" Command="{Binding BackCommand}" />
                <Button MinWidth="140" Margin="10,0,0,0" Command="{Binding NextCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                            <Setter Property="Content" Value="_Next" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}"
                                             Value="{x:Static wizard:WizardStep.Confirm}">
                                    <Setter Property="Content" Value="Create career" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <Border />
        </DockPanel>

        <!-- the four one-screen steps -->
        <Grid>

            <!-- a. season pick -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.SeasonPick}}">
                <TextBlock DockPanel.Dock="Top" Text="Pick a season pack" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="Sources: the bundled packs folder beside the exe, plus Documents\AMS2CareerCompanion\Packs." />
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                               Text="{Binding PackLoadError}"
                               Visibility="{Binding PackLoadError, Converter={StaticResource NullCollapsed}}" />
                    <Button Content="Rescan pack folders" HorizontalAlignment="Left" Margin="0,10,0,0"
                            Click="OnRefreshPacks" />
                </StackPanel>
                <Border Style="{StaticResource Panel}" Padding="8">
                    <Grid>
                        <!-- season pick as a GRID of year-pic cards (like the career gallery): the era
                             image is the hero; no version, no path. Selection gets an accent border.
                             A UniformGrid lays the cards out in 4 responsive columns (Mike's ask) — the
                             cards flex to fill the width at any screen size, and the year-pic hero keeps
                             its 16:9 aspect via AspectHeight so it scales with the card. CanContentScroll
                             is off so the taller cards scroll by pixel when they overflow the panel. -->
                        <ListBox ItemsSource="{Binding Packs}" SelectedItem="{Binding SelectedPack}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="False"
                                 Visibility="{Binding Packs.Count, Converter={StaticResource CountVisible}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Margin" Value="6" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="7" Background="{StaticResource SurfaceAltBrush}"
                                            HorizontalAlignment="Stretch">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <!-- selected card: accent ring -->
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- 16:9 year-pic hero (era art keyed by the season name;
                                                 coloured era placeholder when no image is present). The
                                                 height tracks the card's own width at 16:9 so the hero
                                                 scales as the responsive column flexes. -->
                                            <Grid MinHeight="120"
                                                  Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource AspectHeight}, ConverterParameter=0.5625}">
                                                <Border CornerRadius="6,6,0,0"
                                                        Background="{Binding Title, Converter={StaticResource EraAccent}}" />
                                                <Border CornerRadius="6,6,0,0">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Title, Converter={StaticResource EraImage}}"
                                                                    Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15"
                                                       Margin="12,9,12,12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{StaticResource ErrorBrush}" FontSize="12"
                                                       Margin="12,0,12,10" TextWrapping="Wrap"
                                                       Text="{Binding LoadError, StringFormat='pack.json unreadable: {0}'}"
                                                       Visibility="{Binding LoadError, Converter={StaticResource NullCollapsed}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- empty state (ux-round §4): no packs found → explain the folders + open -->
                        <StackPanel Margin="12,10" MaxWidth="560" HorizontalAlignment="Left"
                                    Visibility="{Binding Packs.Count, Converter={StaticResource CountCollapsed}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE838;" FontSize="20"
                                           Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <TextBlock Text="No season packs found" FontWeight="SemiBold" FontSize="15"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Text="A season pack is a plain folder with a pack.json inside. These places are searched:" />
                            <TextBlock Style="{StaticResource Muted}" Margin="16,6,0,0" TextWrapping="Wrap"
                                       Text="• the bundled packs folder beside the exe" />
                            <TextBlock Style="{StaticResource Muted}" Margin="16,2,0,0" TextWrapping="Wrap"
                                       Text="• Documents\AMS2CareerCompanion\Packs (yours — drop packs here)" />
                            <TextBlock Style="{StaticResource Muted}" Margin="16,2,0,0" TextWrapping="Wrap"
                                       Text="• any extra folders you add under Settings → Data" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Open pack folder" Click="OnOpenPackFolder"
                                        ToolTip="Opens Documents\AMS2CareerCompanion\Packs in Explorer (created if missing)" />
                                <TextBlock Style="{StaticResource Faint}" VerticalAlignment="Center" Margin="10,0,0,0"
                                           Text="then drop a pack in and hit Rescan below" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </DockPanel>

            <!-- b. content verification -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Verification}}">
                <TextBlock DockPanel.Dock="Top" Text="Content verification" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="Structure, AMS2 content and installed liveries checked against the detected install. Errors block; warnings can be overridden." />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <TextBlock Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap"
                               Text="Errors block career creation — fix the pack and rescan."
                               Visibility="{Binding HasErrors, Converter={StaticResource BoolVisible}}" />
                    <CheckBox Content="Proceed anyway — I accept the warnings above"
                              IsChecked="{Binding ProceedAnyway}">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasWarnings}" Value="True" />
                                            <Condition Binding="{Binding HasErrors}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- optional alternate MOD tracks (the "RockyTM track switch"): opt-in AND
                         install-verified. Off (or any required mod missing) => default AMS2 tracks only. -->
                    <Border Style="{StaticResource Panel}" Margin="0,10,0,0"
                            Visibility="{Binding PackHasAlternateTracks, Converter={StaticResource BoolVisible}}">
                        <StackPanel>
                            <CheckBox Content="Use alternate tracks (community mods) where they make sense"
                                      IsChecked="{Binding UseAlternateTracks}"
                                      ToolTip="Swaps this season's placeholder rounds to era/character-appropriate mod circuits — but ONLY if every required mod is installed. Off = default AMS2 tracks only." />
                            <TextBlock Text="{Binding AlternateTrackStatus}" Style="{StaticResource Body}"
                                       TextWrapping="Wrap" Margin="0,6,0,0" />
                            <ItemsControl ItemsSource="{Binding AlternateModTracks}" Margin="0,6,0,0"
                                          Visibility="{Binding UseAlternateTracks, Converter={StaticResource BoolVisible}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,1">
                                            <TextBlock DockPanel.Dock="Left" Width="18" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Setter Property="Text" Value="✗" />
                                                        <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Installed}" Value="True">
                                                                <Setter Property="Text" Value="✔" />
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}"><Run Text="{Binding DisplayName, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="{Binding Tag, Mode=OneWay, StringFormat=' ({0})'}" /></TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Re-check installed mods" Command="{Binding CheckAlternateModsCommand}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0" Style="{StaticResource SubtleButton}"
                                    Visibility="{Binding UseAlternateTracks, Converter={StaticResource BoolVisible}}"
                                    ToolTip="Re-scan your AMS2 install for the mod tracks this season's alternates need" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Style="{StaticResource Panel}">
                    <DockPanel>
                        <!-- per-file livery-scan details (unreadable files): collapsed by default -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0"
                                    Visibility="{Binding HasLiveryScanDetails, Converter={StaticResource BoolVisible}}">
                            <Button HorizontalAlignment="Left" Command="{Binding ToggleLiveryScanDetailsCommand}"
                                    ToolTip="The files the livery scan could not read, one line each">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                        <Setter Property="Content" Value="Show details ▸" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveryScanDetailsExpanded}" Value="True">
                                                <Setter Property="Content" Value="Hide details ▾" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto" Focusable="False"
                                          Visibility="{Binding LiveryScanDetailsExpanded, Converter={StaticResource BoolVisible}}">
                                <ItemsControl ItemsSource="{Binding LiveryScanDetails}" Margin="12,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Style="{StaticResource Faint}"
                                                       TextWrapping="Wrap" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                        <Grid>
                        <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="15"
                                   Visibility="{Binding VerificationItems.Count, Converter={StaticResource CountCollapsed}}">
                            <Run FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" /><Run Text="  All clear — the pack verifies clean against this install." />
                        </TextBlock>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False"
                                      Visibility="{Binding VerificationItems.Count, Converter={StaticResource CountVisible}}">
                            <ItemsControl ItemsSource="{Binding VerificationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,3">
                                            <Border DockPanel.Dock="Left" CornerRadius="4" Padding="8,2"
                                                    VerticalAlignment="Top" Margin="0,0,10,0" Width="76">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource WarningDimBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource ErrorDimBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Severity}" FontSize="12" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- c. seat pick -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.SeatPick}}">
                <TextBlock DockPanel.Dock="Top" Text="Pick your seat" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="You replace this driver for the season (their ratings vacate the seat; the team's car stays as-is)." />
                <!-- ...or race as your own independent entrant (a custom AMS2 livery). Takes precedence
                     over the seat above; leave blank for the ordinary seat pick. -->
                <Border DockPanel.Dock="Bottom" Style="{StaticResource Panel}" Margin="0,10,0,0" Padding="12">
                    <StackPanel>
                        <TextBlock Text="— or race as your own entrant —" Style="{StaticResource Faint}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,6" TextWrapping="Wrap"
                                   Text="Type the exact name of a custom livery installed in AMS2 to race as an independent privateer — your own car, added to the grid instead of replacing a historical driver. Leave blank to take a seat above." />
                        <TextBox Text="{Binding CustomLiveryName, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                 ToolTip="The AMS2 livery name for your own car — leave blank to take a pack seat instead" />
                        <TextBlock Style="{StaticResource Faint}" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Foreground="{StaticResource AccentBrush}"
                                   Text="Racing as your own entrant — the seat above is ignored."
                                   Visibility="{Binding CustomLiveryName, Converter={StaticResource StringVisible}}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Panel}" Padding="8">
                    <ListBox ItemsSource="{Binding Seats}" SelectedItem="{Binding SelectedSeat}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <!-- mouse parity: double-click a seat = select it AND advance -->
                                <EventSetter Event="MouseDoubleClick" Handler="OnSeatDoubleClick" />
                                <Setter Property="ToolTip" Value="Double-click to pick this seat and continue" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Width="44" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                               Text="{Binding Number, StringFormat='#{0}'}" />
                                    <!-- ratings as bars; raw numbers on hover (ux-round §2) -->
                                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Width="190">
                                        <DockPanel ToolTip="{Binding RaceSkill, StringFormat='Race skill (raw): {0:0.000}'}"
                                                   Background="Transparent">
                                            <TextBlock DockPanel.Dock="Left" Width="42" Text="Race"
                                                       Style="{StaticResource Faint}" VerticalAlignment="Center" />
                                            <ProgressBar Style="{StaticResource RatingBar}"
                                                         Value="{Binding RaceSkill, Mode=OneWay}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,4,0,0"
                                                   ToolTip="{Binding QualifyingSkill, StringFormat='Qualifying skill (raw): {0:0.000}'}"
                                                   Background="Transparent">
                                            <TextBlock DockPanel.Dock="Left" Width="42" Text="Quali"
                                                       Style="{StaticResource Faint}" VerticalAlignment="Center" />
                                            <ProgressBar Style="{StaticResource RatingBar}"
                                                         Value="{Binding QualifyingSkill, Mode=OneWay}" />
                                        </DockPanel>
                                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource Faint}" Margin="0,4,0,0"
                                                   ToolTip="{Binding Reliability, StringFormat='Car reliability (raw): {0:0.000}'}">
                                            <Run Text="Team tier " /><Run Text="{Binding TeamTier, Mode=OneWay}" /><Run Text="  ·  Reliability " /><Run Text="{Binding Reliability, Mode=OneWay, StringFormat={}{0:0.00}}" /><Run Text="  ·  Rounds " /><Run Text="{Binding Rounds, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="{Binding DriverName}" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="{Binding TeamName}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- c1. choose the grid (v0.6.0) -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Grid}}">
                <TextBlock DockPanel.Dock="Top" Text="Choose your grid" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,4" TextWrapping="Wrap"
                           Text="Your own car is always in — it's the row marked &quot;You&quot;. Uncheck any driver you don't want racing on the grid this season." />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Faint}" Margin="0,0,0,10" TextWrapping="Wrap">
                    <Run Text="Your season field is " /><Run Text="{Binding IncludedCount, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" cars. Each race fields the ones that qualified — up to " /><Run Text="{Binding MaxRaceCars, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" on the grid. In AMS2 set " /><Run Text="AI Opponents" FontWeight="SemiBold" /><Run Text=" to " /><Run Text="{Binding AiOpponentCount, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" (the briefing before each race shows the exact number)." />
                </TextBlock>
                <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                    <ItemsControl ItemsSource="{Binding GridChoices}" MaxWidth="640" HorizontalAlignment="Left">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Panel}" Padding="12,8" Margin="0,0,0,4">
                                    <DockPanel>
                                        <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsIncluded}"
                                                  IsEnabled="{Binding IsUnlocked}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource Faint}" VerticalAlignment="Center"
                                                   Text="You" Visibility="{Binding IsLocked, Converter={StaticResource BoolVisible}}" />
                                        <StackPanel>
                                            <TextBlock Text="{Binding DriverName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding TeamName}" Style="{StaticResource Faint}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- c2. character (Increment 4a) -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Character}}">
                <TextBlock DockPanel.Dock="Top" Text="Your driver" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="Pick an archetype for a ready-made driver, or customise the stats and perks. Your choices set the sim's expectation of you — a faster driver is judged against a harder bar, never handed secret pace." />
                <views:CharacterView DataContext="{Binding Character}" />
            </DockPanel>

            <!-- d. confirm -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Confirm}}">
                <TextBlock DockPanel.Dock="Top" Text="Confirm" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,16" TextWrapping="Wrap"
                           Text="Creating the career pins the pack into the career file — later pack edits never touch a running season." />
                <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                        <TextBlock Text="Career name" Style="{StaticResource Muted}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding CareerName, UpdateSourceTrigger=PropertyChanged}" FontSize="15" />

                        <TextBlock Text="Master seed (drives every generated grid — same seed, same season)"
                                   Style="{StaticResource Muted}" Margin="0,14,0,4" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Randomize" Margin="10,0,0,0"
                                    Command="{Binding RandomizeSeedCommand}" />
                            <TextBox Text="{Binding MasterSeedText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="Consolas" FontSize="15" />
                        </DockPanel>

                        <!-- NAMeS-first baseline import (locked decision #7a): DEFAULT ON when
                             the installed class XML parses; shows the import diff summary -->
                        <Border Style="{StaticResource Panel}" Margin="0,18,0,0"
                                Visibility="{Binding BaselineImportAvailable, Converter={StaticResource BoolVisible}}">
                            <StackPanel>
                                <TextBlock Text="Season baseline" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <CheckBox IsChecked="{Binding UseInstalledAiBaseline}"
                                          Content="Use your installed AI file as the season baseline (recommended)" />
                                <TextBlock Style="{StaticResource Muted}" Margin="24,4,0,0" TextWrapping="Wrap"
                                           Text="{Binding BaselineImportSummary}" />
                                <TextBlock Style="{StaticResource Faint}" Margin="24,2,0,0" TextWrapping="Wrap"
                                           Text="{Binding InstalledAiFilePath}" />
                                <TextBlock Style="{StaticResource Faint}" Margin="24,4,0,0" TextWrapping="Wrap"
                                           Text="Per-livery ratings, names and countries come from your file; the pack keeps the calendar, entries, teams and scoring. The imported baseline is pinned into the career — it never drifts if the file changes later." />
                            </StackPanel>
                        </Border>

                        <!-- the installed file exists but could not be parsed -->
                        <Border Background="{StaticResource WarningDimBrush}" CornerRadius="6" Padding="12,8" Margin="0,18,0,0"
                                Visibility="{Binding BaselineImportError, Converter={StaticResource NullCollapsed}}">
                            <TextBlock Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap"
                                       Text="{Binding BaselineImportError, StringFormat='Your installed AI file could not be read — the pack baseline will be used instead. ({0})'}" />
                        </Border>

                        <Border Style="{StaticResource Panel}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Season rules" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding RulesSummary}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Style="{StaticResource Body}" Margin="0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource Faint}" Margin="0,12,0,0" TextWrapping="Wrap"
                                   Text="Difficulty note: the pack's AI ratings assume a fixed in-game AI strength — pick one and keep it for the whole season." />

                        <TextBlock Foreground="{StaticResource ErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0"
                                   Text="{Binding CreateError}"
                                   Visibility="{Binding CreateError, Converter={StaticResource NullCollapsed}}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
