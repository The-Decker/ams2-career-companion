<UserControl x:Class="Companion.App.Views.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wizard="clr-namespace:Companion.ViewModels.Wizard;assembly=Companion.ViewModels"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <UserControl.Resources>
        <!-- step-indicator segment: accent when it IS the current step -->
        <Style x:Key="StepLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
            <Setter Property="Margin" Value="0,0,22,8" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- Season-grid identity follows the shared type system: Orbitron for the entry-board driver
             name and Inter for the quieter team line. Pixel type is reserved for the three-glyph YOU badge. -->
        <Style x:Key="GridDriverName" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="GridTeamName" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="40,32">
        <!-- header + step indicator -->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="New career" Style="{StaticResource H1}" />
            <WrapPanel Margin="0,10,0,12">
                <TextBlock Text="1 · Season">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.SeasonPick}">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="2 · Verify content">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Verification}">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="3 · Seat">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.SeatPick}">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="4 · Driver"
                           Visibility="{Binding HasCharacterStep, Converter={StaticResource BoolVisible}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Character}">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Setter Property="Text" Value="5 · Season Grid" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCharacterStep}" Value="False">
                                    <Setter Property="Text" Value="4 · Season Grid" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Grid}">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource StepLabel}">
                            <Setter Property="Text" Value="6 · Confirm" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCharacterStep}" Value="False">
                                    <Setter Property="Text" Value="5 · Confirm" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Step}" Value="{x:Static wizard:WizardStep.Confirm}">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </WrapPanel>
        </StackPanel>

        <!-- footer: cancel / back / next -->
        <DockPanel DockPanel.Dock="Bottom" Margin="0,20,0,0">
            <Button DockPanel.Dock="Left" Content="Cancel"
                    Style="{StaticResource SubtleButton}"
                    Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="_Back" MinWidth="96" Command="{Binding BackCommand}" />
                <Button MinWidth="140" Margin="10,0,0,0" Command="{Binding NextCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                            <Setter Property="Content" Value="_Next" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Step}"
                                             Value="{x:Static wizard:WizardStep.Confirm}">
                                    <Setter Property="Content" Value="Create career" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
            <Border />
        </DockPanel>

        <!-- the four one-screen steps -->
        <Grid>

            <!-- a. season pick -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.SeasonPick}}">
                <TextBlock DockPanel.Dock="Top" Text="Pick a season pack" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="Sources: the bundled packs folder beside the exe, plus Documents\AMS2CareerCompanion\Packs." />
                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,8,0,0"
                               Text="{Binding PackLoadError}"
                               Visibility="{Binding PackLoadError, Converter={StaticResource NullCollapsed}}" />
                    <Button Content="Rescan pack folders" HorizontalAlignment="Left" Margin="0,10,0,0"
                            Click="OnRefreshPacks" />
                </StackPanel>
                <Border Style="{StaticResource Panel}" Padding="8">
                    <Grid>
                        <!-- season pick as a GRID of year-pic cards (like the career gallery): the era
                             image is the hero; no version, no path. Selection gets an accent border.
                             A UniformGrid lays the cards out in 4 responsive columns (Mike's ask) — the
                             cards flex to fill the width at any screen size, and the year-pic hero keeps
                             its 16:9 aspect via AspectHeight so it scales with the card. CanContentScroll
                             is off so the taller cards scroll by pixel when they overflow the panel. -->
                        <ListBox ItemsSource="{Binding Packs}" SelectedItem="{Binding SelectedPack}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.CanContentScroll="False"
                                 Visibility="{Binding Packs.Count, Converter={StaticResource CountVisible}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- adaptive columns (was a fixed 4): the 580px target card width keeps
                                         Mike's asked-for 4 columns at his 2560 screen (after the wizard's
                                         chrome), degrades to 3 at 1920 and an uncramped 2 at the 920 minimum -->
                                    <UniformGrid Columns="{Binding ActualWidth,
                                                           RelativeSource={RelativeSource AncestorType=ListBox},
                                                           Converter={StaticResource WidthToColumns},
                                                           ConverterParameter=580}" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="Margin" Value="6" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="7" HorizontalAlignment="Stretch">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                                                <Setter Property="BorderThickness" Value="2" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                    </DataTrigger>
                                                    <!-- selected card: accent ring -->
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <!-- 16:9 year-pic hero (era art keyed by the season year, or
                                                 by identity for SMGP — its SEGA Grand Prix art rather than
                                                 the shared 1990 photo; coloured era placeholder when none).
                                                 The image binds the whole pack so the converter sees the
                                                 careerStyle; the accent still keys off the title text. -->
                                            <Grid MinHeight="120"
                                                  Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}, Converter={StaticResource AspectHeight}, ConverterParameter=0.5625}">
                                                <Border CornerRadius="6,6,0,0"
                                                        Background="{Binding Title, Converter={StaticResource EraAccent}}" />
                                                <Border CornerRadius="6,6,0,0">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Converter={StaticResource EraImage}}"
                                                                    Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Title}" FontFamily="{StaticResource DisplayFont}"
                                                       FontSize="18" Margin="12,10,12,13" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                                                       Margin="12,0,12,10" TextWrapping="Wrap"
                                                       Text="{Binding LoadError, StringFormat='pack.json unreadable: {0}'}"
                                                       Visibility="{Binding LoadError, Converter={StaticResource NullCollapsed}}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- empty state (ux-round §4): no packs found → explain the folders + open -->
                        <StackPanel Margin="12,10" MaxWidth="560" HorizontalAlignment="Left"
                                    Visibility="{Binding Packs.Count, Converter={StaticResource CountCollapsed}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE838;" FontSize="20"
                                           Foreground="{DynamicResource AccentTextBrush}" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <TextBlock Text="No season packs found" FontWeight="SemiBold" FontSize="15"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0" TextWrapping="Wrap"
                                       Text="A season pack is a plain folder with a pack.json inside. These places are searched:" />
                            <TextBlock Style="{StaticResource Muted}" Margin="16,6,0,0" TextWrapping="Wrap"
                                       Text="• the bundled packs folder beside the exe" />
                            <TextBlock Style="{StaticResource Muted}" Margin="16,2,0,0" TextWrapping="Wrap"
                                       Text="• Documents\AMS2CareerCompanion\Packs (yours — drop packs here)" />
                            <TextBlock Style="{StaticResource Muted}" Margin="16,2,0,0" TextWrapping="Wrap"
                                       Text="• any extra folders you add under Settings → Data" />
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="Open pack folder" Click="OnOpenPackFolder"
                                        ToolTip="Opens Documents\AMS2CareerCompanion\Packs in Explorer (created if missing)" />
                                <TextBlock Style="{StaticResource Faint}" VerticalAlignment="Center" Margin="10,0,0,0"
                                           Text="then drop a pack in and hit Rescan below" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </DockPanel>

            <!-- b. content verification -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Verification}}">
                <TextBlock DockPanel.Dock="Top" Text="Content verification" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="Structure, AMS2 content and installed liveries checked against the detected install. Errors block; warnings can be overridden." />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <TextBlock Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                               Text="Errors block career creation — fix the pack and rescan."
                               Visibility="{Binding HasErrors, Converter={StaticResource BoolVisible}}" />
                    <CheckBox Content="Proceed anyway — I accept the warnings above"
                              IsChecked="{Binding ProceedAnyway}">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasWarnings}" Value="True" />
                                            <Condition Binding="{Binding HasErrors}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- optional alternate MOD tracks (the "RockyTM track switch"): opt-in AND
                         install-verified. Off (or any required mod missing) => default AMS2 tracks only. -->
                    <Border Style="{StaticResource Panel}" Margin="0,10,0,0"
                            Visibility="{Binding PackHasAlternateTracks, Converter={StaticResource BoolVisible}}">
                        <StackPanel>
                            <CheckBox Content="Use alternate tracks (community mods)"
                                      IsChecked="{Binding UseAlternateTracks}"
                                      ToolTip="Swaps this season's placeholder rounds to era-appropriate mod circuits — but ONLY if every required mod is installed. Off = default AMS2 tracks only." />
                            <TextBlock Text="{Binding AlternateTrackStatus}" Style="{StaticResource Body}"
                                       TextWrapping="Wrap" Margin="0,6,0,0" />
                            <ItemsControl ItemsSource="{Binding AlternateModTracks}" Margin="0,6,0,0"
                                          Visibility="{Binding UseAlternateTracks, Converter={StaticResource BoolVisible}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,1">
                                            <TextBlock DockPanel.Dock="Left" Width="18" VerticalAlignment="Top">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Setter Property="Text" Value="✗" />
                                                        <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Installed}" Value="True">
                                                                <Setter Property="Text" Value="✔" />
                                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}"><Run Text="{Binding DisplayName, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="{Binding Tag, Mode=OneWay, StringFormat=' ({0})'}" /></TextBlock>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="Re-check installed mods" Command="{Binding CheckAlternateModsCommand}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0" Style="{StaticResource SubtleButton}"
                                    Visibility="{Binding UseAlternateTracks, Converter={StaticResource BoolVisible}}"
                                    ToolTip="Re-scan your AMS2 install for the mod tracks this season's alternates need" />
                        </StackPanel>
                    </Border>

                    <!-- optional modded FIELD (a community CAR mod): the SMGP McLaren teams by Kobra
                         Fleetworks that round the grid out. Opt-in AND install-verified, exactly like
                         the alternate tracks above. Off (or the mod missing) => base field only. -->
                    <Border Style="{StaticResource Panel}" Margin="0,10,0,0"
                            Visibility="{Binding PackHasModdedField, Converter={StaticResource BoolVisible}}">
                        <StackPanel>
                            <CheckBox IsChecked="{Binding UseModdedField}"
                                      Content="{Binding ModdedVehicle.ModName, StringFormat='Add the {0} cars (community car mod)'}"
                                      ToolTip="Fields the mod's extra cars to round out the grid — but ONLY if the car mod is installed. Off = the base grid." />
                            <TextBlock Text="{Binding ModdedFieldStatus}" Style="{StaticResource Body}"
                                       TextWrapping="Wrap" Margin="0,6,0,0" />
                            <DockPanel Margin="0,6,0,0"
                                       Visibility="{Binding UseModdedField, Converter={StaticResource BoolVisible}}">
                                <TextBlock DockPanel.Dock="Left" Width="18" VerticalAlignment="Top">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Text" Value="✗" />
                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModdedVehicle.Installed}" Value="True">
                                                    <Setter Property="Text" Value="✔" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}"><Run Text="{Binding ModdedVehicle.ModName, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="{Binding ModdedVehicle.VehicleId, Mode=OneWay, StringFormat=' ({0})'}" /></TextBlock>
                            </DockPanel>
                            <Button Content="Re-check installed mod" Command="{Binding CheckModdedFieldCommand}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0" Style="{StaticResource SubtleButton}"
                                    Visibility="{Binding UseModdedField, Converter={StaticResource BoolVisible}}"
                                    ToolTip="Re-scan your AMS2 install for the car mod this season's extra cars need" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border Style="{StaticResource Panel}">
                    <DockPanel>
                        <!-- per-file livery-scan details (unreadable files): collapsed by default -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0"
                                    Visibility="{Binding HasLiveryScanDetails, Converter={StaticResource BoolVisible}}">
                            <Button HorizontalAlignment="Left" Command="{Binding ToggleLiveryScanDetailsCommand}"
                                    ToolTip="The files the livery scan could not read, one line each">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                        <Setter Property="Content" Value="Show details ▸" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LiveryScanDetailsExpanded}" Value="True">
                                                <Setter Property="Content" Value="Hide details ▾" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <ScrollViewer MaxHeight="180" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False"
                                          Visibility="{Binding LiveryScanDetailsExpanded, Converter={StaticResource BoolVisible}}">
                                <ItemsControl ItemsSource="{Binding LiveryScanDetails}" Margin="12,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Style="{StaticResource Faint}"
                                                       TextWrapping="Wrap" Margin="0,1" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                        <Grid>
                        <TextBlock Foreground="{DynamicResource SuccessBrush}" FontSize="15"
                                   Visibility="{Binding VerificationItems.Count, Converter={StaticResource CountCollapsed}}">
                            <Run FontFamily="{StaticResource IconFont}" Text="&#xE73E;" /><Run Text="  All clear — the pack verifies clean against this install." />
                        </TextBlock>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False"
                                      Visibility="{Binding VerificationItems.Count, Converter={StaticResource CountVisible}}">
                            <ItemsControl ItemsSource="{Binding VerificationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,3">
                                            <Border DockPanel.Dock="Left" CornerRadius="4" Padding="8,2"
                                                    VerticalAlignment="Top" Margin="0,0,10,0" Width="76">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Severity}" FontSize="12" HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsInfo}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- c. seat pick -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.SeatPick}}">
                <TextBlock DockPanel.Dock="Top" Text="Pick your seat" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="You replace this driver for the season (their ratings vacate the seat; the team's car stays as-is)." />
                <!-- SMGP: rookies start at the bottom — the list is filtered to LEVEL D cars. -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource AccentDimBrush}" CornerRadius="6"
                        Padding="10,7" Margin="0,0,0,10"
                        Visibility="{Binding IsSmgpPack, Converter={StaticResource BoolVisible}}">
                    <TextBlock Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap"
                               Text="SUPER MONACO GP starts you at the bottom — LEVEL D cars only. Beat the same rival twice to take his seat and climb the ladder." />
                </Border>
                <!-- ...or race as your own independent entrant (a custom AMS2 livery). Takes precedence
                     over the seat above; leave blank for the ordinary seat pick. Hidden for the SMGP
                     replica — a custom livery holds no seat on the mode's ladder. -->
                <Border DockPanel.Dock="Bottom" Style="{StaticResource Panel}" Margin="0,10,0,0" Padding="12"
                        Visibility="{Binding IsSmgpPack, Converter={StaticResource BoolCollapsed}}">
                    <StackPanel>
                        <TextBlock Text="— or race as your own entrant —" Style="{StaticResource Faint}" />
                        <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,6" TextWrapping="Wrap"
                                   Text="Type the exact name of a custom livery installed in AMS2 to race as an independent privateer — your own car, added to the grid instead of replacing a historical driver. Leave blank to take a seat above." />
                        <TextBox Text="{Binding CustomLiveryName, UpdateSourceTrigger=PropertyChanged}" FontSize="14"
                                 ToolTip="The AMS2 livery name for your own car — leave blank to take a pack seat instead" />
                        <TextBlock Style="{StaticResource Faint}" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   Text="Racing as your own entrant — the seat above is ignored."
                                   Visibility="{Binding CustomLiveryName, Converter={StaticResource StringVisible}}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Panel}" Padding="8">
                    <ListBox ItemsSource="{Binding Seats}" SelectedItem="{Binding SelectedSeat}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <!-- mouse parity: double-click a seat = select it AND advance -->
                                <EventSetter Event="MouseDoubleClick" Handler="OnSeatDoubleClick" />
                                <Setter Property="ToolTip" Value="Double-click to pick this seat and continue" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Width="44" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentTextBrush}" VerticalAlignment="Center"
                                               Text="{Binding Number, StringFormat='#{0}'}" />
                                    <!-- ratings as bars; raw numbers on hover (ux-round §2) -->
                                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" MinWidth="190" MaxWidth="280">
                                        <DockPanel ToolTip="{Binding RaceSkill, StringFormat='Race skill (raw): {0:0.000}'}"
                                                   Background="Transparent">
                                            <TextBlock DockPanel.Dock="Left" Width="42" Text="Race"
                                                       Style="{StaticResource Faint}" VerticalAlignment="Center" />
                                            <ProgressBar Style="{StaticResource RatingBar}"
                                                         Value="{Binding RaceSkill, Mode=OneWay}" />
                                        </DockPanel>
                                        <DockPanel Margin="0,4,0,0"
                                                   ToolTip="{Binding QualifyingSkill, StringFormat='Qualifying skill (raw): {0:0.000}'}"
                                                   Background="Transparent">
                                            <TextBlock DockPanel.Dock="Left" Width="42" Text="Quali"
                                                       Style="{StaticResource Faint}" VerticalAlignment="Center" />
                                            <ProgressBar Style="{StaticResource RatingBar}"
                                                         Value="{Binding QualifyingSkill, Mode=OneWay}" />
                                        </DockPanel>
                                        <TextBlock HorizontalAlignment="Right" Style="{StaticResource Faint}" Margin="0,4,0,0"
                                                   ToolTip="{Binding Reliability, StringFormat='Car reliability (raw): {0:0.000}'}">
                                            <Run Text="Team tier " /><Run Text="{Binding TeamTier, Mode=OneWay}" /><Run Text="  ·  Reliability " /><Run Text="{Binding Reliability, Mode=OneWay, StringFormat={}{0:0.00}}" /><Run Text="  ·  Rounds " /><Run Text="{Binding Rounds, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,0">
                                        <TextBlock Text="{Binding DriverName}" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="{Binding TeamName}" Style="{StaticResource Muted}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- c1. choose the grid (v0.6.0) -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Grid}}">
                <TextBlock DockPanel.Dock="Top" Text="The Season's Grid" Style="{StaticResource H2}" />
                <!-- The normal-career blurb (unchecking) — hidden for SMGP, whose field is locked and
                     described by its own accent banner below. -->
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,4" TextWrapping="Wrap"
                           Visibility="{Binding IsSmgpPack, Converter={StaticResource BoolCollapsed}}"
                           Text="The field you'll race — it carries across every season of the career. Your own car is always in (the card marked &quot;You&quot;). Uncheck any driver you don't want on the grid." />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Faint}" Margin="0,0,0,10" TextWrapping="Wrap">
                    <Run Text="Your season field is " /><Run Text="{Binding IncludedCount, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" cars. Each race fields the ones that qualified — up to " /><Run Text="{Binding MaxRaceCars, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" on the grid. In AMS2 set " /><Run Text="AI Opponents" FontWeight="SemiBold" /><Run Text=" to " /><Run Text="{Binding AiOpponentCount, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" (the briefing before each race shows the exact number)." />
                </TextBlock>
                <!-- SMGP: the ladder needs the whole field — the pick is display-only (locked). The
                     banner also sets the mode's expectations: it's a self-contained career (never the
                     historical gallery), the same cars for good, with a per-race DNQ field. -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource AccentDimBrush}" CornerRadius="6"
                        Padding="10,7" Margin="0,0,0,10"
                        Visibility="{Binding IsSmgpPack, Converter={StaticResource BoolVisible}}">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" FontWeight="SemiBold"
                                   Text="SUPER MONACO GP is its own career — these are your cars for good." />
                        <TextBlock Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" Margin="0,3,0,0"
                                   Text="You stay in this 34-car world every season, however many titles you win — it never crosses into the historical careers. The field is locked (the rival ladder needs every seat), and each race only the cars that qualify start: the slowest pre-qualify out, and which ones changes race to race." />
                    </StackPanel>
                </Border>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
                    <!-- adaptive multi-column grid, ~230px per card so more portraits fit a screen
                         (Mike's ask) while the 148px portrait + car keep their detail. The whole
                         control is NOT disabled for SMGP anymore — the cards stay vibrant; only the
                         per-card checkbox is hidden (SMGP forces the whole field). -->
                    <ItemsControl ItemsSource="{Binding GridChoices}" HorizontalAlignment="Stretch"
                                  VerticalAlignment="Top">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid VerticalAlignment="Top"
                                             Columns="{Binding ActualWidth,
                                                       RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                       Converter={StaticResource WidthToColumns},
                                                       ConverterParameter=230}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,5,5" VerticalAlignment="Top">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource Card}">
                                            <Setter Property="Padding" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIncluded}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUnlocked}" Value="False">
                                                    <Setter Property="Opacity" Value="0.72" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentHoverBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <StackPanel>
                                            <!-- the DRIVER PORTRAIT is the hero (data/ams2/portraits/<driverId>.jpg):
                                                 a centered SQUARE (the art is square 1254×1254). A framed
                                                 person-glyph placeholder shows until the art is dropped in. -->
                                            <Grid Width="148" Height="148" HorizontalAlignment="Center" Margin="0,10,0,0">
                                                <Border Style="{StaticResource AssetPlaceholderFrame}">
                                                    <TextBlock Text="&#xE77B;" Style="{StaticResource AssetPlaceholderGlyph}"
                                                               FontSize="44" />
                                                </Border>
                                                <Border CornerRadius="8" ClipToBounds="True">
                                                    <!-- The player's own card shows the TEAM's player image (team-coloured
                                                         helmet, data/ams2/portraits/player.<team>.jpg); every other card shows
                                                         the seat driver's portrait. PortraitKey resolves which. -->
                                                    <Image Stretch="UniformToFill"
                                                           Source="{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                                </Border>
                                            </Grid>
                                            <!-- a smaller CAR thumbnail centered below the portrait
                                                 (data/ams2/cars/<driverId>.png). Collapses when absent. -->
                                            <Image Height="40" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,6,0,0"
                                                   Source="{Binding DriverId, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                            <!-- CENTERED racing-style name + team (Bahnschrift, uppercase) -->
                                            <StackPanel Margin="6,7,6,11" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding DriverNameUpper}" Style="{StaticResource GridDriverName}" />
                                                <TextBlock Text="{Binding TeamNameUpper}" Style="{StaticResource GridTeamName}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <!-- season-field checkbox: ONLY for a normal career. SMGP forces the whole
                                             field, so nothing is clickable there — the checkbox is hidden. Overlaid
                                             top-left so the names stay centered. -->
                                        <CheckBox VerticalAlignment="Top" HorizontalAlignment="Left" Margin="9,9,0,0"
                                                  IsChecked="{Binding IsIncluded}" IsEnabled="{Binding IsUnlocked}"
                                                  Visibility="{Binding DataContext.GridPickEnabled, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolVisible}}" />
                                        <!-- the player's own car marker -->
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,9,9,0"
                                                Background="{DynamicResource AccentDimBrush}" CornerRadius="3" Padding="6,2"
                                                Visibility="{Binding IsLocked, Converter={StaticResource BoolVisible}}">
                                            <TextBlock Text="YOU" FontFamily="{StaticResource PixelFont}" FontSize="8"
                                                       Foreground="{DynamicResource AccentTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- c2. character (Increment 4a) -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Character}}">
                <TextBlock DockPanel.Dock="Top" Text="Your driver" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,12" TextWrapping="Wrap"
                           Text="Pick an archetype for a ready-made driver, or customise the stats and perks. Your choices set the sim's expectation of you — a faster driver is judged against a harder bar, never handed secret pace." />
                <!-- YOU, front and centre: the team-coloured player image (drop art at
                     data\ams2\portraits\player.<team>.jpg) with the car you'll drive beneath it. Both
                     follow the team you joined; framed placeholders show until the art is dropped. -->
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,14">
                    <Grid Width="168" Height="168" HorizontalAlignment="Center"
                          ToolTip="Drop your team player image at data\ams2\portraits\player.&lt;team&gt;.jpg (beside the exe)">
                        <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="52"
                                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border CornerRadius="10" ClipToBounds="True">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding PlayerImageKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                        </Border>
                    </Grid>
                    <Image Height="44" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,8,0,0"
                           Source="{Binding PlayerCarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                    <!-- the car you'll drive, as the arcade spec card — collapses when no spec is authored -->
                    <ContentControl Content="{Binding PlayerCarSpec}" HorizontalAlignment="Center" Margin="0,8,0,0"
                                    Visibility="{Binding PlayerCarSpec, Converter={StaticResource NullCollapsed}}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:CarSpecCard MaxWidth="260" />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
                <views:CharacterView DataContext="{Binding Character}" />
            </DockPanel>

            <!-- d. confirm -->
            <DockPanel Visibility="{Binding Step, Converter={StaticResource EnumVisible}, ConverterParameter={x:Static wizard:WizardStep.Confirm}}">
                <TextBlock DockPanel.Dock="Top" Text="Confirm" Style="{StaticResource H2}" />
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,4,0,16" TextWrapping="Wrap"
                           Text="Creating the career pins the pack into the career file — later pack edits never touch a running season." />
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
                    <StackPanel MaxWidth="640" HorizontalAlignment="Center">
                        <TextBlock Text="Career name" Style="{StaticResource Muted}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding CareerName, UpdateSourceTrigger=PropertyChanged}" FontSize="15" />

                        <TextBlock Text="Master seed (drives every generated grid — same seed, same season)"
                                   Style="{StaticResource Muted}" Margin="0,14,0,4" />
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Randomize" Margin="10,0,0,0"
                                    Command="{Binding RandomizeSeedCommand}" />
                            <TextBox Text="{Binding MasterSeedText, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource MonoFont}" FontSize="15" />
                        </DockPanel>

                        <!-- NAMeS-first baseline import (locked decision #7a): DEFAULT ON when
                             the installed class XML parses; shows the import diff summary -->
                        <Border Style="{StaticResource Panel}" Margin="0,18,0,0"
                                Visibility="{Binding BaselineImportAvailable, Converter={StaticResource BoolVisible}}">
                            <StackPanel>
                                <TextBlock Text="Season baseline" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <CheckBox IsChecked="{Binding UseInstalledAiBaseline}"
                                          Content="Use your installed AI file as the season baseline (recommended)" />
                                <TextBlock Style="{StaticResource Muted}" Margin="24,4,0,0" TextWrapping="Wrap"
                                           Text="{Binding BaselineImportSummary}" />
                                <TextBlock Style="{StaticResource Faint}" Margin="24,2,0,0" TextWrapping="Wrap"
                                           Text="{Binding InstalledAiFilePath}" />
                                <TextBlock Style="{StaticResource Faint}" Margin="24,4,0,0" TextWrapping="Wrap"
                                           Text="Per-livery ratings, names and countries come from your file; the pack keeps the calendar, entries, teams and scoring. The imported baseline is pinned into the career — it never drifts if the file changes later." />
                            </StackPanel>
                        </Border>

                        <!-- the installed file exists but could not be parsed -->
                        <Border Background="{DynamicResource WarningDimBrush}" CornerRadius="6" Padding="12,8" Margin="0,18,0,0"
                                Visibility="{Binding BaselineImportError, Converter={StaticResource NullCollapsed}}">
                            <TextBlock Foreground="{DynamicResource WarningBrush}" TextWrapping="Wrap"
                                       Text="{Binding BaselineImportError, StringFormat='Your installed AI file could not be read — the pack baseline will be used instead. ({0})'}" />
                        </Border>

                        <Border Style="{StaticResource Panel}" Margin="0,18,0,0">
                            <StackPanel>
                                <TextBlock Text="Season rules" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <ItemsControl ItemsSource="{Binding RulesSummary}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Style="{StaticResource Body}" Margin="0,2" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Style="{StaticResource Faint}" Margin="0,12,0,0" TextWrapping="Wrap"
                                   Text="Difficulty note: the pack's AI ratings assume a fixed in-game AI strength — pick one and keep it for the whole season." />

                        <TextBlock Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,12,0,0"
                                   Text="{Binding CreateError}"
                                   Visibility="{Binding CreateError, Converter={StaticResource NullCollapsed}}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
    </DockPanel>
</UserControl>
