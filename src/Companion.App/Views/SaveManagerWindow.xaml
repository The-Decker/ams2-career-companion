<Window x:Class="Companion.App.Views.SaveManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Companion.App"
        xmlns:audio="clr-namespace:Companion.App.Audio"
        Title="Career save points"
        Width="760" Height="620" MinWidth="620" MinHeight="480"
        WindowStyle="None" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{StaticResource BodyFont}" FontSize="{DynamicResource AppFontSize}"
        Background="{DynamicResource BgBrush}" PreviewKeyDown="OnPreviewKeyDown">
    <Grid Background="{StaticResource AppTextureBrush}">
        <Border Background="{StaticResource AppVignetteBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Height="46" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                        app:WindowChromeAssist.IsDragRegion="True">
                    <DockPanel Margin="15,4,5,4">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}"
                                audio:SoundAssist.Cue="Back"
                                app:WindowChromeAssist.IsCloseButton="True"
                                AutomationProperties.Name="Close career saves" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CAREER SAVE POINTS" Style="{StaticResource Eyebrow}"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                            <TextBlock Text="NORMAL MODE · WHOLE-CAREER SNAPSHOTS"
                                       Style="{StaticResource Mono}" FontSize="9.5"
                                       Foreground="{DynamicResource TextMutedBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ErrorCallout}" Margin="18,16,18,0"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullCollapsed}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource ErrorBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Grid Grid.Row="2" Margin="18,16,18,10">
                    <Border Style="{StaticResource Panel}" Padding="22"
                            Visibility="{Binding Slots.Count, Converter={StaticResource CountCollapsed}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource IconFont}" FontSize="34"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="NO SAVE POINTS YET" Style="{StaticResource H2}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0" />
                            <TextBlock Text="Create a manual save before a difficult race. Normal careers also keep season-start autosaves when available."
                                       Style="{StaticResource Muted}" TextWrapping="Wrap" TextAlignment="Center"
                                       MaxWidth="470" Margin="0,7,0,0" />
                        </StackPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False"
                                  Visibility="{Binding Slots.Count, Converter={StaticResource CountVisible}}">
                        <ItemsControl ItemsSource="{Binding Slots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Panel}" Padding="16,13" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <WrapPanel>
                                                    <TextBlock Text="{Binding Label}" FontSize="16"
                                                               FontWeight="SemiBold" VerticalAlignment="Center" />
                                                    <Border Style="{StaticResource CompactChip}" Margin="9,0,0,0"
                                                            Background="{DynamicResource AccentDimBrush}"
                                                            BorderBrush="{DynamicResource AccentBrush}"
                                                            Visibility="{Binding IsAutosave, Converter={StaticResource BoolVisible}}">
                                                        <TextBlock Text="AUTOSAVE" Style="{StaticResource Eyebrow}"
                                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                                    </Border>
                                                </WrapPanel>
                                                <TextBlock Margin="0,6,0,0" Style="{StaticResource Mono}"
                                                           Foreground="{DynamicResource TextMutedBrush}">
                                                    <Run Text="SEASON " /><Run Text="{Binding SeasonYear, Mode=OneWay}" />
                                                    <Run Text="  ·  ROUND " /><Run Text="{Binding Round, Mode=OneWay}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding CreatedUtc}" Style="{StaticResource Faint}"
                                                           FontSize="10.5" Margin="0,4,0,0" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="18,0,0,0">
                                                <Button Content="RESTORE" Style="{StaticResource AccentButton}"
                                                        audio:SoundAssist.Cue="Warning"
                                                        MinWidth="96" Click="OnRestore"
                                                        AutomationProperties.Name="Restore this save point" />
                                                <Button Content="DELETE" Style="{StaticResource SubtleButton}"
                                                        audio:SoundAssist.Cue="Destructive"
                                                        Foreground="{DynamicResource ErrorBrush}"
                                                        MinWidth="82" Margin="8,0,0,0" Click="OnDelete"
                                                        AutomationProperties.Name="Delete this save point" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Border Grid.Row="3" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,1,0,0"
                        Padding="18,13">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="NEW SAVE POINT"
                                audio:SoundAssist.Cue="Navigate"
                                Style="{StaticResource AccentButton}" Padding="18,9"
                                Click="OnCreateSave" AutomationProperties.Name="Create a new save point" />
                        <TextBlock Text="Restoring replaces the entire career timeline, including later race results."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap"
                                   VerticalAlignment="Center" Margin="0,0,18,0" />
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
