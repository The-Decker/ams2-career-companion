<UserControl x:Class="Companion.App.Views.CarSpecCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- The arcade car-select card: machine name + engine·power, then the ENG-TM-SUS-TIRE-BRA bars.
         DataContext is a CarSpecCardViewModel; the host collapses this control when it is null. -->
    <Border Style="{StaticResource Panel}" Padding="16,14">
        <StackPanel>
            <TextBlock Text="{Binding MachineName}" FontWeight="SemiBold" FontSize="20" />
            <TextBlock Text="{Binding SubHeader}" Style="{StaticResource Faint}" FontSize="14" Margin="0,2,0,10"
                       Visibility="{Binding SubHeader, Converter={StaticResource StringVisible}}" />
            <ItemsControl ItemsSource="{Binding Bars}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="0,4">
                            <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="58"
                                       VerticalAlignment="Center" Style="{StaticResource Faint}" FontSize="14" />
                            <TextBlock DockPanel.Dock="Right" Width="34" TextAlignment="Right"
                                       VerticalAlignment="Center" Style="{StaticResource Faint}" FontSize="14"
                                       Text="{Binding Value, Mode=OneWay}" />
                            <ProgressBar Minimum="0" Maximum="{Binding Max}" Value="{Binding Value, Mode=OneWay}"
                                         Height="14" VerticalAlignment="Center" Margin="8,0" />
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
