<UserControl x:Class="Companion.App.Views.PaddockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- The Paddock lens (SMGP driver/team preview): a DRIVERS/TEAMS toggle over a master list (left)
         and a dossier detail pane (right). Click a driver for their bio + predetermined career stats +
         team; click a team for its motto, history, quotes and roster. Display-only. Codex owns the
         visual polish (see docs/dev/codex-gui-brief.md) — this is the functional layout. -->
    <UserControl.Resources>

        <!-- compact driver list row: portrait thumb + name/team/epithet -->
        <DataTemplate x:Key="DriverRow">
            <Grid Margin="2,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Width="46" Height="46">
                    <Border CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}">
                        <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="20"
                                   Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="6" ClipToBounds="True">
                        <Image Stretch="UniformToFill"
                               Source="{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                    </Border>
                </Grid>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding TeamName}" Style="{StaticResource Faint}" FontSize="11"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- compact team list row: logo thumb + name/motto -->
        <DataTemplate x:Key="TeamRow">
            <Grid Margin="2,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Width="46" Height="46">
                    <Border CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}">
                        <TextBlock Text="&#xE7C1;" FontFamily="{StaticResource IconFont}" FontSize="18"
                                   Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="6" ClipToBounds="True">
                        <Image Stretch="Uniform" Margin="4"
                               Source="{Binding LogoKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/logos}"
                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                    </Border>
                </Grid>
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Motto}" Style="{StaticResource Faint}" FontSize="10.5"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- the RIGHT detail pane for a selected driver -->
        <DataTemplate x:Key="DriverDetail">
            <StackPanel>
                <!-- hero: portrait + car + identity -->
                <Border Style="{StaticResource Panel}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="180" Height="180" VerticalAlignment="Top"
                              ToolTip="Drop the portrait at data\ams2\portraits\&lt;driverId&gt;.jpg">
                            <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                                <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="56"
                                           Foreground="{DynamicResource TextMutedBrush}" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="10" ClipToBounds="True">
                                <Image Stretch="UniformToFill"
                                       Source="{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Border>
                        </Grid>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Epithet}" Foreground="{DynamicResource AccentTextBrush}"
                                       FontWeight="SemiBold" Margin="0,2,0,0"
                                       Visibility="{Binding Epithet, Converter={StaticResource StringVisible}}" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Style="{StaticResource Chip}" Margin="0,0,10,0"
                                        Visibility="{Binding Number, Converter={StaticResource StringVisible}}">
                                    <TextBlock Text="{Binding Number, StringFormat='#{0}'}" Style="{StaticResource PixelBadge}"
                                               Foreground="{DynamicResource AccentTextBrush}" VerticalAlignment="Center" />
                                </Border>
                                <Button Content="{Binding TeamName}"
                                        Style="{StaticResource SubtleButton}"
                                        Command="{Binding DataContext.ViewTeamCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding TeamId}"
                                        ToolTip="Open this team's dossier" />
                            </StackPanel>
                            <Image Height="64" Stretch="Uniform" HorizontalAlignment="Left" Margin="0,12,0,0"
                                   Source="{Binding CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}"
                                   ToolTip="Drop the car at data\ams2\cars\&lt;driverId&gt;.png" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- this season (live) + all-time career -->
                <StackPanel Margin="0,16,0,0" Visibility="{Binding Career, Converter={StaticResource NullCollapsed}}">
                    <!-- the live season line, once a round has been scored -->
                    <Border Style="{StaticResource Panel}" Background="{DynamicResource SurfaceAltBrush}"
                            Padding="14,10" Margin="0,0,0,12"
                            Visibility="{Binding Season, Converter={StaticResource NullCollapsed}}">
                        <StackPanel>
                            <TextBlock Text="THIS SEASON" Style="{StaticResource Eyebrow}" Margin="0,0,0,6" />
                            <WrapPanel>
                                <TextBlock Text="{Binding Season.Position, StringFormat=P{0}}"
                                           Style="{StaticResource StatValue}" FontSize="18"
                                           Foreground="{DynamicResource AccentTextBrush}" Margin="0,0,22,0" />
                                <TextBlock Text="{Binding Season.Points, StringFormat={}{0} pts}"
                                           Style="{StaticResource StatValue}" FontSize="18" Margin="0,0,22,0" />
                                <TextBlock Text="{Binding Season.Wins, StringFormat={}{0} W}"
                                           Style="{StaticResource StatValue}" FontSize="18" Margin="0,0,22,0" />
                                <TextBlock Text="{Binding Season.Poles, StringFormat={}{0} pole}"
                                           Style="{StaticResource StatValue}" FontSize="18" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="CAREER RECORD" Style="{StaticResource Eyebrow}" Margin="0,0,0,8" />
                    <WrapPanel>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Titles}" Style="{StaticResource StatValue}"
                                           Foreground="{DynamicResource AccentTextBrush}" />
                                <TextBlock Text="TITLES" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Wins}" Style="{StaticResource StatValue}" />
                                <TextBlock Text="WINS" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Podiums}" Style="{StaticResource StatValue}" />
                                <TextBlock Text="PODIUMS" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Poles}" Style="{StaticResource StatValue}" />
                                <TextBlock Text="POLES" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Top5s}" Style="{StaticResource StatValue}" />
                                <TextBlock Text="TOP 5" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Points}" Style="{StaticResource StatValue}" />
                                <TextBlock Text="POINTS" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatTile}">
                            <StackPanel>
                                <TextBlock Text="{Binding Career.Starts}" Style="{StaticResource StatValue}" />
                                <TextBlock Text="STARTS" Style="{StaticResource Eyebrow}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <!-- biography -->
                <TextBlock Text="PROFILE" Style="{StaticResource Eyebrow}" Margin="0,10,0,8" />
                <ItemsControl ItemsSource="{Binding Bio}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- quotes -->
                <TextBlock Text="IN THEIR WORDS" Style="{StaticResource Eyebrow}" Margin="0,4,0,8" />
                <ItemsControl ItemsSource="{Binding Quotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QuoteCard}">
                                <TextBlock Text="{Binding}" Style="{StaticResource Body}"
                                           FontStyle="Italic" TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <!-- the RIGHT detail pane for a selected team -->
        <DataTemplate x:Key="TeamDetail">
            <StackPanel>
                <Border Style="{StaticResource Panel}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="120" Height="120" VerticalAlignment="Top"
                              ToolTip="Drop the team logo at data\ams2\smgp\logos\&lt;teamId&gt;.png">
                            <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                                <TextBlock Text="&#xE7C1;" FontFamily="{StaticResource IconFont}" FontSize="44"
                                           Foreground="{DynamicResource TextMutedBrush}" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="10" ClipToBounds="True">
                                <Image Stretch="Uniform" Margin="10"
                                       Source="{Binding LogoKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/logos}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Border>
                        </Grid>
                        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Top">
                            <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Motto}" Foreground="{DynamicResource AccentTextBrush}"
                                       FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Visibility="{Binding Motto, Converter={StaticResource StringVisible}}" />
                            <TextBlock Text="DRIVERS" Style="{StaticResource Eyebrow}" Margin="0,12,0,6" />
                            <ItemsControl ItemsSource="{Binding DriverNames}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Chip}" Margin="0,0,6,6">
                                            <TextBlock Text="{Binding}" FontSize="12" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Text="TEAM HISTORY" Style="{StaticResource Eyebrow}" Margin="0,16,0,8" />
                <ItemsControl ItemsSource="{Binding History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="FROM THE GARAGE" Style="{StaticResource Eyebrow}" Margin="0,4,0,8" />
                <ItemsControl ItemsSource="{Binding Quotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QuoteCard}">
                                <TextBlock Text="{Binding}" Style="{StaticResource Body}"
                                           FontStyle="Italic" TextWrapping="Wrap" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- header: title + DRIVERS/TEAMS toggle -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="SMGP RECORD BOOK" Style="{StaticResource Eyebrow}" />
                <TextBlock Text="PADDOCK" Style="{StaticResource H2}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,0"
                           Text="The grid — every driver and the house they race for." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="DRIVERS" MinWidth="90" Command="{Binding ShowDriversCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SelectableSubtleButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTeams}" Value="False">
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="TEAMS" MinWidth="90" Margin="6,0,0,0" Command="{Binding ShowTeamsListCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SelectableSubtleButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTeams}" Value="True">
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- body: master list (left) + dossier detail (right) -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- drivers list -->
            <ListBox Grid.Column="0" Margin="0,0,14,0" ItemsSource="{Binding Drivers}"
                     SelectedItem="{Binding SelectedDriver}" ItemTemplate="{StaticResource DriverRow}"
                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTeams}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>

            <!-- teams list -->
            <ListBox Grid.Column="0" Margin="0,0,14,0" ItemsSource="{Binding Teams}"
                     SelectedItem="{Binding SelectedTeam}" ItemTemplate="{StaticResource TeamRow}"
                     HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTeams}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
            </ListBox>

            <!-- driver dossier -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Focusable="False">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTeams}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ContentControl Content="{Binding SelectedDriver}" ContentTemplate="{StaticResource DriverDetail}" />
            </ScrollViewer>

            <!-- team dossier -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Focusable="False">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowTeams}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ContentControl Content="{Binding SelectedTeam}" ContentTemplate="{StaticResource TeamDetail}" />
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
