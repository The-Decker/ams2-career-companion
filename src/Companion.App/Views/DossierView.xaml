<UserControl x:Class="Companion.App.Views.DossierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             xmlns:smgp="clr-namespace:Companion.Core.Smgp;assembly=Companion.Core"
             Focusable="False">
    <!-- The Driver dossier (character depth 3). DataContext is a DossierViewModel; the character
         data is Dossier (a CharacterDossier). Read-only — this is the "see your driver" lens. -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False" DataContext="{Binding Dossier}">
        <!-- proportional page cap (was a hard 720) -->
        <StackPanel Margin="40,32" HorizontalAlignment="Left"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.6|720|1100}">

            <!-- header: driver portrait + team car on the left; identity, progression + car specs on the right -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- portrait (team-coloured player image) + the car you drive -->
                <StackPanel Grid.Column="0" Margin="0,0,22,0" VerticalAlignment="Top">
                    <Grid Width="150" Height="150"
                          ToolTip="Drop your team player image at data\ams2\portraits\player.&lt;team&gt;.jpg (beside the exe)">
                        <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="48"
                                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border CornerRadius="10" ClipToBounds="True">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding DataContext.PlayerImageKey, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                        </Border>
                    </Grid>
                    <Image Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,10,0,0"
                           Source="{Binding DataContext.PlayerCarKey, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                </StackPanel>

                <!-- identity + progression + car specs -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,0"
                               Text="{Binding DataContext.TeamLine, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Visibility="{Binding DataContext.TeamLine, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullCollapsed}}" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Style="{StaticResource Muted}">
                            <Run Text="Level" /><Run Text=" " /><Run Text="{Binding Level, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource Muted}" Margin="16,0,0,0"
                                   Visibility="{Binding Age, Converter={StaticResource NullCollapsed}}">
                            <Run Text="Age" /><Run Text=" " /><Run Text="{Binding Age, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource Faint}" Margin="16,0,0,0">
                            <Run Text="{Binding Xp, Mode=OneWay}" /><Run Text=" XP" />
                        </TextBlock>
                        <TextBlock Style="{StaticResource Faint}" Margin="16,0,0,0"
                                   Visibility="{Binding CpUnspent, Converter={StaticResource CountVisible}}">
                            <Run Text="{Binding CpUnspent, Mode=OneWay}" /><Run Text=" points to spend" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Margin="0,6,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InjuryRisk}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Injury risk: " /><Run Text="{Binding InjuryRisk, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{DynamicResource ErrorBrush}" /><Run Text="  — a fragile build can be set back at season's end." />
                    </TextBlock>
                    <ProgressBar Value="{Binding LevelProgress, Mode=OneWay}" Maximum="1" Height="6" Margin="0,8,0,0"
                                 ToolTip="Progress to the next level" />

                    <!-- the car you drive, as the arcade spec card — collapses when no spec is authored -->
                    <ContentControl Content="{Binding DataContext.PlayerCarSpec, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    HorizontalAlignment="Left" MaxWidth="300" Margin="0,14,0,0"
                                    Visibility="{Binding DataContext.PlayerCarSpec, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullCollapsed}}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:CarSpecCard />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
            </Grid>

            <!-- The player's evolving SMGP campaign: a typed, chronological story projection over
                 folded results. RelativeSource is intentional because this page's ScrollViewer uses
                 the CharacterDossier as its inner DataContext. -->
            <StackPanel Margin="0,24,0,0"
                        Visibility="{Binding DataContext.HasSmgpNarrative,
                                             RelativeSource={RelativeSource AncestorType=UserControl},
                                             Converter={StaticResource BoolVisible}}">
                <TextBlock Text="YOUR STORY" Style="{StaticResource H2}" />
                <Border Style="{StaticResource AccentCallout}" Margin="0,8,0,12" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="LIVE CAMPAIGN" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock Text="{Binding DataContext.NarrativeIntro,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding DataContext.Timeline,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding WhenLabel}" Style="{StaticResource Mono}"
                                           FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" Margin="0,7,10,0" />
                                <Grid Grid.Column="1">
                                    <Border Width="2" Background="{DynamicResource EdgeBrush}"
                                            HorizontalAlignment="Center" />
                                    <Border Width="12" Height="12" CornerRadius="6"
                                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Promotion}">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.RivalryEarned}">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Demotion}">
                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.RivalryLost}">
                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.NearMiss}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.FirstWin}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Title}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Finale}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>
                                <Border Grid.Column="2" Style="{StaticResource Callout}" Padding="12,9">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Kind}"
                                                       Style="{StaticResource Eyebrow}" Margin="10,0,0,0" />
                                            <TextBlock Text="{Binding Headline}" FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Bold" FontSize="14" TextWrapping="Wrap" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Body}"
                                                   FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- stats -->
            <TextBlock Text="Stats" Style="{StaticResource H2}" Margin="0,28,0,8" />
            <Border Style="{StaticResource Panel}" Padding="14,10">
                <ItemsControl ItemsSource="{Binding Stats}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,4">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="130" VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Width="48" TextAlignment="Right" VerticalAlignment="Center"
                                           Style="{StaticResource Faint}"
                                           Text="{Binding Value, StringFormat={}{0:0.00}}" />
                                <ProgressBar Value="{Binding Value}" Maximum="1" Height="8"
                                             VerticalAlignment="Center" Margin="10,0" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- perks -->
            <TextBlock Text="Perks" Style="{StaticResource H2}" Margin="0,24,0,8" />
            <ItemsControl ItemsSource="{Binding Perks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Panel}" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource Faint}"
                                               Text="{Binding Category}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                </DockPanel>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                                <ItemsControl ItemsSource="{Binding Benefits}" Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}"><Run Text="+  " Foreground="{DynamicResource AccentTextBrush}" FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding Drawbacks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}"><Run Text="−  " FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource Faint}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Your stats set the sim's expectation of you — a faster driver is judged against a harder bar. Perks patch the deterministic inputs; nothing here decides a race." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
