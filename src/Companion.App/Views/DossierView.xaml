<UserControl x:Class="Companion.App.Views.DossierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- The Driver dossier (character depth 3). DataContext is a DossierViewModel; the character
         data is Dossier (a CharacterDossier). Read-only — this is the "see your driver" lens. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False" DataContext="{Binding Dossier}">
        <StackPanel MaxWidth="720" Margin="40,32" HorizontalAlignment="Left">

            <!-- identity + progression -->
            <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" />
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Style="{StaticResource Muted}">
                    <Run Text="Level" /><Run Text=" " /><Run Text="{Binding Level, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Style="{StaticResource Faint}" Margin="16,0,0,0">
                    <Run Text="{Binding Xp, Mode=OneWay}" /><Run Text=" XP" />
                </TextBlock>
                <TextBlock Style="{StaticResource Faint}" Margin="16,0,0,0"
                           Visibility="{Binding CpUnspent, Converter={StaticResource CountVisible}}">
                    <Run Text="{Binding CpUnspent, Mode=OneWay}" /><Run Text=" points to spend" />
                </TextBlock>
            </StackPanel>
            <TextBlock Margin="0,6,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InjuryRisk}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
                <Run Text="Injury risk: " /><Run Text="{Binding InjuryRisk, Mode=OneWay}" FontWeight="SemiBold"
                     Foreground="{StaticResource ErrorBrush}" /><Run Text="  — a fragile build can be set back at season's end." />
            </TextBlock>
            <ProgressBar Value="{Binding LevelProgress, Mode=OneWay}" Maximum="1" Height="6" Margin="0,8,0,0"
                         ToolTip="Progress to the next level" />

            <!-- stats -->
            <TextBlock Text="Stats" Style="{StaticResource H2}" Margin="0,28,0,8" />
            <Border Style="{StaticResource Panel}" Padding="14,10">
                <ItemsControl ItemsSource="{Binding Stats}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,4">
                                <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="130" VerticalAlignment="Center" />
                                <TextBlock DockPanel.Dock="Right" Width="48" TextAlignment="Right" VerticalAlignment="Center"
                                           Style="{StaticResource Faint}"
                                           Text="{Binding Value, StringFormat={}{0:0.00}}" />
                                <ProgressBar Value="{Binding Value}" Maximum="1" Height="8"
                                             VerticalAlignment="Center" Margin="10,0" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- perks -->
            <TextBlock Text="Perks" Style="{StaticResource H2}" Margin="0,24,0,8" />
            <ItemsControl ItemsSource="{Binding Perks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Panel}" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right" Style="{StaticResource Faint}"
                                               Text="{Binding Category}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                </DockPanel>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                                <ItemsControl ItemsSource="{Binding Benefits}" Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}"><Run Text="+  " Foreground="{StaticResource AccentBrush}" FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding Drawbacks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}"><Run Text="−  " FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource Faint}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Your stats set the sim's expectation of you — a faster driver is judged against a harder bar. Perks patch the deterministic inputs; nothing here decides a race." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
