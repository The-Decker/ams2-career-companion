<UserControl x:Class="Companion.App.Views.DossierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             xmlns:controls="clr-namespace:Companion.App.Controls"
             xmlns:views="clr-namespace:Companion.App.Views"
             xmlns:smgp="clr-namespace:Companion.Core.Smgp;assembly=Companion.Core"
             xmlns:character="clr-namespace:Companion.Core.Character;assembly=Companion.Core"
             Focusable="False">
    <UserControl.Resources>
        <DataTemplate x:Key="DossierStatRow">
            <DockPanel Margin="0,5">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="138"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Width="48" TextAlignment="Right"
                           VerticalAlignment="Center" Style="{StaticResource Mono}"
                           Text="{Binding Value, StringFormat={}{0:0.00}}" />
                <ProgressBar Value="{Binding Value, Mode=OneWay}" Maximum="1" Height="8"
                             VerticalAlignment="Center" Margin="10,0" />
            </DockPanel>
        </DataTemplate>

        <!-- Locked is the calm default. Owned and unlockable nodes opt into stronger semantic
             treatments through the bind-contract booleans, avoiding presentation-side logic. -->
        <Style x:Key="SkillNodeCard" TargetType="Border" BasedOn="{StaticResource Panel}">
            <Setter Property="Width" Value="250" />
            <Setter Property="MinHeight" Value="196" />
            <Setter Property="Padding" Value="13,11" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Opacity" Value="0.56" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOwned}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CanUnlock}" Value="True">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Progression-v2 graph nodes stay deliberately compact. All authored prose and
             mechanical boundaries live in the selected-node inspector below the graph. -->
        <Style x:Key="SkillGraphNodeStyle" TargetType="controls:SkillGraphNodeButton"
               BasedOn="{StaticResource SubtleButton}">
            <Setter Property="Padding" Value="9,8" />
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EdgeStrongBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Opacity" Value="0.58" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State, Mode=OneWay}" Value="{x:Static character:SkillNodeState.Unlockable}">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State, Mode=OneWay}" Value="{x:Static character:SkillNodeState.Pending}">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State, Mode=OneWay}" Value="{x:Static character:SkillNodeState.Owned}">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding State, Mode=OneWay}" Value="{x:Static character:SkillNodeState.Mastery}">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="SkillGraphNodeTemplate">
            <controls:SkillGraphNodeButton x:Name="SkillGraphNodeButton"
                                           Style="{StaticResource SkillGraphNodeStyle}"
                                           Command="{Binding DataContext.OpenSkillNodeCommand,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding Mode=OneWay}"
                                           DoubleClickCommand="{Binding DataContext.QueueSkillNodeCommand,
                                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           DoubleClickCommandParameter="{Binding Mode=OneWay}"
                                           AutomationProperties.Name="{Binding Name, Mode=OneWay}"
                                           AutomationProperties.HelpText="{Binding LockReason, Mode=OneWay}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding IconKey, Converter={StaticResource SkillGlyph}, Mode=OneWay}"
                               FontFamily="{StaticResource IconFont}" FontSize="21"
                               Foreground="{DynamicResource AccentTextBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"
                                   TextWrapping="Wrap" MaxHeight="36" />
                        <WrapPanel Margin="0,5,0,0">
                            <TextBlock Text="{Binding Tier, Mode=OneWay, StringFormat=T{0}}"
                                       Style="{StaticResource PixelBadge}" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding Cost, Mode=OneWay, StringFormat={}{0} SP}"
                                       Style="{StaticResource Mono}" FontSize="10" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding State, Mode=OneWay}" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </controls:SkillGraphNodeButton>
        </DataTemplate>
    </UserControl.Resources>
    <!-- The Driver dossier (character depth 3). DataContext is a DossierViewModel; the character
         data is Dossier (a CharacterDossier). Read-only, this is the "see your driver" lens. -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False" DataContext="{Binding Dossier}">
        <!-- proportional page cap (was a hard 720) -->
        <StackPanel Margin="40,32" HorizontalAlignment="Left"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.6|720|1100}">

            <!-- header: driver portrait + team car on the left; identity, progression + car specs on the right -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- portrait (team-coloured player image) + the car you drive -->
                <StackPanel Grid.Column="0" Margin="0,0,22,0" VerticalAlignment="Top">
                    <Grid Width="150" Height="150"
                          ToolTip="Drop your team player image at data\ams2\portraits\player.&lt;team&gt;.jpg (beside the exe)">
                        <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="48"
                                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border CornerRadius="10" ClipToBounds="True">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding DataContext.PlayerImageKey, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                        </Border>
                    </Grid>
                    <Image Height="48" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,10,0,0"
                           Source="{Binding DataContext.PlayerCarKey, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                </StackPanel>

                <!-- identity + progression + car specs -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Name}" Style="{StaticResource H1}" />
                    <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,0"
                               Text="{Binding DataContext.TeamLine, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Visibility="{Binding DataContext.TeamLine, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullCollapsed}}" />
                    <!-- Country is immutable character identity, not season/team metadata. Every
                         binding reaches back through the UserControl because the page ScrollViewer
                         has already changed the local DataContext to CharacterDossier. -->
                    <Border x:Name="DossierCountryIdentity" Style="{StaticResource CompactChip}"
                            HorizontalAlignment="Left" Margin="0,8,0,0" Padding="8,5"
                            Visibility="{Binding DataContext.HasCountry,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolVisible}, Mode=OneWay}"
                            ToolTip="{Binding DataContext.CountryName,
                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                              Mode=OneWay}"
                            AutomationProperties.Name="{Binding DataContext.CountryName,
                                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                                Mode=OneWay}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image x:Name="DossierCountryFlag" Width="32" Height="20" Stretch="Uniform"
                                   Source="{Binding DataContext.CountryFlagKey,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Converter={StaticResource AssetImage},
                                                    ConverterParameter=smgp/flags, Mode=OneWay}"
                                   AutomationProperties.Name="{Binding DataContext.CountryName,
                                                                       RelativeSource={RelativeSource AncestorType=UserControl},
                                                                       Mode=OneWay, StringFormat={}{0} flag}" />
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="COUNTRY" Style="{StaticResource Eyebrow}" FontSize="8" />
                                <TextBlock x:Name="DossierCountryName"
                                           Text="{Binding DataContext.CountryName,
                                                          RelativeSource={RelativeSource AncestorType=UserControl},
                                                          Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Level-up is a one-shot VM moment. Every VM-level binding deliberately
                         reaches back through the UserControl because this ScrollViewer is on the
                         inner CharacterDossier DataContext. -->
                    <Border x:Name="LevelUpBanner" Style="{StaticResource AccentCallout}"
                            Margin="0,10,0,0" Padding="14,11"
                            Visibility="{Binding DataContext.LevelUpPending,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolVisible}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="Got it" Margin="14,0,0,0"
                                    audio:SoundAssist.Cue="Confirm"
                                    Style="{StaticResource SubtleButton}" Padding="11,6"
                                    Command="{Binding DataContext.AcknowledgeLevelUpCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            <StackPanel>
                                <TextBlock Text="LEVEL UP" Style="{StaticResource PixelBadge}"
                                           Foreground="{DynamicResource AccentTextBrush}" />
                                <TextBlock Style="{StaticResource Body}" Margin="0,4,0,0">
                                    <Run Text="Your racecraft evolved. " />
                                    <Run Text="{Binding DataContext.LevelsGained,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        StringFormat=+{0} level}"
                                         FontWeight="Bold" />
                                    <Run Text=", choose what comes next." />
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource Panel}" Padding="14,12" Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="82" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="70" Height="70" CornerRadius="35"
                                    Background="{DynamicResource AccentBrush}"
                                    BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="2">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="LEVEL" Style="{StaticResource PixelBadge}"
                                               Foreground="{DynamicResource OnAccentBrush}" FontSize="8"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Level}" FontFamily="{StaticResource DisplayFont}"
                                               FontSize="27" FontWeight="Bold"
                                               Foreground="{DynamicResource OnAccentBrush}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                            Margin="10,0,0,0"
                                            Visibility="{Binding DataContext.SkillPointsAvailable,
                                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                                 Converter={StaticResource CountVisible},
                                                                 Mode=OneWay}">
                                        <TextBlock Foreground="{DynamicResource AccentTextBrush}"
                                                   FontWeight="Bold">
                                            <Run Text="{Binding DataContext.SkillPointsAvailable,
                                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                                Mode=OneWay}" />
                                            <Run Text=" SKILL POINTS TO SPEND" />
                                        </TextBlock>
                                    </Border>
                                    <WrapPanel>
                                        <TextBlock Style="{StaticResource Muted}" Margin="0,0,10,0"
                                                   Visibility="{Binding Age, Converter={StaticResource NullCollapsed}}">
                                            <Run Text="Age " /><Run Text="{Binding Age}" FontWeight="SemiBold" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource Muted}">
                                            <Run Text="{Binding LifetimeXp, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" lifetime XP  &#x00B7;  " />
                                            <Run Text="{Binding AvailableResetXp, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" reset XP available" />
                                        </TextBlock>
                                    </WrapPanel>
                                </DockPanel>
                                <ProgressBar x:Name="LevelProgressBar" Value="{Binding LevelProgress, Mode=OneWay}"
                                             Maximum="1" Height="10" Margin="0,9,0,0"
                                             ToolTip="Progress to the next level">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar" BasedOn="{StaticResource {x:Type ProgressBar}}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAtLevelCap}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <TextBlock x:Name="NextLevelXpLine" Margin="0,5,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAtLevelCap}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="{Binding XpIntoLevel}" FontWeight="SemiBold" />
                                    <Run Text=" / " /><Run Text="{Binding XpForNextLevel}" />
                                    <Run Text=" XP to next level" />
                                </TextBlock>
                                <Border x:Name="MaxLevelBadge" Style="{StaticResource AccentCallout}"
                                        Margin="0,8,0,0" Padding="10,7"
                                        Visibility="{Binding IsAtLevelCap, Converter={StaticResource BoolVisible}}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="MAX" Style="{StaticResource PixelBadge}"
                                                   Foreground="{DynamicResource AccentTextBrush}" Margin="12,0,0,0" />
                                        <TextBlock FontFamily="{StaticResource DisplayFont}" FontWeight="Bold">
                                            <Run Text="LEVEL " /><Run Text="{Binding LevelCap}" /><Run Text=" &#x00B7; MAX" />
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Current race availability sits beside the long-term injury-risk profile.
                         This ScrollViewer's DataContext is already CharacterDossier, so both are
                         direct bindings; the risk line retains its legacy null-collapse. -->
                    <WrapPanel Margin="0,6,0,0">
                        <Border Padding="8,3" CornerRadius="4" BorderThickness="1" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Availability}"
                                                     Value="{x:Static character:AvailabilityStatus.Injured}">
                                            <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Availability}"
                                                     Value="{x:Static character:AvailabilityStatus.SeasonOver}">
                                            <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Availability}"
                                                     Value="{x:Static character:AvailabilityStatus.Deceased}">
                                            <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Availability}"
                                                         Value="{x:Static character:AvailabilityStatus.Injured}">
                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Availability}"
                                                         Value="{x:Static character:AvailabilityStatus.SeasonOver}">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Availability}"
                                                         Value="{x:Static character:AvailabilityStatus.Deceased}">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="Availability: " /><Run Text="{Binding AvailabilityLabel, Mode=OneWay}"
                                                                     FontWeight="SemiBold" />
                            </TextBlock>
                        </Border>
                        <TextBlock Margin="12,3,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding InjuryRisk}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Injury risk: " /><Run Text="{Binding InjuryRisk, Mode=OneWay}" FontWeight="SemiBold"
                                 Foreground="{DynamicResource ErrorBrush}" /><Run Text=" , a fragile build can be set back at season's end." />
                        </TextBlock>
                        <Border Style="{StaticResource CompactChip}" Margin="8,0,0,0"
                                Background="{DynamicResource SurfaceAltBrush}"
                                Visibility="{Binding DataContext.MortalityLabel,
                                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                                     Converter={StaticResource StringVisible}}">
                            <TextBlock Text="{Binding DataContext.MortalityLabel,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Style="{StaticResource PixelBadge}" />
                        </Border>
                    </WrapPanel>
                    <!-- the car you drive, as the arcade spec card, collapses when no spec is authored -->
                    <ContentControl Content="{Binding DataContext.PlayerCarSpec, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    HorizontalAlignment="Left" MaxWidth="300" Margin="0,14,0,0"
                                    Visibility="{Binding DataContext.PlayerCarSpec, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullCollapsed}}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <views:CarSpecCard />
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </StackPanel>
            </Grid>

            <!-- Permanent progression-v2 identity. The ScrollViewer already scopes DataContext to
                 CharacterDossier, so this projection binds directly to Dossier.RacingDna. Every
                 immutable projection is explicitly OneWay to prevent WPF write-back attempts. -->
            <ContentControl x:Name="RacingDnaIdentityPanel"
                            Content="{Binding RacingDna, Mode=OneWay}"
                            Margin="0,24,0,0" HorizontalContentAlignment="Stretch"
                            Visibility="{Binding RacingDna, Mode=OneWay, Converter={StaticResource NullCollapsed}}">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Panel}" Padding="16,14"
                                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2,1,1,1">
                            <StackPanel>
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="12,0,0,0">
                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontWeight="Bold">
                                            <Run Text="EXACT VERSION  " />
                                            <Run Text="{Binding Version, Mode=OneWay}" Foreground="{DynamicResource AccentTextBrush}" />
                                        </TextBlock>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="RACING DNA" Style="{StaticResource Eyebrow}"
                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                        <TextBlock Text="{Binding Name, Mode=OneWay}" Style="{StaticResource H2}"
                                                   Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding FamilyLine, Mode=OneWay}" FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   Foreground="{DynamicResource AccentTextBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </DockPanel>

                                <TextBlock Text="{Binding Description, Mode=OneWay}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" Margin="0,9,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource Callout}" Padding="11,9">
                                        <StackPanel>
                                            <TextBlock Text="PERSISTENT IDENTITY" Style="{StaticResource Eyebrow}"
                                                       Foreground="{DynamicResource SuccessBrush}" Margin="0,0,0,5" />
                                            <ItemsControl x:Name="RacingDnaPersistentEffects"
                                                          ItemsSource="{Binding PersistentEffects, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock TextWrapping="Wrap" Margin="0,2" FontSize="11">
                                                            <Run Text="+  " FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />
                                                            <Run Text="{Binding Summary, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource Callout}" Padding="11,9">
                                        <StackPanel>
                                            <TextBlock Text="TRADE-OFF" Style="{StaticResource Eyebrow}"
                                                       Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,5" />
                                            <ItemsControl x:Name="RacingDnaTradeoffEffects"
                                                          ItemsSource="{Binding TradeoffEffects, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock TextWrapping="Wrap" Margin="0,2" FontSize="11">
                                                            <Run Text="-  " FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" />
                                                            <Run Text="{Binding Summary, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Style="{StaticResource AccentCallout}" Padding="11,8" Margin="0,12,0,0"
                                        Visibility="{Binding ChoicePrompt, Mode=OneWay, Converter={StaticResource NullCollapsed}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="IDENTITY COMMITMENT" Style="{StaticResource Eyebrow}" />
                                            <TextBlock Text="{Binding ChoicePrompt, Mode=OneWay}" TextWrapping="Wrap"
                                                       FontWeight="SemiBold" Margin="0,3,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ChoiceKind, Mode=OneWay}" Style="{StaticResource Faint}"
                                                       HorizontalAlignment="Right" />
                                            <TextBlock Text="{Binding ChoiceValue, Mode=OneWay, TargetNullValue=NOT SET}"
                                                       FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                                       Foreground="{DynamicResource AccentTextBrush}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- The player's evolving SMGP campaign: a typed, chronological story projection over
                 folded results. RelativeSource is intentional because this page's ScrollViewer uses
                 the CharacterDossier as its inner DataContext. -->
            <Expander x:Name="StoryExpander" Margin="0,24,0,0" IsExpanded="True"
                      HorizontalContentAlignment="Stretch"
                      Visibility="{Binding DataContext.HasSmgpNarrative,
                                           RelativeSource={RelativeSource AncestorType=UserControl},
                                           Converter={StaticResource BoolVisible}}">
                <Expander.Header>
                    <TextBlock Text="YOUR STORY" Style="{StaticResource H2}" />
                </Expander.Header>
                <StackPanel x:Name="StoryContent"
                            Visibility="{Binding IsExpanded,
                                                 RelativeSource={RelativeSource AncestorType=Expander},
                                                 Converter={StaticResource BoolVisible}}">
                <Border Style="{StaticResource AccentCallout}" Margin="0,8,0,12" Padding="14,10">
                    <StackPanel>
                        <TextBlock Text="LIVE CAMPAIGN" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock Text="{Binding DataContext.NarrativeIntro,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" Margin="0,3,0,0" />
                    </StackPanel>
                </Border>
                <ItemsControl ItemsSource="{Binding DataContext.Timeline,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding WhenLabel}" Style="{StaticResource Mono}"
                                           FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"
                                           TextWrapping="Wrap" Margin="0,7,10,0" />
                                <Grid Grid.Column="1">
                                    <Border Width="2" Background="{DynamicResource EdgeBrush}"
                                            HorizontalAlignment="Center" />
                                    <Border Width="12" Height="12" CornerRadius="6"
                                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Promotion}">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.RivalryEarned}">
                                                        <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Demotion}">
                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.RivalryLost}">
                                                        <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.NearMiss}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.FirstWin}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Title}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpBeatKind.Finale}">
                                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </Grid>
                                <Border Grid.Column="2" Style="{StaticResource Callout}" Padding="12,9">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding Kind}"
                                                       Style="{StaticResource Eyebrow}" Margin="10,0,0,0" />
                                            <TextBlock Text="{Binding Headline}" FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Bold" FontSize="14" TextWrapping="Wrap" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource Body}"
                                                   FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
            </Expander>

            <!-- skill tree -->
            <DockPanel Margin="0,28,0,8">
                <WrapPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                        <TextBlock Style="{StaticResource Mono}" Foreground="{DynamicResource AccentTextBrush}">
                            <Run Text="{Binding DataContext.SkillPointsAvailable,
                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                Mode=OneWay}" />
                            <Run Text=" SP" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource CompactChip}"
                            Visibility="{Binding DataContext.RespecTokens,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource CountVisible},
                                                 Mode=OneWay}">
                        <TextBlock Style="{StaticResource Mono}">
                            <Run Text="{Binding DataContext.RespecTokens,
                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                Mode=OneWay}" />
                            <Run Text=" RESPEC" />
                        </TextBlock>
                    </Border>
                </WrapPanel>
                <StackPanel>
                    <TextBlock Text="SKILL TREE" Style="{StaticResource H2}" />
                    <TextBlock Text="Turn earned Skill Points into a distinct driving identity."
                               Style="{StaticResource Muted}" Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>

            <!-- Progression-v2 purchase planning is deliberately a two-step interaction: inspect
                 a node, queue it locally, then confirm the complete ordered plan. RacingDna is the
                 exact-version v2 identity marker; legacy dossiers retain their immediate-spend UI. -->
            <Border x:Name="PendingSkillPlanPanel" Style="{StaticResource AccentCallout}"
                    Margin="0,0,0,12" Padding="15,12"
                    Visibility="{Binding RacingDna, Mode=OneWay,
                                         Converter={StaticResource NullCollapsed}}">
                <StackPanel>
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}">
                            <TextBlock Style="{StaticResource Mono}" Foreground="{DynamicResource AccentTextBrush}">
                                <Run Text="{Binding DataContext.SkillPointsAvailable,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Mode=OneWay}" />
                                <Run Text="  &#x2192;  " />
                                <Run Text="{Binding DataContext.SkillPointsAfterPlan,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Mode=OneWay}" />
                                <Run Text=" SP" />
                            </TextBlock>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="PURCHASE PLAN" Style="{StaticResource Eyebrow}"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                            <TextBlock Text="Queue nodes in order. Nothing is spent until you confirm."
                                       Style="{StaticResource Muted}" Margin="0,3,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Text="Open any node to inspect it and add it to this plan."
                               Style="{StaticResource Faint}" Margin="0,10,0,0"
                               Visibility="{Binding DataContext.SkillPlanDirty,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Converter={StaticResource BoolCollapsed},
                                                    Mode=OneWay}" />

                    <StackPanel Margin="0,10,0,0"
                                Visibility="{Binding DataContext.SkillPlanDirty,
                                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                                     Converter={StaticResource BoolVisible},
                                                     Mode=OneWay}">
                        <ItemsControl x:Name="PendingSkillNodesList"
                                      ItemsSource="{Binding DataContext.PendingSkillNodes,
                                                            RelativeSource={RelativeSource AncestorType=UserControl},
                                                            Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Callout}" Padding="10,7" Margin="0,0,0,6">
                                        <DockPanel>
                                            <Button Content="Remove from here" DockPanel.Dock="Right"
                                                    Style="{StaticResource SubtleButton}" Padding="9,4"
                                                    Command="{Binding DataContext.RemovePendingSkillNodeCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Mode=OneWay}" />
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                                    Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Cost, Mode=OneWay, StringFormat={}{0} SP}"
                                                           Style="{StaticResource Mono}" />
                                            </Border>
                                            <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <DockPanel Margin="0,4,0,0">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button x:Name="ResetSkillPlanButton" Content="RESET PLAN  ·  FREE"
                                        audio:SoundAssist.Cue="Back"
                                        Style="{StaticResource SubtleButton}" Margin="0,0,8,0"
                                        Command="{Binding DataContext.ResetSkillPlanCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <Button x:Name="ConfirmSkillPlanButton" Content="CONFIRM PLAN"
                                        audio:SoundAssist.Cue="SkillUnlock"
                                        Style="{StaticResource AccentButton}"
                                        Command="{Binding DataContext.ConfirmSkillPlanCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </StackPanel>
                            <TextBlock VerticalAlignment="Center" Style="{StaticResource Mono}">
                                <Run Text="PLAN COST  " />
                                <Run Text="{Binding DataContext.PendingSkillPointCost,
                                                    RelativeSource={RelativeSource AncestorType=UserControl},
                                                    Mode=OneWay}" FontWeight="Bold"
                                     Foreground="{DynamicResource AccentTextBrush}" />
                                <Run Text=" SP" />
                            </TextBlock>
                        </DockPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border x:Name="SkillActionErrorPanel" Style="{StaticResource ErrorCallout}"
                    Margin="0,0,0,12"
                    Visibility="{Binding DataContext.SkillActionError,
                                         RelativeSource={RelativeSource AncestorType=UserControl},
                                         Converter={StaticResource NullCollapsed},
                                         Mode=OneWay}">
                <TextBlock Text="{Binding DataContext.SkillActionError,
                                          RelativeSource={RelativeSource AncestorType=UserControl},
                                          Mode=OneWay}"
                           TextWrapping="Wrap" Foreground="{DynamicResource ErrorBrush}" />
            </Border>

            <!-- The selected-node inspector is inline so it remains keyboard- and scroll-friendly.
                 All projections are read-only; commands are the only mutation seam. -->
            <ContentControl x:Name="SkillNodeDetailPanel"
                            Content="{Binding DataContext.SelectedSkillNode,
                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                              Mode=OneWay}"
                            Visibility="{Binding DataContext.SkillNodeDetailOpen,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolVisible},
                                                 Mode=OneWay}"
                            Margin="0,0,0,12">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Panel}" Padding="16,14"
                                Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2">
                            <StackPanel>
                                <DockPanel>
                                    <Button x:Name="CloseSkillNodeButton" Content="Close"
                                            DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                                            Command="{Binding DataContext.CloseSkillNodeCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    <StackPanel>
                                        <TextBlock Text="NODE INSPECTION" Style="{StaticResource Eyebrow}"
                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                        <TextBlock Text="{Binding Name, Mode=OneWay}" Style="{StaticResource H2}"
                                                   Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                                <WrapPanel Margin="0,9,0,0">
                                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding Kind, Mode=OneWay}" Style="{StaticResource PixelBadge}" />
                                    </Border>
                                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding Tier, Mode=OneWay, StringFormat=TIER {0}}"
                                                   Style="{StaticResource PixelBadge}" />
                                    </Border>
                                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding UnlockLevel, Mode=OneWay, StringFormat=LEVEL {0}}"
                                                   Style="{StaticResource PixelBadge}" />
                                    </Border>
                                    <Border Style="{StaticResource CompactChip}">
                                        <TextBlock Text="{Binding Cost, Mode=OneWay, StringFormat={}{0} SP}"
                                                   Style="{StaticResource Mono}"
                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text="{Binding Description, Mode=OneWay}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" Margin="0,9,0,0" />
                                <WrapPanel Margin="0,7,0,0"
                                           Visibility="{Binding RailName, Converter={StaticResource StringVisible}, Mode=OneWay}">
                                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding RailName, Mode=OneWay, StringFormat=RAIL  {0}}"
                                                   Style="{StaticResource PixelBadge}" />
                                    </Border>
                                    <Border Style="{StaticResource CompactChip}">
                                        <TextBlock Text="{Binding AttributeStatId, Mode=OneWay, StringFormat=STAT  {0}}"
                                                   Style="{StaticResource PixelBadge}" />
                                    </Border>
                                </WrapPanel>
                                <ItemsControl x:Name="SkillNodeEffectLines"
                                              ItemsSource="{Binding Effects, Mode=OneWay}" Margin="0,9,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource Callout}" Padding="9,7" Margin="0,0,0,5">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="10" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Style="{StaticResource CompactChip}" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding ClassificationLabel, Mode=OneWay}"
                                                                   Style="{StaticResource PixelBadge}"
                                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                                    </Border>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Condition, Mode=OneWay}"
                                                                   Visibility="{Binding IsConditional,
                                                                                        Converter={StaticResource BoolVisible},
                                                                                        Mode=OneWay}"
                                                                   Style="{StaticResource Faint}" TextWrapping="Wrap"
                                                                   Margin="0,3,0,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding RequiresLabels, Mode=OneWay}" Margin="0,7,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap">
                                                <Run Text="REQUIRES  " FontWeight="Bold" />
                                                <Run Text="{Binding Mode=OneWay}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource SuccessCallout}">
                                        <StackPanel>
                                            <TextBlock Text="GAIN" Style="{StaticResource Eyebrow}" />
                                            <ItemsControl ItemsSource="{Binding Benefits, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Mode=OneWay}" Style="{StaticResource Faint}"
                                                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource WarningCallout}">
                                        <StackPanel>
                                            <TextBlock Text="TRADE-OFF" Style="{StaticResource Eyebrow}" />
                                            <ItemsControl ItemsSource="{Binding Drawbacks, Mode=OneWay}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Mode=OneWay}" Style="{StaticResource Faint}"
                                                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <DockPanel Margin="0,12,0,0">
                                    <TextBlock Text="{Binding LockReason, Mode=OneWay}" Style="{StaticResource Faint}"
                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                    <ContentControl DockPanel.Dock="Right"
                                                    Content="{Binding DataContext.Dossier.RacingDna,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Mode=OneWay}"
                                                    Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Content,
                                                                         Converter={StaticResource NullCollapsed}}">
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <Button x:Name="QueueSkillNodeButton" Content="ADD TO PLAN"
                                                        audio:SoundAssist.Cue="SkillUnlock"
                                                        Style="{StaticResource AccentButton}"
                                                        Command="{Binding DataContext.QueueSkillNodeCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding DataContext.SelectedSkillNode,
                                                                                   RelativeSource={RelativeSource AncestorType=UserControl},
                                                                                   Mode=OneWay}"
                                                        Visibility="{Binding DataContext.SelectedSkillNode.CanUnlock,
                                                                             RelativeSource={RelativeSource AncestorType=UserControl},
                                                                             Converter={StaticResource BoolVisible},
                                                                             Mode=OneWay}" />
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- A committed-tree reset is destructive and XP-funded. The quote and confirmation
                 stay separate from the free local plan reset above. -->
            <ContentControl x:Name="CommittedSkillResetPanel"
                            Content="{Binding DataContext.SkillResetPreview,
                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                              Mode=OneWay}"
                            Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Content,
                                                 Converter={StaticResource NullCollapsed}}"
                            Margin="0,0,0,12">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource WarningCallout}" Padding="15,11">
                            <DockPanel>
                                <Button x:Name="OpenSkillResetButton" Content="RESET COMMITTED TREE"
                                        DockPanel.Dock="Right" Margin="14,0,0,0"
                                        audio:SoundAssist.Cue="Destructive"
                                        Style="{StaticResource SubtleButton}"
                                        IsEnabled="{Binding DataContext.CanResetCommittedSkillTree,
                                                            RelativeSource={RelativeSource AncestorType=UserControl},
                                                            Mode=OneWay}"
                                        Command="{Binding DataContext.OpenSkillResetConfirmationCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                <StackPanel>
                                    <TextBlock Text="COMMITTED BUILD" Style="{StaticResource Eyebrow}"
                                               Foreground="{DynamicResource WarningBrush}" />
                                    <TextBlock Text="Spend reset XP to return every committed node to the pool."
                                               FontWeight="SemiBold" Margin="0,3,0,0" />
                                    <TextBlock Text="{Binding DataContext.SkillResetBlockReason,
                                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                                              Mode=OneWay}"
                                               Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <ContentControl x:Name="SkillResetConfirmationPanel"
                            Content="{Binding DataContext.SkillResetPreview,
                                              RelativeSource={RelativeSource AncestorType=UserControl},
                                              Mode=OneWay}"
                            Visibility="{Binding DataContext.SkillResetConfirmationOpen,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource BoolVisible},
                                                 Mode=OneWay}"
                            Margin="0,0,0,12">
                <ContentControl.ContentTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ErrorCallout}" Padding="16,14" BorderThickness="2">
                            <StackPanel>
                                <TextBlock Text="RESET THE COMMITTED TREE?" Style="{StaticResource H2}"
                                           Foreground="{DynamicResource ErrorBrush}" />
                                <TextBlock Text="This spends XP and removes every committed mastery and attribute node. Racing DNA and creation traits remain permanent."
                                           Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,5,0,0" />
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource StatTile}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="NODES" Style="{StaticResource Eyebrow}" />
                                            <TextBlock Text="{Binding DataContext.SkillResetAcquisitionCount,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Mode=OneWay}"
                                                       Style="{StaticResource Mono}" FontSize="18" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource StatTile}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="RESET COST" Style="{StaticResource Eyebrow}" />
                                            <TextBlock Text="{Binding DataContext.SkillResetCost,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Mode=OneWay,
                                                                      StringFormat={}{0:N0} XP}"
                                                       Style="{StaticResource Mono}" FontSize="18" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="4" Style="{StaticResource StatTile}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="RESET XP AFTER" Style="{StaticResource Eyebrow}" />
                                            <TextBlock Text="{Binding DataContext.AvailableResetXpAfter,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Mode=OneWay,
                                                                      StringFormat={}{0:N0}}"
                                                       Style="{StaticResource Mono}" FontSize="18" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="6" Style="{StaticResource StatTile}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="SP AFTER" Style="{StaticResource Eyebrow}" />
                                            <TextBlock Text="{Binding DataContext.SkillPointsAfterReset,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                                      Mode=OneWay}"
                                                       Style="{StaticResource Mono}" FontSize="18" FontWeight="Bold" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Margin="0,10,0,0" Style="{StaticResource Faint}" TextWrapping="Wrap">
                                    <Run Text="Available reset XP: " />
                                    <Run Text="{Binding DataContext.AvailableResetXp,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        Mode=OneWay,
                                                        StringFormat={}{0:N0}}" FontWeight="Bold" />
                                    <Run Text="  ·  Skill Points refunded: " />
                                    <Run Text="{Binding DataContext.SkillPointsRefunded,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        Mode=OneWay}" FontWeight="Bold" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button x:Name="CloseSkillResetButton" Content="CANCEL"
                                            audio:SoundAssist.Cue="Back"
                                            Style="{StaticResource SubtleButton}" Margin="0,0,8,0"
                                            Command="{Binding DataContext.CloseSkillResetConfirmationCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                    <Button x:Name="ConfirmSkillResetButton" Content="SPEND XP &amp; RESET"
                                            audio:SoundAssist.Cue="Destructive"
                                            Style="{StaticResource AccentButton}"
                                            IsEnabled="{Binding DataContext.CanResetCommittedSkillTree,
                                                                RelativeSource={RelativeSource AncestorType=UserControl},
                                                                Mode=OneWay}"
                                            Command="{Binding DataContext.ConfirmSkillResetCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ContentControl.ContentTemplate>
            </ContentControl>

            <!-- Progression-v2: a real family-at-a-time wiring diagram. The graph panel measures
                 the authored presenters and draws prerequisite paths behind them; the Viewbox
                 only fits the resulting graph to the page and does not introduce nested scrolling. -->
            <Grid x:Name="ProgressionV2SkillGraphHost" Margin="0,0,0,12"
                  Visibility="{Binding DataContext.Dossier.RacingDna,
                                       RelativeSource={RelativeSource AncestorType=UserControl},
                                       Converter={StaticResource NullCollapsed}, Mode=OneWay}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,9">
                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}">
                            <TextBlock Text="CAREER SP  ·  ATOMIC PLAN" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="MASTERY WIRING" Style="{StaticResource H2}" />
                            <TextBlock Text="Choose one family. Open a node for its full contract; double-click an available node to queue it."
                                       Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,3,12,0" />
                        </StackPanel>
                    </DockPanel>

                    <TabControl x:Name="SkillFamilySelector" SelectedIndex="0"
                                ItemsSource="{Binding DataContext.SkillTree,
                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                      Mode=OneWay}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                                    <TextBlock Margin="7,0,0,0" Style="{StaticResource Mono}">
                                        <Run Text="{Binding OwnedMasteryCount, Mode=OneWay}" />
                                        <Run Text="/" />
                                        <Run Text="{Binding TotalMasteryCount, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Panel}" Padding="10" Margin="0,8,0,0"
                                        Background="{DynamicResource SurfaceBrush}">
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                                             HorizontalAlignment="Stretch" VerticalAlignment="Top">
                                        <ItemsControl ItemsSource="{Binding MasteryNodes, Mode=OneWay}"
                                                      ItemTemplate="{StaticResource SkillGraphNodeTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:SkillGraphPanel x:Name="MasterySkillGraph"
                                                                              NodeWidth="154" NodeMinHeight="70"
                                                                              TierGap="34" RowGap="18"
                                                                              ConnectorBrush="{DynamicResource EdgeStrongBrush}"
                                                                              ActiveConnectorBrush="{DynamicResource AccentBrush}"
                                                                              OwnedConnectorBrush="{DynamicResource SuccessBrush}"
                                                                              PendingConnectorBrush="{DynamicResource WarningBrush}" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </Viewbox>
                                </Border>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>

                    <DockPanel Margin="0,18,0,8">
                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}">
                            <TextBlock Text="ATTRIBUTE STEPS" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource SuccessBrush}" />
                        </Border>
                        <StackPanel>
                            <TextBlock Text="ATTRIBUTE RAILS" Style="{StaticResource H2}" />
                            <TextBlock Text="Career-SP upgrades remain separate from the 90 family mastery skills."
                                       Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,3,12,0" />
                        </StackPanel>
                    </DockPanel>
                    <TabControl x:Name="SkillAttributeRailSelector" SelectedIndex="0"
                                ItemsSource="{Binding DataContext.AttributeRails,
                                                      RelativeSource={RelativeSource AncestorType=UserControl},
                                                      Mode=OneWay}">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                                    <TextBlock Margin="7,0,0,0" Style="{StaticResource Mono}">
                                        <Run Text="{Binding OwnedCount, Mode=OneWay}" />
                                        <Run Text="/" />
                                        <Run Text="{Binding TotalCount, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                        <TabControl.ContentTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Panel}" Padding="10" Margin="0,8,0,0"
                                        Background="{DynamicResource SurfaceBrush}">
                                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                                             HorizontalAlignment="Stretch" VerticalAlignment="Top">
                                        <ItemsControl ItemsSource="{Binding Nodes, Mode=OneWay}"
                                                      ItemTemplate="{StaticResource SkillGraphNodeTemplate}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <controls:SkillGraphPanel x:Name="AttributeSkillGraph"
                                                                              NodeWidth="142" NodeMinHeight="66"
                                                                              TierGap="26" RowGap="14"
                                                                              ConnectorBrush="{DynamicResource EdgeStrongBrush}"
                                                                              ActiveConnectorBrush="{DynamicResource AccentBrush}"
                                                                              OwnedConnectorBrush="{DynamicResource SuccessBrush}"
                                                                              PendingConnectorBrush="{DynamicResource WarningBrush}" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                    </Viewbox>
                                </Border>
                            </DataTemplate>
                        </TabControl.ContentTemplate>
                    </TabControl>
                </StackPanel>
            </Grid>

            <!-- Exact legacy fallback for old profiles. V2 profiles exclusively use the graph. -->
            <ItemsControl x:Name="SkillTreeBranches"
                          ItemsSource="{Binding DataContext.SkillTree,
                                                 RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Mode=OneWay}">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.Dossier.RacingDna,
                                                           RelativeSource={RelativeSource AncestorType=UserControl},
                                                           Mode=OneWay}"
                                         Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Panel}">
                                    <Setter Property="Padding" Value="15,13" />
                                    <Setter Property="Margin" Value="0,0,0,12" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMeta}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                            Visibility="{Binding IsMeta, Converter={StaticResource BoolVisible}}">
                                        <TextBlock Text="FAME / LONGEVITY" Style="{StaticResource PixelBadge}"
                                                   Foreground="{DynamicResource WarningBrush}" />
                                    </Border>
                                    <TextBlock Text="{Binding Name}" FontFamily="{StaticResource DisplayFont}"
                                               FontSize="17" FontWeight="Bold" />
                                </DockPanel>
                                <ItemsControl ItemsSource="{Binding Nodes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SkillNodeCard}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                                    Margin="8,0,0,0">
                                                            <Border Style="{StaticResource CompactChip}" Margin="0,0,5,0">
                                                                <TextBlock Text="{Binding Tier, StringFormat=TIER {0}}"
                                                                           Style="{StaticResource PixelBadge}" />
                                                            </Border>
                                                            <Border Style="{StaticResource CompactChip}">
                                                                <TextBlock Text="{Binding Cost, StringFormat={}{0} SP}"
                                                                           Style="{StaticResource Mono}"
                                                                           Foreground="{DynamicResource AccentTextBrush}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14.5"
                                                                   TextWrapping="Wrap" />
                                                    </DockPanel>

                                                    <StackPanel Grid.Row="1" Margin="0,9,0,8">
                                                        <ItemsControl ItemsSource="{Binding Benefits}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap">
                                                                        <Run Text="+  " Foreground="{DynamicResource SuccessBrush}"
                                                                             FontWeight="Bold" />
                                                                        <Run Text="{Binding Mode=OneWay}" />
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <ItemsControl ItemsSource="{Binding Drawbacks}" Margin="0,3,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap">
                                                                        <Run Text="&#x2212;  " Foreground="{DynamicResource ErrorBrush}"
                                                                             FontWeight="Bold" />
                                                                        <Run Text="{Binding Mode=OneWay}" />
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>

                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="8" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="OpenSkillNodeButton" Content="DETAILS"
                                                                Style="{StaticResource SubtleButton}" Padding="9,5"
                                                                Command="{Binding DataContext.OpenSkillNodeCommand,
                                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding Mode=OneWay}" />
                                                        <Grid Grid.Column="2">
                                                            <TextBlock Text="{Binding LockReason, Mode=OneWay}"
                                                                       TextWrapping="Wrap" HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOwned, Mode=OneWay}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding CanUnlock, Mode=OneWay}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="OWNED  &#x2713;" Style="{StaticResource PixelBadge}"
                                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource SuccessBrush}"
                                                                       Visibility="{Binding IsOwned,
                                                                                            Converter={StaticResource BoolVisible},
                                                                                            Mode=OneWay}" />
                                                            <Button Content="Add to plan" HorizontalAlignment="Right"
                                                                    audio:SoundAssist.Cue="SkillUnlock"
                                                                    Style="{StaticResource AccentButton}" Padding="11,6"
                                                                    Command="{Binding DataContext.UnlockNodeCommand,
                                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding Mode=OneWay}"
                                                                    Visibility="{Binding CanUnlock,
                                                                                         Converter={StaticResource BoolVisible},
                                                                                         Mode=OneWay}" />
                                                            <Grid Visibility="{Binding IsOwned,
                                                                                       Converter={StaticResource BoolVisible},
                                                                                       Mode=OneWay}">
                                                                <Button Content="Respec" HorizontalAlignment="Right"
                                                                        audio:SoundAssist.Cue="Destructive"
                                                                        Style="{StaticResource SubtleButton}" Padding="9,5"
                                                                        Command="{Binding DataContext.RespecNodeCommand,
                                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding Mode=OneWay}"
                                                                        Visibility="{Binding DataContext.RespecTokens,
                                                                                             RelativeSource={RelativeSource AncestorType=UserControl},
                                                                                             Converter={StaticResource CountVisible},
                                                                                             Mode=OneWay}" />
                                                            </Grid>
                                                        </Grid>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Talent shapes the driver in the car; meta shapes the career around it. -->
            <TextBlock Text="DRIVER ATTRIBUTES" Style="{StaticResource H2}" Margin="0,20,0,8" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource AccentCallout}" Padding="14,11">
                    <StackPanel>
                        <TextBlock Text="DRIVING TALENT" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}" Margin="0,0,0,5" />
                        <ItemsControl ItemsSource="{Binding DataContext.TalentStatsView,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource DossierStatRow}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="14,11"
                        Background="{DynamicResource WarningDimBrush}"
                        BorderBrush="{DynamicResource WarningBrush}">
                    <StackPanel>
                        <TextBlock Text="FAME &amp; LONGEVITY" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,5" />
                        <ItemsControl ItemsSource="{Binding DataContext.MetaStatsView,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      ItemTemplate="{StaticResource DossierStatRow}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border x:Name="ActiveEffectsPanel" Style="{StaticResource Panel}" Padding="14,11"
                    Margin="0,12,0,0"
                    Visibility="{Binding ActiveModifiers.Count, Converter={StaticResource CountVisible}}">
                <StackPanel>
                    <TextBlock Text="ACTIVE EFFECTS" Style="{StaticResource Eyebrow}"
                               Foreground="{DynamicResource AccentTextBrush}" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding ActiveModifiers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                            Margin="10,0,0,0"
                                            Visibility="{Binding Condition, Converter={StaticResource NullCollapsed}}">
                                        <TextBlock Text="{Binding Condition}" Style="{StaticResource PixelBadge}"
                                                   Foreground="{DynamicResource WarningBrush}" />
                                    </Border>
                                    <TextBlock Text="{Binding Effect}" Style="{StaticResource Body}"
                                               TextWrapping="Wrap" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border x:Name="MedicalRecordPanel" Style="{StaticResource Panel}" Padding="14,11"
                    Margin="0,12,0,0"
                    Visibility="{Binding DataContext.HasInjuryHistory,
                                         RelativeSource={RelativeSource AncestorType=UserControl},
                                         Converter={StaticResource BoolVisible}}">
                <StackPanel>
                    <TextBlock Text="MEDICAL RECORD" Style="{StaticResource Eyebrow}"
                               Foreground="{DynamicResource WarningBrush}" Margin="0,0,0,6" />
                    <ItemsControl ItemsSource="{Binding DataContext.InjuryHistory,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="6"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="12,0,0,0">
                                            <Run Text="S" /><Run Text="{Binding SeasonOrdinal}" />
                                            <Run Text="  &#x00B7;  R" /><Run Text="{Binding Round}" />
                                            <Run Text="  &#x00B7;  " /><Run Text="{Binding SeasonYear}" />
                                        </TextBlock>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource Faint}"
                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                       Visibility="{Binding Description, Converter={StaticResource StringVisible}}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- perks -->
            <TextBlock Text="Perks" Style="{StaticResource H2}" Margin="0,24,0,8" />
            <ItemsControl ItemsSource="{Binding Perks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Panel}" Padding="14,10" Margin="0,0,0,8">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Border Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                                            <TextBlock Text="{Binding Cost, StringFormat={}{0} SP}"
                                                       Style="{StaticResource Mono}"
                                                       Foreground="{DynamicResource AccentTextBrush}" />
                                        </Border>
                                        <TextBlock Style="{StaticResource Faint}"
                                                   Text="{Binding Category}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" />
                                </DockPanel>
                                <TextBlock Text="{Binding Description}" Style="{StaticResource Body}"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                                <ItemsControl ItemsSource="{Binding Benefits}" Margin="0,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}"><Run Text="+  " Foreground="{DynamicResource AccentTextBrush}" FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding Drawbacks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}"><Run Text="−  " FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Style="{StaticResource Faint}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Your stats set the sim's expectation of you, a faster driver is judged against a harder bar. Perks patch the deterministic inputs; nothing here decides a race." />
        </StackPanel>
    </ScrollViewer>
</UserControl>
