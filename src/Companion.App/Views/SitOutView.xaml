<UserControl x:Class="Companion.App.Views.SitOutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- Character injury sit-out step. The VM owns the deterministic auto-simulation; this view
         deliberately exposes only its display status and the single Continue command. -->
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Padding="0,14,0,0">
            <Button x:Name="SitOutContinueButton"
                    Content="Continue — simulate round  &#x23CE;"
                    Style="{StaticResource AccentButton}"
                    MinWidth="260" Padding="18,10" FontWeight="Bold"
                    HorizontalAlignment="Right"
                    Command="{Binding ContinueCommand}"
                    AutomationProperties.Name="Continue and auto-simulate the injured round"
                    ToolTip="Record the player as unavailable, auto-simulate the field, and advance one round" />
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <Grid MaxWidth="900" MinHeight="560" HorizontalAlignment="Center">
                <Border Margin="18" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1"
                        CornerRadius="14" Effect="{StaticResource PanelElevationEffect}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource WarningBrush}" CornerRadius="14,14,0,0" />

                        <StackPanel Grid.Row="1" Margin="48,38,48,44"
                                    HorizontalAlignment="Center" MaxWidth="720">
                            <Border Width="96" Height="96" CornerRadius="48"
                                    Background="{DynamicResource WarningDimBrush}"
                                    BorderBrush="{DynamicResource WarningBrush}" BorderThickness="2"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}"
                                           FontSize="42" Foreground="{DynamicResource WarningBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>

                            <TextBlock Text="MEDICAL WITHDRAWAL" Style="{StaticResource Eyebrow}"
                                       Foreground="{DynamicResource WarningBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,22,0,0" />

                            <TextBlock x:Name="SitOutHeadline" Text="{Binding Status.Headline}"
                                       FontFamily="{StaticResource DisplayFont}" FontSize="30"
                                       FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"
                                       HorizontalAlignment="Center" Margin="0,8,0,0" />

                            <TextBlock Text="The medical team has ruled you out of this round. AMS2 cannot spectate a single-player race, so the field will be auto-simulated while your recovery continues."
                                       Style="{StaticResource Body}" FontSize="15"
                                       TextAlignment="Center" Margin="0,16,0,0" />

                            <Border Style="{StaticResource WarningCallout}" Margin="0,28,0,0"
                                    MinWidth="420"
                                    Visibility="{Binding Status.SeasonEnding, Converter={StaticResource BoolCollapsed}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="RACES STILL TO MISS" Style="{StaticResource Eyebrow}"
                                               Foreground="{DynamicResource WarningBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Status.RaceSuspensionRemaining}"
                                               Style="{StaticResource StatValue}" FontSize="42"
                                               Foreground="{DynamicResource WarningBrush}"
                                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    <TextBlock Text="Continue advances one unavailable round at a time."
                                               Style="{StaticResource Muted}" TextAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ErrorCallout}" Margin="0,28,0,0"
                                    MinWidth="420"
                                    Visibility="{Binding Status.SeasonEnding, Converter={StaticResource BoolVisible}}">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="SEASON-ENDING INJURY" Style="{StaticResource Eyebrow}"
                                               Foreground="{DynamicResource ErrorBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="Recovery continues through the rest of this season."
                                               Style="{StaticResource Body}" FontWeight="SemiBold"
                                               TextAlignment="Center" Margin="0,6,0,0" />
                                    <TextBlock Text="Each remaining round is recorded without a player start; your career can resume next season."
                                               Style="{StaticResource Muted}" TextAlignment="Center"
                                               TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</UserControl>
