<Window x:Class="Companion.App.Views.BriefingCompactWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Companion.App"
        Title="Race setup checklist"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        Width="380" Height="460"
        MinWidth="300" MinHeight="220"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource BodyFont}"
        FontSize="13">
    <Grid Background="{StaticResource AppTextureBrush}">
        <Border Background="{StaticResource AppVignetteBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
          <DockPanel>
            <Border DockPanel.Dock="Top" Height="34" Background="{DynamicResource SurfaceAltBrush}"
                    BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                    app:WindowChromeAssist.IsDragRegion="True">
                <DockPanel Margin="10,2,3,2">
                    <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}"
                            app:WindowChromeAssist.IsCloseButton="True"
                            AutomationProperties.Name="Close race setup checklist" />
                    <TextBlock Text="RACE SETUP CHECKLIST" Style="{StaticResource Eyebrow}" FontSize="11"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>
            <DockPanel Margin="12,10">
        <!-- root UI-scale transform (settings: font scale) keeps this pop-out in step with the
             main window's text size. -->
        <DockPanel.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppUiScale}" ScaleY="{DynamicResource AppUiScale}" />
        </DockPanel.LayoutTransform>
        <!-- header: round title + N of M set -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Border DockPanel.Dock="Right" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Chip}">
                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding AllSet}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ChecklistProgressText}" FontWeight="SemiBold" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AllSet}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" ToolTip="{Binding Title}" />
        </DockPanel>

        <!-- the same checklist state as the briefing screen (one shared viewmodel); the label
             column is shared-size Auto so it never clips yet all rows stay aligned -->
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
            <ItemsControl ItemsSource="{Binding Sections}" Grid.IsSharedSizeScope="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Style="{StaticResource Faint}"
                                       FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"
                                       Visibility="{Binding Title, Converter={StaticResource StringVisible}}" />
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsChecked}" Margin="0,1"
                                                  HorizontalContentAlignment="Stretch">
                                            <Grid Margin="6,1,0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" MinWidth="90" MaxWidth="200"
                                                                      SharedSizeGroup="CompactLabel" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" Margin="0,0,8,0"
                                                           Style="{StaticResource Muted}" FontSize="12"
                                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontFamily="{StaticResource MonoFont}" FontSize="15"
                                                           FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
            </DockPanel>
          </DockPanel>
        </Border>
    </Grid>
</Window>
