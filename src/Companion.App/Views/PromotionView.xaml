<UserControl x:Class="Companion.App.Views.PromotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             Focusable="False">
    <!-- The SMGP promotion / demotion screen (3c-3), its own full-immersion step after the confirm,
         when the round moved seats. DataContext is a PromotionViewModel; its Model carries the new
         team's photo, story and car, and its Accept/Decline commands resolve the offer (or acknowledge
         a forced drop) and advance the round. A promotion offers accept/decline; a demotion only
         acknowledges. All art is absent-tolerant (drop-in files beside the exe). -->
    <DockPanel>

        <!-- action bar: accept (promotion) / acknowledge (demotion), and decline only for an offer -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,1,0,0"
                Padding="0,14,0,0">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Stay put" MinWidth="120" Margin="0,0,10,0"
                        Command="{Binding DeclineCommand}"
                        audio:SoundAssist.Cue="Back"
                        Visibility="{Binding CanDecline, Converter={StaticResource BoolVisible}}"
                        ToolTip="Decline the offer and keep your current seat" />
                <Button Content="{Binding Model.AcceptLabel}" Style="{StaticResource AccentButton}"
                        MinWidth="180" FontWeight="Bold" Command="{Binding AcceptCommand}"
                        audio:SoundAssist.Cue="Confirm"
                        ToolTip="Move to the new team from next round" />
            </WrapPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
            <StackPanel MaxWidth="780" HorizontalAlignment="Center">

                <!-- arcade headline + motto -->
                <TextBlock Text="PADDOCK BULLETIN" Style="{StaticResource Eyebrow}"
                           HorizontalAlignment="Center" Margin="0,0,0,6" />
                <TextBlock Text="{Binding Model.Headline}" Style="{StaticResource H1}"
                           TextAlignment="Center" TextWrapping="Wrap" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding Model.Motto}" Foreground="{DynamicResource AccentTextBrush}"
                           FontStyle="Italic" FontSize="15" TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,4,0,0" HorizontalAlignment="Center"
                           Visibility="{Binding Model.Motto, Converter={StaticResource StringVisible}}" />

                <!-- the VERY LARGE new-team photo: data/ams2/smgp/teams/<team>.jpg (placeholder until dropped) -->
                <Border Style="{StaticResource Panel}" Padding="18" Margin="0,16,0,0">
                    <StackPanel>
                <Grid Height="440"
                      ToolTip="Drop the team photo at data\ams2\smgp\teams\&lt;team&gt;.jpg (beside the exe)">
                    <Border CornerRadius="12" Background="{DynamicResource SurfaceAltBrush}">
                        <TextBlock Text="&#xE7C5;" FontFamily="{StaticResource IconFont}" FontSize="72"
                                   Foreground="{DynamicResource TextMutedBrush}" Opacity="0.4"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="12" ClipToBounds="True">
                        <Image Stretch="Uniform"
                               Source="{Binding Model.TeamPhotoKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/teams}"
                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                    </Border>
                </Grid>

                <TextBlock Text="{Binding Model.TeamName}" Style="{StaticResource H1}"
                           TextAlignment="Center" HorizontalAlignment="Center" Margin="0,14,0,0" />

                <!-- you (in the new colours) + the car you'll drive -->
                <Grid MaxWidth="560" HorizontalAlignment="Stretch" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Width="120" Height="120" Margin="0,0,18,0"
                          ToolTip="Drop the team player image at data\ams2\portraits\player.&lt;team&gt;.jpg">
                        <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                            <TextBlock Text="&#xE7C1;" FontFamily="{StaticResource IconFont}" FontSize="42"
                                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border CornerRadius="10" ClipToBounds="True">
                            <Image Stretch="UniformToFill"
                                   Source="{Binding Model.PlayerImageKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                        </Border>
                    </Grid>
                    <Image Grid.Column="1" Height="96" MaxWidth="400" Stretch="Uniform"
                           HorizontalAlignment="Stretch" VerticalAlignment="Center"
                           Source="{Binding Model.CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}"
                           ToolTip="Drop the car photo at data\ams2\cars\&lt;driverId&gt;.png" />
                </Grid>

                <!-- the rival you beat (promotion only) -->
                <Border Style="{StaticResource AccentCallout}" Margin="0,14,0,0"
                        Visibility="{Binding Model.RivalName, Converter={StaticResource StringVisible}}">
                    <TextBlock TextAlignment="Center" HorizontalAlignment="Stretch"
                               Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                               Text="{Binding Model.VictoryLine, Mode=OneWay}" />
                </Border>
                    </StackPanel>
                </Border>

                <!-- the team's SMGP-world story -->
                <TextBlock Text="THE STORY" Style="{StaticResource Eyebrow}" Margin="0,18,0,8" />
                <ItemsControl ItemsSource="{Binding Model.History}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,10" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- team quotes -->
                <TextBlock Text="FROM THE GARAGE" Style="{StaticResource Eyebrow}" Margin="0,2,0,8" />
                <ItemsControl ItemsSource="{Binding Model.Quotes}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QuoteCard}">
                                <TextBlock Style="{StaticResource Body}" FontStyle="Italic" TextWrapping="Wrap">
                                    <Run Text="&#x201C;" /><Run Text="{Binding Mode=OneWay}" /><Run Text="&#x201D;" />
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
