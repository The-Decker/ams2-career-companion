<UserControl x:Class="Companion.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <UserControl.Resources>
        <!-- one career record: a label over its value (best finish, wins, ...) -->
        <DataTemplate x:Key="RecordCellTemplate">
            <Border Style="{StaticResource Chip}" Margin="0,0,10,10" Padding="14,8">
                <StackPanel>
                    <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource AccentTextBrush}" />
                    <TextBlock Text="{Binding Label}" Style="{StaticResource Faint}" FontSize="11" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- one REAL historical race. Before the player has raced it (IsRevealed=false) it is a RACE
             PREVIEW — circuit map + track detail, NO result spoiler. Once raced it becomes the
             HISTORICAL DOCUMENT — winner + the full classified grid. Declared BEFORE SeasonCardTemplate,
             which references it via StaticResource (no forward refs). -->
        <DataTemplate x:Key="HistoricalRoundTemplate">
            <StackPanel Margin="0,1">
                <Button Style="{StaticResource SubtleButton}" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Padding="4,3"
                        Command="{Binding ToggleCommand}" ToolTip="Preview the circuit / show the result">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding RoundLabel}" FontFamily="{StaticResource MonoFont}"
                                   Foreground="{DynamicResource TextMutedBrush}" Width="34" VerticalAlignment="Center" />
                        <!-- revealed: the winner; preview: a spoiler-free "preview" tag -->
                        <TextBlock DockPanel.Dock="Right" Text="{Binding WinnerText}"
                                   Foreground="{DynamicResource AccentTextBrush}" TextTrimming="CharacterEllipsis"
                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsRevealed, Converter={StaticResource BoolVisible}}" />
                        <TextBlock DockPanel.Dock="Right" Text="preview" Style="{StaticResource Faint}"
                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsRevealed, Converter={StaticResource BoolCollapsed}}" />
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    </DockPanel>
                </Button>
                <StackPanel Margin="34,2,0,8"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                    <!-- circuit map + detail: the "what the track is like" preview, shown either way -->
                    <DockPanel Margin="0,0,0,6" Visibility="{Binding HasCircuit, Converter={StaticResource BoolVisible}}">
                        <!-- per-round mini map scales with the scrapbook column (96–200 square) -->
                        <Viewbox DockPanel.Dock="Left" Margin="0,0,14,0" VerticalAlignment="Top"
                                 Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                         Converter={StaticResource WidthFraction}, ConverterParameter=0.12|96|200}"
                                 Height="{Binding ActualWidth, RelativeSource={RelativeSource Self},
                                          Converter={StaticResource AspectHeight}, ConverterParameter=1}">
                            <Path Data="{Binding CircuitLayoutId, Converter={StaticResource CircuitGeometry}}"
                                  Stroke="{DynamicResource AccentBrush}" StrokeThickness="10"
                                  StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                        </Viewbox>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CircuitCaption}" Foreground="{DynamicResource AccentTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CircuitHistory}" Style="{StaticResource Muted}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                       Visibility="{Binding HasCircuitHistory, Converter={StaticResource BoolVisible}}" />
                        </StackPanel>
                    </DockPanel>
                    <!-- REVEALED: the historical document (fastest lap + full classified result) -->
                    <StackPanel Visibility="{Binding IsRevealed, Converter={StaticResource BoolVisible}}">
                        <TextBlock Text="{Binding FastestLapText}" Style="{StaticResource Faint}" Margin="0,0,0,4"
                                   Visibility="{Binding HasFastestLap, Converter={StaticResource BoolVisible}}" />
                        <ItemsControl ItemsSource="{Binding Results}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,1">
                                        <TextBlock DockPanel.Dock="Left" Text="{Binding Pos}" FontFamily="{StaticResource MonoFont}"
                                                   Width="40" Foreground="{DynamicResource TextMutedBrush}" />
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Team}" Style="{StaticResource Faint}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Driver}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Status}" Style="{StaticResource Faint}" Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding HasStatus, Converter={StaticResource BoolVisible}}" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <!-- PREVIEW (not yet raced): the result stays sealed -->
                    <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap"
                               Visibility="{Binding IsRevealed, Converter={StaticResource BoolCollapsed}}"
                               Text="The real result unlocks once you finish this race in your career." />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- one circuit's SMGP-universe legend. SEALED (a spoiler-free teaser) until the player has
             raced it; once raced, the header shows the champion of record and expanding shows the full
             SEGA-world legend (title / circuit / champion / story paragraphs / lore notes). The
             fictional-world counterpart to HistoricalRoundTemplate. -->
        <DataTemplate x:Key="SmgpWorldRaceTemplate">
            <StackPanel Margin="0,1">
                <Button Style="{StaticResource SubtleButton}" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left" Padding="4,3"
                        Command="{Binding ToggleCommand}" ToolTip="What the world remembers here">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left" Text="{Binding RoundLabel}" FontFamily="{StaticResource MonoFont}"
                                   Foreground="{DynamicResource TextMutedBrush}" Width="34" VerticalAlignment="Center" />
                        <!-- revealed: the champion of record; sealed: a spoiler-free tag -->
                        <TextBlock DockPanel.Dock="Right" Text="{Binding Champion}"
                                   Foreground="{DynamicResource AccentTextBrush}" TextTrimming="CharacterEllipsis"
                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsRevealed, Converter={StaticResource BoolVisible}}" />
                        <TextBlock DockPanel.Dock="Right" Text="sealed" Style="{StaticResource Faint}"
                                   Margin="10,0,0,0" VerticalAlignment="Center"
                                   Visibility="{Binding IsRevealed, Converter={StaticResource BoolCollapsed}}" />
                        <TextBlock Text="{Binding VenueName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    </DockPanel>
                </Button>
                <StackPanel Margin="34,2,0,10"
                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                    <!-- REVEALED: the SEGA world's legend of this circuit -->
                    <StackPanel Visibility="{Binding IsRevealed, Converter={StaticResource BoolVisible}}">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,2"
                                   Visibility="{Binding HasTitle, Converter={StaticResource BoolVisible}}" />
                        <TextBlock Text="{Binding Circuit}" Foreground="{DynamicResource AccentTextBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,6"
                                   Visibility="{Binding HasCircuit, Converter={StaticResource BoolVisible}}" />
                        <DockPanel Margin="0,0,0,8"
                                   Visibility="{Binding HasChampion, Converter={StaticResource BoolVisible}}">
                            <TextBlock DockPanel.Dock="Left" Text="Champion of record" Style="{StaticResource Faint}"
                                       Width="132" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Champion}" TextWrapping="Wrap" />
                        </DockPanel>
                        <ItemsControl ItemsSource="{Binding Body}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource Body}" TextWrapping="Wrap"
                                               Margin="0,0,0,6" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding Notes}" Margin="0,2,0,0"
                                      Visibility="{Binding HasNotes, Converter={StaticResource BoolVisible}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2">
                                        <TextBlock DockPanel.Dock="Left" Text="•" Foreground="{DynamicResource AccentTextBrush}"
                                                   VerticalAlignment="Top" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding}" Style="{StaticResource Muted}" FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <!-- SEALED (not yet raced): a spoiler-free teaser, the legend stays hidden -->
                    <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap"
                               Visibility="{Binding IsRevealed, Converter={StaticResource BoolCollapsed}}"
                               Text="Finish this race in your career to unlock what the world remembers here." />
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- one season's scrapbook card, with a timeline node down the left -->
        <DataTemplate x:Key="SeasonCardTemplate">
            <DockPanel Margin="0,0,0,14">
                <!-- lineage timeline node + connector -->
                <Grid DockPanel.Dock="Left" Width="28" Margin="0,4,10,0">
                    <Border Width="2" Background="{DynamicResource EdgeBrush}" HorizontalAlignment="Center" />
                    <Ellipse Width="12" Height="12" VerticalAlignment="Top" HorizontalAlignment="Center"
                             Fill="{DynamicResource AccentBrush}" />
                </Grid>

                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding YearText}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                            <!-- champion crown for the player's title seasons -->
                            <Border DockPanel.Dock="Right" Style="{StaticResource Chip}"
                                    Background="{DynamicResource WarningDimBrush}" VerticalAlignment="Center"
                                    Visibility="{Binding PlayerIsChampion, Converter={StaticResource BoolVisible}}">
                                <TextBlock Text="World Champion" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{DynamicResource WarningBrush}" />
                            </Border>
                            <!-- The season's final standing is a season-scoped "Why?" walk-back target
                                 (career-hub-design.md §4/§5, decision 18): click (or focus + Enter/Space —
                                 a Button is keyboard-invokable, locked decision 8) opens the shared
                                 inspector for THIS card's season, not just the current one. A year with
                                 no journal behind it returns an empty chain and the panel stays closed. -->
                            <Button HorizontalContentAlignment="Left" HorizontalAlignment="Left"
                                    audio:SoundAssist.Cue="Navigate"
                                    IsEnabled='{Binding CanInspect}'
                                    VerticalAlignment="Center" Margin="12,0,0,0" Padding="0"
                                    Style="{StaticResource SubtleButton}" Content="{Binding ResultText}"
                                    FontSize="14"
                                    Command="{Binding DataContext.OpenSeasonInspectorCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding SeasonYear}"
                                    ToolTip="Why? — walk back the journal rows behind this season" />
                        </DockPanel>

                        <TextBlock Text="{Binding ChampionText}" Style="{StaticResource Muted}"
                                   Margin="0,6,0,0" FontSize="13"
                                   Visibility="{Binding HasChampion, Converter={StaticResource BoolVisible}}" />
                        <TextBlock Text="{Binding FormText}" Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="12" Margin="0,4,0,0"
                                   Visibility="{Binding HasForm, Converter={StaticResource BoolVisible}}" />

                        <!-- the season's archived headline clippings -->
                        <ItemsControl ItemsSource="{Binding Headlines}" Margin="0,8,0,0"
                                      Visibility="{Binding HasHeadlines, Converter={StaticResource BoolVisible}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"
                                               Style="{StaticResource Muted}" FontSize="12" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Expander Header="MY SEASON ALMANAC" Margin="0,12,0,0"
                                  Visibility="{Binding Tag.Count, RelativeSource={RelativeSource Self}, Converter={StaticResource CountVisible}}"
                                  ToolTip="Your finish, named rival, championship leader, and running points after each race">
                            <Expander.Tag>
                                <MultiBinding Converter="{StaticResource HistoryRoundLines}">
                                    <Binding />
                                    <Binding Path="DataContext.Home.Session"
                                             RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                                    <Binding Path="DataContext.Home.RoundText"
                                             RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                                    <Binding Path="Tag.Home.Session"
                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                    <Binding Path="Tag.Home.RoundText"
                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                </MultiBinding>
                            </Expander.Tag>
                            <ItemsControl ItemsSource="{Binding Tag, RelativeSource={RelativeSource AncestorType=Expander}}"
                                          Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Callout}" Margin="0,0,0,6" Padding="10,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Round, StringFormat=R{0}}"
                                                           FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentTextBrush}" />
                                                <StackPanel Grid.Column="1" Margin="4,0,12,0">
                                                    <TextBlock Text="{Binding Venue}" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock FontSize="10.5" Margin="0,2,0,0"
                                                               Visibility="{Binding RivalName, Converter={StaticResource StringVisible}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <Run Text="RIVAL  " /><Run Text="{Binding RivalName}" FontWeight="SemiBold" />
                                                        <Run Text="  ·  " /><Run Text="{Binding RivalFinish, StringFormat=P{0}, TargetNullValue=DNF}" />
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource Faint}" FontSize="10.5" Margin="0,2,0,0"
                                                               Visibility="{Binding ChampionAfter, Converter={StaticResource StringVisible}}">
                                                        <Run Text="Leader after: " /><Run Text="{Binding ChampionAfter}" FontWeight="SemiBold" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                    <TextBlock Text="{Binding PlayerFinish, StringFormat=P{0}, TargetNullValue=DNF}"
                                                               FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                                               Foreground="{DynamicResource AccentTextBrush}" TextAlignment="Right" />
                                                    <TextBlock Text="{Binding PlayerPointsAfter, StringFormat={}{0:0.##} PTS}"
                                                               Style="{StaticResource Faint}" FontSize="10.5"
                                                               TextAlignment="Right" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>

                        <!-- WHAT REALLY HAPPENED: the real f1db results of this year, clearly separated
                             from the player's OWN (diverged) season above by a divider + label. Read-only
                             reference — collapsed by default, expands per season and per race. -->
                        <Border Margin="0,12,0,0" Padding="0,10,0,0" BorderBrush="{DynamicResource EdgeBrush}"
                                BorderThickness="0,1,0,0"
                                Visibility="{Binding HasRealSeason, Converter={StaticResource BoolVisible}}"
                                DataContext="{Binding RealSeason}">
                            <StackPanel>
                                <Button Style="{StaticResource SubtleButton}" HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Left" Padding="0"
                                        Command="{Binding ToggleCommand}"
                                        ToolTip="What really happened in F1 this year — the real results, separate from your career">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE81C;" FontSize="12"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"
                                                   Margin="0,0,8,0" />
                                        <TextBlock Text="What really happened" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Year, StringFormat=' in {0}'}"
                                                   Style="{StaticResource Muted}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding IsExpanded, Converter={StaticResource ExpandGlyph}}"
                                                   FontFamily="{StaticResource IconFont}" FontSize="10" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" />
                                    </StackPanel>
                                </Button>
                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                                    <!-- Optional story image for the season: drop <year>.jpg/.png into
                                         data\ams2\history-art and it appears here (shared user-asset
                                         convention, keyed by year). Collapses when no art is present. -->
                                    <Border CornerRadius="6" ClipToBounds="True" Margin="0,0,0,10"
                                            MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                                       Converter={StaticResource WidthFraction}, ConverterParameter=0.55|620}"
                                            HorizontalAlignment="Left" BorderBrush="{DynamicResource EdgeBrush}"
                                            BorderThickness="1"
                                            Visibility="{Binding ElementName=SeasonStoryImage, Path=Source, Converter={StaticResource NullCollapsed}}">
                                        <Image x:Name="SeasonStoryImage" Stretch="Uniform" StretchDirection="DownOnly"
                                               Source="{Binding Year, Converter={StaticResource AssetImage}, ConverterParameter=history-art}" />
                                    </Border>
                                    <!-- Season SPOILERS (champions + summary): revealed only once the
                                         player has finished the whole season in their career. -->
                                    <StackPanel Visibility="{Binding IsSeasonComplete, Converter={StaticResource BoolVisible}}">
                                        <TextBlock Text="{Binding SummaryText}" Style="{StaticResource Body}"
                                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                                   Visibility="{Binding HasSummary, Converter={StaticResource BoolVisible}}" />
                                        <DockPanel Margin="0,0,0,2"
                                                   Visibility="{Binding HasDriversChampion, Converter={StaticResource BoolVisible}}">
                                            <TextBlock DockPanel.Dock="Left" Text="Champion" Style="{StaticResource Faint}"
                                                       Width="92" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DriversChampionText}" TextWrapping="Wrap" />
                                        </DockPanel>
                                        <DockPanel Margin="0,0,0,8"
                                                   Visibility="{Binding HasConstructorsChampion, Converter={StaticResource BoolVisible}}">
                                            <TextBlock DockPanel.Dock="Left" Text="Constructors" Style="{StaticResource Faint}"
                                                       Width="92" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding ConstructorsChampionText}" TextWrapping="Wrap" />
                                        </DockPanel>
                                    </StackPanel>
                                    <!-- In-progress season: explain the reveal rule (no champion spoiler). -->
                                    <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="4" Padding="10,7"
                                            Margin="0,0,0,8"
                                            Visibility="{Binding IsSeasonComplete, Converter={StaticResource BoolCollapsed}}">
                                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap"
                                                   Text="Results unlock as you race; the champion stays sealed until season's end." />
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Rounds}"
                                                  ItemTemplate="{StaticResource HistoricalRoundTemplate}" />
                                    <TextBlock Text="{Binding Source}" Style="{StaticResource Faint}" FontSize="10"
                                               Margin="0,8,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </DockPanel>
        </DataTemplate>

        <!-- one inspector contribution row: label · detail · value (mirrors StandingsView) -->
        <DataTemplate x:Key="InspectorRowTemplate">
            <DockPanel Margin="0,3">
                <TextBlock DockPanel.Dock="Right" Text="{Binding Value}" FontFamily="{StaticResource MonoFont}"
                           FontWeight="SemiBold" TextAlignment="Right" MinWidth="56" Margin="8,0,0,0"
                           Visibility="{Binding HasValue, Converter={StaticResource BoolVisible}}" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" FontWeight="SemiBold" MinWidth="120" />
                <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap"
                           Visibility="{Binding HasDetail, Converter={StaticResource BoolVisible}}" />
            </DockPanel>
        </DataTemplate>
        <!-- A grounded career beat. Race rows and milestone rows share one chronological spine;
             category text ensures the meaning never depends on colour alone. -->
        <DataTemplate x:Key='HistoryEventTemplate'>
            <Grid Margin='0,0,0,10'>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width='28' />
                    <ColumnDefinition Width='*' />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column='0'>
                    <Border Width='2' Background='{DynamicResource EdgeBrush}' HorizontalAlignment='Center' />
                    <Ellipse Width='11' Height='11' VerticalAlignment='Top' Margin='0,8,0,0'
                             Stroke='{DynamicResource BgBrush}' StrokeThickness='2'>
                        <Ellipse.Style>
                            <Style TargetType='Ellipse'>
                                <Setter Property='Fill' Value='{DynamicResource AccentBrush}' />
                                <Style.Triggers>
                                    <DataTrigger Binding='{Binding IsMajor}' Value='True'>
                                        <Setter Property='Width' Value='15' />
                                        <Setter Property='Height' Value='15' />
                                        <Setter Property='Fill' Value='{DynamicResource WarningBrush}' />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </Grid>
                <Border Grid.Column='1' Style='{StaticResource Card}' Padding='12,10'>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width='Auto' />
                            <ColumnDefinition Width='*' />
                        </Grid.ColumnDefinitions>
                        <Grid Width='66' Height='66' Margin='0,0,12,0'
                              Visibility='{Binding HasSubjectPortrait, Converter={StaticResource BoolVisible}}'>
                            <Border Style='{StaticResource AssetPlaceholderFrame}'>
                                <TextBlock Text='&#xE77B;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='24' />
                            </Border>
                            <Border CornerRadius='4' ClipToBounds='True'>
                                <Image Stretch='UniformToFill'
                                       Source='{Binding SubjectPortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}' />
                            </Border>
                        </Grid>
                        <StackPanel Grid.Column='1'>
                            <DockPanel LastChildFill='True'>
                                <Border DockPanel.Dock='Right' Style='{StaticResource CompactChip}' Margin='10,0,0,0'>
                                    <TextBlock Text='{Binding Category}' Style='{StaticResource Eyebrow}' />
                                </Border>
                                <TextBlock Text='{Binding WhenLabel}' Style='{StaticResource Mono}' FontSize='10.5'
                                           Foreground='{DynamicResource TextMutedBrush}' />
                            </DockPanel>
                            <TextBlock Text='{Binding Title}' FontWeight='SemiBold' FontSize='15'
                                       TextWrapping='Wrap' TextTrimming='None' Margin='0,4,0,0' />
                            <TextBlock Text='{Binding Detail}' Style='{StaticResource Muted}' TextWrapping='Wrap'
                                       TextTrimming='None' Margin='0,4,0,0'
                                       Visibility='{Binding HasDetail, Converter={StaticResource BoolVisible}}' />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- One race in the career-wide archive. All copy is projected from stored results; a
             missing classification is labelled Not classified rather than guessed as DNF/DNS. -->
        <DataTemplate x:Key='HistoryRaceTemplate'>
            <Border Style='{StaticResource Card}' Padding='0' Margin='0,0,10,10' ClipToBounds='True'>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width='106' />
                        <ColumnDefinition Width='*' />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column='0' Background='{DynamicResource SurfaceAltBrush}'>
                        <Border Style='{StaticResource AssetPlaceholderFrame}' Margin='8'>
                            <TextBlock Text='&#xE7C1;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='28' />
                        </Border>
                        <Image Stretch='UniformToFill'
                               Source='{Binding Round, Converter={StaticResource AssetImage}, ConverterParameter=smgp/rounds}'
                               Visibility='{Binding HasCurrentCar, Converter={StaticResource BoolVisible}}' />
                        <Border VerticalAlignment='Bottom' Background='{DynamicResource ScrimBrush}' Padding='7,4'>
                            <TextBlock Text='{Binding RoundLabel}' FontFamily='{StaticResource MonoFont}'
                                       FontWeight='Bold' Foreground='{DynamicResource TextBrush}' />
                        </Border>
                    </Grid>
                    <StackPanel Grid.Column='1' Margin='12,10,12,11'>
                        <DockPanel LastChildFill='True'>
                            <Border DockPanel.Dock='Right' Style='{StaticResource CompactChip}' Margin='10,0,0,0'>
                                <TextBlock Text='{Binding StatusLabel}' Style='{StaticResource Eyebrow}' />
                            </Border>
                            <TextBlock Style='{StaticResource Mono}' FontSize='10.5'
                                       Foreground='{DynamicResource TextMutedBrush}'>
                                <Run Text='{Binding SeasonYear, Mode=OneWay}' /><Run Text='  /  ' /><Run Text='{Binding RoundLabel, Mode=OneWay}' />
                            </TextBlock>
                        </DockPanel>
                        <TextBlock Text='{Binding VenueName}' FontSize='16' FontWeight='SemiBold'
                                   TextWrapping='Wrap' TextTrimming='None' Margin='0,5,0,0' />
                        <WrapPanel Margin='0,7,0,0'>
                            <Border Style='{StaticResource CompactChip}' Margin='0,0,6,5'>
                                <TextBlock Text='{Binding FinishText}' FontFamily='{StaticResource MonoFont}' FontWeight='Bold' />
                            </Border>
                            <Border Style='{StaticResource CompactChip}' Margin='0,0,6,5'>
                                <TextBlock Text='{Binding PointsEarnedText}' />
                            </Border>
                            <Border Style='{StaticResource CompactChip}' Margin='0,0,6,5'
                                    Visibility='{Binding HasRival, Converter={StaticResource BoolVisible}}'>
                                <TextBlock>
                                    <Run Text='Rival  ' /><Run Text='{Binding RivalName, Mode=OneWay}' FontWeight='SemiBold' />
                                    <Run Text='  ' /><Run Text='{Binding RivalFinishText, Mode=OneWay}' />
                                </TextBlock>
                            </Border>
                        </WrapPanel>
                        <TextBlock Text='{Binding StoryContext}' Style='{StaticResource Muted}' TextWrapping='Wrap'
                                   TextTrimming='None' Margin='0,2,0,0' />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- A compact latest-dispatch card inside History. Reading the full desk remains a
              deliberate navigation action through the section-level Open News button. -->
        <DataTemplate x:Key='HistoryDispatchTemplate'>
            <Button Style='{StaticResource SubtleButton}' Padding='0' Margin='0,0,10,10'
                    HorizontalContentAlignment='Stretch' VerticalContentAlignment='Stretch'
                    Tag='{Binding Key, Mode=OneWay}' Click='OnOpenNewsArticle'
                    AutomationProperties.Name='{Binding Headline, Mode=OneWay}'>
            <Border Style='{StaticResource Card}' Padding='0' ClipToBounds='True'>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height='92' />
                        <RowDefinition Height='Auto' />
                    </Grid.RowDefinitions>
                    <Grid Background='{DynamicResource SurfaceAltBrush}'>
                        <Border Style='{StaticResource AssetPlaceholderFrame}' Margin='8'>
                            <TextBlock Text='&#xE8A5;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='28' />
                        </Border>
                        <Image Stretch='UniformToFill'
                               Source='{Binding TeamArtKey, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}'
                               Visibility='{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}' />
                        <Image Stretch='UniformToFill'
                               Source='{Binding DriverPortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}'
                               Visibility='{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}' />
                        <Border VerticalAlignment='Bottom' Background='{DynamicResource ScrimBrush}' Padding='8,4'>
                            <DockPanel>
                                <TextBlock DockPanel.Dock='Right' Text='{Binding ImportanceLabel}'
                                           Style='{StaticResource Eyebrow}' Foreground='{DynamicResource TextBrush}' />
                                <TextBlock Text='{Binding WhenLabel}' Style='{StaticResource Mono}' FontSize='10'
                                           Foreground='{DynamicResource TextBrush}' />
                            </DockPanel>
                        </Border>
                    </Grid>
                    <StackPanel Grid.Row='1' Margin='12,10,12,12'>
                        <TextBlock Text='{Binding Category}' Style='{StaticResource Eyebrow}'
                                   Foreground='{DynamicResource AccentTextBrush}' />
                        <TextBlock Text='{Binding Headline}' FontFamily='{StaticResource DisplayFont}'
                                   FontWeight='SemiBold' FontSize='15' TextWrapping='Wrap' TextTrimming='None'
                                   Margin='0,5,0,0' />
                        <TextBlock Text='{Binding Body}' Style='{StaticResource Muted}' TextWrapping='Wrap'
                                   TextTrimming='WordEllipsis' MaxHeight='54' Margin='0,5,0,0'
                                   Visibility='{Binding HasBody, Converter={StaticResource BoolVisible}}' />
                    </StackPanel>
                </Grid>
            </Border>
            </Button>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
    <DockPanel>
        <!-- header -->
        <Border DockPanel.Dock="Top" Padding="24,14,24,8">
            <StackPanel>
                <TextBlock Text='HISTORY ARCHIVE' Style='{StaticResource H1}' />
                <TextBlock Text='Every race, rivalry, move and milestone preserved from the career state.'
                           Style='{StaticResource Muted}' Margin='0,3,0,0' TextWrapping='Wrap' />
            </StackPanel>
        </Border>

        <!-- The session projection is synchronous today, but the loading surface is a stable
             contract for slow or future archive sources. -->
        <Border x:Name='HistoryLoadingState' DockPanel.Dock='Top' Style='{StaticResource Panel}'
                Margin='24,4,24,14' Padding='18'
                AutomationProperties.Name='History archive loading'
                Visibility='{Binding IsLoading, Converter={StaticResource BoolVisible}}'>
            <StackPanel Orientation='Horizontal'>
                <TextBlock Text='&#xE895;' FontFamily='{StaticResource IconFont}' FontSize='26'
                           Foreground='{DynamicResource AccentTextBrush}' Margin='0,0,14,0' />
                <StackPanel>
                    <TextBlock Text='OPENING THE ARCHIVE' Style='{StaticResource Eyebrow}' />
                    <TextBlock Text='Reading the career ledger and deterministic dispatch record.'
                               Style='{StaticResource Muted}' Margin='0,3,0,0' TextWrapping='Wrap' />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- empty state: no season has an applied round yet -->
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" TextWrapping="Wrap" MaxWidth="460"
                   Margin="24,4,24,20" HorizontalAlignment="Left"
                   Text="No history yet — finish a race and your career starts filling the scrapbook: season cards, a records book, and every dispatch archived forever."
                   AutomationProperties.Name='History archive empty'
                   Visibility='{Binding IsFresh, Converter={StaticResource BoolVisible}}' />

        <ScrollViewer x:Name='HistoryScroll' HorizontalScrollBarVisibility='Disabled' VerticalScrollBarVisibility='Auto'
                      AutomationProperties.Name='Career history archive'
                      Visibility='{Binding HasAnyRace, Converter={StaticResource BoolVisible}}'>
            <!-- proportional scrapbook cap (was a hard 820) -->
            <StackPanel Margin='24,4,24,24' HorizontalAlignment='Stretch'
                        MaxWidth='{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                   Converter={StaticResource WidthFraction}, ConverterParameter=0.94|0|1500}'>
                <Border Style='{StaticResource Callout}' Margin='0,0,0,14' Padding='12,9'
                        AutomationProperties.Name='Legacy career archive notice'
                        Visibility='{Binding IsLegacyLimited, Converter={StaticResource BoolVisible}}'>
                    <DockPanel>
                        <TextBlock DockPanel.Dock='Left' Text='&#xE7BA;' FontFamily='{StaticResource IconFont}'
                                   Foreground='{DynamicResource WarningBrush}' FontSize='20' Margin='0,0,11,0' />
                        <StackPanel>
                            <TextBlock Text='LEGACY ARCHIVE - AVAILABLE RECORDS ONLY' Style='{StaticResource Eyebrow}' />
                            <TextBlock Text='This career predates some identity metadata. Stored results remain intact; unavailable images and links stay hidden.'
                                       Style='{StaticResource Muted}' TextWrapping='Wrap' Margin='0,3,0,0' />
                        </StackPanel>
                    </DockPanel>
                </Border>
                <!-- NEXT RACE preview: the current season's upcoming round — circuit map + track detail,
                     no result spoiler. The History screen's "what's coming next". -->
                <!-- CAREER HERO: current identity and totals from the read-only career/paddock projection. -->
                <Border x:Name='HistoryHero' Style='{StaticResource Panel}' Padding='18' Margin='0,0,0,16'
                        DataContext='{Binding Hero}' AutomationProperties.Name='Career summary'>
                    <StackPanel>
                        <TextBlock Text='CAREER SNAPSHOT' Style='{StaticResource Eyebrow}' Margin='0,0,0,10' />
                        <WrapPanel>
                            <Grid Width='136' Height='164' Margin='0,0,16,12'>
                                <Border Style='{StaticResource AssetPlaceholderFrame}'>
                                    <TextBlock Text='&#xE77B;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='42' />
                                </Border>
                                <Border CornerRadius='6' ClipToBounds='True'>
                                    <Image Stretch='UniformToFill'
                                           Source='{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits|cars}'
                                           Visibility='{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}' />
                                </Border>
                            </Grid>

                            <StackPanel Width='310' Margin='0,0,18,12' VerticalAlignment='Center'>
                                <WrapPanel>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,6,6'>
                                        <TextBlock Text='{Binding EraLabel}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,6,6'>
                                        <TextBlock Text='{Binding SeasonLabel}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text='{Binding PlayerName}' Style='{StaticResource H1}'
                                           TextWrapping='Wrap' TextTrimming='None' />
                                <TextBlock Text='{Binding CareerName}' Style='{StaticResource Muted}'
                                           TextWrapping='Wrap' Margin='0,3,0,0' />
                                <TextBlock Text='{Binding TeamName}' FontSize='16' FontWeight='SemiBold'
                                           Foreground='{DynamicResource AccentTextBrush}' Margin='0,9,0,0'
                                           Visibility='{Binding HasTeam, Converter={StaticResource BoolVisible}}' />
                                <TextBlock Text='{Binding StandingText}' Style='{StaticResource Body}' Margin='0,5,0,0' />
                                <TextBlock Text='{Binding Trajectory}' Style='{StaticResource Muted}'
                                           TextWrapping='Wrap' TextTrimming='None' Margin='0,8,0,0'
                                           Visibility='{Binding HasTrajectory, Converter={StaticResource BoolVisible}}' />

                                <Border Style='{StaticResource Callout}' Margin='0,10,0,0' Padding='9,7'
                                        Visibility='{Binding HasCurrentRival, Converter={StaticResource BoolVisible}}'>
                                    <DockPanel>
                                        <Grid DockPanel.Dock='Left' Width='42' Height='42' Margin='0,0,10,0'>
                                            <Border Style='{StaticResource AssetPlaceholderFrame}'>
                                                <TextBlock Text='&#xE77B;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='18' />
                                            </Border>
                                            <Image Stretch='UniformToFill'
                                                   Source='{Binding CurrentRivalPortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}'
                                                   Visibility='{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}' />
                                        </Grid>
                                        <StackPanel VerticalAlignment='Center'>
                                            <TextBlock Text='CURRENT RIVAL' Style='{StaticResource Eyebrow}' />
                                            <TextBlock Text='{Binding CurrentRivalName}' FontWeight='SemiBold' />
                                            <TextBlock Text='{Binding CurrentRivalTeamName}' Style='{StaticResource Faint}'
                                                       Visibility='{Binding CurrentRivalTeamName, Converter={StaticResource StringVisible}}' />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </StackPanel>

                            <Grid Width='238' Height='164' Margin='0,0,0,12'>
                                <Border Style='{StaticResource AssetPlaceholderFrame}'>
                                    <TextBlock Text='&#xE7C1;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='38' />
                                </Border>
                                <Image Stretch='Uniform' StretchDirection='DownOnly'
                                       Source='{Binding CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}'
                                       Visibility='{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}' />
                            </Grid>
                        </WrapPanel>

                        <WrapPanel Margin='0,4,0,0'>
                            <Border Style='{StaticResource StatTile}' Width='104' Margin='0,0,8,8'>
                                <StackPanel><TextBlock Text='{Binding Titles}' FontSize='22' FontWeight='Bold' /><TextBlock Text='TITLES' Style='{StaticResource Faint}' /></StackPanel>
                            </Border>
                            <Border Style='{StaticResource StatTile}' Width='104' Margin='0,0,8,8'>
                                <StackPanel><TextBlock Text='{Binding Wins}' FontSize='22' FontWeight='Bold' /><TextBlock Text='WINS' Style='{StaticResource Faint}' /></StackPanel>
                            </Border>
                            <Border Style='{StaticResource StatTile}' Width='104' Margin='0,0,8,8'>
                                <StackPanel><TextBlock Text='{Binding Podiums}' FontSize='22' FontWeight='Bold' /><TextBlock Text='PODIUMS' Style='{StaticResource Faint}' /></StackPanel>
                            </Border>
                            <Border Style='{StaticResource StatTile}' Width='104' Margin='0,0,8,8'
                                    Visibility='{Binding HasPoles, Converter={StaticResource BoolVisible}}'>
                                <StackPanel><TextBlock Text='{Binding Poles}' FontSize='22' FontWeight='Bold' /><TextBlock Text='POLES' Style='{StaticResource Faint}' /></StackPanel>
                            </Border>
                            <Border Style='{StaticResource StatTile}' Width='104' Margin='0,0,8,8'
                                    Visibility='{Binding HasStarts, Converter={StaticResource BoolVisible}}'>
                                <StackPanel><TextBlock Text='{Binding Starts}' FontSize='22' FontWeight='Bold' /><TextBlock Text='STARTS' Style='{StaticResource Faint}' /></StackPanel>
                            </Border>
                            <Border Style='{StaticResource StatTile}' Width='104' Margin='0,0,8,8'>
                                <StackPanel><TextBlock Text='{Binding Points}' FontSize='22' FontWeight='Bold' /><TextBlock Text='POINTS' Style='{StaticResource Faint}' /></StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- LATEST DISPATCHES: a compact bridge to the dedicated newsroom. -->
                <Border Style='{StaticResource Panel}' Margin='0,0,0,16'
                        Visibility='{Binding HasLatestDispatches, Converter={StaticResource BoolVisible}}'>
                    <StackPanel>
                        <DockPanel Margin='0,0,0,9'>
                            <Button x:Name='OpenNewsButton' DockPanel.Dock='Right' Style='{StaticResource SubtleButton}' Padding='9,5'
                                    Click='OnOpenNews' audio:SoundAssist.Cue='Navigate'
                                    AutomationProperties.Name='Open the News newsroom'>
                                <StackPanel Orientation='Horizontal'>
                                    <TextBlock Text='Open News' />
                                    <TextBlock Text='&#xE72A;' FontFamily='{StaticResource IconFont}' Margin='7,0,0,0' />
                                </StackPanel>
                            </Button>
                            <StackPanel>
                                <TextBlock Text='LATEST DISPATCHES' Style='{StaticResource H2}' />
                                <TextBlock Text='The newsroom view of the moments preserved below.' Style='{StaticResource Muted}' Margin='0,3,0,0' />
                            </StackPanel>
                        </DockPanel>
                        <ItemsControl ItemsSource='{Binding LatestDispatches}' ItemTemplate='{StaticResource HistoryDispatchTemplate}'>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns='{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource AdaptiveColumns}, ConverterParameter=320|1|3}' />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- CHRONOLOGY: every race plus typed SMGP career beats, oldest to newest. -->
                <Expander IsExpanded='True' Margin='0,0,0,16'
                          AutomationProperties.Name='Chronological career timeline'>
                    <Expander.Header>
                        <StackPanel>
                            <TextBlock Text='CAREER TIMELINE' Style='{StaticResource H2}' />
                            <TextBlock Text='Races, rival battles, moves, injuries and major achievements in recorded order.'
                                       Style='{StaticResource Muted}' Margin='0,3,0,0' />
                        </StackPanel>
                    </Expander.Header>
                    <ItemsControl x:Name='HistoryEventList' ItemsSource='{Binding Events}' ItemTemplate='{StaticResource HistoryEventTemplate}'
                                  Margin='0,10,0,0' />
                </Expander>

                <TextBlock Text='REFERENCE DESK' Style='{StaticResource Eyebrow}' Margin='1,0,0,8' />
                <Border Style="{StaticResource Panel}" Margin="0,0,0,18"
                        Visibility="{Binding HasNextRacePreview, Converter={StaticResource BoolVisible}}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Faint}">
                            <Run Text="NEXT RACE" /><Run Text="{Binding NextRaceYear, StringFormat=' · {0}', Mode=OneWay}" />
                        </TextBlock>
                        <DockPanel Margin="0,8,0,0" DataContext="{Binding NextRacePreview}">
                            <!-- the NEXT RACE hero map scales with the column (160–280 square) -->
                            <Viewbox DockPanel.Dock="Left" Margin="0,0,18,0" VerticalAlignment="Top"
                                     Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                             Converter={StaticResource WidthFraction}, ConverterParameter=0.22|160|280}"
                                     Height="{Binding ActualWidth, RelativeSource={RelativeSource Self},
                                              Converter={StaticResource AspectHeight}, ConverterParameter=1}"
                                     Visibility="{Binding HasCircuit, Converter={StaticResource BoolVisible}}">
                                <Path Data="{Binding CircuitLayoutId, Converter={StaticResource CircuitGeometry}}"
                                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="10"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CircuitCaption}" Foreground="{DynamicResource AccentTextBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding CircuitHistory}" Style="{StaticResource Body}" TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Visibility="{Binding HasCircuitHistory, Converter={StaticResource BoolVisible}}" />
                                <TextBlock Style="{StaticResource Faint}" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Race it in your career to see how it really unfolded." />
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- WHAT THE WORLD REMEMBERS: the SMGP-universe "what really happened" almanac — the
                     fictional SEGA world's own legend of every circuit, each unlocked once the player
                     finishes that race. Shown ONLY for the replica mode (HasSmgpWorld); a normal career
                     never sees it. One panel per History tab (not per season card), since the replica is
                     one continuous fictional world with a fixed set of circuits. -->
                <Border Style="{StaticResource Panel}" Margin="0,0,0,18"
                        Visibility="{Binding HasSmgpWorld, Converter={StaticResource BoolVisible}}"
                        DataContext="{Binding SmgpWorld}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Style="{StaticResource Faint}"
                                       Text="{Binding ProgressText}" VerticalAlignment="Center" />
                            <TextBlock Text="What the world remembers" Style="{StaticResource H2}" />
                        </DockPanel>
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,4,0,10"
                                   Text="The Super Monaco GP world's own account of every circuit — each unlocks once you finish that race." />
                        <ItemsControl ItemsSource="{Binding Races}"
                                      ItemTemplate="{StaticResource SmgpWorldRaceTemplate}" />
                    </StackPanel>
                </Border>

                <!-- records book -->
                <TextBlock Text='RECORDS AND MILESTONES' Style='{StaticResource H2}' Margin='0,0,0,10' />
                <ItemsControl ItemsSource="{Binding Records.Rows}"
                              ItemTemplate="{StaticResource RecordCellTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- season cards + lineage timeline -->
                <TextBlock Text='SEASON FILES' Style='{StaticResource H2}' Margin='0,18,0,10' />
                <ItemsControl ItemsSource="{Binding Seasons}"
                              ItemTemplate="{StaticResource SeasonCardTemplate}" />

                <!-- CAREER-WIDE RACE ARCHIVE: search and filter stay keyboard-native and silent. -->
                <Border Style='{StaticResource Panel}' Margin='0,12,0,18'>
                    <StackPanel>
                        <TextBlock Text='RACE ARCHIVE' Style='{StaticResource H2}' />
                        <TextBlock Text='Search venues, rivals, seasons and result context. Filters use only recorded classifications.'
                                   Style='{StaticResource Muted}' TextWrapping='Wrap' Margin='0,3,0,10' />
                        <WrapPanel>
                            <TextBox x:Name='HistoryRaceSearch' Width='260' MinWidth='180' Margin='0,0,8,8'
                                     Text='{Binding SearchText, UpdateSourceTrigger=PropertyChanged}'
                                     ToolTip='Search the career race archive'
                                     AutomationProperties.Name='Search the career race archive' />
                            <ComboBox Width='210' MinWidth='160' Margin='0,0,8,8'
                                      ItemsSource='{Binding RaceFilters}' DisplayMemberPath='DisplayText'
                                      SelectedItem='{Binding SelectedRaceFilter}'
                                      ToolTip='Filter recorded race outcomes'
                                      AutomationProperties.Name='Race archive outcome filter' />
                            <Button Style='{StaticResource SubtleButton}' Padding='9,5' Margin='0,0,0,8'
                                    Command='{Binding ClearRaceFiltersCommand}'
                                    IsEnabled='{Binding HasActiveRaceFilter}'
                                    AutomationProperties.Name='Clear race archive filters'>
                                <StackPanel Orientation='Horizontal'>
                                    <TextBlock Text='&#xE711;' FontFamily='{StaticResource IconFont}' Margin='0,0,7,0' />
                                    <TextBlock Text='Clear' />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                        <Border Style='{StaticResource Callout}' Padding='12,9' Margin='0,4,0,8'
                                AutomationProperties.Name='No races match the filters'
                                Visibility='{Binding IsRaceFilterEmpty, Converter={StaticResource BoolVisible}}'>
                            <TextBlock Text='No recorded races match this search and filter. Clear them to restore the complete archive.'
                                       Style='{StaticResource Muted}' TextWrapping='Wrap' />
                        </Border>
                        <ItemsControl ItemsSource='{Binding FilteredRaces}' ItemTemplate='{StaticResource HistoryRaceTemplate}'>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns='{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource AdaptiveColumns}, ConverterParameter=430|1|2}' />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- archived journal articles (the deterministic legacy feed, preserved forever) -->
                <TextBlock Text='JOURNAL ARTICLE ARCHIVE' Style='{StaticResource H2}' Margin='0,10,0,4' />
                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="No dispatches archived yet."
                           Visibility="{Binding HasArticles, Converter={StaticResource BoolCollapsed}}" />
                <ItemsControl ItemsSource="{Binding ArchivedArticles}"
                              Visibility="{Binding HasArticles, Converter={StaticResource BoolVisible}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                                    Padding="2,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Meta}" Style="{StaticResource Faint}" FontSize="11" />
                                    <Button HorizontalContentAlignment="Left" Padding="0,3"
                                            Background="Transparent" BorderBrush="Transparent"
                                            Cursor="Hand"
                                            Command="{Binding ToggleExpandedCommand}"
                                            ToolTip="Read the full archived dispatch">
                                        <TextBlock Text="{Binding Headline}" FontSize="15" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                    </Button>
                                    <StackPanel Margin="0,4,0,2"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap"
                                                   Style="{StaticResource Muted}" />
                                        <Border Margin="0,8,0,0" Padding="9,4" CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource AccentDimBrush}"
                                                Visibility="{Binding HasWhy, Converter={StaticResource BoolVisible}}">
                                            <TextBlock Text="{Binding WhyText}" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource AccentTextBrush}" FontSize="12" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

        <!-- The shared "Why?" inspector overlay (career-hub-design.md §5), mirroring StandingsView.
             Shown while an inspector is open; the scrim + Close button (mouse) and the ESC key
             binding (keyboard) both dismiss it — locked decision 8's parity. -->
        <Border x:Name="InspectorScrim" Background="{DynamicResource ScrimBrush}"
                Visibility="{Binding IsInspectorOpen, Converter={StaticResource BoolVisible}, FallbackValue=Collapsed}">
            <Border.InputBindings>
                <KeyBinding Key="Esc" Command="{Binding CloseInspectorCommand}" />
            </Border.InputBindings>
            <!-- proportional modal (was a fixed 520x440) — same fix as StandingsView's inspector -->
            <Border Margin="24" Padding="18"
                    MaxWidth="{Binding ActualWidth, ElementName=InspectorScrim,
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.5|520}"
                    MaxHeight="{Binding ActualHeight, ElementName=InspectorScrim,
                                Converter={StaticResource WidthFraction}, ConverterParameter=0.7|440}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                    BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                    DataContext="{Binding SelectedInspector}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" VerticalAlignment="Top"
                                audio:SoundAssist.Cue="Back"
                                Style="{StaticResource CloseButton}"
                                AutomationProperties.Name="Close history inspector"
                                Command="{Binding DataContext.CloseInspectorCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ToolTip="Close (Esc)" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Summary}" TextWrapping="Wrap"
                               Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Visibility="{Binding HasSummary, Converter={StaticResource BoolVisible}}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
                        <ItemsControl ItemsSource="{Binding Rows}"
                                      ItemTemplate="{StaticResource InspectorRowTemplate}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
