<UserControl x:Class="Companion.App.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <UserControl.Resources>
        <!-- one career record: a label over its value (best finish, wins, ...) -->
        <DataTemplate x:Key="RecordCellTemplate">
            <Border Style="{StaticResource Chip}" Margin="0,0,10,10" Padding="14,8">
                <StackPanel>
                    <TextBlock Text="{Binding Value}" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" />
                    <TextBlock Text="{Binding Label}" Style="{StaticResource Faint}" FontSize="11" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- one season's scrapbook card, with a timeline node down the left -->
        <DataTemplate x:Key="SeasonCardTemplate">
            <DockPanel Margin="0,0,0,14">
                <!-- lineage timeline node + connector -->
                <Grid DockPanel.Dock="Left" Width="28" Margin="0,4,10,0">
                    <Border Width="2" Background="{StaticResource EdgeBrush}" HorizontalAlignment="Center" />
                    <Ellipse Width="12" Height="12" VerticalAlignment="Top" HorizontalAlignment="Center"
                             Fill="{StaticResource AccentBrush}" />
                </Grid>

                <Border Style="{StaticResource Panel}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="{Binding YearText}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <!-- champion crown for the player's title seasons -->
                            <Border DockPanel.Dock="Right" Style="{StaticResource Chip}"
                                    Background="{StaticResource WarningDimBrush}" VerticalAlignment="Center"
                                    Visibility="{Binding PlayerIsChampion, Converter={StaticResource BoolVisible}}">
                                <TextBlock Text="World Champion" FontWeight="SemiBold" FontSize="12"
                                           Foreground="{StaticResource WarningBrush}" />
                            </Border>
                            <!-- The season's final standing is a season-scoped "Why?" walk-back target
                                 (career-hub-design.md §4/§5, decision 18): click (or focus + Enter/Space —
                                 a Button is keyboard-invokable, locked decision 8) opens the shared
                                 inspector for THIS card's season, not just the current one. A year with
                                 no journal behind it returns an empty chain and the panel stays closed. -->
                            <Button HorizontalContentAlignment="Left" HorizontalAlignment="Left"
                                    VerticalAlignment="Center" Margin="12,0,0,0" Padding="0"
                                    Style="{StaticResource SubtleButton}" Content="{Binding ResultText}"
                                    FontSize="14"
                                    Command="{Binding DataContext.OpenSeasonInspectorCommand,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding SeasonYear}"
                                    ToolTip="Why? — walk back the journal rows behind this season" />
                        </DockPanel>

                        <TextBlock Text="{Binding ChampionText}" Style="{StaticResource Muted}"
                                   Margin="0,6,0,0" FontSize="13"
                                   Visibility="{Binding HasChampion, Converter={StaticResource BoolVisible}}" />
                        <TextBlock Text="{Binding FormText}" Foreground="{StaticResource AccentBrush}"
                                   FontSize="12" Margin="0,4,0,0"
                                   Visibility="{Binding HasForm, Converter={StaticResource BoolVisible}}" />

                        <!-- the season's archived headline clippings -->
                        <ItemsControl ItemsSource="{Binding Headlines}" Margin="0,8,0,0"
                                      Visibility="{Binding HasHeadlines, Converter={StaticResource BoolVisible}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2"
                                               Style="{StaticResource Muted}" FontSize="12" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </DockPanel>
        </DataTemplate>

        <!-- one inspector contribution row: label · detail · value (mirrors StandingsView) -->
        <DataTemplate x:Key="InspectorRowTemplate">
            <DockPanel Margin="0,3">
                <TextBlock DockPanel.Dock="Right" Text="{Binding Value}" FontFamily="Consolas"
                           FontWeight="SemiBold" TextAlignment="Right" MinWidth="56" Margin="8,0,0,0"
                           Visibility="{Binding HasValue, Converter={StaticResource BoolVisible}}" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" FontWeight="SemiBold" MinWidth="120" />
                <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap"
                           Visibility="{Binding HasDetail, Converter={StaticResource BoolVisible}}" />
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
    <DockPanel>
        <!-- header -->
        <Border DockPanel.Dock="Top" Padding="24,14,24,8">
            <TextBlock Text="Career scrapbook" Style="{StaticResource Faint}" FontSize="11" />
        </Border>

        <!-- empty state: no season has an applied round yet -->
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" TextWrapping="Wrap" MaxWidth="460"
                   Margin="24,4,24,20" HorizontalAlignment="Left"
                   Text="No history yet — finish a race and your career starts filling the scrapbook: season cards, a records book, and every dispatch archived forever."
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolVisible}}" />

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsEmpty, Converter={StaticResource BoolCollapsed}}">
            <StackPanel Margin="24,4,24,24" MaxWidth="820" HorizontalAlignment="Left">
                <!-- records book -->
                <TextBlock Text="Records" Style="{StaticResource H2}" Margin="0,0,0,10" />
                <ItemsControl ItemsSource="{Binding Records.Rows}"
                              ItemTemplate="{StaticResource RecordCellTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- season cards + lineage timeline -->
                <TextBlock Text="Seasons" Style="{StaticResource H2}" Margin="0,18,0,10" />
                <ItemsControl ItemsSource="{Binding Seasons}"
                              ItemTemplate="{StaticResource SeasonCardTemplate}" />

                <!-- archived articles (the News feed, preserved forever) -->
                <TextBlock Text="Archived dispatches" Style="{StaticResource H2}" Margin="0,10,0,4" />
                <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="No dispatches archived yet."
                           Visibility="{Binding HasArticles, Converter={StaticResource BoolCollapsed}}" />
                <ItemsControl ItemsSource="{Binding ArchivedArticles}"
                              Visibility="{Binding HasArticles, Converter={StaticResource BoolVisible}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1"
                                    Padding="2,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Meta}" Style="{StaticResource Faint}" FontSize="11" />
                                    <Button HorizontalContentAlignment="Left" Padding="0,3"
                                            Background="Transparent" BorderBrush="Transparent"
                                            Cursor="Hand"
                                            Command="{Binding ToggleExpandedCommand}"
                                            ToolTip="Read the full archived dispatch">
                                        <TextBlock Text="{Binding Headline}" FontSize="15" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                    </Button>
                                    <StackPanel Margin="0,4,0,2"
                                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                                        <TextBlock Text="{Binding Body}" TextWrapping="Wrap"
                                                   Style="{StaticResource Muted}" />
                                        <Border Margin="0,8,0,0" Padding="9,4" CornerRadius="3"
                                                HorizontalAlignment="Left"
                                                Background="{StaticResource AccentDimBrush}"
                                                Visibility="{Binding HasWhy, Converter={StaticResource BoolVisible}}">
                                            <TextBlock Text="{Binding WhyText}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource AccentBrush}" FontSize="12" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

        <!-- The shared "Why?" inspector overlay (career-hub-design.md §5), mirroring StandingsView.
             Shown while an inspector is open; the scrim + Close button (mouse) and the ESC key
             binding (keyboard) both dismiss it — locked decision 8's parity. -->
        <Border Background="#99000000"
                Visibility="{Binding IsInspectorOpen, Converter={StaticResource BoolVisible}, FallbackValue=Collapsed}">
            <Border.InputBindings>
                <KeyBinding Key="Esc" Command="{Binding CloseInspectorCommand}" />
            </Border.InputBindings>
            <Border MaxWidth="520" MaxHeight="440" Margin="24" Padding="18"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                    BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                    DataContext="{Binding SelectedInspector}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Content="Close" VerticalAlignment="Top"
                                Style="{StaticResource SubtleButton}"
                                Command="{Binding DataContext.CloseInspectorCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ToolTip="Close (Esc)" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Summary}" TextWrapping="Wrap"
                               Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Visibility="{Binding HasSummary, Converter={StaticResource BoolVisible}}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                        <ItemsControl ItemsSource="{Binding Rows}"
                                      ItemTemplate="{StaticResource InspectorRowTemplate}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
