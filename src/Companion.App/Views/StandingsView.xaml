<UserControl x:Class="Companion.App.Views.StandingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <UserControl.Resources>
        <!-- sortable header cell: click = sort, click again = flip -->
        <Style x:Key="HeaderButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="ToolTip" Value="Click to sort; click again to flip. Right-click for the column chooser." />
        </Style>

        <!-- the column chooser (right-click any header row) -->
        <ContextMenu x:Key="ColumnChooser">
            <MenuItem Header="Points (counted)" IsCheckable="True"
                      IsChecked="{Binding ShowCountedColumn, Mode=TwoWay}" StaysOpenOnClick="True" />
            <MenuItem Header="Gross points (before drops)" IsCheckable="True"
                      IsChecked="{Binding ShowGrossColumn, Mode=TwoWay}" StaysOpenOnClick="True" />
            <MenuItem Header="Dropped rounds" IsCheckable="True"
                      IsChecked="{Binding ShowDroppedColumn, Mode=TwoWay}" StaysOpenOnClick="True" />
            <MenuItem Header="Points per round" IsCheckable="True"
                      IsChecked="{Binding ShowPerRoundColumn, Mode=TwoWay}" StaysOpenOnClick="True" />
        </ContextMenu>

        <!-- shared header row for the drivers/constructors tables. Header + rows are the SAME
             shared-size grid (scope on each tab's DockPanel), so the columns can never drift
             apart and Auto sizing means nothing clips at 130% UI scale. -->
        <DataTemplate x:Key="TableHeader">
            <Grid Margin="4,0,4,4" Background="Transparent"
                  ContextMenu="{StaticResource ColumnChooser}"
                  ToolTip="Right-click to choose columns">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="44" SharedSizeGroup="StandingsPos" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsDropped" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsGross" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsPerRound" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsCounted" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource HeaderButton}"
                        Content="{Binding PositionHeader}"
                        Command="{Binding SortByCommand}" CommandParameter="position" />
                <Button Grid.Column="1" Style="{StaticResource HeaderButton}" HorizontalAlignment="Stretch"
                        Content="{Binding NameHeader}"
                        Command="{Binding SortByCommand}" CommandParameter="name" />
                <Button Grid.Column="2" Style="{StaticResource HeaderButton}" Margin="14,0,0,0"
                        HorizontalContentAlignment="Right"
                        Content="{Binding DroppedHeader}"
                        Command="{Binding SortByCommand}" CommandParameter="dropped"
                        Visibility="{Binding ShowDroppedColumn, Converter={StaticResource BoolVisible}}" />
                <Button Grid.Column="3" Style="{StaticResource HeaderButton}" Margin="14,0,0,0"
                        HorizontalContentAlignment="Right"
                        Content="{Binding GrossHeader}"
                        Command="{Binding SortByCommand}" CommandParameter="gross"
                        Visibility="{Binding ShowGrossColumn, Converter={StaticResource BoolVisible}}" />
                <Button Grid.Column="4" Style="{StaticResource HeaderButton}" Margin="14,0,0,0"
                        HorizontalContentAlignment="Right"
                        Content="{Binding PerRoundHeader}"
                        Command="{Binding SortByCommand}" CommandParameter="perRound"
                        Visibility="{Binding ShowPerRoundColumn, Converter={StaticResource BoolVisible}}" />
                <Button Grid.Column="5" Style="{StaticResource HeaderButton}" Margin="14,0,0,0"
                        HorizontalContentAlignment="Right"
                        Content="{Binding CountedHeader}"
                        Command="{Binding SortByCommand}" CommandParameter="counted"
                        Visibility="{Binding ShowCountedColumn, Converter={StaticResource BoolVisible}}" />
            </Grid>
        </DataTemplate>

        <!-- one drivers/constructors table row; columns mirror the header layout via the shared
             size groups above -->
        <DataTemplate x:Key="StandingsRowTemplate">
            <Grid Margin="4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="44" SharedSizeGroup="StandingsPos" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsDropped" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsGross" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsPerRound" />
                    <ColumnDefinition Width="Auto" SharedSizeGroup="StandingsCounted" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextMutedBrush}" />
                <!-- The name is a "Why?" walk-back target (decisions 4 + 5): click (or focus +
                     Enter/Space — a Button is keyboard-invokable, locked decision 8) opens the
                     shared inspector for this competitor's journal. When no session is wired
                     (CanInspect false) the command no-ops and the row reads as plain text. -->
                <Button Grid.Column="1" Style="{StaticResource SubtleButton}" HorizontalContentAlignment="Left"
                        HorizontalAlignment="Left" Padding="0" Content="{Binding DisplayName}"
                        Command="{Binding DataContext.OpenInspectorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                        CommandParameter="{Binding CompetitorId}"
                        ToolTip="Why? — walk back the journal rows behind this number" />
                <TextBlock Grid.Column="2" Margin="14,0,0,0" Text="{Binding DroppedRoundsText}"
                           TextAlignment="Right" Style="{StaticResource Faint}" VerticalAlignment="Center"
                           ToolTip="Rounds dropped by the best-N rule"
                           Visibility="{Binding DataContext.ShowDroppedColumn, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolVisible}}" />
                <TextBlock Grid.Column="3" Margin="14,0,0,0" Text="{Binding GrossText}"
                           FontFamily="{StaticResource MonoFont}" TextAlignment="Right"
                           Foreground="{DynamicResource TextMutedBrush}"
                           ToolTip="Gross points before the best-N rule dropped anything"
                           Visibility="{Binding DataContext.ShowGrossColumn, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolVisible}}" />
                <TextBlock Grid.Column="4" Margin="14,0,0,0" Text="{Binding PerRoundText}"
                           FontFamily="{StaticResource MonoFont}" TextAlignment="Right"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip="Average counted points per applied round"
                           Visibility="{Binding DataContext.ShowPerRoundColumn, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolVisible}}" />
                <TextBlock Grid.Column="5" Margin="14,0,0,0" Text="{Binding CountedText}" FontWeight="SemiBold"
                           FontFamily="{StaticResource MonoFont}" TextAlignment="Right"
                           ToolTip="Counted points (dropped results excluded)"
                           Visibility="{Binding DataContext.ShowCountedColumn, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolVisible}}" />
            </Grid>
        </DataTemplate>
        <!-- one inspector contribution row: label · detail · value -->
        <DataTemplate x:Key="InspectorRowTemplate">
            <DockPanel Margin="0,3">
                <TextBlock DockPanel.Dock="Right" Text="{Binding Value}" FontFamily="{StaticResource MonoFont}"
                           FontWeight="SemiBold" TextAlignment="Right" MinWidth="56" Margin="8,0,0,0"
                           Visibility="{Binding HasValue, Converter={StaticResource BoolVisible}}" />
                <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" FontWeight="SemiBold" MinWidth="120" />
                <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" TextWrapping="Wrap"
                           Visibility="{Binding HasDetail, Converter={StaticResource BoolVisible}}" />
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
    <DockPanel>
        <!-- first-run coach mark: the rules chip (ux-round §4) -->
        <Border DockPanel.Dock="Top" Style="{StaticResource CoachMark}" Margin="0,0,0,10"
                Visibility="{Binding DataContext.CoachMarks.ShowStandingsRulesChip,
                             RelativeSource={RelativeSource AncestorType=views:HomeView},
                             Converter={StaticResource BoolVisible}, FallbackValue=Collapsed}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource CoachMarkGlyph}" />
                <Button DockPanel.Dock="Right" Content="Got it" VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        ToolTip="Hide this tip for good (Settings → Reset brings tips back)"
                        Command="{Binding DataContext.CoachMarks.DismissStandingsRulesChipCommand,
                                  RelativeSource={RelativeSource AncestorType=views:HomeView}}" />
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"
                           Text="The grey chip below is this season's rulebook in one line — points system, dropped-round rules and scoring quirks come from the season pack, exactly as scored. Click a column header to sort; right-click a header to choose columns." />
            </DockPanel>
        </Border>

        <!-- rules-explainer chip -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Chip}" Margin="0,0,0,10">
            <TextBlock Text="{Binding RulesChipText}" Style="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <!-- no rounds yet -->
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,8,0,0"
                   Text="No rounds applied yet — standings appear after the first result."
                   Visibility="{Binding DriverRows.Count, Converter={StaticResource CountCollapsed}}" />

        <!-- The VM owns the tab set (StandingsViewModel.Tabs): each TabItem's visibility binds
             to a Show*Tab flag so no tab is ever hard-hidden in XAML. Drivers + Round matrix
             appear once a round is applied; Constructors appears only for a season with a
             constructors championship. SelectedTabIndex is guarded by the VM to never start on
             a hidden tab, so every shown tab is switchable by mouse (click) and keyboard
             (Tab/arrows — the TabItem style is keyboard-focusable, locked decision 8). -->
        <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                    Visibility="{Binding DriverRows.Count, Converter={StaticResource CountVisible}}">
            <TabItem Header="Drivers"
                     Visibility="{Binding ShowDriversTab, Converter={StaticResource BoolVisible}}">
                <!-- proportional table cap (was a hard 760): ~65% of the lens, 760–1200 -->
                <DockPanel HorizontalAlignment="Left" Grid.IsSharedSizeScope="True"
                           MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=TabControl},
                                      Converter={StaticResource WidthFraction}, ConverterParameter=0.65|760|1200}">
                    <ContentPresenter DockPanel.Dock="Top" ContentTemplate="{StaticResource TableHeader}"
                                      Content="{Binding}" />
                    <!-- virtualized (ux-round §4): shared-drive eras classify 60+ drivers -->
                    <ItemsControl Style="{StaticResource VirtualizedList}"
                                  ItemsSource="{Binding DriverRows}"
                                  ItemTemplate="{StaticResource StandingsRowTemplate}" />
                </DockPanel>
            </TabItem>

            <TabItem Header="Constructors"
                     Visibility="{Binding ShowConstructorsTab, Converter={StaticResource BoolVisible}}">
                <DockPanel HorizontalAlignment="Left" Grid.IsSharedSizeScope="True"
                           MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=TabControl},
                                      Converter={StaticResource WidthFraction}, ConverterParameter=0.65|760|1200}">
                    <ContentPresenter DockPanel.Dock="Top" ContentTemplate="{StaticResource TableHeader}"
                                      Content="{Binding}" />
                    <ItemsControl Style="{StaticResource VirtualizedList}"
                                  ItemsSource="{Binding ConstructorRows}"
                                  ItemTemplate="{StaticResource StandingsRowTemplate}" />
                </DockPanel>
            </TabItem>

            <TabItem Header="Round matrix"
                     Visibility="{Binding ShowMatrixTab, Converter={StaticResource BoolVisible}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Bottom" Style="{StaticResource Faint}" Margin="4,8,0,0"
                               Text="Struck-through cells are dropped results (best-N rule); points per round as scored." />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Focusable="False">
                        <StackPanel>
                            <!-- header row -->
                            <StackPanel Orientation="Horizontal" Margin="4,0,4,4">
                                <TextBlock Width="190" Text="Driver" Style="{StaticResource Muted}" FontWeight="SemiBold" />
                                <ItemsControl ItemsSource="{Binding RoundHeaders}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- 56 wide (was 48) so big values (25.5, 26+FL) never clip; header and
                                                 body cells stay the same fixed width so the columns can't drift -->
                                            <TextBlock Width="56" Text="{Binding}" Style="{StaticResource Muted}"
                                                       FontWeight="SemiBold" TextAlignment="Center" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <!-- driver × round cells -->
                            <ItemsControl ItemsSource="{Binding MatrixRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="4,2">
                                            <TextBlock Width="190" Text="{Binding DisplayName}" />
                                            <ItemsControl ItemsSource="{Binding Cells}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- Each cell is a per-round "Why?" target: click (or focus +
                                                             Enter/Space) walks that driver's journal narrowed to the
                                                             round. A blank cell (InspectorRef null) still renders its
                                                             number; the command no-ops on null. -->
                                                        <Button Style="{StaticResource SubtleButton}" Padding="0" Width="56"
                                                                Command="{Binding DataContext.OpenCellInspectorCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding InspectorRef}"
                                                                ToolTip="Why? — walk back this round for this driver">
                                                            <TextBlock Text="{Binding Text}" TextAlignment="Center"
                                                                       FontFamily="{StaticResource MonoFont}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDropped}" Value="True">
                                                                                <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
                                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>

        <!-- The shared "Why?" inspector overlay (career-hub-design.md §5). Shown while an
             inspector is open; the scrim + Close button (mouse) and the ESC key binding
             (keyboard) both dismiss it — locked decision 8's parity. -->
        <Border x:Name="InspectorScrim" Background="{DynamicResource ScrimBrush}"
                Visibility="{Binding IsInspectorOpen, Converter={StaticResource BoolVisible}, FallbackValue=Collapsed}">
            <Border.InputBindings>
                <KeyBinding Key="Esc" Command="{Binding CloseInspectorCommand}" />
            </Border.InputBindings>
            <!-- proportional modal (was a fixed 520x440 — cramped on 1440p): half the lens wide,
                 70% tall, never below the old size -->
            <Border Margin="24" Padding="18"
                    MaxWidth="{Binding ActualWidth, ElementName=InspectorScrim,
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.5|520}"
                    MaxHeight="{Binding ActualHeight, ElementName=InspectorScrim,
                                Converter={StaticResource WidthFraction}, ConverterParameter=0.7|440}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}" CornerRadius="6"
                    BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                    DataContext="{Binding SelectedInspector}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Button DockPanel.Dock="Right" Content="Close" VerticalAlignment="Top"
                                Style="{StaticResource SubtleButton}"
                                Command="{Binding DataContext.CloseInspectorCommand,
                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                ToolTip="Close (Esc)" />
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Summary}" TextWrapping="Wrap"
                               Style="{StaticResource Muted}" Margin="0,0,0,10"
                               Visibility="{Binding HasSummary, Converter={StaticResource BoolVisible}}" />
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
                        <ItemsControl ItemsSource="{Binding Rows}"
                                      ItemTemplate="{StaticResource InspectorRowTemplate}" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
