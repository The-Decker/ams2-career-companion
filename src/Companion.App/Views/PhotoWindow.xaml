<Window x:Class="Companion.App.Views.PhotoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Companion.App"
        Width="960" Height="680" MinWidth="320" MinHeight="240"
        WindowStartupLocation="CenterOwner" WindowStyle="None"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource BodyFont}" FontSize="{DynamicResource AppFontSize}">
    <!-- The image fills the window and scales with it (Stretch=Uniform): resize the window, the photo
         resizes with it. Whole-window UI-scale transform keeps it in step with the app's text size. -->
    <Grid Background="{StaticResource AppTextureBrush}">
        <Border Background="{StaticResource AppVignetteBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Height="34" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                        app:WindowChromeAssist.IsDragRegion="True">
                    <DockPanel Margin="10,2,3,2">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}"
                                app:WindowChromeAssist.IsCloseButton="True"
                                AutomationProperties.Name="Close circuit photo" />
                        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Style="{StaticResource Eyebrow}" FontSize="11" VerticalAlignment="Center" />
                    </DockPanel>
                </Border>
                <Grid>
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{DynamicResource AppUiScale}" ScaleY="{DynamicResource AppUiScale}" />
                    </Grid.LayoutTransform>
                    <Image x:Name="Photo" Stretch="Uniform" Margin="10" RenderOptions.BitmapScalingMode="HighQuality" />
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
