<UserControl x:Class="Companion.App.Views.SessionIntroView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             Focusable="False"
             AutomationProperties.Name="{Binding Title, StringFormat={}{0} session introduction}">
    <!-- The compact session gate: one banner, one line of context, one action. The VM owns
         progression and the artwork key; the generated plates stay text-free. -->
    <Grid x:Name="SessionIntroRoot"
          FocusManager.IsFocusScope="True"
          FocusManager.FocusedElement="{Binding ElementName=ContinueButton}"
          KeyboardNavigation.TabNavigation="Cycle">
        <Border Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource EdgeStrongBrush}"
                BorderThickness="1"
                CornerRadius="12"
                ClipToBounds="True"
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{StaticResource PanelElevationEffect}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Short text-free art band; one soft fade keeps the caption readable. -->
                <Image x:Name="SessionArtwork"
                       Stretch="UniformToFill"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       AutomationProperties.Name="Session atmosphere artwork">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Source"
                                    Value="/AMS2CareerCompanion;component/Assets/SessionIntros/qualifying.png" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ArtworkKey}" Value="race">
                                    <Setter Property="Source"
                                            Value="/AMS2CareerCompanion;component/Assets/SessionIntros/race.png" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>
                <Border Background="{StaticResource MainMenuBottomFadeBrush}" />

                <DockPanel Grid.Row="1" Margin="18,12,18,14">
                    <Border x:Name="ModeSignal"
                            DockPanel.Dock="Left"
                            Width="34" Height="34" CornerRadius="17"
                            BorderThickness="1.5" Margin="0,0,12,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ArtworkKey}" Value="race">
                                        <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock x:Name="ModeGlyph"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Q" />
                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ArtworkKey}" Value="race">
                                            <Setter Property="Text" Value="R" />
                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <Button x:Name="ContinueButton"
                            DockPanel.Dock="Right"
                            MinWidth="168" MinHeight="38"
                            Padding="16,8"
                            IsDefault="True"
                            VerticalAlignment="Center"
                            Command="{Binding ContinueCommand}"
                            audio:SoundAssist.Cue="Confirm"
                            AutomationProperties.Name="{Binding ActionLabel}"
                            AutomationProperties.HelpText="Continue to the session entry screen">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ArtworkKey}" Value="race">
                                        <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right" Text="&#x2192;"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="13" FontWeight="Bold" Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ActionLabel}"
                                       FontFamily="{StaticResource DisplayFont}"
                                       FontSize="11" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Button>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Eyebrow}"
                                   Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource OnMediaMutedBrush}" />
                        <TextBlock x:Name="SessionTitle"
                                   Text="{Binding Title}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="26" FontWeight="Black"
                                   Foreground="{DynamicResource OnMediaBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   AutomationProperties.LiveSetting="Polite" />
                        <TextBlock x:Name="SessionSubtitle"
                                   Text="{Binding Subtitle}"
                                   FontSize="12"
                                   Foreground="{DynamicResource OnMediaMutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
