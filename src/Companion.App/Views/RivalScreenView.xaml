<UserControl x:Class="Companion.App.Views.RivalScreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <!-- The SMGP rival screen — its own step after race setup, before qualifying. DataContext is a
         RivalScreenViewModel; the inner content binds to the shared BriefingViewModel (Briefing), so
         the round header / D.P. readout / pick-a-rival / dossier / "name him" all reuse the exact
         briefing state and commands (the naming rides into the race draft at Apply, unchanged). -->
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="Your rival" Style="{StaticResource H2}" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,0,0,12" TextWrapping="Wrap"
                   Text="{Binding Briefing.SmgpRivalIntro}" />

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
            <!-- the content DataContext is the shared briefing, so every Smgp* binding works verbatim -->
            <Border Style="{StaticResource Panel}" DataContext="{Binding Briefing}"
                    Padding="24" CornerRadius="14" BorderThickness="2">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="ROUND" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding SmgpRoundHeader}" Style="{StaticResource H2}"
                                       TextWrapping="Wrap" Margin="0,3,0,0" />
                            <!-- Mike's 17-season grand campaign: "SEASON n / 17" -->
                            <TextBlock Text="{Binding SmgpCampaignLine}" Style="{StaticResource Faint}"
                                       FontWeight="SemiBold" Margin="0,3,0,0"
                                       Visibility="{Binding SmgpCampaignLine, Converter={StaticResource StringVisible}}" />
                        </StackPanel>
                        <!-- the player's live readout (replaces the old "D.P."): season standing + the
                             career record they're building from zero -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding SmgpSeasonLine}" Style="{StaticResource Mono}"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontWeight="Bold" TextAlignment="Right" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SmgpCareerLine}" Style="{StaticResource Faint}"
                                       TextAlignment="Right" Margin="0,3,0,0" TextWrapping="Wrap"
                                       Visibility="{Binding SmgpCareerLine, Converter={StaticResource StringVisible}}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{Binding SmgpAdviceLine}" Style="{StaticResource Body}"
                               FontStyle="Italic" Margin="0,6,0,0" />

                    <!-- optional round card art: data/ams2/smgp/rounds/<round>.jpg -->
                    <Image MaxHeight="180" HorizontalAlignment="Left" Margin="0,12,0,0" Stretch="Uniform"
                           Source="{Binding Briefing.Round.Round, Converter={StaticResource AssetImage}, ConverterParameter=smgp/rounds}"
                           Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />

                    <TextBlock Text="{Binding SmgpRivalPrompt}" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <WrapPanel>
                        <ComboBox MinWidth="260" Margin="0,0,8,8" ItemsSource="{Binding SmgpRivals}"
                                  SelectedItem="{Binding SelectedSmgpRival}"
                                  IsEnabled="{Binding SmgpPickEnabled}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!-- the rival's ladder CLASS chip, coloured by tier (A gold … D slate),
                                             so who you can climb toward reads at a glance in the dropdown. An
                                             OUTLINED chip (colour on border + text) keeps it legible in both
                                             themes without an inline paint. -->
                                        <Border CornerRadius="4" Padding="6,1" Margin="0,0,8,0" VerticalAlignment="Center"
                                                BorderThickness="1.5"
                                                BorderBrush="{Binding TierColorHex, Converter={StaticResource HexBrush}}">
                                            <TextBlock Text="{Binding Tier, Mode=OneWay}" FontWeight="Bold" FontSize="11"
                                                       Foreground="{Binding TierColorHex, Converter={StaticResource HexBrush}}" />
                                        </Border>
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="{Binding DriverName, Mode=OneWay}" FontWeight="SemiBold" />
                                            <Run Text=" — " /><Run Text="{Binding TeamName, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="No rival" Margin="0,0,8,8" MinWidth="80"
                                Command="{Binding SmgpDeclineRivalCommand}"
                                Visibility="{Binding SmgpPickEnabled, Converter={StaticResource BoolVisible}}"
                                ToolTip="Race without naming a rival this round" />
                    </WrapPanel>

                    <!-- the rival dossier card: banner, big driver PORTRAIT + car thumbnail, MACHINE
                         block + arcade car-spec card, his line, the ladder telegraph, and the YES
                         commitment (nothing rides the result until it is pressed). -->
                    <Border Style="{StaticResource Panel}" Background="{DynamicResource SurfaceBrush}"
                            CornerRadius="14" Padding="24" Margin="0,16,0,0"
                            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
                            Visibility="{Binding SelectedSmgpRival, Converter={StaticResource NullCollapsed}}">
                        <StackPanel>
                            <Image MaxHeight="90" MaxWidth="470" HorizontalAlignment="Center" Stretch="Uniform" Margin="0,0,0,10"
                                   Source="{Binding SelectedSmgpRival.TeamId, Converter={StaticResource AssetImage}, ConverterParameter=smgp/banners}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            <StackPanel Margin="0,2,0,0">
                                <!-- DownOnly keeps the hero crisp at full size, while allowing it to
                                     shrink with the viewport at larger UI-scale settings. -->
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                                         MaxWidth="400" MaxHeight="400" HorizontalAlignment="Center"
                                         ToolTip="Drop the rival's portrait at data\ams2\portraits\&lt;driverId&gt;.jpg (beside the exe)">
                                    <Grid Width="400" Height="400">
                                        <Border CornerRadius="10" Background="{DynamicResource SurfaceAltBrush}">
                                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource IconFont}" FontSize="96"
                                                       Foreground="{DynamicResource TextMutedBrush}" Opacity="0.45"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="10" ClipToBounds="True">
                                            <Image Stretch="UniformToFill"
                                                   Source="{Binding SelectedSmgpRival.DriverId, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                        </Border>
                                    </Grid>
                                </Viewbox>
                                <Image Height="150" MaxWidth="520" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,16,0,0"
                                       Source="{Binding SelectedSmgpRival.DriverId, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}"
                                       ToolTip="Drop the rival's car photo at data\ams2\cars\&lt;driverId&gt;.png (beside the exe)" />
                            </StackPanel>
                            <TextBlock Style="{StaticResource H1}" FontSize="28" Margin="0,16,0,0"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap">
                                <Run Text="{Binding SelectedSmgpRival.DriverName, Mode=OneWay}" />
                                <Run Text=" · " /><Run Text="{Binding SelectedSmgpRival.TeamName, Mode=OneWay}" />
                            </TextBlock>
                            <TextBlock Text="MACHINE" Style="{StaticResource Eyebrow}"
                                       HorizontalAlignment="Center" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding SelectedSmgpRival.MachineLine}" Style="{StaticResource Mono}"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="16"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            <ContentControl Content="{Binding SelectedSmgpRival.CarSpec}"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                            Margin="0,14,0,0"
                                            Visibility="{Binding SelectedSmgpRival.CarSpec, Converter={StaticResource NullCollapsed}}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate>
                                        <views:CarSpecCard MaxWidth="440" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                            <!-- Trash-talk lands below as the rival's reaction after the player commits. -->
                            <TextBlock Text="{Binding SmgpLadderLine}" Foreground="{DynamicResource AccentTextBrush}"
                                       FontWeight="SemiBold" FontSize="21" TextWrapping="Wrap" Margin="0,12,0,0"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       Visibility="{Binding SmgpLadderLine, Converter={StaticResource StringVisible}}" />

                            <Button x:Name="SmgpNameRivalButton" Style="{StaticResource AccentButton}"
                                    Content="{Binding SmgpNameButtonLabel}" MinWidth="320" Margin="0,16,0,0"
                                    HorizontalAlignment="Center" FontWeight="Bold" FontSize="16"
                                    Command="{Binding SmgpNameRivalCommand}"
                                    Visibility="{Binding SmgpCanName, Converter={StaticResource BoolVisible}}"
                                    ToolTip="Commit this rival for the round — finish ahead of them twice without losing and you may take their seat" />
                            <!-- after naming: the rival reacts in their OWN voice (mood-aware trash-talk),
                                 then the commitment line spells out what beating them means. -->
                            <Border x:Name="SmgpNamedBanner" Style="{StaticResource SuccessCallout}"
                                    Padding="16,12" Margin="0,14,0,0"
                                    Visibility="{Binding SmgpRivalNamed, Converter={StaticResource BoolVisible}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding SmgpNamedRivalQuote}" Foreground="{DynamicResource AccentTextBrush}"
                                               FontStyle="Italic" FontWeight="SemiBold" FontSize="19" TextWrapping="Wrap"
                                               HorizontalAlignment="Center" TextAlignment="Center"
                                               Visibility="{Binding SmgpNamedRivalQuote, Converter={StaticResource StringVisible}}" />
                                    <TextBlock Text="{Binding SmgpNamedLine}" Foreground="{DynamicResource SuccessBrush}"
                                               FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" Margin="0,8,0,0"
                                               HorizontalAlignment="Center" TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <CheckBox Content="{Binding SmgpSwapAcceptLabel}" IsChecked="{Binding SmgpSwapAccept}"
                                      Margin="0,12,0,0" FontSize="17"
                                      Visibility="{Binding SmgpSwapPromptVisible, Converter={StaticResource BoolVisible}}"
                                      ToolTip="Beat the same rival twice without losing and you may get an offer to join their team — this is your standing answer" />
                        </StackPanel>
                    </Border>

                    <!-- Keep the primary action in the flow: selected rivals place it directly under
                         YES/the dossier, while a collapsed dossier leaves it reachable below the picker. -->
                    <Button x:Name="ContinueButton" Style="{StaticResource AccentButton}"
                            HorizontalAlignment="Center" Margin="0,18,0,4" MinWidth="240" FontSize="17"
                            Content="{Binding DataContext.ConfirmButtonText, RelativeSource={RelativeSource AncestorType=views:HomeView}, FallbackValue='Continue  ⏎'}"
                            Command="{Binding DataContext.ConfirmResultCommand, RelativeSource={RelativeSource AncestorType=views:HomeView}}"
                            ToolTip="Continue to qualifying" />
                </StackPanel>
            </Border>
        </ScrollViewer>
    </DockPanel>
</UserControl>
