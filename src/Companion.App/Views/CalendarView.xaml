<UserControl x:Class="Companion.App.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Companion.ViewModels.Services;assembly=Companion.ViewModels"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
        <StackPanel Margin="16,0,16,16">
            <TextBlock Text="Season calendar" Style="{StaticResource H2}" />
            <TextBlock Text="{Binding HeaderNote}" Style="{StaticResource Muted}" Margin="0,4,0,0" />
            <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,2,0,0"
                       Text="Every circuit you'll race this season — the actual AMS2 track, and where a stand-in or a mod alternate replaces a venue AMS2 doesn't have. No spoilers: results stay hidden until you race (see History)." />

            <!-- empty state -->
            <TextBlock Style="{StaticResource Muted}" Margin="0,16,0,0" Text="No calendar to show yet."
                       Visibility="{Binding IsEmpty, Converter={StaticResource BoolVisible}}" />

            <!-- alternate-available hint (only when a round has an alternate that wasn't enabled) -->
            <Border Background="{DynamicResource AccentDimBrush}" CornerRadius="6" Padding="10,7" Margin="0,10,0,0"
                    Visibility="{Binding HasUnusedAlternates, Converter={StaticResource BoolVisible}}">
                <TextBlock Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap"
                           Text="Some rounds offer optional community-mod alternate circuits — tick “Use alternate tracks” when you start a career to race them." />
            </Border>

            <!-- The whole season as a 4-in-a-row board: one compact card per round with its circuit
                 map, the real venue + AMS2 track, and era-capped fun facts. Fixed 4 columns (Mike). -->
            <ItemsControl ItemsSource="{Binding Rounds}" Margin="0,14,0,0"
                          Visibility="{Binding IsEmpty, Converter={StaticResource BoolCollapsed}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Command="{Binding ToggleCommand}" Style="{StaticResource SubtleButton}"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                Padding="0" Margin="0" ToolTip="Open this round's circuit almanac">
                        <Border x:Name="RoundCard" Margin="0,0,8,8" Padding="12,10" VerticalAlignment="Stretch">
                            <Border.Tag>
                                <MultiBinding Converter="{StaticResource CalendarTask3Detail}">
                                    <Binding />
                                    <Binding Path="DataContext.Home.Session"
                                             RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                                    <Binding Path="DataContext.Home.RoundText"
                                             RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                                    <Binding Path="Tag.Home.Session"
                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                    <Binding Path="Tag.Home.RoundText"
                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                </MultiBinding>
                            </Border.Tag>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource Panel}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Tag.Status, RelativeSource={RelativeSource Self}}"
                                                     Value="{x:Static services:SeasonRoundStatus.Done}">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tag.Status, RelativeSource={RelativeSource Self}}"
                                                     Value="{x:Static services:SeasonRoundStatus.Next}">
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <!-- header: round + name, with the kind badge -->
                                <DockPanel>
                                    <Border DockPanel.Dock="Right" CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                            VerticalAlignment="Top" DataContext="{Binding Tag, ElementName=RoundCard}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static services:SeasonRoundStatus.Done}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static services:SeasonRoundStatus.Next}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static services:SeasonRoundStatus.Upcoming}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="9.5" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static services:SeasonRoundStatus.Done}">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static services:SeasonRoundStatus.Next}">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <Border DockPanel.Dock="Right" CornerRadius="4" Padding="6,2" Margin="6,0,0,0" VerticalAlignment="Top">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsStandIn}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding BadgeText}" FontSize="10" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsStandIn}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text="{Binding RoundLabel}" Style="{StaticResource Faint}"
                                                   FontSize="10" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DockPanel>

                                <!-- the circuit MAP (the track image): shipped geometry, cached; scales
                                     with the card and keeps its stroke inside the box -->
                                <Viewbox Height="88" Margin="0,8,0,0" HorizontalAlignment="Center"
                                         Visibility="{Binding HasCircuit, Converter={StaticResource BoolVisible}}">
                                    <Path Data="{Binding CircuitLayoutId, Converter={StaticResource CircuitGeometry}}"
                                          Stroke="{DynamicResource AccentBrush}" StrokeThickness="10" Margin="8"
                                          StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                </Viewbox>
                                <Border Height="88" Margin="0,8,0,0" CornerRadius="6" Background="{DynamicResource SurfaceAltBrush}"
                                        Visibility="{Binding HasCircuit, Converter={StaticResource BoolCollapsed}}">
                                    <TextBlock Text="no circuit map" Style="{StaticResource Faint}" FontSize="10"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- real venue + one-line specs + the AMS2 track / stand-in -->
                                <TextBlock Text="{Binding RealVenue}" FontWeight="SemiBold" FontSize="12" Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasCircuit, Converter={StaticResource BoolVisible}}" />
                                <TextBlock Text="{Binding CircuitCaption}" Foreground="{DynamicResource AccentTextBrush}"
                                           FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding HasCircuitCaption, Converter={StaticResource BoolVisible}}" />
                                <TextBlock Text="{Binding TrackLine}" Style="{StaticResource Faint}" FontSize="11"
                                           Margin="0,4,0,0" TextWrapping="Wrap" />
                                <TextBlock Style="{StaticResource Faint}" FontSize="11" Margin="0,2,0,0"><Run Text="{Binding DateText, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding LapsText, Mode=OneWay}" /></TextBlock>
                                <TextBlock Text="{Binding UnusedAlternateNote}" Style="{StaticResource Faint}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,3,0,0"
                                           Visibility="{Binding HasUnusedAlternate, Converter={StaticResource BoolVisible}}" />

                                <!-- era-capped fun facts (spoiler-free), compact -->
                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding HasCircuitFacts, Converter={StaticResource BoolVisible}}">
                                    <Border Height="1" Background="{DynamicResource EdgeBrush}" Margin="0,0,0,6" />
                                    <ItemsControl ItemsSource="{Binding CircuitFacts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Style="{StaticResource Faint}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,2"><Run Text="•  " Foreground="{DynamicResource AccentTextBrush}" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- Full almanac is click-to-reveal; the map/caption/facts stay inline for
                                     scanability and for the established calendar render contract. -->
                                <Border Style="{StaticResource AccentCallout}" Margin="0,8,0,0" Padding="9,7"
                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                                    <StackPanel>
                                        <StackPanel DataContext="{Binding Tag, ElementName=RoundCard}">
                                            <TextBlock Text="ROUND OPERATIONS" Style="{StaticResource Eyebrow}"
                                                       Foreground="{DynamicResource AccentTextBrush}" Margin="0,0,0,5" />
                                            <WrapPanel Margin="0,0,0,5">
                                                <Border Style="{StaticResource CompactChip}" Margin="0,0,5,5"
                                                        Visibility="{Binding Championship, Converter={StaticResource BoolCollapsed}}">
                                                    <TextBlock Text="NON-CHAMPIONSHIP" Style="{StaticResource Eyebrow}"
                                                               Foreground="{DynamicResource WarningBrush}" />
                                                </Border>
                                                <Border Style="{StaticResource CompactChip}" Margin="0,0,5,5"
                                                        Visibility="{Binding GridSize, Converter={StaticResource NullCollapsed}}">
                                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10.5">
                                                        <Run Text="GRID " /><Run Text="{Binding GridSize}" FontWeight="Bold" />
                                                    </TextBlock>
                                                </Border>
                                                <Border Style="{StaticResource CompactChip}" Margin="0,0,5,5"
                                                        Visibility="{Binding Opponents, Converter={StaticResource NullCollapsed}}">
                                                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="10.5">
                                                        <Run Text="AI OPPONENTS " /><Run Text="{Binding Opponents}" FontWeight="Bold" />
                                                    </TextBlock>
                                                </Border>
                                                <Border Style="{StaticResource CompactChip}" Margin="0,0,5,5"
                                                        Visibility="{Binding WeatherLabel, Converter={StaticResource StringVisible}}">
                                                    <TextBlock Text="{Binding WeatherLabel}" FontSize="10.5" />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Text="{Binding SetupNote}" Style="{StaticResource Muted}"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"
                                                       Visibility="{Binding SetupNote, Converter={StaticResource StringVisible}}" />
                                            <StackPanel Visibility="{Binding Dnq.Count, Converter={StaticResource CountVisible}}"
                                                        Margin="0,0,0,6">
                                                <TextBlock Text="DID NOT QUALIFY" Style="{StaticResource Eyebrow}"
                                                           Foreground="{DynamicResource ErrorBrush}" Margin="0,0,0,3" />
                                                <ItemsControl ItemsSource="{Binding Dnq}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <DockPanel Margin="0,1">
                                                                <TextBlock DockPanel.Dock="Left" Width="34"
                                                                           Text="{Binding Number, TargetNullValue=—, StringFormat='#{0}'}"
                                                                           FontFamily="{StaticResource MonoFont}"
                                                                           Foreground="{DynamicResource TextMutedBrush}" />
                                                                <TextBlock DockPanel.Dock="Right" Text="{Binding TeamName}"
                                                                           Style="{StaticResource Faint}" Margin="8,0,0,0" />
                                                                <TextBlock Text="{Binding Name}" />
                                                            </DockPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Height="1" Background="{DynamicResource EdgeBrush}" Margin="0,2,0,7" />
                                        <TextBlock Text="CIRCUIT ALMANAC" Style="{StaticResource Eyebrow}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding CircuitHistory}" Style="{StaticResource Body}"
                                                   FontSize="11" TextWrapping="Wrap"
                                                   Visibility="{Binding HasCircuitHistory, Converter={StaticResource BoolVisible}}" />
                                        <TextBlock Text="No additional circuit history is filed for this round yet."
                                                   Style="{StaticResource Faint}" TextWrapping="Wrap"
                                                   Visibility="{Binding HasCircuitHistory, Converter={StaticResource BoolCollapsed}}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
