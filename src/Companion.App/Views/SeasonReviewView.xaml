<UserControl x:Class="Companion.App.Views.SeasonReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             Focusable="False">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
        <!-- proportional page cap (was a hard 1000) -->
        <StackPanel HorizontalAlignment="Left"
                    MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer},
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.75|1000|1500}">

            <!-- title + player summary -->
            <TextBlock Text="{Binding Title}" Style="{StaticResource H2}" />
            <TextBlock Style="{StaticResource Muted}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="{Binding PlayerSummaryText}" />

            <!-- offer letters: accept ONE (journaled) -->
            <Border x:Name="OfferLettersPanel" Margin="0,16,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Panel}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasOffers}" Value="True" />
                                    <Condition Binding="{Binding HasNextSeason}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Offer letters" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Faint}" Margin="0,0,0,10" TextWrapping="Wrap"
                               Text="Each seat, written up in the medium of its era. Scored from your season-long reputation and overperformance; accepting is journaled and a new acceptance replaces the previous one." />
                    <ItemsControl x:Name="OfferLetters" ItemsSource="{Binding Offers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- the offer as a period document (telegram / fax / email by era) -->
                                <Border CornerRadius="6" Margin="0,4" BorderThickness="1"
                                        BorderBrush="{Binding AccentHex, Converter={StaticResource HexBrush}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAccepted}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <DockPanel>
                                        <!-- era accent spine -->
                                        <Border DockPanel.Dock="Left" Width="4"
                                                Background="{Binding AccentHex, Converter={StaticResource HexBrush}}" />
                                        <StackPanel Margin="14,11">
                                            <!-- masthead: letterhead + medium stamp -->
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="{Binding MediumLabel}"
                                                           FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"
                                                           Foreground="{Binding AccentHex, Converter={StaticResource HexBrush}}" />
                                                <TextBlock Text="{Binding Letterhead}" FontWeight="SemiBold" FontSize="13"
                                                           FontFamily="{Binding DocumentFontStack}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Dateline}" Style="{StaticResource Faint}"
                                                       FontSize="11" FontFamily="{Binding DocumentFontStack}"
                                                       Margin="0,1,0,9" />
                                            <!-- the letter itself, in the era's voice -->
                                            <TextBlock Text="{Binding BodyText}" TextWrapping="Wrap" FontSize="13"
                                                       LineHeight="19" FontFamily="{Binding DocumentFontStack}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <!-- footer: terms + accept -->
                                            <DockPanel Margin="0,11,0,0">
                                                <Button DockPanel.Dock="Right" MinWidth="110" VerticalAlignment="Center"
                                                        Command="{Binding DataContext.AcceptOfferCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        audio:SoundAssist.Cue="Confirm"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                                            <Setter Property="Content" Value="Accept" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsAccepted}" Value="True">
                                                                    <Setter Property="Content" Value="✔ Accepted" />
                                                                    <Setter Property="IsEnabled" Value="False" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <TextBlock VerticalAlignment="Center" Style="{StaticResource Muted}" FontSize="12">
                                                    <Run Text="{Binding TierText, Mode=OneWay}" /><Run Text="   ·   " /><Run Text="{Binding SalaryText, Mode=OneWay}" />
                                                </TextBlock>
                                            </DockPanel>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,6,0,0"
                               Text="{Binding OfferError}"
                               Visibility="{Binding OfferError, Converter={StaticResource NullCollapsed}}" />
                </StackPanel>
            </Border>

            <!-- character development: spend banked points before signing (depth 4) -->
            <Border x:Name="DevelopmentPanel" Margin="0,12,0,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Panel}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding HasCharacter}" Value="True" />
                                    <Condition Binding="{Binding HasNextSeason}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="Develop your driver" FontWeight="SemiBold" DockPanel.Dock="Left" />
                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentTextBrush}">
                            <Run Text="{Binding AvailableCp, Mode=OneWay}" /><Run Text=" points to spend" />
                        </TextBlock>
                    </DockPanel>
                    <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,4,0,10"
                               Text="Spend points earned this season to raise a stat a step. Development is journaled and carries into next season when you sign." />
                    <ItemsControl ItemsSource="{Binding DevelopmentStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="12,8" Margin="0,3" Background="{DynamicResource SurfaceAltBrush}">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" MinWidth="90" VerticalAlignment="Center"
                                                Content="Raise +"
                                                Command="{Binding DataContext.RaiseStatCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                audio:SoundAssist.Cue="Confirm"
                                                CommandParameter="{Binding Id}"
                                                IsEnabled="{Binding DataContext.HasCp, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="15">
                                            <Run Text="{Binding Label, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="   " /><Run Text="{Binding ValueText, Mode=OneWay}" Foreground="{DynamicResource TextMutedBrush}" />
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- buy a NEW perk with banked points -->
                    <StackPanel Visibility="{Binding HasPurchasablePerks, Converter={StaticResource BoolVisible}}">
                        <TextBlock Text="New perks you can afford" FontWeight="SemiBold" Margin="0,14,0,4" />
                        <ItemsControl ItemsSource="{Binding DevelopmentPerks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="12,8" Margin="0,3" Background="{DynamicResource SurfaceAltBrush}">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" MinWidth="90" VerticalAlignment="Center"
                                                    Content="Buy"
                                                    Command="{Binding DataContext.BuyPerkCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                audio:SoundAssist.Cue="Confirm"
                                                    CommandParameter="{Binding Id}" />
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock FontSize="15">
                                                    <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="   " /><Run Text="{Binding CostText, Mode=OneWay}" Foreground="{DynamicResource AccentTextBrush}" />
                                                </TextBlock>
                                                <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,0" TextWrapping="Wrap"
                                                           Text="{Binding BenefitText}" />
                                                <TextBlock Style="{StaticResource Faint}" Margin="0,1,0,0" TextWrapping="Wrap"
                                                           Text="{Binding DrawbackText}"
                                                           Visibility="{Binding HasDrawback, Converter={StaticResource BoolVisible}}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- era transition: sign & continue (M6) -->
            <Border x:Name="TransitionPanel" Background="{DynamicResource AccentDimBrush}"
                    CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock x:Name="TransitionText" Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap"
                               Text="{Binding EraTransitionText}" />
                    <!-- bridge note: skipped years age through deterministically -->
                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"
                               Text="{Binding BridgeNote}"
                               Visibility="{Binding HasBridgeNote, Converter={StaticResource BoolVisible}}" />
                    <Button x:Name="SignAndContinueButton" HorizontalAlignment="Left" MinWidth="180" Margin="0,10,0,0"
                            Style="{StaticResource AccentButton}"
                            Content="{Binding SignButtonText}"
                            Command="{Binding SignAndContinueCommand}"
                            audio:SoundAssist.Cue="Confirm"
                            ToolTip="Carries your age, reputation, form and every team lineage into the next season's pack"
                            Visibility="{Binding HasNextSeason, Converter={StaticResource BoolVisible}}" />
                    <TextBlock TextWrapping="Wrap" Margin="0,6,0,0"
                               Text="Accept an offer letter above to enable signing.">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                <!-- the nudge shows only while signing is still blocked on the offer -->
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding HasNextSeason}" Value="True" />
                                            <Condition Binding="{Binding OfferAccepted}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,6,0,0"
                               Text="{Binding TransitionError}"
                               Visibility="{Binding TransitionError, Converter={StaticResource NullCollapsed}}" />
                </StackPanel>
            </Border>

            <!-- NAMeS restore (locked decision #7c) -->
            <Border Style="{StaticResource Panel}" Margin="0,12,0,0"
                    Visibility="{Binding CanRestoreAiFile, Converter={StaticResource BoolVisible}}">
                <StackPanel>
                    <TextBlock Text="Your AI file" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Put your own community NAMeS file back exactly as it was before the season, the current file is re-backed-up first, so nothing is ever lost." />
                    <Button Content="Restore my original AI file" HorizontalAlignment="Left" MinWidth="230"
                            Command="{Binding RestoreAiFileCommand}"
                            audio:SoundAssist.Cue="Warning" />
                    <Border CornerRadius="6" Padding="12,8" Margin="0,10,0,0"
                            Visibility="{Binding RestoreBanner, Converter={StaticResource NullCollapsed}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RestoreSucceeded}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding RestoreBanner}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RestoreSucceeded}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- journal digest: the season's headlines -->
            <Border Style="{StaticResource Panel}" Margin="0,12,0,0"
                    Visibility="{Binding HasHeadlines, Converter={StaticResource BoolVisible}}">
                <StackPanel>
                    <TextBlock Text="The season story" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding Headlines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,2"
                                           Text="{Binding StringFormat='– {0}'}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- final standings: reuses the standings screen via its DataTemplate -->
            <TextBlock Text="Final standings" Style="{StaticResource H2}" Margin="0,20,0,8" />
            <ContentControl Content="{Binding FinalStandings}" Focusable="False" Margin="0,0,0,24" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
