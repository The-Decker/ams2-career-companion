<UserControl x:Class="Companion.App.Views.ConfirmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <DockPanel MaxWidth="960" HorizontalAlignment="Left">

        <!-- headline (M5 news engine replaces the static template) -->
        <TextBlock DockPanel.Dock="Top" Text="{Binding Headline}" Style="{StaticResource H2}"
                   TextWrapping="Wrap" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,0,0,14"
                   Text="Review the round before it becomes history — Apply writes the result and advances the season." />

        <!-- actions -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="◀ Back to result entry" MinWidth="170" Command="{Binding BackCommand}" />
            <Button Content="Apply result" Style="{StaticResource AccentButton}" MinWidth="170"
                    Margin="12,0,0,0" Command="{Binding ApplyCommand}" />
        </StackPanel>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- points this round (StandingsEngine output) -->
            <Border Grid.Column="0" Style="{StaticResource Panel}" Margin="0,0,7,0" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Points this round" FontWeight="SemiBold" Margin="2,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                        <ItemsControl ItemsSource="{Binding RoundPoints}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="2,3">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding PointsText}"
                                                   FontWeight="SemiBold" FontFamily="Consolas" />
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- standings movement -->
            <Border Grid.Column="1" Style="{StaticResource Panel}" Margin="7,0,0,0" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Championship movement" FontWeight="SemiBold" Margin="2,0,0,8" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                        <ItemsControl ItemsSource="{Binding Movements}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="2,3">
                                        <TextBlock DockPanel.Dock="Left" Width="52" Text="{Binding Glyph}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Glyph, Converter={StaticResource GlyphBrush}}" />
                                        <TextBlock DockPanel.Dock="Right" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextMutedBrush}">
                                            <Run Text="{Binding FromText, Mode=OneWay}" /><Run Text=" → " /><Run Text="{Binding ToText, Mode=OneWay}" />
                                        </TextBlock>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource TextSecondaryBrush}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
