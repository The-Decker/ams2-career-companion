<Window x:Class="Companion.App.Views.TabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Companion.App"
        xmlns:audio="clr-namespace:Companion.App.Audio"
        Title="{Binding Title}"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        Width="560" Height="680"
        MinWidth="340" MinHeight="280"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource BodyFont}" FontSize="{DynamicResource AppFontSize}">
    <!-- A generic tear-off companion window (career-hub-design.md §2.1, "own windows"): its
         DataContext is a hub TAB view-model, and it hosts that tab's Content through the app-wide
         VM→View DataTemplates. Because the tab's Content is observable, a lens whose view-model is
         swapped in place after a round (Standings is rebuilt each Apply) updates the pop-out LIVE —
         the window binds the stable tab, not the throwaway view-model. Read-only mirror of a tab the
         player also sees in the hub, so there is no state or parity cost. The root UI-scale transform
         keeps this pop-out in step with the main window's text size. -->
    <Grid Background="{StaticResource AppTextureBrush}">
        <Border Background="{StaticResource AppVignetteBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
            <!-- Content is declared before the overlaid title bar so the existing harness still
                 finds the hosted lens as the first ContentControl in the visual tree. -->
            <Grid>
                <Grid Margin="0,34,0,0">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{DynamicResource AppUiScale}" ScaleY="{DynamicResource AppUiScale}" />
                    </Grid.LayoutTransform>
                    <ContentControl Content="{Binding Content}" Focusable="False" />
                </Grid>
                <Border Height="34" VerticalAlignment="Top" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                        app:WindowChromeAssist.IsDragRegion="True">
                    <DockPanel Margin="10,2,3,2">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}"
                                audio:SoundAssist.Cue="Back"
                                app:WindowChromeAssist.IsCloseButton="True"
                                AutomationProperties.Name="Close tear-off window" />
                        <TextBlock Text="{Binding Title}" Style="{StaticResource Eyebrow}" FontSize="11"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
