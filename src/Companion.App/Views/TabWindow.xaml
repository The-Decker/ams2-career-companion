<Window x:Class="Companion.App.Views.TabWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        Width="560" Height="680"
        MinWidth="340" MinHeight="280"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource AeromoveFont}" FontSize="{DynamicResource AppFontSize}">
    <!-- A generic tear-off companion window (career-hub-design.md §2.1, "own windows"): its
         DataContext is a hub TAB view-model, and it hosts that tab's Content through the app-wide
         VM→View DataTemplates. Because the tab's Content is observable, a lens whose view-model is
         swapped in place after a round (Standings is rebuilt each Apply) updates the pop-out LIVE —
         the window binds the stable tab, not the throwaway view-model. Read-only mirror of a tab the
         player also sees in the hub, so there is no state or parity cost. The root UI-scale transform
         keeps this pop-out in step with the main window's text size. -->
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppUiScale}" ScaleY="{DynamicResource AppUiScale}" />
        </Grid.LayoutTransform>
        <ContentControl Content="{Binding Content}" Focusable="False" />
    </Grid>
</Window>
