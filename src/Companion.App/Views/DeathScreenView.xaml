<UserControl x:Class="Companion.App.Views.DeathScreenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- DB-free terminal surface. Its DataContext is HomeViewModel, but every content binding below
         intentionally stays on DeathScreen or CareerOver. In particular: never bind Summary/Session. -->
    <DockPanel Background="{DynamicResource BgBrush}">
        <Border DockPanel.Dock="Bottom" Padding="24,14,24,20"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <Button DockPanel.Dock="Right" Content="Return to main menu"
                        Style="{StaticResource SubtleButton}" MinWidth="180" Padding="14,9"
                        Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        AutomationProperties.Name="Return to main menu" />
                <TextBlock Text="THE PADDOCK REMEMBERS" Style="{StaticResource Eyebrow}"
                           Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Focusable="False">
            <StackPanel MaxWidth="1040" Margin="32,28,32,38" HorizontalAlignment="Center">
                <!-- terminal state ribbon -->
                <Border x:Name="PermadeathRibbon" Padding="16,7" CornerRadius="5"
                        Background="{DynamicResource ErrorBrush}" HorizontalAlignment="Center"
                        Visibility="{Binding DeathScreen.IsPermadeath, Converter={StaticResource BoolVisible}}">
                    <TextBlock Text="H A R D C O R E   :   P E R M A D E A T H"
                               Style="{StaticResource PixelBadge}" FontSize="9"
                               Foreground="{DynamicResource OnAccentBrush}" />
                </Border>
                <Border Padding="16,7" CornerRadius="5"
                        Background="{DynamicResource ErrorDimBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                        HorizontalAlignment="Center"
                        Visibility="{Binding DeathScreen.IsPermadeath, Converter={StaticResource BoolCollapsed}}">
                    <TextBlock Text="C A R E E R   O V E R" Style="{StaticResource PixelBadge}"
                               FontSize="9" Foreground="{DynamicResource ErrorBrush}" />
                </Border>

                <TextBlock Text="IN MEMORIAM" FontFamily="{StaticResource DisplayFont}"
                           FontSize="15" FontWeight="Bold"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center" Margin="0,18,0,0" />
                <TextBlock x:Name="DeathDriverName" Text="{Binding DeathScreen.DriverName}"
                           FontFamily="{StaticResource DisplayFont}" FontSize="40" FontWeight="Bold"
                           TextAlignment="Center" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />

                <WrapPanel HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,7"
                            Visibility="{Binding DeathScreen.Age, Converter={StaticResource NullCollapsed}}">
                        <TextBlock Style="{StaticResource Mono}">
                            <Run Text="AGE  " /><Run Text="{Binding DeathScreen.Age, Mode=OneWay}" FontWeight="Bold" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,7"
                            Visibility="{Binding DeathScreen.Venue, Converter={StaticResource StringVisible}}">
                        <TextBlock Style="{StaticResource Mono}">
                            <Run Text="VENUE  " /><Run Text="{Binding DeathScreen.Venue, Mode=OneWay}" FontWeight="Bold" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource CompactChip}" Margin="0,0,7,7"
                            Visibility="{Binding DeathScreen.Round, Converter={StaticResource NullCollapsed}}">
                        <TextBlock Style="{StaticResource Mono}">
                            <Run Text="ROUND  " /><Run Text="{Binding DeathScreen.Round, Mode=OneWay}" FontWeight="Bold" />
                        </TextBlock>
                    </Border>
                    <Border Style="{StaticResource CompactChip}" Margin="0,0,0,7"
                            Visibility="{Binding DeathScreen.Severity, Converter={StaticResource NullCollapsed}}">
                        <TextBlock Style="{StaticResource Mono}">
                            <Run Text="SEVERITY  " /><Run Text="{Binding DeathScreen.Severity, Mode=OneWay}" FontWeight="Bold" />
                        </TextBlock>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource ErrorCallout}" Margin="0,14,0,0" Padding="20,13">
                    <TextBlock x:Name="CauseOfDeath" Text="{Binding DeathScreen.CauseOfDeath}"
                               FontFamily="{StaticResource DisplayFont}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ErrorBrush}"
                               TextAlignment="Center" TextWrapping="Wrap" />
                </Border>

                <Border Style="{StaticResource QuoteCard}" Margin="0,14,0,0" Padding="22,18">
                    <TextBlock x:Name="Obituary" Text="{Binding DeathScreen.Obituary}"
                               Style="{StaticResource Body}" FontSize="16" FontStyle="Italic"
                               LineHeight="25" TextAlignment="Center" />
                </Border>

                <!-- DB-free career record captured before a Hardcore file is erased -->
                <TextBlock Text="CAREER RECORD" Style="{StaticResource H2}"
                           HorizontalAlignment="Center" Margin="0,28,0,12" />
                <UniformGrid Columns="4" Rows="2">
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="BEST FINISH" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.BestFinish, StringFormat=P{0}, TargetNullValue=-}"
                                       Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="WINS" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.Wins}" Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="PODIUMS" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.Podiums}" Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="POINTS" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.TotalPoints, StringFormat={}{0:0.#}}"
                                       Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="TITLES" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.Championships}" Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="SEASONS" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.SeasonsRaced}" Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="WIN STREAK" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.LongestWinStreak}" Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource StatTile}">
                        <StackPanel>
                            <TextBlock Text="PODIUM STREAK" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding DeathScreen.Record.LongestPodiumStreak}" Style="{StaticResource StatValue}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- compact season almanac; all values are part of DeathScreen's captured model -->
                <TextBlock Text="SEASONS RACED" Style="{StaticResource H2}"
                           HorizontalAlignment="Center" Margin="0,24,0,12"
                           Visibility="{Binding DeathScreen.Seasons.Count, Converter={StaticResource CountVisible}}" />
                <ItemsControl x:Name="DeathSeasonRecap" ItemsSource="{Binding DeathScreen.Seasons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Width="238" Margin="0,0,10,10">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Style="{StaticResource Mono}"
                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                   FontWeight="Bold"
                                                   Text="{Binding PlayerPosition, StringFormat=P{0}, TargetNullValue=-}" />
                                        <TextBlock Text="{Binding SeasonYear}" Style="{StaticResource H2}" />
                                    </DockPanel>
                                    <TextBlock Style="{StaticResource Muted}" Margin="0,5,0,0">
                                        <Run Text="Rounds  " /><Run Text="{Binding RoundsApplied, Mode=OneWay}" FontWeight="Bold" />
                                        <Run Text=" / " /><Run Text="{Binding RoundCount, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding ChampionName, StringFormat=Champion: {0}}"
                                               Style="{StaticResource Faint}" Margin="0,5,0,0"
                                               Visibility="{Binding ChampionName, Converter={StaticResource StringVisible}}" />
                                    <Border Style="{StaticResource AccentCallout}" Padding="7,4" Margin="0,8,0,0"
                                            Visibility="{Binding PlayerIsChampion, Converter={StaticResource BoolVisible}}">
                                        <TextBlock Text="WORLD CHAMPION" Style="{StaticResource PixelBadge}"
                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Normal death: saves survive and may reverse the fatal fold. The view raises a
                     typed event; the owning Hub performs restore + shell reopen. -->
                <Border x:Name="NormalDeathPanel" Style="{StaticResource Panel}" Margin="0,24,0,0"
                        BorderBrush="{DynamicResource WarningBrush}"
                        Visibility="{Binding DeathScreen.IsPermadeath, Converter={StaticResource BoolCollapsed}}">
                    <StackPanel>
                        <TextBlock Text="THE LAST CHANCE" Style="{StaticResource H2}"
                                   Foreground="{DynamicResource WarningBrush}" />
                        <TextBlock Text="Normal mortality preserves your snapshots. Restoring replaces the whole career with that earlier save, then reopens it from disk."
                                   Style="{StaticResource Body}" Margin="0,5,0,0" />

                        <ItemsControl x:Name="RestoreSlotsList" ItemsSource="{Binding DeathScreen.RestoreSlots}"
                                      Margin="0,14,0,0"
                                      Visibility="{Binding DeathScreen.CanRestore, Converter={StaticResource BoolVisible}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Callout}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <TextBlock Text="{Binding Label}" FontWeight="Bold" />
                                                    <Border Style="{StaticResource CompactChip}" Margin="8,0,0,0"
                                                            Visibility="{Binding IsAutosave, Converter={StaticResource BoolVisible}}">
                                                        <TextBlock Text="AUTOSAVE" Style="{StaticResource PixelBadge}"
                                                                   Foreground="{DynamicResource AccentTextBrush}" />
                                                    </Border>
                                                </DockPanel>
                                                <TextBlock Style="{StaticResource Faint}" Margin="0,4,0,0">
                                                    <Run Text="Season " /><Run Text="{Binding SeasonYear, Mode=OneWay}" />
                                                    <Run Text="  ·  Round " /><Run Text="{Binding Round, Mode=OneWay}" />
                                                    <Run Text="  ·  " /><Run Text="{Binding CreatedUtc, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Restore this save"
                                                    Style="{StaticResource AccentButton}" Margin="14,0,0,0"
                                                    Padding="14,8" Click="OnRestoreRequestedClicked"
                                                    AutomationProperties.Name="Restore this career save" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource WarningCallout}" Margin="0,14,0,0"
                                Visibility="{Binding DeathScreen.CanRestore, Converter={StaticResource BoolCollapsed}}">
                            <TextBlock Text="No restorable save exists. This career is over, but the file remains in your career archive."
                                       Style="{StaticResource Body}" />
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Hardcore: explicit terminal language; never offers or even instantiates a
                     restore-slot item. CareerOver is used only for its DB-free deletion flag. -->
                <Border x:Name="PermadeathPanel" Style="{StaticResource ErrorCallout}"
                        Margin="0,24,0,0" Padding="22,18"
                        Visibility="{Binding DeathScreen.IsPermadeath, Converter={StaticResource BoolVisible}}">
                    <StackPanel>
                        <TextBlock Text="PERMADEATH IS FINAL" Style="{StaticResource H2}"
                                   Foreground="{DynamicResource ErrorBrush}" />
                        <TextBlock Text="Hardcore mortality has no rollback. This driver's story ends here, exactly as chosen when the career began."
                                   Style="{StaticResource Body}" FontSize="15" Margin="0,6,0,0" />
                        <Border Background="{DynamicResource ErrorBrush}" CornerRadius="4"
                                Padding="10,6" Margin="0,14,0,0" HorizontalAlignment="Left"
                                Visibility="{Binding CareerOver.CareerFileDeleted, Converter={StaticResource BoolVisible}}">
                            <TextBlock Text="CAREER FILE AND SAVES ERASED" Style="{StaticResource PixelBadge}"
                                       Foreground="{DynamicResource OnAccentBrush}" />
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
