<UserControl x:Class="Companion.App.Views.BriefingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <ScrollViewer x:Name="BriefingScroll" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
        <!-- proportional page cap (was a hard 860): ~94% of the viewport, never under 860 where
             there is room, fills a 2560 window in two columns yet still hugs a small one -->
        <StackPanel HorizontalAlignment="Left"
                    MaxWidth="{Binding ActualWidth, ElementName=BriefingScroll,
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.94|860}">

            <!-- title (placeholder rounds carry the "— placeholder: <track>" label) -->
            <TextBlock Text="{Binding Title}" Style="{StaticResource H2}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Style="{StaticResource Muted}" Text="{Binding VenueDisplayName, StringFormat='Venue: {0}'}" />
                <Border Style="{StaticResource Chip}" Background="{DynamicResource WarningDimBrush}" Margin="10,0,0,0"
                        Visibility="{Binding IsPlaceholder, Converter={StaticResource BoolVisible}}">
                    <TextBlock Text="placeholder round" Foreground="{DynamicResource WarningBrush}" FontSize="12" />
                </Border>
            </StackPanel>

            <Border Style="{StaticResource AccentCallout}" Margin="0,12,0,0" Padding="14,10"
                    Visibility="{Binding HasSmgpSeasonLore, Converter={StaticResource BoolVisible}}">
                <DockPanel>
                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="12,0,0,0"
                            Background="{DynamicResource AccentDimBrush}"
                            BorderBrush="{DynamicResource AccentBrush}">
                        <TextBlock Text="{Binding SmgpSeasonEra}" Style="{StaticResource PixelBadge}"
                                   Foreground="{DynamicResource AccentTextBrush}" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding SmgpCampaignLine}" Style="{StaticResource Eyebrow}"
                                   Foreground="{DynamicResource AccentTextBrush}" />
                        <TextBlock Text="{Binding SmgpSeasonTitle}" FontFamily="{StaticResource DisplayFont}"
                                   FontSize="19" FontWeight="Bold" Margin="0,3,0,0" />
                        <TextBlock Text="{Binding SmgpSeasonSubtitle}" Style="{StaticResource Muted}"
                                   TextWrapping="Wrap" Margin="0,3,0,0"
                                   Visibility="{Binding SmgpSeasonSubtitle, Converter={StaticResource StringVisible}}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Optional track-layout thumbnail: drop <trackId>.jpg/.png into data\ams2\track-art
                 (the shared user-asset convention, keyed by the round's AMS2 track id). Collapses
                 entirely when no image is present, so the briefing is unchanged without art. The
                 x:Name lets the converter re-read when the round changes. -->
            <Border x:Name="TrackArt" Margin="0,12,0,0" CornerRadius="7" HorizontalAlignment="Left"
                    MaxWidth="{Binding ActualWidth, ElementName=BriefingScroll,
                               Converter={StaticResource WidthFraction}, ConverterParameter=0.6|420}"
                    BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                    Visibility="{Binding ElementName=TrackArtImage, Path=Source, Converter={StaticResource NullCollapsed}}">
                <Border CornerRadius="6" ClipToBounds="True">
                    <Image x:Name="TrackArtImage" Stretch="Uniform" StretchDirection="DownOnly"
                           Source="{Binding TrackId, Converter={StaticResource TrackImage}}"
                           ToolTip="{Binding VenueDisplayName, StringFormat='{}{0}, track layout'}" />
                </Border>
            </Border>

            <!-- season-complete state (Home normally swaps away before this shows) -->
            <TextBlock Style="{StaticResource Muted}" Margin="0,16,0,0"
                       Text="Season complete, there is no round left to brief."
                       Visibility="{Binding SeasonComplete, Converter={StaticResource BoolVisible}}" />

            <!-- two-column race-day layout: checklist + staging (3*) | circuit + advisories (2*).
                 The left column's floor is PROPORTIONAL (55% of the viewport, capped at 520): a
                 fixed 520 floor would shove the whole right column, including the Setup Gamble
                 buttons, outside the non-scrolling viewport at 130% UI scale near the 920px
                 window minimum. -->
            <Grid Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"
                                      MinWidth="{Binding ActualWidth, ElementName=BriefingScroll,
                                                 Converter={StaticResource WidthFraction}, ConverterParameter=0.55|0|520}" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- ===== LEFT: the work column, checklist, staging, outcomes ===== -->
                <StackPanel Grid.Column="0">

                    <!-- first-run coach mark: the briefing checklist (ux-round §4; binds through
                         Home so the compact window, no HomeView ancestor, falls back to hidden) -->
                    <Border Style="{StaticResource CoachMark}" Margin="0,16,0,0"
                            Visibility="{Binding DataContext.CoachMarks.ShowBriefingChecklist,
                                         RelativeSource={RelativeSource AncestorType=views:HomeView},
                                         Converter={StaticResource BoolVisible}, FallbackValue=Collapsed}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource CoachMarkGlyph}" />
                            <Button DockPanel.Dock="Right" Content="Got it" VerticalAlignment="Center"
                                    Margin="12,0,0,0"
                                    ToolTip="Hide this tip for good (Settings → Reset brings tips back)"
                                    Command="{Binding DataContext.CoachMarks.DismissBriefingChecklistCommand,
                                              RelativeSource={RelativeSource AncestorType=views:HomeView}}" />
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Text="New here? This checklist mirrors AMS2's custom-race screen top to bottom. The game can't paste values, so set each line in-game and click the row here to tick it off, the Compact overlay button keeps the list on top of AMS2 while you do." />
                        </DockPanel>
                    </Border>

                    <!-- the manual setup CHECKLIST (ux-round correction: AMS2's custom-race settings
                         are arrow-steppers, nothing can be pasted, tick each row as you set it) -->
                    <Border Style="{StaticResource Panel}" Margin="0,16,0,0"
                            Visibility="{Binding SeasonComplete, Converter={StaticResource BoolCollapsed}}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <Border DockPanel.Dock="Right" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource Chip}">
                                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AllSet}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding ChecklistProgressText}" FontWeight="SemiBold" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AllSet}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="In-game race setup, set each line, tick it off" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource Faint}" Margin="0,2,0,0" TextWrapping="Wrap"
                                               Text="Rows follow AMS2's custom-race screen top to bottom (the values can't be pasted, the game uses arrow-steppers). Click a row to tick it." />
                                </StackPanel>
                            </DockPanel>

                            <!-- sectioned checklist: outer = Race-Day sections (Event / Practice /
                                 Qualifying / Race / Rules), inner = the tickable rows. Grouping is done in
                                 the viewmodel (Sections), so this is a plain nested ItemsControl with no
                                 grouping CollectionViewSource. (Render-test thread-safety comes from the
                                 harness's DisableTestParallelization, not from this structure.)
                                 Label column is shared-size Auto so long labels never clip at 130% scale. -->
                            <ItemsControl ItemsSource="{Binding Sections}" Grid.IsSharedSizeScope="True">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- section header; collapses for an ungrouped (empty-title) section -->
                                            <TextBlock Text="{Binding Title}" Style="{StaticResource Faint}"
                                                       FontSize="11" FontWeight="SemiBold" Margin="0,8,0,1"
                                                       ToolTip="AMS2 custom-race screen section"
                                                       Visibility="{Binding Title, Converter={StaticResource StringVisible}}" />
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <!-- the whole row is the toggle hit-target -->
                                                        <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0"
                                                                  HorizontalContentAlignment="Stretch"
                                                                  ToolTip="Click to tick this setting off (ticks reset each round)">
                                                            <Grid Margin="8,1,0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" MinWidth="130" SharedSizeGroup="ChecklistLabel" />
                                                                    <ColumnDefinition Width="*" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Label}" Margin="0,0,12,0"
                                                                           Style="{StaticResource Muted}" VerticalAlignment="Center" />
                                                                <!-- big glanceable value; read-only TextBox keeps it selectable -->
                                                                <TextBox Grid.Column="1" Text="{Binding Value, Mode=OneWay}"
                                                                         IsReadOnly="True" IsTabStop="False"
                                                                         BorderThickness="0" Background="Transparent" Padding="0"
                                                                         FontFamily="{StaticResource MonoFont}" FontSize="15" FontWeight="SemiBold"
                                                                         VerticalAlignment="Center" TextWrapping="Wrap"
                                                                         ToolTip="Selectable, but AMS2 can't paste it; use the tick instead">
                                                                    <TextBox.Style>
                                                                        <Style TargetType="TextBox">
                                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBox.Style>
                                                                </TextBox>
                                                            </Grid>
                                                        </CheckBox>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <WrapPanel Margin="0,12,0,0">
                                <Button Content="Copy summary" Margin="0,0,10,8"
                                        Command="{Binding CopySummaryCommand}"
                                        ToolTip="Copies the whole checklist as text, for sharing outside the game (AMS2 itself can't paste)" />
                                <Button Margin="0,0,10,8" Command="{Binding ToggleCompactChecklistCommand}"
                                        ToolTip="A small always-on-top checklist window to keep over AMS2 in windowed/borderless mode">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Content" Value="Compact overlay" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompactChecklistOpen}" Value="True">
                                                    <Setter Property="Content" Value="Close overlay" />
                                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- staging (confirmation popovers per the ux-round contract) -->
                    <WrapPanel Margin="0,18,0,0"
                               Visibility="{Binding SeasonComplete, Converter={StaticResource BoolCollapsed}}">
                        <Button x:Name="StageButton" Content="Set up this race in AMS2" Style="{StaticResource AccentButton}"
                                audio:SoundAssist.Cue="Navigate"
                                MinWidth="200" Margin="0,0,10,8" Click="OnStageClick"
                                ToolTip="Writes this round's drivers and skins into AMS2 (backup-first) so the grid matches your career" />
                        <Button x:Name="ForceStageButton" Content="Overwrite anyway (backup first)" Margin="0,0,10,8"
                                audio:SoundAssist.Cue="Warning"
                                Click="OnForceStageClick"
                                ToolTip="Your installed AI is a community file, this overwrites it; a timestamped backup is still taken first">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding CanForceStage}" Value="True" />
                                                <Condition Binding="{Binding StageSucceeded}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <MultiDataTrigger.Setters>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger.Setters>
                                        </MultiDataTrigger>
                                        <!-- last trigger wins: never show before a staging attempt -->
                                        <DataTrigger Binding="{Binding LastStageOutcome}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- the loop-walker: set the race up in AMS2, race it, then Continue through
                             qualifying → grid → result → confirm (the Upcoming Race tab's own advance,
                             now that the header loop buttons are gone, reserved for the tycoon mode).
                             Binds up to the hosting HomeView; absent there (e.g. the render harness) it
                             simply disables. -->
                        <Button Content="Continue  ⏎" Style="{StaticResource AccentButton}"
                                audio:SoundAssist.Cue="Confirm"
                                MinWidth="150" Margin="0,0,10,8"
                                Command="{Binding DataContext.EnterResultCommand,
                                          RelativeSource={RelativeSource AncestorType=views:HomeView}}"
                                ToolTip="Continue the race weekend, qualifying, then the result" />
                    </WrapPanel>

                    <!-- stage confirmation popover -->
                    <Popup x:Name="StageConfirmPopup" StaysOpen="False" AllowsTransparency="True"
                           PlacementTarget="{Binding ElementName=StageButton}" Placement="Bottom">
                        <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource EdgeBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12" MaxWidth="420">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}"
                                           Text="This writes the round's generated AI grid into your AMS2 install. Any existing file is backed up first with a timestamp, and if your installed file already matches, nothing is written at all." />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Stage grid" Style="{StaticResource AccentButton}" Click="OnStageConfirm"
                                            audio:SoundAssist.Cue="Confirm" />
                                    <Button Content="Cancel" Margin="8,0,0,0" Click="OnStagePopupCancel"
                                            audio:SoundAssist.Cue="Back" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- force-stage confirmation popover: the NAMeS marker rule in plain words -->
                    <Popup x:Name="ForceConfirmPopup" StaysOpen="False" AllowsTransparency="True"
                           PlacementTarget="{Binding ElementName=ForceStageButton}" Placement="Bottom">
                        <Border Background="{DynamicResource SurfaceAltBrush}" BorderBrush="{DynamicResource WarningBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,12" MaxWidth="440">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}"
                                           Text="The app normally only overwrites AI files it wrote itself, it recognizes its own files by a marker it puts inside them. This file has no marker, so it is YOURS (hand-edited, or a community file like NAMeS) and normal staging refuses to touch it." />
                                <TextBlock TextWrapping="Wrap" Style="{StaticResource Body}" Margin="0,8,0,0"
                                           Text="Overwrite anyway takes a timestamped backup first, and season end offers one-click restore of the original." />
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Overwrite anyway (backup first)" Click="OnForceStageConfirm"
                                            audio:SoundAssist.Cue="Destructive">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Cancel" Margin="8,0,0,0" Click="OnStagePopupCancel"
                                            audio:SoundAssist.Cue="Back" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- staging outcome banner: green = staged/no-op, amber = the expected
                         community-file force gate (a choice, not a failure), red = real failure -->
                    <Border CornerRadius="6" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding LastStageOutcome, Converter={StaticResource NullCollapsed}}">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Callout}">
                                <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding BannerTone}" Value="Success">
                                        <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding BannerTone}" Value="Info">
                                        <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StageBanner}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BannerTone}" Value="Success">
                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding BannerTone}" Value="Info">
                                            <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>

                    <!-- ⚠ staged file changed outside the app -->
                    <Border Style="{StaticResource WarningCallout}" Margin="0,8,0,0"
                            Visibility="{Binding StagedFileTouchedExternally, Converter={StaticResource BoolVisible}}">
                        <TextBlock Foreground="{DynamicResource WarningBrush}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="⚠ The staged file was modified outside the app, re-stage before racing." />
                    </Border>

                    <!-- preflight / staging summary messages (the livery scan is ONE line here) -->
                    <ItemsControl ItemsSource="{Binding StageMessages}" Margin="0,8,0,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- per-file livery-scan details (unreadable files): collapsed by default -->
                    <StackPanel Margin="0,0,0,24"
                                Visibility="{Binding HasStageDetails, Converter={StaticResource BoolVisible}}">
                        <Button HorizontalAlignment="Left" Command="{Binding ToggleStageDetailsCommand}"
                                ToolTip="The files the livery scan could not read, one line each">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource SubtleButton}">
                                    <Setter Property="Content" Value="Show details ▸" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StageDetailsExpanded}" Value="True">
                                            <Setter Property="Content" Value="Hide details ▾" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <ItemsControl ItemsSource="{Binding StageDetails}" Margin="12,4,0,0"
                                      Visibility="{Binding StageDetailsExpanded, Converter={StaticResource BoolVisible}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>

                <!-- ===== RIGHT: reference + advisories, circuit, difficulty, fuel, gamble, notes ===== -->
                <StackPanel Grid.Column="2">

                    <!-- Circuit map: the f1db-derived vector layout of the circuit this round is run on,
                         with a one-line caption (name · length · turns · direction). Collapses when the
                         round has no circuit data. Always shows (no user art needed), the "very
                         important visual per race". Map scales with the column (140–280 square). -->
                    <Border x:Name="CircuitPanel" Style="{StaticResource Panel}" Margin="0,16,0,0"
                            Visibility="{Binding CircuitLayoutId, Converter={StaticResource StringVisible}}">
                        <StackPanel>
                            <TextBlock Text="CIRCUIT" Style="{StaticResource Faint}" FontSize="11" />
                            <Viewbox HorizontalAlignment="Center" Margin="0,10,0,0"
                                     Width="{Binding ActualWidth, ElementName=CircuitPanel,
                                             Converter={StaticResource WidthFraction}, ConverterParameter=0.55|140|280}"
                                     Height="{Binding ActualWidth, RelativeSource={RelativeSource Self},
                                              Converter={StaticResource AspectHeight}, ConverterParameter=1}">
                                <Path Data="{Binding CircuitLayoutId, Converter={StaticResource CircuitGeometry}}"
                                      Stroke="{DynamicResource AccentBrush}" StrokeThickness="10"
                                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                            </Viewbox>
                            <TextBlock Text="{Binding VenueDisplayName}" FontWeight="SemiBold" FontSize="18"
                                       TextWrapping="Wrap" Margin="0,10,0,0" />
                            <TextBlock Text="{Binding CircuitCaption}" Foreground="{DynamicResource AccentTextBrush}"
                                       TextWrapping="Wrap" Margin="0,5,0,0" />
                            <TextBlock Text="{Binding CircuitHistory}" Style="{StaticResource Body}"
                                       TextWrapping="Wrap" Margin="0,10,0,0"
                                       Visibility="{Binding CircuitHistory, Converter={StaticResource StringVisible}}" />

                            <!-- era-capped fun facts (same reference data as the Calendar expander) -->
                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding HasCircuitFacts, Converter={StaticResource BoolVisible}}">
                                <TextBlock Text="FUN FACTS" Style="{StaticResource Faint}" FontSize="11" Margin="0,0,0,4" />
                                <ItemsControl ItemsSource="{Binding CircuitFacts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,0,0,2"><Run Text="•  " /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- difficulty recommendation from the folded pace anchor (never auto-applied) -->
                    <Border Style="{StaticResource AccentCallout}" Margin="0,12,0,0"
                            Visibility="{Binding DifficultyRecommendation, Converter={StaticResource NullCollapsed}}">
                        <TextBlock Foreground="{DynamicResource AccentTextBrush}" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="{Binding DifficultyRecommendation}" />
                    </Border>

                    <!-- fuel advisory: one-tank range vs race length + the AMS2 "set your own fuel" gotcha
                         (not a tick row). Collapses when no per-class fuel profile applies. -->
                    <Border Style="{StaticResource Panel}" Margin="0,12,0,0"
                            Visibility="{Binding FuelNote, Converter={StaticResource NullCollapsed}}">
                        <StackPanel>
                            <TextBlock Text="Fuel" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding FuelNote}" Style="{StaticResource Body}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Optional reputation bet: unlocked only after one completed race has calibrated
                         player pace, and shown only when the team benchmark leaves room for a harder call.
                         (BoolVisible: true => Visible, BoolCollapsed is the INVERSE converter and had
                         this panel backwards since 4b shipped; the render test now pins visibility.) -->
                    <Border x:Name="GamblePanel" Style="{StaticResource Panel}" Margin="0,12,0,0"
                            Visibility="{Binding CanGamble, Converter={StaticResource BoolVisible}}">
                        <StackPanel>
                            <TextBlock Text="Optional reputation bet" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding CalledShotSummary}" Style="{StaticResource Body}" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="Harder target ◂" Command="{Binding CallBolderCommand}" MinWidth="120" Margin="0,0,8,8"
                                        ToolTip="Choose a better finishing target and risk more reputation" />
                                <Button Content="▸ Easier target" Command="{Binding CallSaferCommand}" Margin="0,0,8,8" MinWidth="120"
                                        ToolTip="Ease the target by one finishing position" />
                                <Button x:Name="GambleNoBetButton" Content="Clear bet" Command="{Binding ClearCallCommand}"
                                        Margin="0,0,8,8" MinWidth="80"
                                        Visibility="{Binding HasCalledShot, Converter={StaticResource BoolVisible}}"
                                        ToolTip="Withdraw the gamble for this round" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- The SMGP rival panel (round header / D.P. / pick-a-rival / dossier / "name him")
                         now lives on its OWN step in the Upcoming Race flow (RivalScreenView), shown
                         after this race-setup briefing and before qualifying. -->

                    <!-- setup notes (placeholder distance note etc.) -->
                    <Border Style="{StaticResource Panel}" Margin="0,12,0,0"
                            Visibility="{Binding SetupNotes, Converter={StaticResource NullCollapsed}}">
                        <StackPanel>
                            <TextBlock Text="Notes" FontWeight="SemiBold" Margin="0,0,0,6" />
                            <TextBlock Text="{Binding SetupNotes}" Style="{StaticResource Body}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
