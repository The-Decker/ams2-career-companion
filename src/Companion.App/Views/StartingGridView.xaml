<UserControl x:Class="Companion.App.Views.StartingGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <!-- The starting grid, shown after qualifying and before the race: the grid pole-first as
         driver + car cards, two wide and scrolling down. Display-only. -->
    <DockPanel>
        <TextBlock DockPanel.Dock="Top" Text="{Binding Title}" Style="{StaticResource H2}" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Style="{StaticResource Muted}" Margin="0,0,0,14"
                   Text="Your grid for the race — pole first. Start the race when you're ready." />
        <!-- primary action ("Start the race"); binds up to the hosting HomeView like the result entry -->
        <Button DockPanel.Dock="Bottom" Style="{StaticResource AccentButton}" HorizontalAlignment="Right"
                Margin="0,14,0,0" MinWidth="160"
                Content="{Binding DataContext.ConfirmButtonText, RelativeSource={RelativeSource AncestorType=views:HomeView}, FallbackValue='Start the race  ⏎'}"
                Command="{Binding DataContext.ConfirmResultCommand, RelativeSource={RelativeSource AncestorType=views:HomeView}}"
                ToolTip="Go racing from this grid" />

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
            <ItemsControl ItemsSource="{Binding Slots}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,10,10" Padding="12,10" CornerRadius="8"
                                Background="{StaticResource SurfaceBrush}" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}" />
                                    <Style.Triggers>
                                        <!-- the player's own slot stands out -->
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel>
                                <!-- grid position -->
                                <Border DockPanel.Dock="Left" Width="34" Height="34" CornerRadius="17"
                                        Background="{StaticResource SurfaceAltBrush}" VerticalAlignment="Center"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Position}" FontWeight="Bold" FontSize="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- portrait (team player image on the player's card, else the driver) -->
                                <Grid DockPanel.Dock="Left" Width="52" Height="52" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Border CornerRadius="8" Background="{StaticResource SurfaceAltBrush}">
                                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                                   Foreground="{StaticResource TextMutedBrush}" Opacity="0.45"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border CornerRadius="8" ClipToBounds="True">
                                        <Image Stretch="UniformToFill"
                                               Source="{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                    </Border>
                                </Grid>

                                <!-- car preview (right) -->
                                <Image DockPanel.Dock="Right" Width="64" Height="34" Stretch="Uniform"
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       Source="{Binding CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />

                                <!-- driver + team -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriverNameUpper}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Style="{StaticResource Faint}" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding TeamName, Mode=OneWay}" /><Run Text="  " /><Run Text="{Binding NumberLabel, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
