<UserControl x:Class="Companion.App.Views.StartingGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             xmlns:smgp="clr-namespace:Companion.Core.Smgp;assembly=Companion.Core"
             Focusable="False">
    <!-- The display-only starting grid after qualifying: historical careers retain the compact,
         horizontally paged two-row cards; SMGP alone switches to the vertically scrolling pixel
         starting straight with one keyed miniature car per driver. -->
    <UserControl.Resources>
        <!-- one grid card: team-coloured position box + name, portrait + car, team edge. -->
        <DataTemplate x:Key="GridCard">
            <Border Width="264" Margin="7,6" CornerRadius="10" Background="{StaticResource SurfaceBrush}"
                    BorderThickness="1" BorderBrush="{Binding TeamColor, Converter={StaticResource HexBrush}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- header: position box (team colour) + driver / team -->
                    <DockPanel Margin="10,10,10,0">
                        <Border DockPanel.Dock="Left" Width="44" Height="44" CornerRadius="8"
                                Background="{Binding TeamColor, Converter={StaticResource HexBrush}}">
                            <TextBlock Text="{Binding Position}" Foreground="White" FontWeight="Bold"
                                       FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DriverNameUpper}" FontWeight="Bold" FontSize="15"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding TeamNameUpper}" FontSize="11.5" Margin="0,2,0,0"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{Binding TeamColor, Converter={StaticResource HexBrush}}" />
                        </StackPanel>
                    </DockPanel>

                    <!-- portrait + car -->
                    <Grid Height="112" Margin="10,8,10,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.15*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0" Margin="0,0,6,0">
                            <Border CornerRadius="8" Background="{StaticResource SurfaceAltBrush}">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="34"
                                           Foreground="{StaticResource TextMutedBrush}" Opacity="0.4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="8" ClipToBounds="True">
                                <Image Stretch="UniformToFill"
                                       Source="{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Border>
                        </Grid>

                        <Image Grid.Column="1" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Source="{Binding CarKey, Converter={StaticResource AssetImage}, ConverterParameter=cars}"
                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- SMGP-only pixel track: code-native repeating textures scale cleanly through the full
             34-car field. The supplied reference establishes the top-down asphalt/grass/kerb look;
             driver art stays keyed to canonical dist assets instead of being baked into a bitmap. -->
        <DrawingBrush x:Key="SmgpAsphaltBrush" TileMode="Tile"
                      Viewport="0,0,32,32" ViewportUnits="Absolute"
                      Viewbox="0,0,32,32" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#34383B">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,32,32" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#2D3134">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="3,5,3,2" /><RectangleGeometry Rect="19,2,2,3" />
                                <RectangleGeometry Rect="10,20,2,2" /><RectangleGeometry Rect="26,24,3,2" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#414549">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="12,8,2,2" /><RectangleGeometry Rect="28,11,2,2" />
                                <RectangleGeometry Rect="4,27,2,2" /><RectangleGeometry Rect="21,18,3,2" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="SmgpGrassBrush" TileMode="Tile"
                      Viewport="0,0,24,24" ViewportUnits="Absolute"
                      Viewbox="0,0,24,24" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#426C16">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,24,24" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#31570F">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="2,4,4,3" /><RectangleGeometry Rect="14,1,3,4" />
                                <RectangleGeometry Rect="8,15,3,3" /><RectangleGeometry Rect="19,18,4,3" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#6F941F">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="9,6,3,2" /><RectangleGeometry Rect="20,9,2,3" />
                                <RectangleGeometry Rect="3,20,3,2" /><RectangleGeometry Rect="15,13,2,2" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="SmgpCurbBrush" TileMode="Tile"
                      Viewport="0,0,18,64" ViewportUnits="Absolute"
                      Viewbox="0,0,18,64" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#F1EEE7">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,18,64" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#C52A23">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,18,32" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#771A18">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,28,18,4" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="SmgpCheckeredBrush" TileMode="Tile"
                      Viewport="0,0,32,32" ViewportUnits="Absolute"
                      Viewbox="0,0,32,32" ViewboxUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#EEECE5">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,32,32" /></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#17191B">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,16,16" />
                                <RectangleGeometry Rect="16,16,16,16" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DataTemplate x:Key="SmgpGridSlot">
            <Border x:Name="SmgpGridSlotCard" Height="136" Margin="4" CornerRadius="6"
                    UseLayoutRounding="True" RenderOptions.BitmapScalingMode="NearestNeighbor">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#C51B1F22" />
                        <Setter Property="BorderBrush"
                                Value="{Binding TeamColor, Converter={StaticResource HexBrush}}" />
                        <Setter Property="BorderThickness" Value="2" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderThickness" Value="4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="22" />
                        <RowDefinition Height="62" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <Border DockPanel.Dock="Left" MinWidth="38" CornerRadius="4" Padding="6,2"
                                Background="{Binding TeamColor, Converter={StaticResource HexBrush}}">
                            <TextBlock Text="{Binding PositionLabel}" Foreground="White" FontWeight="Bold"
                                       FontFamily="{StaticResource MicrosportFont}" FontSize="12"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Border x:Name="SmgpYouBadge" DockPanel.Dock="Right" CornerRadius="4" Padding="6,2"
                                Background="{StaticResource AccentBrush}"
                                Visibility="{Binding IsPlayer, Converter={StaticResource BoolVisible}}">
                            <TextBlock Text="YOU" Foreground="{StaticResource BgBrush}" FontWeight="Bold"
                                       FontFamily="{StaticResource MicrosportFont}" FontSize="10" />
                        </Border>
                        <TextBlock Text="{Binding NumberLabel}" Margin="4,0" VerticalAlignment="Center"
                                   HorizontalAlignment="Right" FontFamily="Consolas" FontWeight="Bold"
                                   Foreground="{Binding TeamColor, Converter={StaticResource HexBrush}}" />
                    </DockPanel>

                    <!-- Put the driver's portrait directly beside their exact car, like a compact
                         broadcast entry rather than a detached identity footer. -->
                    <Grid x:Name="SmgpDriverVisuals" Grid.Row="1" Margin="0,4,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="54" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="SmgpPortraitFrame" Width="54" Height="54"
                              HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border CornerRadius="4" Background="#D826292D">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                                           Foreground="{StaticResource TextMutedBrush}" Opacity="0.55"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Border CornerRadius="4" ClipToBounds="True">
                                <Image x:Name="SmgpPortraitImage" Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                       Source="{Binding PortraitKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                            </Border>
                        </Grid>

                        <!-- Prefer a bespoke overhead sprite, then use the canonical dist side preview. -->
                        <Grid x:Name="SmgpCarBay" Grid.Column="2" Margin="0,0,2,0">
                            <Border BorderBrush="#AAB9BCBD" BorderThickness="2,2,2,0" CornerRadius="2,2,0,0" />
                            <Border Width="18" Height="3" Margin="0,-1,0,0" VerticalAlignment="Top"
                                    HorizontalAlignment="Center" Background="#F1EEE7" />
                            <Image x:Name="SmgpCarImage" MaxHeight="56" Stretch="Uniform"
                                   HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Source="{Binding CarKey, Converter={StaticResource AssetImage}, ConverterParameter=smgp/grid-cars|cars}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                        </Grid>
                    </Grid>

                    <!-- Nationality is driver-keyed in canonical dist art so this remains XAML-only;
                         the synthetic player has no authored nationality, therefore its flag collapses. -->
                    <Grid x:Name="SmgpDriverIdentity" Grid.Row="2" Margin="0,1,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid x:Name="SmgpFlagFrame" Width="24" Height="18" VerticalAlignment="Center">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border Background="#D826292D" BorderBrush="#6E7B7D80" BorderThickness="1" />
                            <Image x:Name="SmgpFlagImage" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   Source="{Binding DriverId, Converter={StaticResource AssetImage}, ConverterParameter=smgp/flags}"
                                   Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                        </Grid>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DriverNameUpper}" FontWeight="Bold" FontSize="13"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding DriverName}" />
                            <TextBlock Text="{Binding TeamNameUpper}" FontSize="10.5" Margin="0,1,0,0"
                                       Foreground="{Binding TeamColor, Converter={StaticResource HexBrush}}"
                                       TextTrimming="CharacterEllipsis" ToolTip="{Binding TeamName}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <ItemsPanelTemplate x:Key="SmgpGridPanel">
            <UniformGrid Columns="2" />
        </ItemsPanelTemplate>

        <!-- a horizontal row of cards (the panel both grid rows reuse) -->
        <ItemsPanelTemplate x:Key="RowPanel">
            <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- ===== top: title + race-conditions bar ===== -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="STARTING GRID" Style="{StaticResource H2}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,2,0,0"
                           Text="Your grid for the race — pole first. Start the race when you're ready." />
            </StackPanel>

            <Border x:Name="DesktopConditionsPanel" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="8" Padding="4"
                    Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                    DataContext="{Binding Conditions}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding DataContext.Session.Pack.Manifest.CareerStyle,
                                                  RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                Value="{x:Static smgp:SmgpRules.CareerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="14,6" MinWidth="76">
                        <TextBlock Text="LAP DISTANCE" Style="{StaticResource Faint}" FontSize="10" />
                        <TextBlock Text="{Binding LapDistanceLabel}" FontWeight="SemiBold" FontSize="14" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Width="1" Background="{StaticResource EdgeBrush}" Margin="2,6" />
                    <StackPanel Margin="14,6" MinWidth="70">
                        <TextBlock Text="WEATHER" Style="{StaticResource Faint}" FontSize="10" />
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock Text="{Binding WeatherGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding Weather}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Border Width="1" Background="{StaticResource EdgeBrush}" Margin="2,6" />
                    <StackPanel Margin="14,6" MinWidth="66">
                        <TextBlock Text="TRACK TEMP" Style="{StaticResource Faint}" FontSize="10" />
                        <TextBlock Text="{Binding TrackTempLabel}" FontWeight="SemiBold" FontSize="14" Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Width="1" Background="{StaticResource EdgeBrush}" Margin="2,6" />
                    <StackPanel Margin="14,6" MinWidth="58">
                        <TextBlock Text="AIR TEMP" Style="{StaticResource Faint}" FontSize="10" />
                        <TextBlock Text="{Binding AirTempLabel}" FontWeight="SemiBold" FontSize="14" Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== bottom: DID NOT QUALIFY strip + conditions strip + START RACE ===== -->
        <StackPanel DockPanel.Dock="Bottom">
          <!-- the dynamic per-race DNQ field: the cars that missed this round's cut (SMGP rotates the
               slowest 8-9 out each race). Hidden for a full-field pack. -->
          <Border x:Name="DnqStrip" Margin="0,10,0,0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource EdgeBrush}"
                  BorderThickness="1" CornerRadius="8" Padding="12,8"
                  Visibility="{Binding HasDnq, Converter={StaticResource BoolVisible}}">
              <StackPanel>
                  <TextBlock Text="{Binding DnqHeader}" Style="{StaticResource Faint}" FontSize="10.5" Margin="0,0,0,6" />
                  <ItemsControl x:Name="DnqList" ItemsSource="{Binding Dnq}">
                      <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                          <DataTemplate>
                              <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="10"
                                      Padding="9,3" Margin="0,0,6,6" Opacity="0.7">
                                  <TextBlock>
                                      <Run Text="{Binding NameUpper, Mode=OneWay}" FontSize="11" FontWeight="SemiBold" />
                                      <Run Text="  " /><Run Text="{Binding TeamName, Mode=OneWay}" FontSize="10.5"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                  </TextBlock>
                              </Border>
                          </DataTemplate>
                      </ItemsControl.ItemTemplate>
                  </ItemsControl>
              </StackPanel>
          </Border>

          <Border Margin="0,12,0,0" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource EdgeBrush}" Padding="0,12,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}" MinWidth="170" FontWeight="Bold"
                        Content="{Binding DataContext.ConfirmButtonText, RelativeSource={RelativeSource AncestorType=views:HomeView}, FallbackValue='START RACE'}"
                        Command="{Binding DataContext.ConfirmResultCommand, RelativeSource={RelativeSource AncestorType=views:HomeView}}"
                        ToolTip="Go racing from this grid" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DataContext="{Binding Conditions}">
                    <TextBlock Text="{Binding WeatherGlyph}" FontFamily="Segoe MDL2 Assets" FontSize="15"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Weather}" Margin="7,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding WindLabel}" Style="{StaticResource Muted}" Margin="20,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding HumidityLabel}" Style="{StaticResource Muted}" Margin="20,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TrackStateLabel}" Style="{StaticResource Muted}" Margin="20,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
          </Border>
        </StackPanel>

        <!-- ===== mode-specific grid surface: historical cards OR the SMGP pixel track ===== -->
        <Grid Margin="0,14,0,0">
            <!-- Preserve the original shared/historical grid exactly. Unknown modes fail safely here. -->
            <Grid x:Name="HistoricalCardGrid">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding DataContext.Session.Pack.Manifest.CareerStyle,
                                                  RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                Value="{x:Static smgp:SmgpRules.CareerStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <ScrollViewer x:Name="GridScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                              Focusable="False" Padding="36,0">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding TopRow}" ItemTemplate="{StaticResource GridCard}"
                                      ItemsPanel="{StaticResource RowPanel}" />
                        <!-- the back row sits a half-car to the right, like a real grid -->
                        <ItemsControl ItemsSource="{Binding BottomRow}" ItemTemplate="{StaticResource GridCard}"
                                      ItemsPanel="{StaticResource RowPanel}" Margin="139,4,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- carousel arrows -->
                <Button x:Name="ScrollLeftButton" Click="OnScrollLeft" HorizontalAlignment="Left" VerticalAlignment="Center"
                        Width="30" Height="52" Content="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Style="{StaticResource SubtleButton}" ToolTip="Earlier on the grid" />
                <Button x:Name="ScrollRightButton" Click="OnScrollRight" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Width="30" Height="52" Content="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                        Style="{StaticResource SubtleButton}" ToolTip="Further down the grid" />
            </Grid>

            <!-- SMGP alone gets the long, vertically scrolling pixel-art starting straight. -->
            <Grid x:Name="SmgpPixelTrack" RenderOptions.BitmapScalingMode="NearestNeighbor"
                  SnapsToDevicePixels="True" AutomationProperties.Name="SMGP pixel starting grid">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding DataContext.Session.Pack.Manifest.CareerStyle,
                                                  RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                Value="{x:Static smgp:SmgpRules.CareerStyle}">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <ScrollViewer x:Name="SmgpGridScroll" HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto" Focusable="True" IsTabStop="True"
                              HorizontalContentAlignment="Stretch"
                              AutomationProperties.Name="Scroll through the SMGP starting order">
                    <Grid MaxWidth="900" HorizontalAlignment="Stretch" Background="{StaticResource SmgpGrassBrush}">
                        <!-- Proportional verges preserve the pixel track at minimum size while giving
                             portrait + car + identity enough width in each of the two grid bays. -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.08*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="0.08*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource SmgpGrassBrush}" />
                        <Border Grid.Column="1" Background="{StaticResource SmgpCurbBrush}" />
                        <Border Grid.Column="2" Background="{StaticResource SmgpAsphaltBrush}" />
                        <Border Grid.Column="3" Background="{StaticResource SmgpCurbBrush}" />
                        <Border Grid.Column="4" Background="{StaticResource SmgpGrassBrush}" />

                        <!-- Compact pixel fence rails at the outside edges. -->
                        <Border Grid.Column="0" Width="10" HorizontalAlignment="Left" Margin="4,0,0,0"
                                Background="#2A332F" BorderBrush="#9AA39E" BorderThickness="2,0" />
                        <Border Grid.Column="4" Width="10" HorizontalAlignment="Right" Margin="0,0,4,0"
                                Background="#2A332F" BorderBrush="#9AA39E" BorderThickness="2,0" />

                        <StackPanel Grid.Column="2" Margin="8,14,8,24">
                            <!-- The authored race length and the existing class/lap/rules-aware fuel
                                 advisory are already owned by the Race Day briefing. Bind through the
                                 HomeView ancestor so this view adds presentation, never strategy logic. -->
                            <Border x:Name="SmgpRacePlanPanel" Background="#E6202327"
                                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                    CornerRadius="5" Padding="10,8" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="RACE DISTANCE" Style="{StaticResource Faint}"
                                                   FontFamily="{StaticResource MicrosportFont}" FontSize="9" />
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock x:Name="SmgpLapCount" FontFamily="{StaticResource MicrosportFont}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       Text="{Binding DataContext.Briefing.Briefing.Round.Laps,
                                                                      RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}},
                                                                      Mode=OneWay, FallbackValue='—'}" />
                                            <TextBlock Text=" LAPS" FontFamily="{StaticResource MicrosportFont}"
                                                       FontSize="11" FontWeight="Bold" VerticalAlignment="Bottom"
                                                       Margin="0,0,0,3" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource EdgeBrush}" />
                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                        <TextBlock Text="PIT WALL  ·  POTENTIAL STRATEGIES" Style="{StaticResource Faint}"
                                                   FontFamily="{StaticResource MicrosportFont}" FontSize="9" />
                                        <TextBlock x:Name="SmgpTacticalAdvice" Margin="0,3,0,0"
                                                   FontSize="10.5" FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding DataContext.Briefing.SmgpAdviceLine,
                                                                  RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}},
                                                                  Mode=OneWay}"
                                                   Visibility="{Binding DataContext.Briefing.SmgpAdviceLine,
                                                                        RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}},
                                                                        Converter={StaticResource StringVisible}}" />
                                        <TextBlock x:Name="SmgpStrategyText" Margin="0,3,0,0"
                                                   FontSize="10" LineHeight="13" TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextBrush}"
                                                   Text="{Binding DataContext.Briefing.FuelNote,
                                                                  RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}},
                                                                  Mode=OneWay}"
                                                   ToolTip="{Binding DataContext.Briefing.FuelNote,
                                                                     RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}},
                                                                     Mode=OneWay}" />
                                        <WrapPanel Margin="0,5,0,0">
                                            <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="3"
                                                    Padding="5,2" Margin="0,0,5,0">
                                                <TextBlock x:Name="SmgpPitRule" FontSize="9">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                                            <Setter Property="Text" Value="PIT STOP  ·  UNKNOWN" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding DataContext.Briefing.Briefing.Round.SetupGuide.Session.MandatoryPitStop,
                                                                                      RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                                    Value="True">
                                                                    <Setter Property="Text" Value="PIT STOP  ·  REQUIRED" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                    Binding="{Binding DataContext.Briefing.Briefing.Round.SetupGuide.Session.MandatoryPitStop,
                                                                                      RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                                    Value="False">
                                                                    <Setter Property="Text" Value="PIT STOP  ·  OPTIONAL" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <Border Background="{StaticResource SurfaceAltBrush}" CornerRadius="3" Padding="5,2">
                                                <TextBlock x:Name="SmgpRefuelRule" FontSize="9">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                                            <Setter Property="Text" Value="REFUELLING  ·  UNKNOWN" />
                                                            <Style.Triggers>
                                                                <DataTrigger
                                                                    Binding="{Binding DataContext.Session.Pack.Season.RefuellingAllowed,
                                                                                      RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                                    Value="True">
                                                                    <Setter Property="Text" Value="REFUELLING  ·  ALLOWED" />
                                                                </DataTrigger>
                                                                <DataTrigger
                                                                    Binding="{Binding DataContext.Session.Pack.Season.RefuellingAllowed,
                                                                                      RelativeSource={RelativeSource AncestorType={x:Type views:HomeView}}}"
                                                                    Value="False">
                                                                    <Setter Property="Text" Value="REFUELLING  ·  NOT ALLOWED" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Background="#DC171A1D" Padding="8,4" Margin="0,0,0,4"
                                    DataContext="{Binding Conditions}">
                                <TextBlock TextAlignment="Center" TextWrapping="Wrap" FontSize="11"
                                           Foreground="{StaticResource TextMutedBrush}">
                                    <Run Text="{Binding LapDistanceLabel, Mode=OneWay}" />
                                    <Run Text="  ·  " /><Run Text="{Binding Weather, Mode=OneWay}" />
                                    <Run Text="  ·  TRACK " /><Run Text="{Binding TrackTempLabel, Mode=OneWay}" />
                                    <Run Text="  ·  AIR " /><Run Text="{Binding AirTempLabel, Mode=OneWay}" />
                                </TextBlock>
                            </Border>
                            <Border Height="20" Background="{StaticResource SmgpCheckeredBrush}"
                                    BorderBrush="#EAE7DF" BorderThickness="0,2" />
                            <Border Background="#DC171A1D" Padding="8,4" Margin="0,0,0,4">
                                <TextBlock Text="SUPER MONACO GP · STARTING ORDER" TextAlignment="Center"
                                           FontFamily="{StaticResource MicrosportFont}" FontSize="12"
                                           Foreground="{StaticResource AccentBrush}" />
                            </Border>
                            <ItemsControl x:Name="SmgpSlotList" ItemsSource="{Binding Slots}"
                                          ItemTemplate="{StaticResource SmgpGridSlot}"
                                          ItemsPanel="{StaticResource SmgpGridPanel}" />
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
