<UserControl x:Class="Companion.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <UserControl.Resources>
        <!-- header nav button that shows an accent underline when its state is active -->
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
    </UserControl.Resources>

    <DockPanel>
        <!-- career header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Race day" Command="{Binding ShowBriefingCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBriefingState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Enter result" Command="{Binding EnterResultCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsResultEntryState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsConfirmState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Standings" Command="{Binding ShowStandingsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStandingsState}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Border Width="1" Background="{StaticResource EdgeBrush}" Margin="10,4" />
                    <Button Content="⌂ Start" Style="{StaticResource NavButton}"
                            ToolTip="Close this career and return to the start screen"
                            Command="{Binding DataContext.GoToStartCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding HeaderTitle}" FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Style="{StaticResource Muted}" FontSize="13" Margin="0,2,0,0">
                        <Run Text="{Binding RoundText, Mode=OneWay}" /><Run Text="   ·   " /><Run Text="{Binding StandingText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- content error banner -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ErrorDimBrush}"
                Visibility="{Binding ContentError, Converter={StaticResource NullCollapsed}}">
            <TextBlock Text="{Binding ContentError}" Foreground="{StaticResource ErrorBrush}"
                       Margin="20,8" TextWrapping="Wrap" />
        </Border>

        <!-- season review banner -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SuccessDimBrush}"
                Visibility="{Binding IsSeasonReview, Converter={StaticResource BoolVisible}}">
            <TextBlock Foreground="{StaticResource SuccessBrush}" Margin="20,8" FontWeight="SemiBold"
                       Text="🏁 Season complete — final standings below. The journal holds the full season story." />
        </Border>

        <!-- two-state content: Briefing ⇄ Enter result (plus Confirm and Standings) -->
        <ContentControl Content="{Binding CurrentContent}" Focusable="False" Margin="20,16" />
    </DockPanel>
</UserControl>
