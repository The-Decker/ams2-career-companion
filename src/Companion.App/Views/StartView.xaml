<UserControl x:Class="Companion.App.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <!-- Keyboard parity (career-hub-design.md decision 8): Ctrl+O opens the career file picker,
         mirroring the button + its tooltip. The shell's window-level Esc/tab routing is unaffected
         (no modifier there); this chord requires Ctrl so it never collides. -->
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="O" Command="{x:Static views:StartView.OpenCareerFileCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <!-- right-click parity (ux-round contract section 2). A PAGE resource on purpose:
             event handlers on menu items nested inside a Style's Setter.Value hit WPF's
             connection-id mismatch ("Set connectionId threw an exception", MenuItem cast to
             Button) the first time a row renders — same pattern as ResultEntryView's
             DriverRowMenu. DataContext flows in from the row under the cursor. -->
        <ContextMenu x:Key="RecentCareerMenu">
            <MenuItem Header="Continue this career" Click="OnRecentContinue" />
            <Separator />
            <MenuItem Header="Open containing folder" Click="OnRecentOpenFolder"
                      ToolTip="Show the .ams2career file in Explorer" />
            <MenuItem Header="Remove from this list" Click="OnRecentRemove"
                      ToolTip="Only removes the shortcut — the career file stays on disk" />
            <Separator />
            <MenuItem Header="Delete career file…" Click="OnRecentDelete"
                      ToolTip="Deletes this career's .ams2career file from disk — asks first, cannot be undone" />
        </ContextMenu>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Focusable="False">
            <StackPanel MaxWidth="680" Margin="48,56" HorizontalAlignment="Center">
                <TextBlock Text="AMS2 Career Companion" Style="{StaticResource H1}" />
                <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,28" TextWrapping="Wrap"
                           Text="Historical career seasons around Automobilista 2 single-player custom races — offline, one file per career." />

                <StackPanel Orientation="Horizontal">
                    <Button Content="_New career" Style="{StaticResource AccentButton}"
                            MinWidth="160" Command="{Binding NewCareerCommand}" />
                    <Button Content="_Open career…" Margin="12,0,0,0"
                            Click="OnOpenCareerFile"
                            ToolTip="Open an existing .ams2career file that is not in your recent list (Ctrl+O)"
                            AutomationProperties.Name="Open career file" />
                    <Button Content="Open pack folder" Margin="12,0,0,0"
                            Click="OnOpenPackFolder"
                            ToolTip="Opens Documents\AMS2CareerCompanion\Packs — drop season packs here" />
                </StackPanel>

                <!-- Open-career picker pre-flight error (blank/missing path). A file that exists but
                     will not open is reported by the shell's own StatusError banner instead. -->
                <Border Background="{StaticResource ErrorDimBrush}" CornerRadius="4" Padding="12,8"
                        Margin="0,12,0,0"
                        Visibility="{Binding OpenError, Converter={StaticResource NullCollapsed}}">
                    <TextBlock Text="{Binding OpenError}" Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <TextBlock Text="Recent careers" Style="{StaticResource H2}" Margin="0,36,0,8" />

                <!-- "Delete career file…" failure (locked by an open session, permissions). The
                     entry stays in the gallery because the file is still on disk. -->
                <Border Background="{StaticResource ErrorDimBrush}" CornerRadius="4" Padding="12,8"
                        Margin="0,0,0,8"
                        Visibility="{Binding DeleteError, Converter={StaticResource NullCollapsed}}">
                    <TextBlock Text="{Binding DeleteError}" Foreground="{StaticResource ErrorBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <!-- empty state (ux-round §4): no careers yet → arrow to New career + open button -->
                <Border Style="{StaticResource Panel}" Padding="20"
                        Visibility="{Binding HasRecentCareers, Converter={StaticResource BoolCollapsed}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C1;" FontSize="20"
                                       Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                       Margin="0,0,12,0" />
                            <TextBlock Text="No careers yet" FontWeight="SemiBold" FontSize="15"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource Body}" Margin="0,8,0,0">
                            <Run FontFamily="Segoe MDL2 Assets" Text="&#xE74A;"
                                 Foreground="{StaticResource AccentBrush}" /><Run
                                 Text="  Start with " /><Run Text="New career" FontWeight="SemiBold"
                                 Foreground="{StaticResource AccentBrush}" /><Run
                                 Text=" above — pick a season pack, verify it against your install, pick your seat, race." />
                        </TextBlock>
                        <TextBlock Style="{StaticResource Faint}" Margin="0,6,0,0" TextWrapping="Wrap"
                                   Text="Each career is a single *.ams2career file in Documents\AMS2CareerCompanion\Careers — copy it to back up or share a season." />
                        <Button Content="Open careers folder" HorizontalAlignment="Left" Margin="0,12,0,0"
                                Click="OnOpenCareersFolder"
                                ToolTip="Opens Documents\AMS2CareerCompanion\Careers in Explorer (created if missing)" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Panel}" Padding="8"
                        Visibility="{Binding HasRecentCareers, Converter={StaticResource BoolVisible}}">
                    <StackPanel>
                        <!-- picture-rich career gallery: each card is coloured by its era (resolved
                             from the career's STORED season year, name-parse fallback for legacy
                             entries — see career-hub-design.md §11); the top band is the era-art slot
                             — drop real historical images in later and they replace the placeholder. -->
                        <ListBox ItemsSource="{Binding RecentCareers}"
                                 SelectedItem="{Binding SelectedCareer}"
                                 MaxHeight="420" Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <EventSetter Event="MouseDoubleClick" Handler="OnRecentDoubleClick" />
                                    <Setter Property="ContextMenu" Value="{StaticResource RecentCareerMenu}" />
                                    <Setter Property="Margin" Value="6" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="288" CornerRadius="7"
                                            Background="{StaticResource SurfaceAltBrush}"
                                            BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                                            ToolTip="{Binding Path}">
                                        <DockPanel>
                                            <!-- era-art band: a real historical photo when one is dropped
                                                 in data\ams2\era-art (resolved most-specific-first by the
                                                 career's STORED year — see career-hub-design.md §11);
                                                 otherwise the EraImage source is null and the coloured era
                                                 placeholder underneath shows through. Bound to the whole
                                                 RecentCareer so the converters read SeasonYear (name-parse
                                                 fallback for legacy entries with no stored year). -->
                                            <Grid DockPanel.Dock="Top" Height="88">
                                                <Border CornerRadius="6,6,0,0"
                                                        Background="{Binding Converter={StaticResource EraAccent}}" />
                                                <Border CornerRadius="6,6,0,0" ClipToBounds="True">
                                                    <Image Source="{Binding Converter={StaticResource EraImage}}"
                                                           Stretch="UniformToFill" />
                                                    <Border.Clip>
                                                        <RectangleGeometry Rect="0,0,288,88" RadiusX="6" RadiusY="6" />
                                                    </Border.Clip>
                                                </Border>
                                                <TextBlock Text="{Binding Converter={StaticResource EraLabel}}"
                                                           Foreground="#F2FFFFFF" FontWeight="Bold" FontSize="12"
                                                           VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                           Margin="12,0,0,8"
                                                           Visibility="{Binding DataContext.EraThemingEnabled, RelativeSource={RelativeSource AncestorType=ListBox}, Converter={StaticResource BoolVisible}}" />
                                                <Button Content="&#xE711;" Style="{StaticResource IconButton}"
                                                        VerticalAlignment="Top" HorizontalAlignment="Right" Margin="4"
                                                        ToolTip="Remove from this list (the career file stays)"
                                                        AutomationProperties.Name="Remove from recent careers"
                                                        Command="{Binding DataContext.RemoveRecentCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                            <StackPanel Margin="12,9,12,12">
                                                <TextBlock Text="{Binding CareerName}" FontWeight="SemiBold"
                                                           FontSize="15" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Style="{StaticResource Faint}" Margin="0,3,0,0"
                                                           Text="{Binding LastOpenedUtc.LocalDateTime, StringFormat='last opened {0:g}'}" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Button Content="_Continue selected career" Margin="10,10,10,6" HorizontalAlignment="Left"
                                Command="{Binding ContinueCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- install detection status from the shell -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,1,0,0">
            <TextBlock Margin="16,8" Style="{StaticResource Faint}" TextWrapping="Wrap"
                       Text="{Binding DataContext.InstallStatus, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Border>
    </Grid>
</UserControl>
