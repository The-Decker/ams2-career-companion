<UserControl x:Class="Companion.App.Views.StartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             xmlns:views="clr-namespace:Companion.App.Views"
             Focusable="False">
    <!-- Ctrl+O remains the keyboard twin of LOAD CAREER. -->
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="O"
                    Command="{x:Static views:StartView.OpenCareerFileCommand}" />
        <KeyBinding Modifiers="Alt" Key="C" Command="{Binding ContinueCommand}"
                    CommandParameter="{Binding RecentCareers[0]}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <Style x:Key="MainMenuButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="15,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource MainMenuGlassBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MainMenuGlassEdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource OnMediaBrush}" />
        </Style>

        <Style x:Key="MainMenuPrimaryButton" TargetType="Button"
               BasedOn="{StaticResource MainMenuButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
        </Style>

        <Style x:Key="MainMenuUtilityButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource MainMenuGlassBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource MainMenuGlassEdgeBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource OnMediaMutedBrush}" />
            <Setter Property="FontSize" Value="10.5" />
        </Style>

        <Style x:Key="CareerModeCardButton" TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="148" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="13,11" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource MainMenuGlassBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource OnMediaBrush}" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Id}" Value="smgp">
                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                    <!-- The SMGP identity art is authored at 1800x874 (2.059:1). The mode card
                         keeps that aspect instead of cropping it into the compact text-card shape. -->
                    <Setter Property="Height" Value="216" />
                    <Setter Property="MinHeight" Value="0" />
                    <Setter Property="Padding" Value="0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Id}" Value="racingPassport">
                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.8" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Right-click parity for every career card in the garage drawer. -->
        <ContextMenu x:Key="RecentCareerMenu">
            <MenuItem Header="Continue this career" Click="OnRecentContinue" />
            <MenuItem Header="Manage save points…" Click="OnRecentManageSaves"
                      ToolTip="Normal-mode whole-career saves and restores" />
            <Separator />
            <MenuItem Header="Open containing folder" Click="OnRecentOpenFolder"
                      ToolTip="Show the .ams2career file in Explorer" />
            <Separator />
            <MenuItem Header="Set card image…" Click="OnRecentSetImage"
                      ToolTip="Pick a 16:9 image for this career card" />
            <MenuItem Header="Clear card image" Click="OnRecentClearImage"
                      ToolTip="Revert the card to its era art" />
            <Separator />
            <MenuItem Header="Rename career…" Click="OnRecentRename" />
            <MenuItem Header="Duplicate career" Click="OnRecentDuplicate" />
            <MenuItem Header="Remove from this list" Click="OnRecentRemove"
                      ToolTip="The career file stays on disk" />
            <Separator />
            <MenuItem Header="Delete career file…" Click="OnRecentDelete"
                      ToolTip="Deletes the file after confirmation" />
        </ContextMenu>
    </UserControl.Resources>

    <Grid x:Name="MainMenuRoot" ClipToBounds="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Mike's 1990s grand-prix race photograph. UniformToFill accepts 16:9 through 4K
             without stretching; layered scrims keep every command readable. -->
        <Image x:Name="MainMenuBackdrop" Grid.RowSpan="2" IsHitTestVisible="False"
               Source="/AMS2CareerCompanion;component/Assets/MainMenu/main-menu.png"
               Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality" />
        <Border Grid.RowSpan="2" IsHitTestVisible="False"
                Background="{StaticResource MainMenuScrimBrush}" />
        <Border Grid.RowSpan="2" IsHitTestVisible="False"
                Background="{StaticResource MainMenuBottomFadeBrush}" />
        <Border Grid.RowSpan="2" IsHitTestVisible="False"
                Background="{StaticResource MainMenuVignetteBrush}" />

        <Grid x:Name="MainMenuStage" Grid.Row="0">
            <!-- Every menu command lives in one left-side rail. The photograph stays open across
                 the center and right; high UI scales scroll the rail vertically, never sideways. -->
            <ScrollViewer x:Name="MainMenuModeStage"
                          Width="560" HorizontalAlignment="Left"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto" Focusable="False">
                <Border x:Name="MainMenuCommandRail" Width="480" MaxWidth="520" Margin="28,22,28,18"
                        HorizontalAlignment="Left" VerticalAlignment="Top"
                        Background="{StaticResource MainMenuGlassStrongBrush}"
                        BorderBrush="{StaticResource MainMenuGlassEdgeBrush}" BorderThickness="1"
                        CornerRadius="10" Effect="{StaticResource PanelElevationEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="18,16,18,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <Border Width="216" Height="5" HorizontalAlignment="Left"
                                    Background="{StaticResource SmgpCheckeredBrush}" Margin="0,0,0,10" />
                            <TextBlock Text="A MOTORSPORT CAREER EXPERIENCE"
                                       FontFamily="{StaticResource DisplayFont}" FontSize="9.5"
                                       FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}" />
                            <TextBlock Text="AMS2" FontFamily="{StaticResource DisplayFont}"
                                       FontSize="35" FontWeight="Bold"
                                       Foreground="{DynamicResource OnMediaBrush}" />
                            <TextBlock Text="CAREER COMPANION" FontFamily="{StaticResource DisplayFont}"
                                       FontSize="19" FontWeight="Bold"
                                       Foreground="{DynamicResource OnMediaBrush}" Margin="0,-4,0,0" />
                            <TextBlock Text="THREE WAYS TO BUILD YOUR RACING LEGACY"
                                       FontFamily="{StaticResource MonoFont}" FontSize="8.5"
                                       Foreground="{DynamicResource OnMediaMutedBrush}" Margin="0,5,0,0" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,14,0,0">
                            <Button Style="{StaticResource MainMenuPrimaryButton}"
                                    audio:SoundAssist.Cue="Navigate"
                                    Command="{Binding ContinueCommand}"
                                    CommandParameter="{Binding RecentCareers[0]}"
                                    ToolTip="Continue the most recently opened career"
                                    AutomationProperties.Name="Continue most recent career">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="34" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}"
                                               FontSize="18" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="CONTINUE CAREER"
                                                   FontFamily="{StaticResource DisplayFont}"
                                                   FontWeight="Bold" FontSize="13" />
                                        <TextBlock Text="{Binding RecentCareers[0].CareerName, Mode=OneWay, FallbackValue=NO RECENT CAREER}"
                                                   FontSize="9" Opacity="0.78"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="&#xE76C;"
                                               FontFamily="{StaticResource IconFont}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Height="36" Click="OnOpenCareerFile"
                                        audio:SoundAssist.Cue="Navigate" Content="LOAD CAREER"
                                        ToolTip="Open an existing .ams2career file (Ctrl+O)"
                                        AutomationProperties.Name="Open career file" />
                                <Button x:Name="ModeCareerGarageButton" Grid.Column="2" Height="36"
                                        audio:SoundAssist.Cue="Navigate" Click="OnToggleCareerGarage"
                                        ToolTip="Browse, continue, rename, duplicate, or delete saved careers"
                                        AutomationProperties.Name="Open career garage">
                                    <TextBlock>
                                        <Run Text="CAREER GARAGE  " />
                                        <Run Text="{Binding RecentCareers.Count, Mode=OneWay}" />
                                    </TextBlock>
                                </Button>
                            </Grid>

                            <Border Background="{DynamicResource ErrorDimBrush}"
                                    BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                                    CornerRadius="5" Padding="9,6" Margin="0,7,0,0"
                                    Visibility="{Binding OpenError, Converter={StaticResource NullCollapsed}}">
                                <TextBlock Text="{Binding OpenError}"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="9.5" TextWrapping="Wrap" />
                            </Border>
                            <TextBlock Text="No saved careers yet. Choose one of the modes below to begin."
                                       Foreground="{DynamicResource OnMediaMutedBrush}" FontSize="9"
                                       TextWrapping="Wrap" Margin="2,7,0,0"
                                       Visibility="{Binding HasRecentCareers, Converter={StaticResource BoolCollapsed}}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Margin="18,14,18,8">
                        <TextBlock Text="START A NEW CAREER"
                                   FontFamily="{StaticResource DisplayFont}" FontSize="17"
                                   FontWeight="Bold" Foreground="{DynamicResource OnMediaBrush}" />
                        <TextBlock Text="Choose a career structure, then build your driver."
                                   FontSize="9.5" Foreground="{DynamicResource OnMediaMutedBrush}" />
                        <TextBlock Text="L300  &#xB7;  30 RACING DNA  &#xB7;  90 MASTERY SKILLS"
                                   FontFamily="{StaticResource MonoFont}" FontSize="8"
                                   Foreground="{DynamicResource OnMediaMutedBrush}"
                                   TextWrapping="Wrap" Margin="0,2,0,0" />
                    </StackPanel>

                    <ItemsControl x:Name="CareerModeList" Grid.Row="2" Margin="18,0,18,0"
                                  ItemsSource="{Binding CareerModes}"
                                  AutomationProperties.Name="New career modes">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <!-- SMGP owns one full-width key-art tile; the other modes retain
                                     their compact cards instead of being stretched to its height. -->
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource CareerModeCardButton}"
                                        audio:SoundAssist.Cue="Navigate"
                                        Command="{Binding DataContext.StartCareerModeCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="{Binding IsAvailable}"
                                        ToolTip="{Binding PersistenceSummary}"
                                        AutomationProperties.Name="{Binding DisplayName}"
                                        AutomationProperties.HelpText="{Binding Description}"
                                        AutomationProperties.ItemStatus="{Binding AvailabilityLabel}">
                                    <Grid>
                                        <!-- The exact full SMGP picture is embedded for reliable
                                             startup and shown uncropped. All command, keyboard,
                                             tooltip and automation behaviour remains on the Button. -->
                                        <Grid x:Name="SmgpModeCardContent" Visibility="Collapsed"
                                              Background="{StaticResource MainMenuGlassStrongBrush}"
                                              ClipToBounds="True">
                                            <Image x:Name="SmgpModeArtwork"
                                                   Source="/AMS2CareerCompanion;component/Assets/MainMenu/smgp-mode.jpg"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Stretch"
                                                   VerticalAlignment="Stretch"
                                                   RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Grid>

                                        <Grid x:Name="StandardModeCardContent">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left" FontFamily="{StaticResource IconFont}"
                                                       FontSize="20" Foreground="{DynamicResource AccentTextBrush}"
                                                       Margin="0,0,9,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE7C1;" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Id}" Value="smgp">
                                                                <Setter Property="Text" Value="&#xE7FC;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Id}" Value="racingPassport">
                                                                <Setter Property="Text" Value="&#xE774;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap"
                                                       FontFamily="{StaticResource DisplayFont}" FontSize="13"
                                                       FontWeight="Bold" Foreground="{DynamicResource OnMediaBrush}"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>

                                        <TextBlock Grid.Row="1" Text="{Binding Tagline}" TextWrapping="Wrap"
                                                   FontWeight="SemiBold" FontSize="9.5"
                                                   Foreground="{DynamicResource OnMediaMutedBrush}"
                                                   Margin="0,6,0,0" />

                                        <TextBlock Grid.Row="2" Text="{Binding Description}" TextWrapping="Wrap"
                                                   FontSize="8.8" LineHeight="12.5"
                                                   Foreground="{DynamicResource OnMediaBrush}"
                                                   Margin="0,7,0,8" />

                                        <Border Grid.Row="3" Background="{DynamicResource OverlaySurfaceAltBrush}"
                                                BorderBrush="{DynamicResource EdgeBrush}"
                                                BorderThickness="1" CornerRadius="4" Padding="8,6"
                                                VerticalAlignment="Bottom">
                                            <StackPanel>
                                                <TextBlock Text="SAVE MODEL" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="7.5" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentTextBrush}" />
                                                <TextBlock Text="{Binding PersistenceSummary}" TextWrapping="Wrap"
                                                           FontSize="8.5" LineHeight="11.5"
                                                           Foreground="{DynamicResource OnMediaMutedBrush}"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>

                                            <Border Grid.Row="4" CornerRadius="3" Padding="7,4" Margin="0,8,0,0"
                                                 BorderThickness="1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAvailable}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right" Text="&#xE76C;"
                                                           FontFamily="{StaticResource IconFont}"
                                                           Foreground="{DynamicResource SuccessBrush}"
                                                           Visibility="{Binding IsAvailable, Converter={StaticResource BoolVisible}}" />
                                                <TextBlock Text="{Binding AvailabilityLabel}" TextWrapping="Wrap"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="7.5"
                                                           FontWeight="Bold" Foreground="{DynamicResource OnMediaBrush}" />
                                            </DockPanel>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Button>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Id}" Value="smgp">
                                        <Setter TargetName="StandardModeCardContent" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="SmgpModeCardContent" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="3" Margin="18,2,18,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Height="30" FontSize="9"
                                audio:SoundAssist.Cue="Navigate"
                                Command="{Binding DataContext.ToggleSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Content="SETTINGS" ToolTip="Appearance, UI size, audio, and racing defaults" />
                        <Button Grid.Column="2" Height="30" FontSize="9"
                                audio:SoundAssist.Cue="Navigate"
                                Content="PACKS" Click="OnOpenPackFolder"
                                ToolTip="Open the user season-pack folder" />
                        <Button Grid.Column="4" Height="30" FontSize="9"
                                audio:SoundAssist.Cue="Back"
                                Content="EXIT" Click="OnExitApplication"
                                ToolTip="Exit AMS2 Career Companion" />
                    </Grid>
                </Grid>
                </Border>
            </ScrollViewer>


            <!-- Clicking CAREER GARAGE opens this modal-like gallery without replacing the menu
                 or adding navigation state to the view model. -->
            <Border x:Name="CareerGarageBackdrop" Visibility="Collapsed"
                    Background="{StaticResource MainMenuScrimBrush}" Opacity="0.55"
                    MouseLeftButtonDown="OnCloseCareerGarage" />

            <Border x:Name="CareerGaragePanel" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    Width="{Binding ActualWidth, ElementName=MainMenuStage,
                                    Converter={StaticResource WidthFraction},
                                    ConverterParameter=0.64|620|1040}"
                    Margin="24" Padding="18"
                    Background="{StaticResource MainMenuGlassStrongBrush}"
                    BorderBrush="{StaticResource MainMenuGlassEdgeBrush}" BorderThickness="1"
                    CornerRadius="10" Effect="{StaticResource PanelElevationEffect}"
                    PreviewKeyDown="OnGaragePreviewKeyDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <Button x:Name="CareerGarageCloseButton" DockPanel.Dock="Right"
                                audio:SoundAssist.Cue="Back"
                                Style="{StaticResource CloseButton}" Click="OnCloseCareerGarage"
                                ToolTip="Close career garage"
                                AutomationProperties.Name="Close career garage" />
                        <StackPanel>
                            <TextBlock Text="CAREER GARAGE" FontFamily="{StaticResource DisplayFont}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource OnMediaBrush}" />
                            <TextBlock Text="Select a career, then continue—or right-click a card for file operations."
                                       Foreground="{DynamicResource OnMediaMutedBrush}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1" Background="{DynamicResource ErrorDimBrush}"
                            BorderBrush="{DynamicResource ErrorBrush}" BorderThickness="1"
                            CornerRadius="5" Padding="10,7" Margin="0,0,0,10"
                            Visibility="{Binding GalleryError, Converter={StaticResource NullCollapsed}}">
                        <TextBlock Text="{Binding GalleryError}" Foreground="{DynamicResource ErrorBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Grid Grid.Row="2">
                        <Border Padding="18" Background="{StaticResource MainMenuGlassBrush}"
                                BorderBrush="{StaticResource MainMenuGlassEdgeBrush}"
                                BorderThickness="1" CornerRadius="7"
                                Visibility="{Binding HasRecentCareers, Converter={StaticResource BoolCollapsed}}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE7C1;" FontFamily="{StaticResource IconFont}"
                                           FontSize="30" Foreground="{DynamicResource AccentTextBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="THE GARAGE IS EMPTY" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="Bold" FontSize="15"
                                           Foreground="{DynamicResource OnMediaBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0" />
                                <TextBlock Text="Start a new career or open an existing .ams2career file."
                                           Foreground="{DynamicResource OnMediaMutedBrush}"
                                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,5,0,0" />
                                <Button Content="OPEN CAREERS FOLDER" Margin="0,12,0,0"
                                        audio:SoundAssist.Cue="Navigate"
                                        HorizontalAlignment="Center" Click="OnOpenCareersFolder" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto" Focusable="False"
                                      Visibility="{Binding HasRecentCareers, Converter={StaticResource BoolVisible}}">
                            <ListBox x:Name="CareerGalleryList" ItemsSource="{Binding RecentCareers}"
                                     SelectedItem="{Binding SelectedCareer}" SelectedIndex="0"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                        <EventSetter Event="MouseDoubleClick" Handler="OnRecentDoubleClick" />
                                        <Setter Property="ContextMenu" Value="{StaticResource RecentCareerMenu}" />
                                        <Setter Property="Margin" Value="5" />
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="258" CornerRadius="7" ToolTip="{Binding Path}"
                                                Background="{StaticResource MainMenuGlassBrush}"
                                                BorderBrush="{StaticResource MainMenuGlassEdgeBrush}"
                                                BorderThickness="1">
                                            <DockPanel>
                                                <Grid DockPanel.Dock="Top" Height="145">
                                                    <Border CornerRadius="6,6,0,0"
                                                            Background="{Binding Converter={StaticResource EraAccent}}" />
                                                    <Border CornerRadius="6,6,0,0">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding Converter={StaticResource EraImage}}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                    </Border>
                                                    <Border CornerRadius="6,6,0,0" Height="56"
                                                            VerticalAlignment="Bottom"
                                                            Background="{DynamicResource MediaCaptionGradientBrush}" />
                                                    <TextBlock Text="{Binding Converter={StaticResource EraLabel}}"
                                                               Foreground="{DynamicResource OnMediaMutedBrush}"
                                                               FontWeight="Bold" FontSize="11"
                                                               VerticalAlignment="Bottom" HorizontalAlignment="Left"
                                                               Margin="11,0,0,8"
                                                               Visibility="{Binding DataContext.EraThemingEnabled,
                                                                                    RelativeSource={RelativeSource AncestorType=ListBox},
                                                                                    Converter={StaticResource BoolVisible}}" />
                                                    <Button Content="&#xE711;" Style="{StaticResource IconButton}"
                                                            VerticalAlignment="Top" HorizontalAlignment="Right"
                                                            Margin="4" Foreground="{DynamicResource OnMediaMutedBrush}"
                                                            ToolTip="Remove from recent careers"
                                                            AutomationProperties.Name="Remove from recent careers"
                                                            Command="{Binding DataContext.RemoveRecentCommand,
                                                                              RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                            CommandParameter="{Binding}" />
                                                </Grid>
                                                <StackPanel Margin="11,8,11,10">
                                                    <TextBlock Text="{Binding CareerName}" FontWeight="SemiBold"
                                                               FontSize="14" Foreground="{DynamicResource OnMediaBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <DockPanel Margin="0,2,0,0">
                                                        <Button DockPanel.Dock="Right" Content="SAVES"
                                                                audio:SoundAssist.Cue="Navigate"
                                                                Style="{StaticResource MainMenuUtilityButton}"
                                                                Height="26" Padding="8,0" Margin="8,0,0,0"
                                                                Click="OnRecentManageSaves"
                                                                AutomationProperties.Name="Manage career save points" />
                                                        <TextBlock Text="{Binding LastOpenedUtc.LocalDateTime,
                                                                                  StringFormat='last opened {0:g}'}"
                                                                   FontSize="9.5" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource OnMediaMutedBrush}" />
                                                    </DockPanel>
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,12,0,0">
                        <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}"
                                audio:SoundAssist.Cue="Navigate"
                                Content="CONTINUE SELECTED CAREER" MinWidth="210"
                                Command="{Binding ContinueCommand}" />
                        <Button DockPanel.Dock="Left" Content="OPEN CAREERS FOLDER"
                                audio:SoundAssist.Cue="Navigate"
                                Click="OnOpenCareersFolder"
                                ToolTip="Open Documents\AMS2CareerCompanion\Careers" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Install detection remains visible without turning into a bright desktop status bar. -->
        <Border Grid.Row="1" Background="{StaticResource MainMenuGlassStrongBrush}"
                BorderBrush="{StaticResource MainMenuGlassEdgeBrush}" BorderThickness="0,1,0,0">
            <TextBlock Margin="14,6" FontFamily="{StaticResource MonoFont}" FontSize="9"
                       Foreground="{DynamicResource OnMediaMutedBrush}" TextWrapping="Wrap"
                       Text="{Binding DataContext.InstallStatus, RelativeSource={RelativeSource AncestorType=Window}}" />
        </Border>
    </Grid>
</UserControl>
