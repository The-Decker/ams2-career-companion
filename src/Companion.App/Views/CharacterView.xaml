<UserControl x:Class="Companion.App.Views.CharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <!-- The character-creation step (Increment 4a). DataContext is a CharacterViewModel. Every
         control is keyboard-operable: the archetype list (arrows), the stat sliders (arrows), and
         the perk checkboxes (Space) — decision 8 parity. -->
    <DockPanel>
        <!-- driver name: the identity the whole app uses -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" Text="Driver name" FontWeight="SemiBold" FontSize="15"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontSize="15"
                     MaxLength="40" AutomationProperties.Name="Driver name" />
        </DockPanel>

        <!-- character-points meter (always in view at the bottom) -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource Panel}" Padding="12,8" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock>
                    <Run Text="Talent: " /><Run Text="{Binding StatTotal, Mode=OneWay, StringFormat={}{0:0.00}}" FontWeight="SemiBold" /><Run Text=" of " /><Run Text="{Binding StatCap, Mode=OneWay, StringFormat={}{0:0.00}}" /><Run Text=" allocated   ·   Perks: " /><Run Text="{Binding SelectedPerkCount, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" of " /><Run Text="{Binding MaxPerks, Mode=OneWay}" /><Run Text="   ·   Perk points: " /><Run Text="{Binding NetCpSpend, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" of " /><Run Text="{Binding Budget, Mode=OneWay}" /><Run Text=" spent" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource ErrorBrush}" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding Invalidity}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Invalidity}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- archetype presets: one click = a complete, valid character -->
            <DockPanel Grid.Column="0" Margin="0,0,14,0">
                <TextBlock DockPanel.Dock="Top" Text="Archetype" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6" />
                <Border Style="{StaticResource Panel}" Padding="6">
                    <ListBox ItemsSource="{Binding Archetypes}" SelectedItem="{Binding SelectedArchetype}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Faint}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- stats + perks -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Focusable="False">
                <StackPanel>
                    <TextBlock Text="Stats" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Stats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="120" VerticalAlignment="Center" />
                                    <TextBlock DockPanel.Dock="Right" Width="44" TextAlignment="Right" VerticalAlignment="Center"
                                               Style="{StaticResource Faint}"
                                               Text="{Binding Value, StringFormat={}{0:0.00}}" />
                                    <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                                            Value="{Binding Value, Mode=TwoWay}"
                                            SmallChange="0.05" LargeChange="0.1"
                                            VerticalAlignment="Center" Margin="8,0" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding MetaStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="120" VerticalAlignment="Center" />
                                    <TextBlock DockPanel.Dock="Right" Width="44" TextAlignment="Right" VerticalAlignment="Center"
                                               Style="{StaticResource Faint}"
                                               Text="{Binding Value, StringFormat={}{0:0.00}}" />
                                    <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                                            Value="{Binding Value, Mode=TwoWay}"
                                            SmallChange="0.05" LargeChange="0.1"
                                            VerticalAlignment="Center" Margin="8,0" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Perks" FontWeight="SemiBold" FontSize="15" Margin="0,14,0,4" />
                    <ItemsControl ItemsSource="{Binding PerkCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource Faint}" Margin="0,0,0,2" />
                                    <ItemsControl ItemsSource="{Binding Perks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="4,2">
                                                    <CheckBox.ToolTip>
                                                        <StackPanel MaxWidth="320">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                                       Margin="0,2,0,0" Opacity="0.85" />
                                                            <ItemsControl ItemsSource="{Binding Benefits}" Margin="0,6,0,0">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock TextWrapping="Wrap"><Run Text="+  " FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <ItemsControl ItemsSource="{Binding Drawbacks}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock TextWrapping="Wrap" Opacity="0.85"><Run Text="−  " FontWeight="Bold" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </CheckBox.ToolTip>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" />
                                                        <TextBlock Text="{Binding CostLabel}" Style="{StaticResource Faint}"
                                                                   Margin="8,0,0,0" />
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
