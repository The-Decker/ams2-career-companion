<UserControl x:Class="Companion.App.Views.CharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="{StaticResource OpenSansFont}"
             Focusable="False">
    <!-- The character-creation step (Increment 4a). DataContext is a CharacterViewModel. Every
         control is keyboard-operable: the archetype list (arrows), the Random button (Enter/Space),
         the stat sliders (arrows), the perk checkboxes (Space), and the specialism combo — decision
         8 parity. Three tiers of depth: pick an archetype (or roll a random build), free-customize
         the sliders + perk shelf against a live meter, and reveal the raw numbers in "Advanced". -->
    <DockPanel>
        <!-- driver name: the identity the whole app uses -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" Text="Driver name" FontWeight="SemiBold" FontSize="15"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontSize="15"
                     MaxLength="40" AutomationProperties.Name="Driver name" />
        </DockPanel>

        <!-- driver age: the character's REAL first-season age — drives aging + contract offers -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock DockPanel.Dock="Left" Text="Age" FontWeight="SemiBold" FontSize="15"
                       VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0" MinWidth="24"
                       FontSize="15" FontWeight="SemiBold" TextAlignment="Right"
                       Text="{Binding Age, Mode=OneWay}" />
            <Slider Minimum="16" Maximum="45" Value="{Binding Age}" IsSnapToTickEnabled="True"
                    TickFrequency="1" VerticalAlignment="Center"
                    AutomationProperties.Name="Driver age" />
        </DockPanel>

        <!-- character-points meter (always in view at the bottom) -->
        <Border DockPanel.Dock="Bottom" Style="{StaticResource Panel}" Padding="12,8" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock>
                    <Run Text="Talent: " /><Run Text="{Binding StatTotal, Mode=OneWay, StringFormat={}{0:0.00}}" FontWeight="SemiBold" /><Run Text=" of " /><Run Text="{Binding StatCap, Mode=OneWay, StringFormat={}{0:0.00}}" /><Run Text=" allocated   ·   Perks: " /><Run Text="{Binding SelectedPerkCount, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" of " /><Run Text="{Binding MaxPerks, Mode=OneWay}" /><Run Text="   ·   Perk points: " /><Run Text="{Binding NetCpSpend, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" of " /><Run Text="{Binding MaxPerkPoints, Mode=OneWay}" /><Run Text=" spent · " /><Run Text="{Binding RemainingCp, Mode=OneWay}" FontWeight="SemiBold" /><Run Text=" left (budget " /><Run Text="{Binding Budget, Mode=OneWay}" /><Run Text=")" />
                </TextBlock>
                <TextBlock Foreground="{StaticResource ErrorBrush}" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="{Binding Invalidity}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Invalidity}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- both columns flex (was a fixed 270 archetype rail) -->
                <ColumnDefinition Width="1*" MinWidth="240" MaxWidth="400" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- archetype presets: one click = a complete, valid character -->
            <DockPanel Grid.Column="0" Margin="0,0,14,0">
                <TextBlock DockPanel.Dock="Top" Text="Archetype" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,6" />
                <!-- roll a complete random build — the other one-click way to a valid character -->
                <Button DockPanel.Dock="Bottom" Margin="0,8,0,0" Padding="8,6"
                        Command="{Binding RandomBuildCommand}"
                        Content="🎲  Random balanced build"
                        HorizontalContentAlignment="Center"
                        ToolTip="Roll a random archetype and a fresh stat spread — always valid and in budget." />
                <Border Style="{StaticResource Panel}" Padding="6">
                    <ListBox ItemsSource="{Binding Archetypes}" SelectedItem="{Binding SelectedArchetype}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock Text="{Binding Description}" Style="{StaticResource Faint}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- stats + perks -->
            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Focusable="False">
                <StackPanel>
                    <TextBlock Text="Stats" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,4" />
                    <ItemsControl ItemsSource="{Binding Stats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="120" VerticalAlignment="Center" />
                                    <TextBlock DockPanel.Dock="Right" Width="44" TextAlignment="Right" VerticalAlignment="Center"
                                               Style="{StaticResource Faint}"
                                               Text="{Binding Value, StringFormat={}{0:0.00}}" />
                                    <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                                            Value="{Binding Value, Mode=TwoWay}"
                                            SmallChange="0.05" LargeChange="0.1"
                                            VerticalAlignment="Center" Margin="8,0" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding MetaStats}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,3">
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="120" VerticalAlignment="Center" />
                                    <TextBlock DockPanel.Dock="Right" Width="44" TextAlignment="Right" VerticalAlignment="Center"
                                               Style="{StaticResource Faint}"
                                               Text="{Binding Value, StringFormat={}{0:0.00}}" />
                                    <Slider Minimum="{Binding Min}" Maximum="{Binding Max}"
                                            Value="{Binding Value, Mode=TwoWay}"
                                            SmallChange="0.05" LargeChange="0.1"
                                            VerticalAlignment="Center" Margin="8,0" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Perks" FontWeight="SemiBold" FontSize="15" Margin="0,14,0,4" />
                    <ItemsControl ItemsSource="{Binding PerkCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding DisplayName}" Style="{StaticResource Faint}" Margin="0,0,0,2" />
                                    <ItemsControl ItemsSource="{Binding Perks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="4,2">
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                                        <CheckBox.ToolTip>
                                                            <StackPanel MaxWidth="320">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                                           Margin="0,2,0,0" Opacity="0.85" />
                                                            </StackPanel>
                                                        </CheckBox.ToolTip>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" />
                                                            <TextBlock Text="{Binding CostLabel}" Style="{StaticResource Faint}"
                                                                       Margin="8,0,0,0" />
                                                        </StackPanel>
                                                    </CheckBox>
                                                    <!-- benefit/drawback inline once picked — keyboard-reachable,
                                                         no hover required (decision-8 parity) -->
                                                    <StackPanel Margin="22,2,0,4"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolVisible}}">
                                                        <ItemsControl ItemsSource="{Binding Benefits}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="12"><Run Text="+  " FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <ItemsControl ItemsSource="{Binding Drawbacks}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.9"><Run Text="−  " FontWeight="Bold" Foreground="{StaticResource ErrorBrush}" /><Run Text="{Binding Mode=OneWay}" /></TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- One-Trick Pony: pick the single specialism its +0.30 lands on and locks to.
                         Shown only when the perk is selected. -->
                    <Border Style="{StaticResource Panel}" Padding="10,8" Margin="0,10,0,0"
                            Visibility="{Binding IsOneTrickSelected, Converter={StaticResource BoolVisible}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0"
                                       Text="Your one weapon" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding EligibleFlavors}" SelectedItem="{Binding ChosenFlavor}"
                                      DisplayMemberPath="Label" MinWidth="180"
                                      AutomationProperties.Name="One-Trick specialism" />
                        </DockPanel>
                    </Border>

                    <!-- Advanced (tier 3): the raw stat → written-rating numbers, so the honesty
                         constraint is loud — talent sets the sim's EXPECTATION of you, not secret pace. -->
                    <Expander Header="Advanced — show the numbers" Margin="0,12,0,0" FontSize="13">
                        <StackPanel Margin="4,6,0,0">
                            <TextBlock Style="{StaticResource Faint}" TextWrapping="Wrap" Margin="0,0,0,6"
                                       Text="Each talent stat writes these AI-rating fields on your seat. They set how good the sim EXPECTS you to be (a stiffer bar to beat), never a secret in-race buff." />
                            <ItemsControl ItemsSource="{Binding Stats}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2">
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" Width="120" Style="{StaticResource Faint}" />
                                            <TextBlock Text="{Binding WrittenPreview}" TextWrapping="Wrap" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</UserControl>
