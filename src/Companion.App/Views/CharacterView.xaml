<UserControl x:Class="Companion.App.Views.CharacterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Companion.App.Controls"
             FontFamily="{StaticResource BodyFont}"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="CharacterSectionLabel" TargetType="TextBlock" BasedOn="{StaticResource Eyebrow}">
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="CharacterTelemetryCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="11,8" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>

        <Style x:Key="CharacterArchetypeItem" TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Width" Value="260" />
            <Setter Property="MinHeight" Value="96" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="CharacterDnaItem" TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="AutomationProperties.Name" Value="{Binding Name, Mode=OneWay}" />
            <Setter Property="AutomationProperties.HelpText"
                    Value="Choose this permanent Racing DNA identity and review its strengths and trade-off." />
        </Style>

        <Style x:Key="CharacterCompactListItem" TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="CharacterCountryItem" TargetType="ComboBoxItem"
               BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="AutomationProperties.Name"
                    Value="{Binding Name, Mode=OneWay, StringFormat={}{0} country flag}" />
            <Setter Property="AutomationProperties.HelpText"
                    Value="{Binding Code, Mode=OneWay, StringFormat={}{0} country code}" />
        </Style>

        <Style x:Key="CharacterPreviewNodeItem" TargetType="ListBoxItem"
               BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="AutomationProperties.Name" Value="{Binding Name, Mode=OneWay}" />
            <Setter Property="AutomationProperties.HelpText"
                    Value="Preview only. The card shows branch depth, minimum level and Skill Point cost." />
        </Style>

        <DataTemplate x:Key="CharacterStatTemplate">
            <Border Style="{StaticResource CharacterTelemetryCard}"
                    AutomationProperties.Name="{Binding Label, Mode=OneWay, StringFormat={}{0} starting attribute}">
                <Border.ToolTip>
                    <StackPanel MaxWidth="340">
                        <TextBlock Text="{Binding Label, Mode=OneWay}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CreationGuidance, Mode=OneWay}"
                                   TextWrapping="Wrap" Margin="0,3,0,0" />
                        <TextBlock Text="{Binding WrittenPreview, Mode=OneWay}" TextWrapping="Wrap"
                                   Margin="0,4,0,0" Style="{StaticResource Faint}" />
                    </StackPanel>
                </Border.ToolTip>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                Margin="8,0,0,0">
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       Text="{Binding Value, StringFormat={}{0:P0}}" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Label}" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold" FontSize="12" />
                            <TextBlock Text="STARTING VALUE" Style="{StaticResource Faint}"
                                       FontSize="9" Margin="0,1,0,0" />
                        </StackPanel>
                    </DockPanel>
                    <Slider Grid.Row="1" Minimum="{Binding Min}" Maximum="{Binding Max}"
                            Value="{Binding Value, Mode=TwoWay}"
                            SmallChange="0.05" LargeChange="0.1"
                            Margin="0,7,0,0" VerticalAlignment="Center"
                            ToolTip="{Binding Value, StringFormat={}{0:0.00}}"
                            AutomationProperties.Name="{Binding Label, Mode=OneWay, StringFormat={}{0} starting value}"
                            AutomationProperties.HelpText="{Binding CreationGuidance, Mode=OneWay}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CharacterPerkTemplate">
            <CheckBox Width="300" Margin="0,0,9,9"
                      HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}">
                <CheckBox.ToolTip>
                    <StackPanel MaxWidth="340">
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                   Margin="0,3,0,0" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>
                </CheckBox.ToolTip>
                <Border Padding="10,8" MinHeight="76" CornerRadius="7"
                        BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                            <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=CheckBox}}"
                                             Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                    <Setter Property="BorderThickness" Value="2" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <DockPanel>
                            <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                    Margin="8,0,0,0">
                                <TextBlock FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                           Text="{Binding CostLabel, StringFormat={}{0} CP}" />
                            </Border>
                            <TextBlock Text="{Binding Name}" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold" FontSize="12" TextWrapping="Wrap" />
                        </DockPanel>
                        <TextBlock Text="{Binding Description}" Style="{StaticResource Body}"
                                   FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap" />
                        <StackPanel Margin="0,7,0,0"
                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolVisible}}">
                            <ItemsControl ItemsSource="{Binding Benefits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,1">
                                            <Run Text="+  " FontWeight="Bold"
                                                 Foreground="{DynamicResource SuccessBrush}" />
                                            <Run Text="{Binding Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding Drawbacks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,1">
                                            <Run Text="-  " FontWeight="Bold"
                                                 Foreground="{DynamicResource ErrorBrush}" />
                                            <Run Text="{Binding Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </CheckBox>
        </DataTemplate>
    </UserControl.Resources>

    <!-- Driver creation is a compact garage workbench: identity stays visible above a set of
         keyboard-reachable build panes, and the live budget remains pinned below them. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Identity strip: the two fields that define the driver's public record. -->
        <Border x:Name="CharacterIdentityStrip" Grid.Row="0" Style="{StaticResource Panel}"
                Padding="12,9" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="DRIVER PROFILE" Style="{StaticResource CharacterSectionLabel}" />
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource DisplayFont}" FontSize="15"
                             MaxLength="40" AutomationProperties.Name="Driver name"
                             ToolTip="The name used on contracts, results, records and headlines." />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <DockPanel Margin="0,0,0,3">
                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                Margin="8,0,0,0">
                            <TextBlock Text="{Binding Age, Mode=OneWay}"
                                       FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                        </Border>
                        <TextBlock Text="STARTING AGE" Style="{StaticResource CharacterSectionLabel}" />
                    </DockPanel>
                    <Slider Minimum="16" Maximum="45" Value="{Binding Age}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            AutomationProperties.Name="Driver age"
                            ToolTip="Your age in season one. It affects development, retirement risk and contract offers."
                            AutomationProperties.HelpText="Your age in season one. It affects development, retirement risk and contract offers." />
                </StackPanel>

                <!-- Nationality is an explicit, permanent v2 identity choice. The immutable
                     catalog is read-only; only the selected option writes back to creation. -->
                <Border x:Name="CharacterCountrySelector" Grid.Row="1" Grid.ColumnSpan="3"
                        Margin="0,9,0,0" Padding="8,7" CornerRadius="6"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                        Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolVisible}}"
                        AutomationProperties.Name="Driver country selection">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <DockPanel>
                            <Border x:Name="CharacterCountryValidationBadge" DockPanel.Dock="Right"
                                    Margin="8,0,0,0" Padding="7,3" CornerRadius="4" BorderThickness="1"
                                    AutomationProperties.Name="Country selection status">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCountryValid, Mode=OneWay}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="8.5"
                                           FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="CHOOSE COUNTRY" />
                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCountryValid, Mode=OneWay}" Value="True">
                                                    <Setter Property="Text" Value="COUNTRY SET" />
                                                    <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <StackPanel>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="COUNTRY &amp; FLAG"
                                               Style="{StaticResource CharacterSectionLabel}"
                                               Margin="0,0,8,0" />
                                    <TextBlock x:Name="CharacterCountrySummary"
                                               Text="{Binding CountrySummary, Mode=OneWay}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="9.5"
                                               FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}"
                                               TextWrapping="Wrap" />
                                </DockPanel>
                                <TextBlock x:Name="CharacterCountryReadiness"
                                           Text="Choose the country and flag shown on your driver profile."
                                           Style="{StaticResource Faint}" FontSize="8.5"
                                           TextWrapping="Wrap" Margin="0,-2,0,0" />
                            </StackPanel>
                        </DockPanel>

                        <ComboBox x:Name="CharacterCountryDropdown" Grid.Row="1" Margin="0,6,0,0"
                                  Width="244" MinHeight="36" MaxDropDownHeight="320"
                                  HorizontalAlignment="Left"
                                  ItemsSource="{Binding CountryOptions, Mode=OneWay}"
                                  SelectedItem="{Binding SelectedCountry, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  ItemContainerStyle="{StaticResource CharacterCountryItem}"
                                  IsTextSearchEnabled="True" TextSearch.TextPath="Name"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.IsDeferredScrollingEnabled="True"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  AutomationProperties.Name="Driver nationality and flag"
                                  AutomationProperties.HelpText="Your permanent nationality and profile flag. Some Racing DNA identities may also use this choice.">
                            <ComboBox.Resources>
                                <Style TargetType="{x:Type ScrollViewer}">
                                    <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True" />
                                </Style>
                            </ComboBox.Resources>
                            <ComboBox.ToolTip>
                                <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                           Text="Your permanent nationality and profile flag. Some Racing DNA identities may also use this choice." />
                            </ComboBox.ToolTip>
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel
                                        VirtualizingPanel.IsVirtualizing="True"
                                        VirtualizingPanel.VirtualizationMode="Recycling" />
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="202" ToolTip="{Binding Name, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="38" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Image x:Name="CharacterCountryItemFlag"
                                               Width="30" Height="20" Margin="0,0,8,0"
                                               Stretch="Uniform" IsHitTestVisible="False"
                                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                                               Source="{Binding FlagKey, Mode=OneWay, Converter={StaticResource AssetImage}, ConverterParameter=smgp/flags}"
                                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}"
                                               AutomationProperties.Name="{Binding Name, Mode=OneWay, StringFormat={}{0} flag}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name, Mode=OneWay}"
                                                   VerticalAlignment="Center" FontWeight="SemiBold"
                                                   FontSize="10.5" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Five focused panes keep permanent identity, starting choices and later progression distinct. -->
        <TabControl x:Name="CharacterWorkbench" Grid.Row="1" SelectedIndex="0">
            <TabItem Header="RACING DNA"
                     ToolTip="Choose the permanent identity that shapes your starting build and stays with you for the whole career.">
                <Grid>
                    <!-- Progression v2 owns a 30-card, exact-version Racing DNA catalog. Every
                         read-only catalog projection is explicitly OneWay: WPF must never attempt
                         to write back into immutable effect/trait summaries. -->
                    <Grid x:Name="CharacterRacingDnaPanel"
                          Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolVisible}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,9">
                            <Button x:Name="CharacterRandomBuildButton" DockPanel.Dock="Right"
                                    Style="{StaticResource AccentButton}"
                                    Padding="12,6" Command="{Binding RandomBuildCommand}"
                                    Content="SURPRISE ME"
                                    ToolTipService.ShowOnDisabled="True"
                                    AutomationProperties.Name="Create a surprise driver build"
                                    AutomationProperties.HelpText="Creates a valid random DNA, attribute spread and starting-trait loadout. Your name, age and country stay unchanged.">
                                <Button.ToolTip>
                                    <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                               Text="Creates a valid random DNA, attribute spread and starting-trait loadout. Your name, age and country stay unchanged." />
                                </Button.ToolTip>
                            </Button>
                            <StackPanel>
                                <TextBlock Text="CHOOSE YOUR PERMANENT IDENTITY" Style="{StaticResource CharacterSectionLabel}" />
                                <TextBlock Text="Racing DNA loads a valid starting build with a lasting strength and trade-off. You can tune attributes and starting traits afterward, but your DNA cannot be changed or reset."
                                           Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.82*" MinWidth="180" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="1.38*" MinWidth="240" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource Panel}" Padding="6">
                                <ListBox x:Name="CharacterRacingDnaList"
                                         ItemsSource="{Binding RacingDnaCards, Mode=OneWay}"
                                         SelectedItem="{Binding SelectedRacingDna, Mode=TwoWay}"
                                         ItemContainerStyle="{StaticResource CharacterDnaItem}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         AutomationProperties.Name="Racing DNA identities"
                                         AutomationProperties.HelpText="Choose one permanent identity, then review its full starting build in the detail panel.">
                                    <ListBox.ToolTip>
                                        <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                   Text="Choose one permanent identity. Its two natural mastery families do not grant free skills." />
                                    </ListBox.ToolTip>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="9,7" CornerRadius="6" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                <Setter Property="BorderThickness" Value="2" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontFamily="{StaticResource DisplayFont}"
                                                               FontWeight="Bold" FontSize="11.5" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding FamilyLine, Mode=OneWay}" Style="{StaticResource Faint}"
                                                               Foreground="{DynamicResource AccentTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Style="{StaticResource Panel}" Padding="11,9">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled" Focusable="False">
                                        <ContentControl x:Name="CharacterRacingDnaDetail"
                                                        Content="{Binding SelectedRacingDna, Mode=OneWay}">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name, Mode=OneWay}" Style="{StaticResource H2}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding FamilyLine, Mode=OneWay}" Style="{StaticResource Eyebrow}"
                                                                   Foreground="{DynamicResource AccentTextBrush}" Margin="0,2,0,0">
                                                            <TextBlock.ToolTip>
                                                                <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                                           Text="These are this identity's two natural mastery families. They do not grant free skills." />
                                                            </TextBlock.ToolTip>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Description, Mode=OneWay}" TextWrapping="Wrap"
                                                                   Margin="0,7,0,9" Foreground="{DynamicResource TextSecondaryBrush}" />

                                                        <TextBlock Text="LOADED STARTING TRAITS" Style="{StaticResource CharacterSectionLabel}" />
                                                        <ItemsControl ItemsSource="{Binding StartingTraitNames, Mode=OneWay}" Margin="0,0,0,5">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Style="{StaticResource CompactChip}" Margin="0,0,4,4">
                                                                        <TextBlock Text="{Binding Mode=OneWay}" FontSize="9.5" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>

                                                        <TextBlock Text="LASTING STRENGTH" Style="{StaticResource CharacterSectionLabel}" />
                                                        <ItemsControl ItemsSource="{Binding PersistentEffectSummaries, Mode=OneWay}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock TextWrapping="Wrap" Margin="0,1">
                                                                        <Run Text="+  " FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />
                                                                        <Run Text="{Binding Mode=OneWay}" />
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <TextBlock Text="TRADE-OFF" Style="{StaticResource CharacterSectionLabel}" Margin="0,8,0,4" />
                                                        <ItemsControl ItemsSource="{Binding TradeoffEffectSummaries, Mode=OneWay}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock TextWrapping="Wrap" Margin="0,1">
                                                                        <Run Text="-  " FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" />
                                                                        <Run Text="{Binding Mode=OneWay}" />
                                                                    </TextBlock>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </ScrollViewer>
                                </Border>

                                <Border x:Name="CharacterRacingDnaChoice" Grid.Row="1"
                                        Style="{StaticResource AccentCallout}" Padding="9,7" Margin="0,7,0,0"
                                        Visibility="{Binding HasRacingDnaChoice, Mode=OneWay, Converter={StaticResource BoolVisible}}">
                                    <StackPanel>
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0"
                                                    Visibility="{Binding IsRacingDnaChoiceRequired, Mode=OneWay, Converter={StaticResource BoolVisible}}">
                                                <TextBlock Text="REQUIRED" Style="{StaticResource PixelBadge}"
                                                           Foreground="{DynamicResource WarningBrush}" />
                                            </Border>
                                            <TextBlock Text="DNA FOCUS" Style="{StaticResource CharacterSectionLabel}" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding RacingDnaChoicePrompt, Mode=OneWay}"
                                                   TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,5" />
                                        <ComboBox ItemsSource="{Binding RacingDnaChoiceOptions, Mode=OneWay}"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding RacingDnaChoiceValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Stretch"
                                                  AutomationProperties.Name="Racing DNA focus"
                                                  AutomationProperties.HelpText="This personal choice becomes a permanent part of your Racing DNA.">
                                            <ComboBox.ToolTip>
                                                <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                           Text="This personal choice becomes a permanent part of your Racing DNA." />
                                            </ComboBox.ToolTip>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate><TextBlock Text="{Binding Label, Mode=OneWay}" /></DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Legacy creation remains byte-for-byte in spirit and is only shown for v1. -->
                    <Grid x:Name="CharacterLegacyArchetypePanel"
                          Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolCollapsed}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,9">
                            <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}"
                                    Padding="12,6" Command="{Binding RandomBuildCommand}"
                                    Content="RANDOM BALANCED BUILD"
                                    ToolTip="Roll a fresh valid archetype and stat spread."
                                    AutomationProperties.Name="Random balanced build" />
                            <StackPanel>
                                <TextBlock Text="CHOOSE YOUR ARCHETYPE" Style="{StaticResource CharacterSectionLabel}" />
                                <TextBlock Text="Every card is a complete, valid starting build. Pick one, then tune it."
                                           Style="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                        <ListBox x:Name="CharacterArchetypeList" Grid.Row="1"
                                 ItemsSource="{Binding Archetypes, Mode=OneWay}"
                                 SelectedItem="{Binding SelectedArchetype, Mode=TwoWay}"
                                 ItemContainerStyle="{StaticResource CharacterArchetypeItem}"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 AutomationProperties.Name="Driver archetypes">
                            <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="11,9" CornerRadius="7" BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Name, Mode=OneWay}" FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Bold" FontSize="13" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="{Binding Description, Mode=OneWay}" TextWrapping="Wrap"
                                                       FontSize="11" Margin="0,5,0,6" Foreground="{DynamicResource TextMutedBrush}" />
                                            <TextBlock Grid.Row="2" Style="{StaticResource Faint}" FontSize="9"
                                                       Text="{Binding PerkIds.Count, Mode=OneWay, StringFormat={}{0} SIGNATURE PERKS}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="ATTRIBUTES"
                     ToolTip="Set seven starting attributes. They shape expectations and career systems; they do not directly make the player car faster.">
                <ScrollViewer x:Name="CharacterAttributeScroll" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled" Focusable="False">
                    <StackPanel>
                        <TextBlock Text="DRIVING ATTRIBUTES" Style="{StaticResource CharacterSectionLabel}" />
                        <TextBlock Text="Pace helps set your starting result target. The other ratings describe your driver and support specific career systems. None of these sliders directly increases player-car speed."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <ItemsControl x:Name="CharacterStatsList" ItemsSource="{Binding Stats}"
                                      ItemTemplate="{StaticResource CharacterStatTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <TextBlock Text="CAREER ATTRIBUTES" Style="{StaticResource CharacterSectionLabel}"
                                   Margin="0,6,0,5" />
                        <TextBlock Text="Marketability affects reputation, contracts and commercial value. Durability affects aging, retirement risk and career longevity."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding MetaStats}"
                                      ItemTemplate="{StaticResource CharacterStatTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem ToolTip="Choose the permanent traits and trade-offs your driver begins with. Career mastery is earned separately after creation.">
                <TabItem.Header>
                    <TextBlock>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Text" Value="PERK DECK" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProgressionV2, Mode=OneWay}" Value="True">
                                        <Setter Property="Text" Value="STARTING TRAITS" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </TabItem.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- One-Trick Pony remains keyboard-visible as soon as that perk is selected. -->
                    <Border Grid.Row="0" Style="{StaticResource AccentCallout}" Margin="0,0,0,9"
                            Visibility="{Binding IsOneTrickSelected, Converter={StaticResource BoolVisible}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,12,0"
                                       Text="ONE-TRICK FOCUS" FontFamily="{StaticResource DisplayFont}"
                                       FontWeight="Bold" FontSize="11" />
                            <ComboBox ItemsSource="{Binding EligibleFlavors}"
                                      SelectedItem="{Binding ChosenFlavor}"
                                      DisplayMemberPath="Label" MinWidth="190"
                                      AutomationProperties.Name="One-Trick focus"
                                      AutomationProperties.HelpText="Choose the rating that receives this trait's special bonus. Later attribute development is limited to that focus.">
                                <ComboBox.ToolTip>
                                    <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                               Text="Choose the rating that receives this trait's special bonus. While One-Trick is active, later attribute development is limited to that focus." />
                                </ComboBox.ToolTip>
                            </ComboBox>
                        </DockPanel>
                    </Border>

                    <!-- V2 keeps the 42 creation-only traits separate from the 90 career mastery
                         skills. Compact rows select one full, wrapping detail surface; no fixed card
                         width and no horizontal text path can truncate supplied prose. -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolVisible}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource AccentCallout}" Padding="10,7" Margin="0,0,0,7">
                            <StackPanel>
                                <TextBlock Text="YOUR STARTING TRAITS" Style="{StaticResource CharacterSectionLabel}" />
                                <TextBlock Text="These traits are locked into your starting identity. They use Creation Points now and are separate from the Skill Points you earn during the career."
                                           Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding CreationTraitSummary, Mode=OneWay}" TextWrapping="Wrap"
                                           FontFamily="{StaticResource MonoFont}" FontSize="10" FontWeight="Bold" />
                                <TextBlock Text="{Binding CreationBudgetSummary, Mode=OneWay}" TextWrapping="Wrap"
                                           Style="{StaticResource Faint}" FontSize="9.5" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <DockPanel Grid.Row="1" Margin="0,0,0,7">
                            <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9">
                                    <Run Text="{Binding CreationTraitCount, Mode=OneWay}" />
                                    <Run Text=" TRAITS" />
                                </TextBlock>
                            </Border>
                            <TextBlock DockPanel.Dock="Left" Text="TRAIT FAMILY" Style="{StaticResource CharacterSectionLabel}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ComboBox x:Name="CharacterV2TraitCategory"
                                      Width="244" MinHeight="36"
                                      ItemsSource="{Binding PerkCategories, Mode=OneWay}"
                                      IsTextSearchEnabled="True" TextSearch.TextPath="DisplayName"
                                      SelectedIndex="0"
                                      HorizontalAlignment="Left"
                                      AutomationProperties.Name="Starting trait family"
                                      AutomationProperties.HelpText="Families only organize the list. Choosing a family does not affect your build.">
                                <ComboBox.ToolTip>
                                    <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                               Text="Families only organize the list. Choosing a family does not affect your build." />
                                </ComboBox.ToolTip>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName, Mode=OneWay}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DockPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.92*" MinWidth="132" />
                                <ColumnDefinition Width="9" />
                                <ColumnDefinition Width="1.38*" MinWidth="150" />
                            </Grid.ColumnDefinitions>

                            <Border Style="{StaticResource Panel}" Padding="6">
                                <ListBox x:Name="CharacterV2TraitList"
                                         ItemsSource="{Binding SelectedItem.Perks, ElementName=CharacterV2TraitCategory, Mode=OneWay}"
                                         SelectedIndex="0" SelectionMode="Single"
                                         ItemContainerStyle="{StaticResource CharacterCompactListItem}"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         AutomationProperties.Name="Starting traits"
                                         AutomationProperties.HelpText="Choose permanent starting traits. Their Creation Point cost applies only while creating this driver.">
                                    <ListBox.ToolTip>
                                        <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                   Text="Choose permanent starting traits. Their Creation Point cost applies only while creating this driver." />
                                    </ListBox.ToolTip>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="7,6" CornerRadius="5" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                              VerticalAlignment="Center" Margin="0,0,5,0"
                                                              AutomationProperties.Name="{Binding Name, Mode=OneWay, StringFormat={}{0} starting trait}"
                                                              AutomationProperties.HelpText="Select or remove this permanent starting trait. Every trait has a benefit and a trade-off." />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name, Mode=OneWay}"
                                                               TextWrapping="Wrap" FontWeight="SemiBold" FontSize="10.5"
                                                               VerticalAlignment="Center" />
                                                    <Border Grid.Column="2" Style="{StaticResource CompactChip}" Margin="5,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <Border.ToolTip>
                                                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                                       Text="{Binding CreationPointHelpText, Mode=OneWay}" />
                                                        </Border.ToolTip>
                                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="8.5">
                                                            <Run Text="{Binding CreationPointLabel, Mode=OneWay}" FontWeight="Bold" />
                                                        </TextBlock>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="10,8">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled" Focusable="False">
                                    <ContentControl Content="{Binding SelectedItem, ElementName=CharacterV2TraitList, Mode=OneWay}">
                                        <ContentControl.ContentTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                                            <Border.ToolTip>
                                                                <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                                           Text="{Binding CreationPointHelpText, Mode=OneWay}" />
                                                            </Border.ToolTip>
                                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontWeight="Bold">
                                                                <Run Text="{Binding CreationPointLabel, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name, Mode=OneWay}" Style="{StaticResource H2}"
                                                                       TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Category, Mode=OneWay}" Style="{StaticResource Eyebrow}"
                                                                       Foreground="{DynamicResource AccentTextBrush}" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                     <TextBlock Text="{Binding Description, Mode=OneWay}" Style="{StaticResource Body}"
                                                                TextWrapping="Wrap" Margin="0,7,0,8" />
                                                     <TextBlock Text="WHAT THIS AFFECTS" Style="{StaticResource CharacterSectionLabel}" />
                                                     <Border Style="{StaticResource Callout}" Padding="7,5" Margin="0,0,0,6">
                                                         <TextBlock TextWrapping="Wrap" FontSize="9.5"
                                                                    Text="EXPECTATION changes the target you are judged against. CAREER changes progression, reputation, contracts, aging or injury. CAR changes player-car weight, power or drag in AMS2." />
                                                     </Border>
                                                     <ItemsControl x:Name="CharacterTraitEffectLines"
                                                                   ItemsSource="{Binding Effects, Mode=OneWay}" Margin="0,0,0,7">
                                                         <ItemsControl.ItemTemplate>
                                                             <DataTemplate>
                                                                 <Border Style="{StaticResource Callout}" Padding="7,5" Margin="0,0,0,4">
                                                                     <DockPanel>
                                                                         <Border DockPanel.Dock="Left" Style="{StaticResource CompactChip}"
                                                                                 Margin="0,0,6,0" VerticalAlignment="Top">
                                                                             <TextBlock Text="{Binding ClassificationLabel, Mode=OneWay}"
                                                                                        FontFamily="{StaticResource MonoFont}"
                                                                                        FontSize="8" FontWeight="Bold"
                                                                                        Foreground="{DynamicResource AccentTextBrush}" />
                                                                         </Border>
                                                                         <StackPanel>
                                                                             <TextBlock Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" />
                                                                             <TextBlock Text="{Binding Condition, Mode=OneWay}"
                                                                                        Visibility="{Binding IsConditional,
                                                                                                             Converter={StaticResource BoolVisible},
                                                                                                             Mode=OneWay}"
                                                                                        Style="{StaticResource Faint}"
                                                                                        TextWrapping="Wrap" Margin="0,2,0,0" />
                                                                         </StackPanel>
                                                                     </DockPanel>
                                                                 </Border>
                                                             </DataTemplate>
                                                         </ItemsControl.ItemTemplate>
                                                     </ItemsControl>
                                                     <TextBlock Text="BENEFITS" Style="{StaticResource CharacterSectionLabel}" />
                                                    <ItemsControl ItemsSource="{Binding Benefits, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock TextWrapping="Wrap" Margin="0,1">
                                                                    <Run Text="+  " FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" />
                                                                    <Run Text="{Binding Mode=OneWay}" />
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="TRADE-OFFS" Style="{StaticResource CharacterSectionLabel}" Margin="0,8,0,4" />
                                                    <ItemsControl ItemsSource="{Binding Drawbacks, Mode=OneWay}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock TextWrapping="Wrap" Margin="0,1">
                                                                    <Run Text="-  " FontWeight="Bold" Foreground="{DynamicResource ErrorBrush}" />
                                                                    <Run Text="{Binding Mode=OneWay}" />
                                                                </TextBlock>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ContentControl.ContentTemplate>
                                    </ContentControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Legacy creation retains its shipped card deck and CP vocabulary. -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolCollapsed}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Panel}" Padding="6">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="PERK FAMILIES"
                                           Style="{StaticResource CharacterSectionLabel}" Margin="6,5,6,8" />
                                <ListBox x:Name="CharacterPerkCategoryList"
                                         ItemsSource="{Binding PerkCategories}" SelectedIndex="0"
                                         Background="Transparent" BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         AutomationProperties.Name="Perk families">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="2">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Perks.Count, StringFormat={}{0} OPTIONS}"
                                                           Style="{StaticResource Faint}" FontSize="9" Margin="0,1,0,0" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <ContentControl Grid.Column="2"
                                        Content="{Binding SelectedItem, ElementName=CharacterPerkCategoryList}">
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <DockPanel Margin="0,0,0,8">
                                            <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                                    Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Perks.Count, StringFormat={}{0} CARDS}" />
                                            </Border>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" Style="{StaticResource H2}" />
                                                <TextBlock Text="Select a card to equip it; selected cards reveal their full trade-off."
                                                           Style="{StaticResource Muted}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </DockPanel>
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled" Focusable="False">
                                            <ItemsControl x:Name="CharacterPerkList" ItemsSource="{Binding Perks}"
                                                          ItemTemplate="{StaticResource CharacterPerkTemplate}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="PROGRESSION"
                     ToolTip="Preview the skills and attribute improvements you can earn after the career begins. Nothing is purchased here."
                     Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolVisible}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource AccentCallout}" Padding="10,7" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="CAREER PROGRESSION" Style="{StaticResource CharacterSectionLabel}" />
                            <TextBlock Text="{Binding ProgressionSummary, Mode=OneWay}"
                                       TextWrapping="Wrap" FontFamily="{StaticResource MonoFont}"
                                       FontWeight="Bold" FontSize="10" />
                            <TextBlock Text="Starting traits are chosen now. During the career, levels and campaign progress earn Skill Points (SP). Spend SP on mastery skills and attribute steps from the Driver screen. This page is preview-only."
                                       Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="1">
                        <TabItem Header="90 MASTERY SKILLS"
                                 ToolTip="Mastery skills add focused expectation, career or car effects. Each has a level gate, prerequisites and an SP cost.">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,7">
                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9">
                                            <Run Text="{Binding MasteryPreviewSkillCount, Mode=OneWay}" />
                                            <Run Text=" SKILLS" />
                                        </TextBlock>
                                    </Border>
                                    <TextBlock DockPanel.Dock="Left" Text="SKILL FAMILY"
                                               Style="{StaticResource CharacterSectionLabel}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="CharacterMasteryFamilyPicker"
                                              ItemsSource="{Binding MasteryPreviewFamilies, Mode=OneWay}"
                                              DisplayMemberPath="Name" SelectedIndex="0"
                                              HorizontalAlignment="Stretch"
                                              AutomationProperties.Name="Career mastery family"
                                              AutomationProperties.HelpText="Choose a family to preview its ten connected mastery skills.">
                                        <ComboBox.ToolTip>
                                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                       Text="Choose a family to preview its ten connected mastery skills." />
                                        </ComboBox.ToolTip>
                                    </ComboBox>
                                </DockPanel>

                                <ContentControl Grid.Row="1"
                                                Content="{Binding SelectedItem, ElementName=CharacterMasteryFamilyPicker}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="1.2*" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="*" MinHeight="92" />
                                                </Grid.RowDefinitions>

                                                <ListBox x:Name="CharacterMasterySkillGraph"
                                                         ItemsSource="{Binding Skills, Mode=OneWay}"
                                                         SelectedIndex="0" SelectionMode="Single"
                                                         ItemContainerStyle="{StaticResource CharacterPreviewNodeItem}"
                                                         Background="{DynamicResource SurfaceAltBrush}"
                                                         BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                         AutomationProperties.Name="Read-only mastery wiring diagram"
                                                         AutomationProperties.HelpText="Preview connected mastery skills, their level gates and Skill Point costs. Skills are purchased later from the Driver screen.">
                                                    <ListBox.ToolTip>
                                                        <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                                   Text="Preview connected mastery skills, their level gates and Skill Point costs. Skills are purchased later from the Driver screen." />
                                                    </ListBox.ToolTip>
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <controls:SkillGraphPanel NodeWidth="128" NodeMinHeight="54"
                                                                                      TierGap="28" RowGap="12" GraphPadding="14"
                                                                                      ConnectorBrush="{DynamicResource EdgeStrongBrush}"
                                                                                      ActiveConnectorBrush="{DynamicResource AccentBrush}"
                                                                                      OwnedConnectorBrush="{DynamicResource SuccessBrush}"
                                                                                      PendingConnectorBrush="{DynamicResource WarningBrush}" />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="7,5" CornerRadius="5" BorderThickness="1">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource EdgeStrongBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="24" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="&#xE9D9;" FontFamily="{StaticResource IconFont}"
                                                                               Foreground="{DynamicResource AccentTextBrush}"
                                                                               FontSize="15" VerticalAlignment="Center"
                                                                               ToolTip="{Binding Name, Mode=OneWay}" />
                                                                    <StackPanel Grid.Column="1">
                                                                        <TextBlock Text="{Binding Name, Mode=OneWay}" TextWrapping="Wrap"
                                                                                   FontWeight="SemiBold" FontSize="9.5" />
                                                                        <TextBlock Style="{StaticResource Faint}" FontSize="8">
                                                                            <Run Text="T" /><Run Text="{Binding Tier, Mode=OneWay}" />
                                                                            <Run Text="  ·  L" /><Run Text="{Binding UnlockLevel, Mode=OneWay}" />
                                                                            <Run Text="  ·  " /><Run Text="{Binding Cost, Mode=OneWay}" /><Run Text=" SP" />
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <Border Grid.Row="2" Style="{StaticResource Panel}" Padding="10,7">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled" Focusable="False">
                                                        <ContentControl Content="{Binding SelectedItem, ElementName=CharacterMasterySkillGraph}">
                                                            <ContentControl.ContentTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel>
                                                                        <DockPanel>
                                                                            <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                                                                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold">
                                                                                    <Run Text="L" /><Run Text="{Binding UnlockLevel, Mode=OneWay}" />
                                                                                    <Run Text="  ·  " /><Run Text="{Binding Cost, Mode=OneWay}" /><Run Text=" SP" />
                                                                                </TextBlock>
                                                                            </Border>
                                                                            <TextBlock Text="{Binding Name, Mode=OneWay}" Style="{StaticResource H2}"
                                                                                       TextWrapping="Wrap" />
                                                                        </DockPanel>
                                                                        <TextBlock Text="{Binding Description, Mode=OneWay}" Style="{StaticResource Body}"
                                                                                   TextWrapping="Wrap" Margin="0,5,0,7" />
                                                                        <ItemsControl ItemsSource="{Binding Effects, Mode=OneWay}">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <DockPanel Margin="0,1">
                                                                                        <Border DockPanel.Dock="Left" Style="{StaticResource CompactChip}" Margin="0,0,6,0">
                                                                                            <TextBlock Text="{Binding ClassificationLabel, Mode=OneWay}"
                                                                                                       FontFamily="{StaticResource MonoFont}" FontSize="8" FontWeight="Bold" />
                                                                                        </Border>
                                                                                        <TextBlock Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" />
                                                                                    </DockPanel>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                        <ItemsControl ItemsSource="{Binding RequiresLabels, Mode=OneWay}" Margin="0,5,0,0">
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBlock TextWrapping="Wrap" Style="{StaticResource Faint}">
                                                                                        <Run Text="REQUIRES  " FontWeight="Bold" />
                                                                                        <Run Text="{Binding Mode=OneWay}" />
                                                                                    </TextBlock>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ContentControl.ContentTemplate>
                                                        </ContentControl>
                                                    </ScrollViewer>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </Grid>
                        </TabItem>

                        <TabItem Header="ATTRIBUTE DEVELOPMENT"
                                 ToolTip="An attribute rail is the step-by-step path for raising one attribute after creation. Every step has a level gate, prerequisite and SP cost.">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <DockPanel Margin="0,0,0,7">
                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9">
                                            <Run Text="{Binding MasteryPreviewAttributeNodeCount, Mode=OneWay}" />
                                            <Run Text=" STEPS  ·  " />
                                            <Run Text="{Binding MasteryPreviewAttributeCost, Mode=OneWay}" />
                                            <Run Text=" SP" />
                                        </TextBlock>
                                    </Border>
                                    <TextBlock DockPanel.Dock="Left" Text="CHOOSE AN ATTRIBUTE"
                                               Style="{StaticResource CharacterSectionLabel}"
                                               VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ComboBox x:Name="CharacterAttributeRailPicker"
                                              ItemsSource="{Binding MasteryPreviewAttributeRails, Mode=OneWay}"
                                              DisplayMemberPath="Name" SelectedIndex="0"
                                              HorizontalAlignment="Stretch"
                                              AutomationProperties.Name="Career attribute rail"
                                              AutomationProperties.HelpText="Choose an attribute to preview its step-by-step career development path.">
                                        <ComboBox.ToolTip>
                                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                       Text="Choose an attribute to preview its step-by-step career development path. Every step has a level gate, prerequisite and Skill Point cost." />
                                        </ComboBox.ToolTip>
                                    </ComboBox>
                                </DockPanel>

                                <ContentControl Grid.Row="1"
                                                Content="{Binding SelectedItem, ElementName=CharacterAttributeRailPicker}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="8" />
                                                    <RowDefinition Height="Auto" MinHeight="74" />
                                                </Grid.RowDefinitions>
                                                <DockPanel Margin="2,0,2,5">
                                                    <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                                        <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9">
                                                            <Run Text="{Binding StepCount, Mode=OneWay}" /><Run Text=" STEPS  ·  " />
                                                            <Run Text="{Binding TotalCost, Mode=OneWay}" /><Run Text=" SP  ·  CAP " />
                                                            <Run Text="{Binding CapValue, Mode=OneWay, StringFormat={}{0:0.00}}" />
                                                        </TextBlock>
                                                    </Border>
                                                    <TextBlock Text="{Binding FamilyLabel, Mode=OneWay}" Style="{StaticResource Eyebrow}"
                                                               Foreground="{DynamicResource AccentTextBrush}" VerticalAlignment="Center" />
                                                </DockPanel>

                                                <ListBox x:Name="CharacterAttributeNodeGraph" Grid.Row="1"
                                                         ItemsSource="{Binding Nodes, Mode=OneWay}"
                                                         SelectedIndex="0" SelectionMode="Single"
                                                         ItemContainerStyle="{StaticResource CharacterPreviewNodeItem}"
                                                         Background="{DynamicResource SurfaceAltBrush}"
                                                         BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                         AutomationProperties.Name="Read-only attribute wiring diagram"
                                                         AutomationProperties.HelpText="Preview the level gates and Skill Point cost for each step in this attribute path. Steps are purchased later from the Driver screen.">
                                                    <ListBox.ToolTip>
                                                        <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                                                   Text="Preview the level gates and Skill Point cost for each step in this attribute path. Steps are purchased later from the Driver screen." />
                                                    </ListBox.ToolTip>
                                                    <ListBox.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <controls:SkillGraphPanel NodeWidth="108" NodeMinHeight="48"
                                                                                      TierGap="22" RowGap="8" GraphPadding="12"
                                                                                      ConnectorBrush="{DynamicResource EdgeStrongBrush}"
                                                                                      ActiveConnectorBrush="{DynamicResource AccentBrush}" />
                                                        </ItemsPanelTemplate>
                                                    </ListBox.ItemsPanel>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="6,4" CornerRadius="5" BorderThickness="1">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource EdgeStrongBrush}" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name, Mode=OneWay}" TextWrapping="Wrap"
                                                                               FontWeight="SemiBold" FontSize="9" />
                                                                    <TextBlock Style="{StaticResource Faint}" FontSize="8">
                                                                        <Run Text="L" /><Run Text="{Binding UnlockLevel, Mode=OneWay}" />
                                                                        <Run Text="  ·  " /><Run Text="{Binding Cost, Mode=OneWay}" /><Run Text=" SP" />
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <Border Grid.Row="3" Style="{StaticResource Panel}" Padding="10,7">
                                                    <ContentControl Content="{Binding SelectedItem, ElementName=CharacterAttributeNodeGraph}">
                                                        <ContentControl.ContentTemplate>
                                                            <DataTemplate>
                                                                <StackPanel>
                                                                    <DockPanel>
                                                                        <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}" Margin="8,0,0,0">
                                                                            <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold">
                                                                                <Run Text="+" /><Run Text="{Binding StepValue, Mode=OneWay, StringFormat={}{0:0.00}}" />
                                                                                <Run Text="  ·  " /><Run Text="{Binding Cost, Mode=OneWay}" /><Run Text=" SP" />
                                                                            </TextBlock>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Name, Mode=OneWay}" Style="{StaticResource H2}"
                                                                                   TextWrapping="Wrap" />
                                                                    </DockPanel>
                                                                    <ItemsControl ItemsSource="{Binding Effects, Mode=OneWay}" Margin="0,4,0,0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <DockPanel Margin="0,1">
                                                                                    <Border DockPanel.Dock="Left" Style="{StaticResource CompactChip}" Margin="0,0,6,0">
                                                                                        <TextBlock Text="{Binding ClassificationLabel, Mode=OneWay}"
                                                                                                   FontFamily="{StaticResource MonoFont}" FontSize="8" FontWeight="Bold" />
                                                                                    </Border>
                                                                                    <TextBlock Text="{Binding Text, Mode=OneWay}" TextWrapping="Wrap" />
                                                                                </DockPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ContentControl.ContentTemplate>
                                                    </ContentControl>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <TabItem Header="ADVANCED"
                     ToolTip="See exactly how the Companion sets your result target and which ratings are written to AMS2.">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Focusable="False">
                    <StackPanel MaxWidth="760" HorizontalAlignment="Left">
                        <Border Style="{StaticResource AccentCallout}" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="HOW YOUR RESULT TARGET IS SET" FontFamily="{StaticResource DisplayFont}"
                                           FontWeight="Bold" FontSize="12"
                                           Foreground="{DynamicResource AccentTextBrush}" />
                                <TextBlock Style="{StaticResource Body}" Margin="0,5,0,0" TextWrapping="Wrap"
                                           Text="{Binding ExpectedPerformanceBasisSummary, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="WHAT SETS THE TARGET" Style="{StaticResource CharacterSectionLabel}" />
                        <ItemsControl ItemsSource="{Binding ExpectedPerformanceComponents, Mode=OneWay}"
                                      Margin="0,0,0,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CharacterTelemetryCard}" Padding="10,7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="76" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Percent, Mode=OneWay, StringFormat={}{0}%}"
                                                           FontFamily="{StaticResource MonoFont}" FontSize="18"
                                                           FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}" />
                                                <TextBlock Text="{Binding Label, Mode=OneWay}" Style="{StaticResource Eyebrow}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <ProgressBar Style="{StaticResource RatingBar}" Height="5"
                                                             Minimum="0" Maximum="100" Value="{Binding Percent, Mode=OneWay}" />
                                                <TextBlock Text="{Binding Description, Mode=OneWay}" Style="{StaticResource Muted}"
                                                           TextWrapping="Wrap" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Style="{StaticResource Panel}" Padding="10,7" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="HOW YOUR RACE RECORD CHANGES IT" Style="{StaticResource CharacterSectionLabel}" />
                                <TextBlock Text="{Binding ExpectedPerformanceCalibrationSummary, Mode=OneWay}"
                                           Style="{StaticResource Body}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="RATINGS WRITTEN TO AMS2" Style="{StaticResource CharacterSectionLabel}" />
                        <TextBlock Text="Only Pace helps set your starting result target. The other fields describe your driver and are shown for transparency. AMS2 does not use these AI ratings to make the human-driven car faster."
                                   Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,7" />
                        <ItemsControl ItemsSource="{Binding Stats, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource CharacterTelemetryCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label, Mode=OneWay}" FontFamily="{StaticResource DisplayFont}"
                                                       FontWeight="Bold" FontSize="11" />
                                            <TextBlock Grid.Column="1" Text="{Binding WrittenPreview, Mode=OneWay}"
                                                       FontFamily="{StaticResource MonoFont}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Persistent live budget: scannable tiles replace the old single dense sentence. -->
        <Border x:Name="CharacterBudgetBar" Grid.Row="2" Style="{StaticResource Panel}"
                Padding="9" Margin="0,10,0,0">
            <Grid>
                <!-- V2 uses a compact 2x2 summary board so the minimum window and 130% scale never
                     squeeze four non-wrapping columns into unreadable shards. -->
                <Grid Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolVisible}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="CharacterDnaStatus" Grid.Row="0" Grid.Column="0"
                            Style="{StaticResource CompactChip}" Margin="0,0,4,4"
                            AutomationProperties.Name="Racing DNA status"
                            AutomationProperties.HelpText="Permanent identity; it is not removed by a skill-tree reset.">
                        <Border.ToolTip>
                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                       Text="Permanent identity; it is not removed by a skill-tree reset." />
                        </Border.ToolTip>
                        <StackPanel>
                            <TextBlock Text="DNA" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding RacingDnaSummary, Mode=OneWay}" TextWrapping="Wrap"
                                       FontSize="9.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="CharacterTraitStatus" Grid.Row="0" Grid.Column="1"
                            Style="{StaticResource CompactChip}" Margin="4,0,0,4"
                            AutomationProperties.Name="Starting traits and Creation Points status"
                            AutomationProperties.HelpText="Creation Points only shape this starting build. Unused points never become career Skill Points.">
                        <Border.ToolTip>
                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                       Text="Creation Points only shape this starting build. Unused points are forfeited and never become career Skill Points." />
                        </Border.ToolTip>
                        <StackPanel>
                            <TextBlock Text="STARTING TRAITS &amp; CREATION POINTS" Style="{StaticResource Eyebrow}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding CreationTraitSummary, Mode=OneWay}" TextWrapping="Wrap"
                                       FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold" />
                            <TextBlock Text="{Binding CreationBudgetSummary, Mode=OneWay}" TextWrapping="Wrap"
                                       Style="{StaticResource Faint}" FontSize="8.5" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="CharacterAttributeStatus" Grid.Row="1" Grid.Column="0"
                            Style="{StaticResource CompactChip}" Margin="0,4,4,0"
                            AutomationProperties.Name="Starting attribute status"
                            AutomationProperties.HelpText="You may redistribute starting values freely, but their combined total cannot exceed the displayed limit.">
                        <Border.ToolTip>
                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                       Text="You may redistribute starting values freely, but their combined total cannot exceed the displayed limit." />
                        </Border.ToolTip>
                        <StackPanel>
                            <TextBlock Text="STARTING ATTRIBUTES" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding AttributeBuildSummary, Mode=OneWay}" TextWrapping="Wrap"
                                       FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold" />
                            <ProgressBar Style="{StaticResource RatingBar}" Height="4" Margin="0,4,0,0"
                                         Minimum="0" Maximum="{Binding StatCap, Mode=OneWay}"
                                         Value="{Binding StatTotal, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="CharacterReadyStatus" Grid.Row="1" Grid.Column="1" Padding="8,5" CornerRadius="4"
                            BorderThickness="1" Margin="4,4,0,0"
                            AutomationProperties.Name="Ready to continue status"
                            AutomationProperties.HelpText="Complete every required choice and keep traits and attributes within their starting limits to continue.">
                        <Border.ToolTip>
                            <TextBlock MaxWidth="340" TextWrapping="Wrap"
                                       Text="Complete every required choice and keep traits and attributes within their starting limits to continue." />
                        </Border.ToolTip>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid, Mode=OneWay}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="READY TO CONTINUE" Style="{StaticResource Eyebrow}" />
                            <TextBlock Text="{Binding BuildReadinessSummary, Mode=OneWay}" TextWrapping="Wrap"
                                       FontFamily="{StaticResource MonoFont}" FontSize="9" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid, Mode=OneWay}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="4,6,4,0"
                               Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Text="{Binding Invalidity, Mode=OneWay}"
                               Visibility="{Binding Invalidity, Mode=OneWay, Converter={StaticResource NullCollapsed}}" />
                </Grid>

                <!-- Legacy status bar remains untouched in behavior and vocabulary. -->
                <Grid Visibility="{Binding IsProgressionV2, Mode=OneWay, Converter={StaticResource BoolCollapsed}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="TALENT" Style="{StaticResource Eyebrow}" />
                                <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource MonoFont}"
                                           FontWeight="Bold">
                                    <Run Text="{Binding StatTotal, Mode=OneWay, StringFormat={}{0:0.00}}" />
                                    <Run Text=" / " /><Run Text="{Binding StatCap, Mode=OneWay, StringFormat={}{0:0.00}}" />
                                </TextBlock>
                            </DockPanel>
                            <ProgressBar Style="{StaticResource RatingBar}" Height="4" Margin="0,5,0,0"
                                         Minimum="0" Maximum="{Binding StatCap, Mode=OneWay}"
                                         Value="{Binding StatTotal, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                        <StackPanel>
                            <TextBlock Text="PERKS EQUIPPED" Style="{StaticResource Eyebrow}" />
                            <TextBlock FontFamily="{StaticResource MonoFont}" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentTextBrush}">
                                <Run Text="{Binding SelectedPerkCount, Mode=OneWay}" />
                                <Run Text=" / " /><Run Text="{Binding MaxPerks, Mode=OneWay, TargetNullValue=NO CAP}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CompactChip}" Margin="0,0,7,0">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="CP REMAINING" Style="{StaticResource Eyebrow}" />
                                <TextBlock HorizontalAlignment="Right" FontFamily="{StaticResource MonoFont}"
                                           FontWeight="Bold" Foreground="{DynamicResource AccentTextBrush}"
                                           Text="{Binding RemainingCp, Mode=OneWay}" />
                            </DockPanel>
                            <TextBlock Style="{StaticResource Faint}" FontSize="9">
                                <Run Text="{Binding NetCpSpend, Mode=OneWay}" /><Run Text=" / " />
                                <Run Text="{Binding MaxPerkPoints, Mode=OneWay}" /><Run Text=" SPENT  -  BUDGET " />
                                <Run Text="{Binding Budget, Mode=OneWay}" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="8,5" CornerRadius="4" BorderThickness="1">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsValid, Mode=OneWay}" Value="False">
                                        <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock FontFamily="{StaticResource PixelFont}" FontSize="9" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                        <Setter Property="Text" Value="BUILD READY" />
                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid, Mode=OneWay}" Value="False">
                                                <Setter Property="Text" Value="FIX BUILD" />
                                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock FontSize="8" HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Faint}">
                                        <Setter Property="Text" Value="NEXT STEP UNLOCKED" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid, Mode=OneWay}" Value="False">
                                                <Setter Property="Text" Value="ADJUST TO CONTINUE" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.ColumnSpan="4" Margin="4,7,4,0"
                               Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap"
                               FontWeight="SemiBold" Text="{Binding Invalidity, Mode=OneWay}"
                               Visibility="{Binding Invalidity, Mode=OneWay, Converter={StaticResource NullCollapsed}}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
