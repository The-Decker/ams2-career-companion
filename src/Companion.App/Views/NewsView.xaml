<UserControl x:Class="Companion.App.Views.NewsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:audio="clr-namespace:Companion.App.Audio"
             xmlns:views="clr-namespace:Companion.App.Views"
             xmlns:smgp="clr-namespace:Companion.Core.Smgp;assembly=Companion.Core"
             Focusable="False">
    <UserControl.InputBindings>
        <KeyBinding Key='Escape' Command='{Binding CloseArticleCommand}' />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <!-- Live bookmark state for the reader toggle (declared in NewsView.xaml.cs). -->
        <views:NewsBookmarkStateConverter x:Key='NewsBookmarkState' />

        <!-- One editorial badge row shared by every story card and the reader. Every chip
             carries its own text so no meaning ever rides on colour alone; the provenance chip
             is deliberately the only accent-framed one - it is the visible boundary between
             simulated coverage and the real historical record. -->
        <DataTemplate x:Key='NewsStoryBadgesTemplate'>
            <WrapPanel>
                <Border Style='{StaticResource CompactChip}' Margin='0,6,6,0'
                        ToolTip='The desk that filed this story'
                        Visibility='{Binding HasDesk, Converter={StaticResource BoolVisible}}'>
                    <StackPanel Orientation='Horizontal'>
                        <Border Background='{DynamicResource AccentDimBrush}' CornerRadius='3'
                                Padding='4,1' Margin='0,0,6,0' VerticalAlignment='Center'>
                            <TextBlock Text='{Binding DeskMonogram, Mode=OneWay}' Style='{StaticResource Eyebrow}'
                                       Foreground='{DynamicResource AccentTextBrush}' />
                        </Border>
                        <TextBlock Text='{Binding DeskName, Mode=OneWay}' Style='{StaticResource Faint}'
                                   FontSize='11' VerticalAlignment='Center' />
                    </StackPanel>
                </Border>
                <Border Style='{StaticResource CompactChip}' Margin='0,6,6,0'
                        Visibility='{Binding HasStatus, Converter={StaticResource BoolVisible}}'>
                    <TextBlock Text='{Binding StatusLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                </Border>
                <Border Style='{StaticResource ProvenanceChip}' Margin='0,6,6,0'
                        ToolTip='Provenance: whether this coverage is from your simulated career universe or the real historical record'
                        Visibility='{Binding HasProvenance, Converter={StaticResource BoolVisible}}'>
                    <StackPanel Orientation='Horizontal'>
                        <TextBlock Text='&#xE946;' FontFamily='{StaticResource IconFont}' FontSize='10'
                                   Foreground='{DynamicResource AccentTextBrush}' Margin='0,0,5,0'
                                   VerticalAlignment='Center' />
                        <TextBlock Text='{Binding ProvenanceLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}'
                                   Foreground='{DynamicResource AccentTextBrush}' />
                    </StackPanel>
                </Border>
                <Border Style='{StaticResource CompactChip}' Margin='0,6,6,0'
                        ToolTip='Editorial layout tier'
                        Visibility='{Binding HasTier, Converter={StaticResource BoolVisible}}'>
                    <TextBlock Text='{Binding TierLabel, Mode=OneWay}' Style='{StaticResource Mono}' FontSize='10' />
                </Border>
                <StackPanel Orientation='Horizontal' Margin='0,6,6,0' VerticalAlignment='Center'
                            ToolTip='You have not opened this story yet'
                            Visibility='{Binding IsUnread, Converter={StaticResource BoolVisible}}'>
                    <Ellipse Width='7' Height='7' Fill='{DynamicResource AccentBrush}'
                             Margin='0,0,5,0' VerticalAlignment='Center' />
                    <TextBlock Text='NEW' Style='{StaticResource Eyebrow}'
                               Foreground='{DynamicResource AccentTextBrush}' />
                </StackPanel>
                <TextBlock Text='{Binding ReadingTimeLabel, Mode=OneWay}' Style='{StaticResource Mono}'
                           FontSize='10' Foreground='{DynamicResource TextMutedBrush}' Margin='0,6,6,0'
                           VerticalAlignment='Center'
                           Visibility='{Binding ReadingTimeLabel, Mode=OneWay, Converter={StaticResource StringVisible}}' />
            </WrapPanel>
        </DataTemplate>

        <!-- Tier-driven front-page dispatch. LEAD/FEATURED/STANDARD/BRIEF are the only inputs
             allowed to change scale; subject, category and importance never randomize layout. -->
        <DataTemplate x:Key='NewsSecondaryStoryTemplate'>
            <Button x:Name='SecondaryStoryButton' Style='{StaticResource SubtleButton}'
                    Padding='0' Margin='0,0,10,10'
                    Width='{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource WidthFraction}, ConverterParameter=0.32|280|480}'
                    VerticalAlignment='Top'
                    HorizontalContentAlignment='Stretch' VerticalContentAlignment='Stretch'
                    Command='{Binding DataContext.OpenArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}'
                    CommandParameter='{Binding}' Click='OnStoryOpened'
                    audio:SoundAssist.Cue='Navigate'
                    AutomationProperties.Name='{Binding Headline, Mode=OneWay}'
                    AutomationProperties.HelpText='{Binding TierLabel, Mode=OneWay}'>
                <Border Style='{StaticResource Card}' Padding='0' ClipToBounds='True'>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height='Auto' />
                            <RowDefinition Height='Auto' />
                        </Grid.RowDefinitions>
                        <Grid x:Name='SecondaryStoryArt' Height='104'
                              Background='{DynamicResource SurfaceAltBrush}'>
                            <Border Style='{StaticResource AssetPlaceholderFrame}' Margin='8'>
                                <TextBlock Text='&#xE8A5;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='30' />
                            </Border>
                            <Image Stretch='UniformToFill'
                                   Source='{Binding TrackArtKey, Mode=OneWay, Converter={StaticResource TrackBannerImage}}'
                                   Visibility='{Binding HasTrackArt, Converter={StaticResource BoolVisible}}' />
                            <Image Stretch='UniformToFill'
                                   Source='{Binding TeamArtKey, Mode=OneWay, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}'
                                   Visibility='{Binding HasTeamArt, Converter={StaticResource BoolVisible}}' />
                            <Image Stretch='UniformToFill' HorizontalAlignment='Right' Width='126'
                                   Source='{Binding DriverPortraitKey, Mode=OneWay, Converter={StaticResource AssetImage}, ConverterParameter=portraits}'
                                   Visibility='{Binding HasDriverPortrait, Converter={StaticResource BoolVisible}}' />
                            <Border VerticalAlignment='Bottom' Background='{DynamicResource ScrimBrush}' Padding='8,5'>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock='Right' Text='{Binding ImportanceLabel, Mode=OneWay}'
                                               Style='{StaticResource Eyebrow}' Foreground='{DynamicResource TextBrush}' />
                                    <TextBlock Text='{Binding DateLabel, Mode=OneWay}' Style='{StaticResource Mono}' FontSize='10'
                                               Foreground='{DynamicResource TextBrush}' />
                                </DockPanel>
                            </Border>
                        </Grid>
                        <StackPanel x:Name='SecondaryStoryBody' Grid.Row='1' Margin='12,11,12,13'>
                            <DockPanel LastChildFill='True'>
                                <Border DockPanel.Dock='Right' Style='{StaticResource CompactChip}' Margin='8,0,0,0'>
                                    <TextBlock Text='{Binding RoundLabel, Mode=OneWay}' Style='{StaticResource Mono}' FontSize='10' />
                                </Border>
                                <Grid>
                                    <!-- the fine editorial category wins over the coarse bucket when present -->
                                    <TextBlock Text='{Binding CategoryLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}'
                                               Foreground='{DynamicResource AccentTextBrush}'
                                               Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolCollapsed}}' />
                                    <TextBlock Text='{Binding CategoryDetail, Mode=OneWay}' Style='{StaticResource Eyebrow}'
                                               Foreground='{DynamicResource AccentTextBrush}'
                                               Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolVisible}}' />
                                </Grid>
                            </DockPanel>
                            <TextBlock x:Name='SecondaryStoryHeadline'
                                       Text='{Binding Headline, Mode=OneWay}' FontFamily='{StaticResource DisplayFont}'
                                       FontWeight='SemiBold' FontSize='16' TextWrapping='Wrap' TextTrimming='None'
                                       Margin='0,6,0,0' />
                            <WrapPanel x:Name='SecondaryStoryIdentity' Margin='0,5,0,0'>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,6,0'
                                        Visibility='{Binding HasDriver, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding DriverName}' FontSize='11' />
                                </Border>
                                <Border Style='{StaticResource CompactChip}'
                                        Visibility='{Binding HasTeam, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding TeamName}' FontSize='11' />
                                </Border>
                            </WrapPanel>
                            <TextBlock x:Name='SecondaryStoryDeck' Text='{Binding Deck, Mode=OneWay}'
                                       Style='{StaticResource Muted}' FontStyle='Italic'
                                       TextWrapping='Wrap' TextTrimming='WordEllipsis' MaxHeight='42'
                                       Margin='0,5,0,0' Visibility='Collapsed' />
                            <TextBlock x:Name='SecondaryStoryStandfirst'
                                       Text='{Binding Standfirst, Mode=OneWay}' Style='{StaticResource Muted}'
                                       TextWrapping='Wrap' TextTrimming='WordEllipsis' MaxHeight='54' Margin='0,5,0,0'
                                       Visibility='Collapsed' />
                            <ContentControl Focusable='False' IsTabStop='False' Content='{Binding}'
                                            ContentTemplate='{StaticResource NewsStoryBadgesTemplate}' />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
            <DataTemplate.Triggers>
                <DataTrigger Binding='{Binding TierLabel}' Value='LEAD'>
                    <Setter TargetName='SecondaryStoryArt' Property='Height' Value='190' />
                    <Setter TargetName='SecondaryStoryHeadline' Property='FontSize' Value='24' />
                    <Setter TargetName='SecondaryStoryHeadline' Property='FontWeight' Value='Bold' />
                    <Setter TargetName='SecondaryStoryBody' Property='Margin' Value='16,14,16,17' />
                </DataTrigger>
                <DataTrigger Binding='{Binding TierLabel}' Value='FEATURED'>
                    <Setter TargetName='SecondaryStoryArt' Property='Height' Value='154' />
                    <Setter TargetName='SecondaryStoryHeadline' Property='FontSize' Value='20' />
                    <Setter TargetName='SecondaryStoryBody' Property='Margin' Value='14,12,14,15' />
                </DataTrigger>
                <DataTrigger Binding='{Binding TierLabel}' Value='STANDARD'>
                    <Setter TargetName='SecondaryStoryArt' Property='Height' Value='104' />
                    <Setter TargetName='SecondaryStoryHeadline' Property='FontSize' Value='16' />
                </DataTrigger>
                <DataTrigger Binding='{Binding TierLabel}' Value='BRIEF'>
                    <Setter TargetName='SecondaryStoryArt' Property='Visibility' Value='Collapsed' />
                    <Setter TargetName='SecondaryStoryIdentity' Property='Visibility' Value='Collapsed' />
                    <Setter TargetName='SecondaryStoryHeadline' Property='FontSize' Value='14.5' />
                    <Setter TargetName='SecondaryStoryBody' Property='Margin' Value='11,9,11,10' />
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding='{Binding TierLabel}' Value='LEAD' />
                        <Condition Binding='{Binding HasDeck}' Value='True' />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName='SecondaryStoryDeck' Property='Visibility' Value='Visible' />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding='{Binding TierLabel}' Value='FEATURED' />
                        <Condition Binding='{Binding HasDeck}' Value='True' />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName='SecondaryStoryDeck' Property='Visibility' Value='Visible' />
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding='{Binding TierLabel}' Value='FEATURED' />
                        <Condition Binding='{Binding HasStandfirst}' Value='True' />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName='SecondaryStoryStandfirst' Property='Visibility' Value='Visible' />
                </MultiDataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Dense all-story row for searching the complete deterministic archive. -->
        <DataTemplate x:Key='NewsArchiveStoryTemplate'>
            <Button Style='{StaticResource SubtleButton}' Padding='0' Margin='0,0,0,8'
                    HorizontalContentAlignment='Stretch'
                    Command='{Binding DataContext.OpenArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}'
                    CommandParameter='{Binding}' Click='OnStoryOpened'
                    audio:SoundAssist.Cue='Navigate'
                    AutomationProperties.Name='{Binding Headline, Mode=OneWay}'>
                <Border Style='{StaticResource Card}' Padding='0' ClipToBounds='True'>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width='132' />
                            <ColumnDefinition Width='*' />
                        </Grid.ColumnDefinitions>
                        <Grid Background='{DynamicResource SurfaceAltBrush}'>
                            <Border Style='{StaticResource AssetPlaceholderFrame}' Margin='7'>
                                <TextBlock Text='&#xE8A5;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='26' />
                            </Border>
                            <Image Stretch='UniformToFill'
                                   Source='{Binding TeamArtKey, Mode=OneWay, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}'
                                   Visibility='{Binding HasTeamArt, Converter={StaticResource BoolVisible}}' />
                            <Image Stretch='UniformToFill'
                                   Source='{Binding DriverPortraitKey, Mode=OneWay, Converter={StaticResource AssetImage}, ConverterParameter=portraits}'
                                   Visibility='{Binding HasDriverPortrait, Converter={StaticResource BoolVisible}}' />
                        </Grid>
                        <StackPanel Grid.Column='1' Margin='13,10,14,11'>
                            <DockPanel LastChildFill='True'>
                                <WrapPanel DockPanel.Dock='Right' Margin='10,0,0,0'>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,5,0'>
                                        <TextBlock Text='{Binding ImportanceLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}'
                                            Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolCollapsed}}'>
                                        <TextBlock Text='{Binding CategoryLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}'
                                            Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolVisible}}'>
                                        <TextBlock Text='{Binding CategoryDetail, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                </WrapPanel>
                                <TextBlock Text='{Binding DateLabel, Mode=OneWay}' Style='{StaticResource Mono}' FontSize='10.5'
                                           Foreground='{DynamicResource TextMutedBrush}' />
                            </DockPanel>
                            <TextBlock Text='{Binding Headline, Mode=OneWay}' FontFamily='{StaticResource DisplayFont}'
                                       FontWeight='SemiBold' FontSize='16' TextWrapping='Wrap' TextTrimming='None'
                                       Margin='0,6,0,0' />
                            <TextBlock Text='{Binding Standfirst, Mode=OneWay}' Style='{StaticResource Muted}'
                                       TextWrapping='Wrap' TextTrimming='WordEllipsis' MaxHeight='40' Margin='0,4,0,0'
                                       Visibility='{Binding HasStandfirst, Converter={StaticResource BoolVisible}}' />
                            <ContentControl Focusable='False' IsTabStop='False' Content='{Binding}'
                                            ContentTemplate='{StaticResource NewsStoryBadgesTemplate}' />
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
    <DockPanel Visibility='Collapsed' IsHitTestVisible='False'>
        <!-- header: pop-out to an always-on-top companion window (decision 1: "own windows") -->
        <Border DockPanel.Dock="Top" Padding="24,16,20,10">
            <DockPanel>
                <Button x:Name="LegacyPopOutButton" DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                        Click="OnPopOut" Padding="8,4"
                        ToolTip="Pop the retired news control out into a companion window"
                        AutomationProperties.Name="Pop news out into its own window">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8A7;" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,7,0" />
                        <TextBlock Text="Pop out" />
                    </StackPanel>
                </Button>
                <StackPanel>
                    <TextBlock Text="PADDOCK DISPATCH" Style="{StaticResource H1}" />
                    <TextBlock Text="The latest wire reports from inside the championship"
                               Style="{StaticResource Muted}" Margin="0,3,0,0" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="24,4,24,20" MaxWidth="1180" HorizontalAlignment="Stretch">
            <!-- Empty only when BOTH the legacy journal feed and Task-4 SMGP wire are empty. -->
            <Border Padding="20" HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Panel}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsEmpty}" Value="True" />
                                    <Condition Binding="{Binding HasItems, ElementName=SmgpDispatchList}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE7BA;" FontFamily="{StaticResource IconFont}" FontSize="28"
                               Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,14,0"
                               VerticalAlignment="Center" />
                    <StackPanel>
                        <TextBlock Text="THE WIRE IS QUIET" Style="{StaticResource Eyebrow}" />
                        <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" MaxWidth="540"
                                   Margin="0,3,0,0"
                                   Text="Run a race and the paddock starts talking. Every dispatch will remain here in your season archive." />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Task 4: the actual SMGP living world, read from the public session projection.
                         RoundText is the refresh token after each fold. A pop-out has no Hub ancestor,
                         so it gracefully retains the legacy journal cards below. -->
                    <TextBlock Text="SMGP WORLD WIRE" Style="{StaticResource Eyebrow}" Margin="1,0,0,7"
                               Foreground="{DynamicResource AccentTextBrush}"
                               Visibility="{Binding HasItems, ElementName=SmgpDispatchList, Converter={StaticResource BoolVisible}}" />
                    <ItemsControl x:Name="SmgpDispatchList">
                        <ItemsControl.ItemsSource>
                            <MultiBinding Converter="{StaticResource SmgpDispatches}">
                                <Binding Path="DataContext.Home.Session"
                                         RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                                <Binding Path="DataContext.Home.RoundText"
                                         RelativeSource="{RelativeSource AncestorType={x:Type views:HubView}}" />
                                <Binding Path="Tag.Home.Session"
                                         RelativeSource="{RelativeSource AncestorType=Window}" />
                                <Binding Path="Tag.Home.RoundText"
                                         RelativeSource="{RelativeSource AncestorType=Window}" />
                            </MultiBinding>
                        </ItemsControl.ItemsSource>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Panel}" Padding="0" Margin="0,0,0,10"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="128" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpDispatchKind.Milestone}">
                                                            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpDispatchKind.Setback}">
                                                            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpDispatchKind.RivalWatch}">
                                                            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static smgp:SmgpDispatchKind.TitleRace}">
                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <Grid Grid.Column="1" Width="112" Height="88" Margin="10,12,6,12">
                                            <Border Style="{StaticResource AssetPlaceholderFrame}">
                                                <TextBlock Text="&#xE8A5;" Style="{StaticResource AssetPlaceholderGlyph}"
                                                           FontSize="30" />
                                            </Border>
                                            <Border CornerRadius="5" ClipToBounds="True">
                                                <Image Stretch="UniformToFill"
                                                       Source="{Binding TeamArtKey, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}"
                                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                            </Border>
                                            <Border CornerRadius="5" ClipToBounds="True">
                                                <Image Stretch="UniformToFill"
                                                       Source="{Binding DriverArtKey, Converter={StaticResource AssetImage}, ConverterParameter=portraits}"
                                                       Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Source, Converter={StaticResource NullCollapsed}}" />
                                            </Border>
                                        </Grid>
                                        <StackPanel Grid.Column="2" Margin="8,12,16,13">
                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                                        Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding Kind}" Style="{StaticResource Eyebrow}" />
                                                </Border>
                                                <TextBlock Text="{Binding WhenLabel}" Style="{StaticResource Mono}"
                                                           FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding Headline}" FontFamily="{StaticResource DisplayFont}"
                                                       FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"
                                                       TextTrimming="None" Margin="0,7,0,0" />
                                            <TextBlock Text="{Binding Body}" Style="{StaticResource Body}"
                                                       TextWrapping="Wrap" TextTrimming="None" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="JOURNAL CLIPPINGS" Style="{StaticResource Eyebrow}" Margin="1,4,0,7"
                               Visibility="{Binding IsEmpty, Converter={StaticResource BoolCollapsed}}" />
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Panel}" Padding="0" Margin="0,0,0,10"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{DynamicResource AccentBrush}" />
                                        <StackPanel Grid.Column="1" Margin="16,13,16,14">
                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Right" Style="{StaticResource CompactChip}"
                                                        Margin="12,0,0,0" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Kind}" Style="{StaticResource Eyebrow}"
                                                               TextOptions.TextFormattingMode="Display" />
                                                </Border>
                                                <TextBlock Text="{Binding Meta}" Style="{StaticResource Mono}"
                                                           FontSize="10.5" Foreground="{DynamicResource TextMutedBrush}"
                                                           VerticalAlignment="Center" />
                                            </DockPanel>

                                            <!-- Retired journal headline expansion. -->
                                            <Button HorizontalContentAlignment="Stretch" Padding="0,7,0,3"
                                                    Background="Transparent" BorderBrush="Transparent"
                                                    Command="{Binding ToggleExpandedCommand}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Cursor" Value="Arrow" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasBody}" Value="True">
                                                                <Setter Property="Cursor" Value="Hand" />
                                                                <Setter Property="ToolTip" Value="Read the full dispatch" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Headline}" FontFamily="{StaticResource DisplayFont}"
                                                               FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"
                                                               TextTrimming="None" />
                                                    <TextBlock Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandGlyph}}"
                                                               FontFamily="{StaticResource IconFont}" FontSize="13"
                                                               Foreground="{DynamicResource AccentTextBrush}" Margin="14,2,2,0"
                                                               VerticalAlignment="Top"
                                                               Visibility="{Binding HasBody, Converter={StaticResource BoolVisible}}" />
                                                </Grid>
                                            </Button>

                                            <StackPanel Margin="0,6,0,1"
                                                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolVisible}}">
                                                <Border Height="1" Background="{DynamicResource EdgeBrush}" Margin="0,0,0,11" />
                                                <TextBlock Text="{Binding Body}" TextWrapping="Wrap" TextTrimming="None"
                                                           Style="{StaticResource Body}" />
                                                <Border Margin="0,12,0,0" Padding="10,6" CornerRadius="4"
                                                        HorizontalAlignment="Left" BorderThickness="1"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        Background="{DynamicResource AccentDimBrush}"
                                                        Visibility="{Binding HasWhy, Converter={StaticResource BoolVisible}}">
                                                    <DockPanel>
                                                        <TextBlock Text="WHY" Style="{StaticResource PixelBadge}"
                                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                                   Margin="0,1,9,0" VerticalAlignment="Top" />
                                                        <TextBlock Text="{Binding WhyText}" TextWrapping="Wrap" TextTrimming="None"
                                                                   Foreground="{DynamicResource AccentTextBrush}" FontSize="12" />
                                                    </DockPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>

    <!-- Living newsroom front page. All stories are read-only projections over the already
         deterministic dispatch and journal seams. -->
    <DockPanel x:Name='NewsFrontPage'>
        <Border x:Name='NewsMasthead' DockPanel.Dock='Top' Padding='24,12,20,10'
                AutomationProperties.Name='SMGP newsroom masthead'>
            <StackPanel>
                <Border Style='{StaticResource EditorialRule}' />
                <DockPanel Margin='0,9,0,0'>
                    <Button x:Name='PopOutButton' DockPanel.Dock='Right' Style='{StaticResource SubtleButton}'
                            audio:SoundAssist.Cue='Navigate' Click='OnPopOut' Padding='9,5'
                            ToolTip='Open the newsroom in an always-on-top companion window'
                            AutomationProperties.Name='Pop news out into its own window'>
                        <StackPanel Orientation='Horizontal'>
                            <TextBlock FontFamily='{StaticResource IconFont}' Text='&#xE8A7;' FontSize='13'
                                       VerticalAlignment='Center' Margin='0,0,7,0' />
                            <TextBlock Text='Pop out' />
                        </StackPanel>
                    </Button>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height='Auto' />
                            <RowDefinition Height='Auto' />
                            <RowDefinition Height='Auto' />
                        </Grid.RowDefinitions>
                        <DockPanel>
                            <TextBlock DockPanel.Dock='Right' Text='{Binding LeadStory.DateLabel, StringFormat=CAREER EDITION / {0}}'
                                       Style='{StaticResource Mono}' FontSize='10.5'
                                       Foreground='{DynamicResource TextMutedBrush}' Margin='10,0,0,0' />
                            <TextBlock Text='THE PADDOCK RECORD' Style='{StaticResource Eyebrow}'
                                       Foreground='{DynamicResource AccentTextBrush}' />
                        </DockPanel>
                        <StackPanel Grid.Row='1' Orientation='Horizontal' Margin='0,2,0,0'>
                            <TextBlock Text='SMGP NEWSROOM' Style='{StaticResource EditorialMasthead}' />
                            <Border x:Name='UnreadCountChip' Style='{StaticResource CompactChip}' Margin='12,2,0,0'
                                    VerticalAlignment='Center' ToolTip='Stories you have not opened yet'
                                    Visibility='{Binding HasUnread, Converter={StaticResource BoolVisible}}'>
                                <TextBlock Text='{Binding UnreadCount, Mode=OneWay, StringFormat={}{0} unread}'
                                           Style='{StaticResource Eyebrow}'
                                           Foreground='{DynamicResource AccentTextBrush}' />
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Row='2'
                                   Text='Championship reports, rivalries and paddock movement from the recorded career. Every story names its desk, status and provenance.'
                                   Style='{StaticResource Muted}' Margin='0,3,0,0' TextWrapping='Wrap' />
                    </Grid>
                </DockPanel>
            </StackPanel>
        </Border>

        <Border x:Name='NewsLoadingState' DockPanel.Dock='Top' Style='{StaticResource Panel}'
                Margin='24,4,24,14' Padding='18'
                AutomationProperties.Name='Newsroom loading'
                Visibility='{Binding IsLoading, Converter={StaticResource BoolVisible}}'>
            <StackPanel Orientation='Horizontal'>
                <TextBlock Text='&#xE895;' FontFamily='{StaticResource IconFont}' FontSize='26'
                           Foreground='{DynamicResource AccentTextBrush}' Margin='0,0,14,0' />
                <StackPanel>
                    <TextBlock Text='OPENING THE NEWS DESK' Style='{StaticResource Eyebrow}' />
                    <TextBlock Text='Reading the deterministic dispatch archive.' Style='{StaticResource Muted}'
                               Margin='0,3,0,0' />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name='NewsEmptyState' DockPanel.Dock='Top' Style='{StaticResource Panel}'
                Margin='24,4,24,20' Padding='20'
                AutomationProperties.Name='Newsroom empty'
                Visibility='{Binding IsEmpty, Converter={StaticResource BoolVisible}}'>
            <StackPanel Orientation='Horizontal'>
                <TextBlock Text='&#xE7BA;' FontFamily='{StaticResource IconFont}' FontSize='30'
                           Foreground='{DynamicResource TextMutedBrush}' Margin='0,0,14,0'
                           VerticalAlignment='Center' />
                <StackPanel>
                    <TextBlock Text='THE WIRE IS QUIET' Style='{StaticResource Eyebrow}' />
                    <TextBlock Text='Complete a race and truthful dispatches will begin filling this front page.'
                               Style='{StaticResource Muted}' TextWrapping='Wrap' MaxWidth='560' Margin='0,3,0,0' />
                </StackPanel>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name='NewsScroll' HorizontalScrollBarVisibility='Disabled'
                      VerticalScrollBarVisibility='Auto' Focusable='True'
                      AutomationProperties.Name='Newsroom front page'
                      Visibility='{Binding IsEmpty, Converter={StaticResource BoolCollapsed}}'>
            <StackPanel Margin='24,4,24,24' HorizontalAlignment='Stretch'
                        MaxWidth='{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}, Converter={StaticResource WidthFraction}, ConverterParameter=0.94|0|1500}'>
                <Border Style='{StaticResource Callout}' Padding='12,9' Margin='0,0,0,12'
                        AutomationProperties.Name='Legacy news archive notice'
                        Visibility='{Binding IsLegacyLimited, Converter={StaticResource BoolVisible}}'>
                    <DockPanel>
                        <TextBlock DockPanel.Dock='Left' Text='&#xE7BA;' FontFamily='{StaticResource IconFont}'
                                   Foreground='{DynamicResource WarningBrush}' FontSize='20' Margin='0,0,11,0' />
                        <StackPanel>
                            <TextBlock Text='LEGACY NEWS ARCHIVE - AVAILABLE RECORDS ONLY' Style='{StaticResource Eyebrow}' />
                            <TextBlock Text='Older careers can lack identity artwork and event links. Stored headlines and article text remain unchanged.'
                                       Style='{StaticResource Muted}' TextWrapping='Wrap' Margin='0,3,0,0' />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Border Style='{StaticResource Panel}' Padding='12' Margin='0,0,0,14'>
                    <DockPanel LastChildFill='True'>
                        <Button DockPanel.Dock='Right' Style='{StaticResource SubtleButton}' Padding='9,5'
                                Command='{Binding ClearFiltersCommand}' IsEnabled='{Binding HasActiveFilter}'
                                AutomationProperties.Name='Clear newsroom filters'>
                            <StackPanel Orientation='Horizontal'>
                                <TextBlock Text='&#xE711;' FontFamily='{StaticResource IconFont}' Margin='0,0,7,0' />
                                <TextBlock Text='Clear' />
                            </StackPanel>
                        </Button>
                        <WrapPanel>
                            <TextBox x:Name='NewsSearch' Width='280' MinWidth='180' Margin='0,0,8,0'
                                     Text='{Binding SearchText, UpdateSourceTrigger=PropertyChanged}'
                                     ToolTip='Search headlines, article text, drivers and teams'
                                     AutomationProperties.Name='Search newsroom stories' />
                            <ComboBox x:Name='NewsCategoryFilter' Width='230' MinWidth='170' Margin='0,0,8,0'
                                      ItemsSource='{Binding AvailableCategories}' DisplayMemberPath='DisplayText'
                                      SelectedItem='{Binding SelectedCategory}'
                                      ToolTip='Filter newsroom stories by category'
                                      AutomationProperties.Name='Newsroom category filter' />
                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- One dominant story establishes front-page hierarchy. -->
                <Button x:Name='LeadStoryButton' Style='{StaticResource SubtleButton}' Padding='0'
                        HorizontalContentAlignment='Stretch' Margin='0,0,0,16'
                        DataContext='{Binding LeadStory}'
                        Command='{Binding DataContext.OpenArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}'
                        CommandParameter='{Binding}'
                        Click='OnStoryOpened' audio:SoundAssist.Cue='Navigate'
                        AutomationProperties.Name='Open lead news story'
                        AutomationProperties.HelpText='{Binding TierLabel, Mode=OneWay}'
                        Visibility='{Binding DataContext.HasLeadStory, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolVisible}}'>
                    <Border x:Name='LeadStoryCard' Style='{StaticResource Panel}' Padding='0' ClipToBounds='True'>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height='Auto' />
                                <RowDefinition Height='Auto' />
                            </Grid.RowDefinitions>
                            <Grid x:Name='LeadStoryArt' Background='{DynamicResource SurfaceAltBrush}'>
                                <Grid.Style>
                                    <Style TargetType='Grid'>
                                        <Setter Property='Height' Value='150' />
                                        <Style.Triggers>
                                            <DataTrigger Binding='{Binding TierLabel}' Value='LEAD'>
                                                <Setter Property='Height' Value='280' />
                                            </DataTrigger>
                                            <DataTrigger Binding='{Binding TierLabel}' Value='FEATURED'>
                                                <Setter Property='Height' Value='210' />
                                            </DataTrigger>
                                            <DataTrigger Binding='{Binding TierLabel}' Value='STANDARD'>
                                                <Setter Property='Height' Value='120' />
                                            </DataTrigger>
                                            <DataTrigger Binding='{Binding TierLabel}' Value='BRIEF'>
                                                <Setter Property='Visibility' Value='Collapsed' />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Border Style='{StaticResource AssetPlaceholderFrame}' Margin='10'>
                                    <TextBlock Text='&#xE8A5;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='52' />
                                </Border>
                                <Image Stretch='UniformToFill'
                                       Source='{Binding TrackArtKey, Mode=OneWay, Converter={StaticResource TrackBannerImage}}'
                                       Visibility='{Binding HasTrackArt, Converter={StaticResource BoolVisible}}' />
                                <Image Stretch='UniformToFill'
                                       Source='{Binding TeamArtKey, Mode=OneWay, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}'
                                       Visibility='{Binding HasTeamArt, Converter={StaticResource BoolVisible}}' />
                                <Image Stretch='UniformToFill' HorizontalAlignment='Right' Width='330'
                                       Source='{Binding DriverPortraitKey, Mode=OneWay, Converter={StaticResource AssetImage}, ConverterParameter=portraits}'
                                       Visibility='{Binding HasDriverPortrait, Converter={StaticResource BoolVisible}}' />
                                <Border VerticalAlignment='Bottom' Background='{DynamicResource ScrimBrush}' Padding='14,8'>
                                    <DockPanel>
                                        <Border DockPanel.Dock='Right' Style='{StaticResource CompactChip}' Margin='12,0,0,0'>
                                            <TextBlock Text='{Binding ImportanceLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}'
                                                       Foreground='{DynamicResource TextBrush}' />
                                        </Border>
                                        <TextBlock Text='{Binding DateLabel, Mode=OneWay}' Style='{StaticResource Mono}'
                                                   Foreground='{DynamicResource TextBrush}' />
                                    </DockPanel>
                                </Border>
                            </Grid>
                            <StackPanel x:Name='LeadStoryBody' Grid.Row='1' Margin='18,15,18,18'>
                                <WrapPanel>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,7,6'
                                            Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolCollapsed}}'>
                                        <TextBlock Text='{Binding CategoryLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,7,6'
                                            Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolVisible}}'>
                                        <TextBlock Text='{Binding CategoryDetail, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,7,6'
                                            Visibility='{Binding HasRound, Converter={StaticResource BoolVisible}}'>
                                        <TextBlock Text='{Binding RoundLabel, Mode=OneWay}' Style='{StaticResource Mono}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,7,6'
                                            Visibility='{Binding HasDriver, Converter={StaticResource BoolVisible}}'>
                                        <TextBlock Text='{Binding DriverName, Mode=OneWay}' />
                                    </Border>
                                    <Border Style='{StaticResource CompactChip}' Margin='0,0,7,6'
                                            Visibility='{Binding HasTeam, Converter={StaticResource BoolVisible}}'>
                                        <TextBlock Text='{Binding TeamName, Mode=OneWay}' />
                                    </Border>
                                </WrapPanel>
                                <ContentControl Focusable='False' IsTabStop='False' Content='{Binding}'
                                                ContentTemplate='{StaticResource NewsStoryBadgesTemplate}' />
                                <TextBlock Text='{Binding Headline, Mode=OneWay}' FontFamily='{StaticResource DisplayFont}'
                                           FontWeight='Bold' TextWrapping='Wrap' TextTrimming='None'
                                           Margin='0,7,0,0'>
                                    <TextBlock.Style>
                                        <Style TargetType='TextBlock' BasedOn='{StaticResource {x:Type TextBlock}}'>
                                            <Setter Property='FontSize' Value='22' />
                                            <Style.Triggers>
                                                <DataTrigger Binding='{Binding TierLabel}' Value='LEAD'>
                                                    <Setter Property='FontSize' Value='32' />
                                                </DataTrigger>
                                                <DataTrigger Binding='{Binding TierLabel}' Value='FEATURED'>
                                                    <Setter Property='FontSize' Value='26' />
                                                </DataTrigger>
                                                <DataTrigger Binding='{Binding TierLabel}' Value='STANDARD'>
                                                    <Setter Property='FontSize' Value='19' />
                                                </DataTrigger>
                                                <DataTrigger Binding='{Binding TierLabel}' Value='BRIEF'>
                                                    <Setter Property='FontSize' Value='16' />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text='{Binding Deck, Mode=OneWay}' Style='{StaticResource Muted}'
                                           FontSize='16' FontStyle='Italic' TextWrapping='Wrap' TextTrimming='None'
                                           Margin='0,7,0,0'
                                           Visibility='{Binding HasDeck, Converter={StaticResource BoolVisible}}' />
                                <TextBlock Text='{Binding Standfirst, Mode=OneWay}' Style='{StaticResource Body}'
                                           FontSize='15' TextWrapping='Wrap' TextTrimming='None' Margin='0,8,0,0'
                                           Visibility='{Binding HasStandfirst, Converter={StaticResource BoolVisible}}' />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Button>

                <TextBlock Text='TOP DISPATCHES' Style='{StaticResource H2}' Margin='0,0,0,9'
                           Visibility='{Binding HasSecondaryStories, Converter={StaticResource BoolVisible}}' />
                <ItemsControl ItemsSource='{Binding SecondaryStories}'
                              ItemTemplate='{StaticResource NewsSecondaryStoryTemplate}'
                              Visibility='{Binding HasSecondaryStories, Converter={StaticResource BoolVisible}}'>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <Border x:Name='NewsFilteredEmptyState' Style='{StaticResource Callout}' Padding='14,11'
                        Margin='0,4,0,12' AutomationProperties.Name='No newsroom stories match the filters'
                        Visibility='{Binding IsFilteredEmpty, Converter={StaticResource BoolVisible}}'>
                    <TextBlock Text='No recorded stories match this search and category. Clear the filters to restore the full desk.'
                               Style='{StaticResource Muted}' TextWrapping='Wrap' />
                </Border>

                <!-- Developing-story threads: the desk's remembered narratives, derived read-only
                     from the same deterministic event spine as the wire itself. -->
                <Expander x:Name='ThreadsRail' IsExpanded='True' Margin='0,10,0,10'
                          AutomationProperties.Name='Developing stories rail'
                          Visibility='{Binding HasThreads, Converter={StaticResource BoolVisible}}'>
                    <Expander.Header>
                        <StackPanel Margin='4,0,0,0'>
                            <TextBlock Text='DEVELOPING STORIES' Style='{StaticResource H2}' />
                            <TextBlock Text='Running storylines the desk keeps returning to, round after round.'
                                       Style='{StaticResource Muted}' Margin='0,3,0,0' />
                        </StackPanel>
                    </Expander.Header>
                    <ItemsControl x:Name='ThreadsList' ItemsSource='{Binding Threads}' Margin='0,10,0,0'
                                  VirtualizingPanel.IsVirtualizing='True'
                                  VirtualizingPanel.VirtualizationMode='Recycling'>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style='{StaticResource Card}' Margin='0,0,0,8'>
                                    <StackPanel>
                                        <DockPanel LastChildFill='True'>
                                            <WrapPanel DockPanel.Dock='Right' Margin='10,0,0,0'>
                                                <Border Style='{StaticResource CompactChip}' Margin='0,0,5,0'>
                                                    <TextBlock Text='{Binding TypeLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                                </Border>
                                                <!-- the lifecycle chip always carries its state as text; the accent
                                                     frame only underlines an ACTIVE thread, never replaces the word -->
                                                <Border>
                                                    <Border.Style>
                                                        <Style TargetType='Border' BasedOn='{StaticResource CompactChip}'>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding='{Binding IsActive}' Value='True'>
                                                                    <Setter Property='Background' Value='{DynamicResource AccentDimBrush}' />
                                                                    <Setter Property='BorderBrush' Value='{DynamicResource AccentBrush}' />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text='{Binding StateLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                                </Border>
                                            </WrapPanel>
                                            <TextBlock Text='{Binding Title, Mode=OneWay}' FontFamily='{StaticResource DisplayFont}'
                                                       FontWeight='SemiBold' FontSize='16' TextWrapping='Wrap' TextTrimming='None' />
                                        </DockPanel>
                                        <TextBlock Text='{Binding LatestSummary, Mode=OneWay}' Style='{StaticResource Muted}'
                                                   TextWrapping='Wrap' TextTrimming='None' Margin='0,5,0,0'
                                                   Visibility='{Binding LatestSummary, Mode=OneWay, Converter={StaticResource StringVisible}}' />
                                        <ItemsControl ItemsSource='{Binding Entries}' Margin='0,8,0,0'>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <DockPanel Margin='0,0,0,4' LastChildFill='True'>
                                                        <Border DockPanel.Dock='Left' Style='{StaticResource CompactChip}'
                                                                Margin='0,0,8,0' VerticalAlignment='Top'>
                                                            <TextBlock Text='{Binding Round, Mode=OneWay, StringFormat=R{0}}'
                                                                       Style='{StaticResource Mono}' FontSize='10' />
                                                        </Border>
                                                        <TextBlock Text='{Binding Summary, Mode=OneWay}' Style='{StaticResource Body}'
                                                                   FontSize='12.5' TextWrapping='Wrap' TextTrimming='None' />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!-- Rumour desk: fact-backed whispers that always READ as speculation - the
                     status chip is unconditional, and resolution links a later story rather
                     than rewriting the original claim. -->
                <Expander x:Name='RumourRail' IsExpanded='True' Margin='0,0,0,10'
                          AutomationProperties.Name='Paddock Whispers rumour column'
                          Visibility='{Binding HasRumors, Converter={StaticResource BoolVisible}}'>
                    <Expander.Header>
                        <DockPanel x:Name='RumourColumnMasthead' Margin='4,0,0,0'>
                            <Border DockPanel.Dock='Left' Style='{StaticResource CompactChip}'
                                    Background='{DynamicResource WarningDimBrush}'
                                    BorderBrush='{DynamicResource WarningBrush}' Padding='7,5'
                                    Margin='0,0,10,0' VerticalAlignment='Top'>
                                <TextBlock Text='PW' Style='{StaticResource PixelBadge}'
                                           Foreground='{DynamicResource WarningBrush}' />
                            </Border>
                            <Border DockPanel.Dock='Right' Style='{StaticResource CompactChip}'
                                    Margin='10,0,0,0' VerticalAlignment='Top'>
                                <TextBlock Text='SPECULATION / NOT CONFIRMED' Style='{StaticResource Eyebrow}' />
                            </Border>
                            <StackPanel>
                                <TextBlock Text='PADDOCK WHISPERS' Style='{StaticResource H2}' />
                                <TextBlock Text='The rumour column preserves speculation as speculation until the record resolves it.'
                                           Style='{StaticResource Muted}' Margin='0,3,0,0' TextWrapping='Wrap' />
                            </StackPanel>
                        </DockPanel>
                    </Expander.Header>
                    <ItemsControl x:Name='RumourList' ItemsSource='{Binding Rumors}' Margin='0,10,0,0'
                                  VirtualizingPanel.IsVirtualizing='True'
                                  VirtualizingPanel.VirtualizationMode='Recycling'>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style='{StaticResource QuoteCard}'>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width='3' />
                                            <ColumnDefinition Width='*' />
                                        </Grid.ColumnDefinitions>
                                        <Border Background='{DynamicResource WarningBrush}' CornerRadius='1' />
                                        <StackPanel Grid.Column='1' Margin='11,0,0,0'>
                                        <DockPanel LastChildFill='True'>
                                            <!-- ALWAYS visible: a rumour must never read as settled fact -->
                                            <Border DockPanel.Dock='Right' Margin='10,0,0,0' VerticalAlignment='Top'>
                                                <Border.Style>
                                                    <Style TargetType='Border' BasedOn='{StaticResource CompactChip}'>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding='{Binding IsOpen}' Value='True'>
                                                                <Setter Property='Background' Value='{DynamicResource WarningDimBrush}' />
                                                                <Setter Property='BorderBrush' Value='{DynamicResource WarningBrush}' />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text='{Binding StatusLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                            </Border>
                                            <TextBlock Text='PADDOCK WHISPERS / REPORTED TALK' Style='{StaticResource Eyebrow}'
                                                       VerticalAlignment='Center' />
                                        </DockPanel>
                                        <TextBlock Text='{Binding Claim, Mode=OneWay}' Style='{StaticResource Body}'
                                                   FontStyle='Italic' TextWrapping='Wrap' TextTrimming='None'
                                                   Margin='0,6,0,0' />
                                        <TextBlock Text='{Binding ResolutionNote, Mode=OneWay}' Style='{StaticResource Muted}'
                                                   TextWrapping='Wrap' TextTrimming='None' Margin='0,6,0,0'
                                                   Visibility='{Binding HasResolution, Converter={StaticResource BoolVisible}}' />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander>

                <!-- Bookmarks: the reader-kept shelf, same card language as the archive. -->
                <Expander x:Name='BookmarksRail' IsExpanded='True' Margin='0,0,0,10'
                          AutomationProperties.Name='Bookmarked stories rail'
                          Visibility='{Binding HasBookmarks, Converter={StaticResource BoolVisible}}'>
                    <Expander.Header>
                        <StackPanel Margin='4,0,0,0'>
                            <TextBlock Text='BOOKMARKS' Style='{StaticResource H2}' />
                            <TextBlock Text='Stories you chose to keep - saved with the career.'
                                       Style='{StaticResource Muted}' Margin='0,3,0,0' />
                        </StackPanel>
                    </Expander.Header>
                    <ItemsControl x:Name='BookmarksList' ItemsSource='{Binding BookmarkedStories}'
                                  ItemTemplate='{StaticResource NewsArchiveStoryTemplate}' Margin='0,10,0,0'
                                  VirtualizingPanel.IsVirtualizing='True'
                                  VirtualizingPanel.VirtualizationMode='Recycling'>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Expander>

                <TextBlock Text='LATEST DISPATCHES' Style='{StaticResource H2}' Margin='0,12,0,4' />
                <TextBlock Text='The complete searchable career desk, newest first.' Style='{StaticResource Muted}'
                           Margin='0,0,0,9' />
                <ItemsControl ItemsSource='{Binding FilteredStories}'
                              ItemTemplate='{StaticResource NewsArchiveStoryTemplate}'
                              VirtualizingPanel.IsVirtualizing='True'
                              VirtualizingPanel.VirtualizationMode='Recycling'>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>

    <!-- Article reader: one scrollable, keyboard-dismissable layer over the live desk. -->
    <Grid x:Name='ArticleReader' Panel.ZIndex='20' Background='{DynamicResource ScrimBrush}'
          Visibility='{Binding IsReaderOpen, Converter={StaticResource BoolVisible}}'
          AutomationProperties.Name='News article reader'>
        <Border Style='{StaticResource Panel}' Margin='24' Padding='0' MaxWidth='980'
                HorizontalAlignment='Center' VerticalAlignment='Stretch'
                DataContext='{Binding SelectedArticle}'>
            <DockPanel>
                <Border DockPanel.Dock='Top' Padding='14,10' Background='{DynamicResource SurfaceAltBrush}'
                        BorderBrush='{DynamicResource EdgeBrush}' BorderThickness='0,0,0,1'>
                    <DockPanel>
                        <Button x:Name='ArticleCloseButton' DockPanel.Dock='Right'
                                Style='{StaticResource CloseButton}'
                                Command='{Binding DataContext.CloseArticleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}'
                                Click='OnArticleClosed' audio:SoundAssist.Cue='Back'
                                AutomationProperties.Name='Close news article' />
                        <!-- Bookmark toggle: the live BookmarkedStories overlay drives the filled
                             state (its Count re-triggers the binding); the word always spells the
                             state out, the glyph only echoes it. -->
                        <Button x:Name='ArticleBookmarkButton' DockPanel.Dock='Right'
                                Style='{StaticResource SubtleButton}' Margin='0,0,10,0' Padding='9,5'
                                VerticalAlignment='Center'
                                Command='{Binding DataContext.ToggleBookmarkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}'
                                CommandParameter='{Binding}'
                                ToolTip='Keep this article on the BOOKMARKS rail of the front page'
                                AutomationProperties.Name='Toggle article bookmark'>
                            <StackPanel Orientation='Horizontal'>
                                <TextBlock FontFamily='{StaticResource IconFont}' FontSize='12'
                                           Margin='0,0,7,0' VerticalAlignment='Center'>
                                    <TextBlock.Style>
                                        <Style TargetType='TextBlock' BasedOn='{StaticResource {x:Type TextBlock}}'>
                                            <Setter Property='Text' Value='&#xE734;' />
                                            <Style.Triggers>
                                                <DataTrigger Value='True'>
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter='{StaticResource NewsBookmarkState}'>
                                                            <Binding Path='DataContext.BookmarkedStories' RelativeSource='{RelativeSource AncestorType=UserControl}' />
                                                            <Binding Path='DataContext.BookmarkedStories.Count' RelativeSource='{RelativeSource AncestorType=UserControl}' />
                                                            <Binding />
                                                            <Binding Path='IsBookmarked' />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property='Text' Value='&#xE735;' />
                                                    <Setter Property='Foreground' Value='{DynamicResource AccentTextBrush}' />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock VerticalAlignment='Center'>
                                    <TextBlock.Style>
                                        <Style TargetType='TextBlock' BasedOn='{StaticResource {x:Type TextBlock}}'>
                                            <Setter Property='Text' Value='BOOKMARK' />
                                            <Style.Triggers>
                                                <DataTrigger Value='True'>
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter='{StaticResource NewsBookmarkState}'>
                                                            <Binding Path='DataContext.BookmarkedStories' RelativeSource='{RelativeSource AncestorType=UserControl}' />
                                                            <Binding Path='DataContext.BookmarkedStories.Count' RelativeSource='{RelativeSource AncestorType=UserControl}' />
                                                            <Binding />
                                                            <Binding Path='IsBookmarked' />
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property='Text' Value='BOOKMARKED' />
                                                    <Setter Property='Foreground' Value='{DynamicResource AccentTextBrush}' />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <StackPanel Orientation='Horizontal'>
                            <Border Style='{StaticResource CompactChip}' Margin='0,0,9,0'
                                    Background='{DynamicResource AccentDimBrush}'
                                    BorderBrush='{DynamicResource AccentBrush}'
                                    Visibility='{Binding HasDesk, Converter={StaticResource BoolVisible}}'>
                                <TextBlock Text='{Binding DeskMonogram}' Style='{StaticResource PixelBadge}'
                                           Foreground='{DynamicResource AccentTextBrush}' />
                            </Border>
                            <StackPanel>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType='TextBlock' BasedOn='{StaticResource Eyebrow}'>
                                            <Setter Property='Text' Value='SMGP NEWSROOM' />
                                            <Style.Triggers>
                                                <DataTrigger Binding='{Binding HasDesk}' Value='True'>
                                                    <Setter Property='Text' Value='{Binding DeskName}' />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text='{Binding CategoryLabel, Mode=OneWay}' Style='{StaticResource Faint}'
                                           Margin='0,2,0,0'
                                           Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolCollapsed}}' />
                                <TextBlock Text='{Binding CategoryDetail, Mode=OneWay}' Style='{StaticResource Faint}'
                                           Margin='0,2,0,0'
                                           Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolVisible}}' />
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ScrollViewer x:Name='ArticleReaderScroll' HorizontalScrollBarVisibility='Disabled'
                              VerticalScrollBarVisibility='Auto' Focusable='True'
                              AutomationProperties.Name='Article content'>
                    <StackPanel>
                        <Grid Height='250' Background='{DynamicResource SurfaceAltBrush}'>
                            <Border Style='{StaticResource AssetPlaceholderFrame}' Margin='10'>
                                <TextBlock Text='&#xE8A5;' Style='{StaticResource AssetPlaceholderGlyph}' FontSize='50' />
                            </Border>
                            <Image Stretch='UniformToFill'
                                   Source='{Binding TrackArtKey, Mode=OneWay, Converter={StaticResource TrackBannerImage}}'
                                   Visibility='{Binding HasTrackArt, Converter={StaticResource BoolVisible}}' />
                            <Image Stretch='UniformToFill'
                                   Source='{Binding TeamArtKey, Mode=OneWay, Converter={StaticResource TeamAssetImage}, ConverterParameter=smgp/teams}'
                                   Visibility='{Binding HasTeamArt, Converter={StaticResource BoolVisible}}' />
                            <Image Stretch='UniformToFill' HorizontalAlignment='Right' Width='320'
                                   Source='{Binding DriverPortraitKey, Mode=OneWay, Converter={StaticResource AssetImage}, ConverterParameter=portraits}'
                                   Visibility='{Binding HasDriverPortrait, Converter={StaticResource BoolVisible}}' />
                            <Image Stretch='Uniform' HorizontalAlignment='Left' VerticalAlignment='Bottom'
                                   Width='390' Margin='18,0,0,10'
                                   Source='{Binding CarArtKey, Mode=OneWay, Converter={StaticResource AssetImage}, ConverterParameter=cars}'
                                   Visibility='{Binding HasCarArt, Converter={StaticResource BoolVisible}}' />
                            <Border VerticalAlignment='Bottom' Background='{DynamicResource ScrimBrush}' Padding='14,7'>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock='Right' Text='{Binding ImportanceLabel, Mode=OneWay}'
                                               Style='{StaticResource Eyebrow}' Foreground='{DynamicResource TextBrush}' />
                                    <TextBlock Text='{Binding DateLabel, Mode=OneWay}' Style='{StaticResource Mono}'
                                               Foreground='{DynamicResource TextBrush}' />
                                </DockPanel>
                            </Border>
                        </Grid>

                        <StackPanel Margin='24,20,24,28' MaxWidth='820' HorizontalAlignment='Center'>
                            <WrapPanel>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,7,7'
                                        Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolCollapsed}}'>
                                    <TextBlock Text='{Binding CategoryLabel, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                </Border>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,7,7'
                                        Visibility='{Binding HasCategoryDetail, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding CategoryDetail, Mode=OneWay}' Style='{StaticResource Eyebrow}' />
                                </Border>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,7,7'
                                        Visibility='{Binding HasRound, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding RoundLabel, Mode=OneWay}' Style='{StaticResource Mono}' />
                                </Border>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,7,7'
                                        Visibility='{Binding HasVenue, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding VenueName, Mode=OneWay}' />
                                </Border>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,7,7'
                                        Visibility='{Binding HasDriver, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding DriverName, Mode=OneWay}' />
                                </Border>
                                <Border Style='{StaticResource CompactChip}' Margin='0,0,7,7'
                                        Visibility='{Binding HasTeam, Converter={StaticResource BoolVisible}}'>
                                    <TextBlock Text='{Binding TeamName, Mode=OneWay}' />
                                </Border>
                            </WrapPanel>

                            <ContentControl Focusable='False' IsTabStop='False' Content='{Binding}'
                                            ContentTemplate='{StaticResource NewsStoryBadgesTemplate}' />
                            <Border x:Name='ArticleByline' Style='{StaticResource EditorialColumn}'
                                    Margin='0,12,0,0'
                                    Visibility='{Binding HasDesk, Converter={StaticResource BoolVisible}}'
                                    AutomationProperties.Name='Article filing desk and status'>
                                <DockPanel>
                                    <Border DockPanel.Dock='Left' Style='{StaticResource ProvenanceChip}'
                                            Margin='0,0,10,0' VerticalAlignment='Center'>
                                        <TextBlock Text='{Binding DeskMonogram}' Style='{StaticResource PixelBadge}'
                                                   Foreground='{DynamicResource AccentTextBrush}' />
                                    </Border>
                                    <Border DockPanel.Dock='Right' Style='{StaticResource CompactChip}'
                                            Margin='10,0,0,0' VerticalAlignment='Center'
                                            Visibility='{Binding HasStatus, Converter={StaticResource BoolVisible}}'>
                                        <TextBlock Text='{Binding StatusLabel}' Style='{StaticResource Eyebrow}' />
                                    </Border>
                                    <StackPanel>
                                        <TextBlock Text='FILED BY' Style='{StaticResource Eyebrow}' />
                                        <TextBlock Text='{Binding DeskName}' FontFamily='{StaticResource DisplayFont}'
                                                   FontSize='15' FontWeight='SemiBold' Margin='0,2,0,0' />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <TextBlock Text='{Binding Headline, Mode=OneWay}' FontFamily='{StaticResource DisplayFont}'
                                       FontSize='31' FontWeight='Bold' TextWrapping='Wrap' TextTrimming='None'
                                       Margin='0,8,0,0'
                                       AutomationProperties.Name='{Binding Headline, Mode=OneWay}' />
                            <TextBlock Text='{Binding Deck, Mode=OneWay}' Style='{StaticResource Muted}'
                                       FontSize='15.5' FontStyle='Italic' TextWrapping='Wrap' TextTrimming='None'
                                       Margin='0,7,0,0'
                                       Visibility='{Binding HasDeck, Converter={StaticResource BoolVisible}}' />
                            <TextBlock Text='{Binding Standfirst, Mode=OneWay}' Style='{StaticResource Body}'
                                       FontSize='16' FontWeight='SemiBold' TextWrapping='Wrap' TextTrimming='None'
                                       Margin='0,11,0,0'
                                       Visibility='{Binding HasStandfirst, Converter={StaticResource BoolVisible}}' />
                            <Border Height='1' Background='{DynamicResource EdgeBrush}' Margin='0,18,0,17' />
                            <Border BorderBrush='{DynamicResource AccentBrush}' BorderThickness='3,0,0,0'
                                    Padding='15,1,0,1'
                                    Visibility='{Binding HasBody, Converter={StaticResource BoolVisible}}'>
                                <TextBlock Text='{Binding Body, Mode=OneWay}' Style='{StaticResource Body}'
                                           FontSize='14.5' LineHeight='22' TextWrapping='Wrap' TextTrimming='None' />
                            </Border>

                            <Border Style='{StaticResource Callout}' Padding='12,9' Margin='0,18,0,0'
                                    Visibility='{Binding HasWhy, Converter={StaticResource BoolVisible}}'>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock='Left' Text='WHY' Style='{StaticResource PixelBadge}'
                                               Foreground='{DynamicResource AccentTextBrush}' Margin='0,1,10,0' />
                                    <TextBlock Text='{Binding WhyText, Mode=OneWay}' Style='{StaticResource Muted}'
                                               TextWrapping='Wrap' TextTrimming='None' />
                                </DockPanel>
                            </Border>

                            <Button x:Name='HistoryLinkButton' Style='{StaticResource SubtleButton}'
                                    HorizontalAlignment='Left' Margin='0,20,0,0' Padding='12,7'
                                    Tag='{Binding HistoryEventKey, Mode=OneWay}' Click='OnOpenHistory'
                                    audio:SoundAssist.Cue='Navigate'
                                    AutomationProperties.Name='Open the related History event'
                                    Visibility='{Binding HasHistoryLink, Converter={StaticResource BoolVisible}}'>
                                <StackPanel Orientation='Horizontal'>
                                    <TextBlock Text='&#xE81C;' FontFamily='{StaticResource IconFont}' Margin='0,0,8,0' />
                                    <TextBlock Text='Open related History event' />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
    </Grid>
</UserControl>
