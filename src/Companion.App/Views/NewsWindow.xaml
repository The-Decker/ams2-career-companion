<Window x:Class="Companion.App.Views.NewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Companion.App.Views"
        xmlns:app="clr-namespace:Companion.App"
        xmlns:audio="clr-namespace:Companion.App.Audio"
        Title="SMGP Newsroom"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="None"
        ResizeMode="CanResize"
        Width="560" Height="720"
        MinWidth="420" MinHeight="360"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{StaticResource BodyFont}" FontSize="{DynamicResource AppFontSize}">
    <!-- the SAME NewsViewModel as the hub's News tab (set as DataContext on open), so the
         torn-off window stays in sync as rounds apply. Read-only mirror → zero state cost.
         The root UI-scale transform (settings: font scale) keeps this pop-out in step with the
         main window's text size. -->
    <Grid Background="{StaticResource AppTextureBrush}">
        <Border Background="{StaticResource AppVignetteBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1">
            <DockPanel>
                <Border DockPanel.Dock="Top" Height="34" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1"
                        app:WindowChromeAssist.IsDragRegion="True">
                    <DockPanel Margin="10,2,3,2">
                        <Button DockPanel.Dock="Right" Style="{StaticResource CloseButton}"
                                audio:SoundAssist.Cue="Back"
                                app:WindowChromeAssist.IsCloseButton="True"
                                AutomationProperties.Name="Close paddock news" />
                        <TextBlock Text="SMGP NEWSROOM" Style="{StaticResource Eyebrow}" FontSize="11"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>
                <Grid>
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{DynamicResource AppUiScale}" ScaleY="{DynamicResource AppUiScale}" />
                    </Grid.LayoutTransform>
                    <views:NewsView />
                </Grid>
            </DockPanel>
        </Border>
    </Grid>
</Window>
