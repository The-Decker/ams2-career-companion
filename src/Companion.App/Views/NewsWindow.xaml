<Window x:Class="Companion.App.Views.NewsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Companion.App.Views"
        Title="Paddock news"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        Width="400" Height="540"
        MinWidth="300" MinHeight="240"
        Background="{StaticResource BgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <!-- the SAME NewsViewModel as the hub's News tab (set as DataContext on open), so the
         torn-off window stays in sync as rounds apply. Read-only mirror → zero state cost.
         The root UI-scale transform (settings: font scale) keeps this pop-out in step with the
         main window's text size. -->
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{DynamicResource AppUiScale}" ScaleY="{DynamicResource AppUiScale}" />
        </Grid.LayoutTransform>
        <views:NewsView />
    </Grid>
</Window>
