<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:app="clr-namespace:Companion.App"
                    xmlns:conv="clr-namespace:Companion.App.Converters">

    <!-- Compatibility facade. The runtime selector replaces only the first two dictionaries;
         stable fonts, converters, SMGP art, styles, and templates remain instantiated. -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Theme.Dark.xaml" />
        <ResourceDictionary Source="Accents/Dark/Accent.RoyalBlue.xaml" />
        <ResourceDictionary Source="Smgp.Track.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Root font size; every window binds through DynamicResource. -->
    <sys:Double x:Key="AppFontSize">15</sys:Double>

    <!-- Theme-agnostic embedded type system. Static font instances keep WPF weight selection
         deterministic inside the self-contained executable. -->
    <FontFamily x:Key="DisplayFont">/Fonts/#Orbitron</FontFamily>
    <FontFamily x:Key="BodyFont">/Fonts/#Inter</FontFamily>
    <FontFamily x:Key="PixelFont">/Fonts/#Press Start 2P</FontFamily>
    <FontFamily x:Key="MonoFont">/Fonts/#JetBrains Mono</FontFamily>
    <FontFamily x:Key="IconFont">Segoe MDL2 Assets</FontFamily>
    <FontFamily x:Key="AltDisplayFont">/Fonts/#Chakra Petch</FontFamily>
    <FontFamily x:Key="AltBodyFont">/Fonts/#Saira</FontFamily>
    <FontFamily x:Key="AltPixelFont">/Fonts/#Silkscreen</FontFamily>

    <!-- root UI scale (settings: font scale 90–130% ÷ 100). Every window's root LayoutTransform
         multiplies by this, so ALL text + spacing scales uniformly — inline font sizes, headings
         and the tear-off windows included, not just inherited body text. App.ApplyAppearance
         replaces the value on change (live); 1 = no scaling. -->
    <sys:Double x:Key="AppUiScale">1</sys:Double>

    <!-- ===== motion (tactile "game feel": controls physically respond to touch) =====
         Shared easing curves so every interaction springs with one consistent vocabulary.
         SpringOut overshoots then settles — the satisfying "pop" on release; the others are
         quick, natural accelerations for press-down and hover. Durations are short (80–450ms)
         so the app feels crisp, never sluggish. -->
    <BackEase x:Key="SpringOut" EasingMode="EaseOut" Amplitude="0.55" />
    <BackEase x:Key="SpringOutSoft" EasingMode="EaseOut" Amplitude="0.32" />
    <CubicEase x:Key="EaseOut" EasingMode="EaseOut" />
    <QuadraticEase x:Key="EaseIn" EasingMode="EaseIn" />

    <!-- ===== converters (shared by every view) ===== -->
    <conv:NullToVisibilityConverter x:Key="NullCollapsed" />
    <conv:BoolToVisibilityConverter x:Key="BoolVisible" />
    <conv:BoolToVisibilityConverter x:Key="BoolCollapsed" Invert="True" />
    <conv:NegateBoolConverter x:Key="InverseBool" />
    <conv:CountToVisibilityConverter x:Key="CountVisible" />
    <conv:CountToVisibilityConverter x:Key="CountCollapsed" Invert="True" />
    <conv:StringToVisibilityConverter x:Key="StringVisible" />
    <conv:EnumEqualsToVisibilityConverter x:Key="EnumVisible" />
    <conv:AlternationPositionConverter x:Key="AltPosition" />
    <conv:DnfReasonConverter x:Key="DnfReason" />
    <conv:DsqReasonLabelConverter x:Key="DsqReasonLabel" />
    <conv:StringEqualsToVisibilityConverter x:Key="StringEqualsVisible" />
    <conv:GlyphBrushConverter x:Key="GlyphBrush" />
    <conv:CandidatesVisibilityConverter x:Key="CandidatesVisible" />
    <conv:EraAccentBrushConverter x:Key="EraAccent" />
    <conv:HexBrushConverter x:Key="HexBrush" />
    <conv:EraLabelConverter x:Key="EraLabel" />
    <conv:EraImageConverter x:Key="EraImage" />
    <conv:TrackImageConverter x:Key="TrackImage" />
    <conv:ExpandGlyphConverter x:Key="ExpandGlyph" />
    <conv:KeyedAssetImageConverter x:Key="AssetImage" />
    <conv:CircuitGeometryConverter x:Key="CircuitGeometry" />
    <conv:AspectRatioHeightConverter x:Key="AspectHeight" />
    <conv:WidthFractionConverter x:Key="WidthFraction" />
    <conv:WidthToColumnsConverter x:Key="WidthToColumns" />

    <!-- ===== typography ===== -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
    <Style x:Key="H1" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style x:Key="H2" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style x:Key="Body" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="Muted" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style x:Key="Faint" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{DynamicResource TextFaintBrush}" />
        <Setter Property="FontSize" Value="12" />
    </Style>
    <Style x:Key="Mono" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
    </Style>
    <Style x:Key="Eyebrow" TargetType="TextBlock" BasedOn="{StaticResource Faint}">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="10" />
    </Style>
    <Style x:Key="StatValue" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="FontSize" Value="22" />
    </Style>
    <Style x:Key="PixelBadge" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource PixelFont}" />
        <Setter Property="FontSize" Value="8" />
        <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <!-- ===== keyboard focus ring (ux-round §2/§4 focus-visuals audit) =====
         FocusVisualStyle only renders for KEYBOARD focus (Tab/arrows), so mouse users never
         see it — every focusable control below opts in so the ring is never lost. -->
    <Style x:Key="FocusRing">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Margin="-2" RadiusX="4" RadiusY="4" SnapsToDevicePixels="True"
                               StrokeThickness="1.5" Stroke="{DynamicResource AccentBrush}"
                               StrokeDashArray="1.5 1.5" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== panels / chips ===== -->
    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Effect" Value="{StaticResource PanelElevationEffect}" />
    </Style>
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style x:Key="Card" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>
    <Style x:Key="StatTile" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="MinWidth" Value="88" />
    </Style>
    <Style x:Key="CompactChip" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,3" />
    </Style>
    <Style x:Key="QuoteCard" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style x:Key="Callout" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style x:Key="AccentCallout" TargetType="Border" BasedOn="{StaticResource Callout}">
        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>
    <Style x:Key="SuccessCallout" TargetType="Border" BasedOn="{StaticResource Callout}">
        <Setter Property="Background" Value="{DynamicResource SuccessDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}" />
    </Style>
    <Style x:Key="WarningCallout" TargetType="Border" BasedOn="{StaticResource Callout}">
        <Setter Property="Background" Value="{DynamicResource WarningDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}" />
    </Style>
    <Style x:Key="ErrorCallout" TargetType="Border" BasedOn="{StaticResource Callout}">
        <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
    </Style>
    <Style x:Key="AssetPlaceholderFrame" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
    <Style x:Key="AssetPlaceholderGlyph" TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Opacity" Value="0.42" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ===== buttons ===== -->
    <Style TargetType="Button">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="420" />
        <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        <!-- every button radiates a click-point ripple (fails safe; see MotionAssist) -->
        <Setter Property="app:MotionAssist.Ripple" Value="True" />
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <!-- content alignment must be TEMPLATE-BOUND (below), not hard-coded: full-width list
             buttons (calendar round headers) set Stretch and it has to actually apply. These two
             setters keep the classic centered look for every ordinary button. -->
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- RenderTransform (post-layout) so the press/hover scale never nudges
                         neighbouring controls — the button just feels like it moves. -->
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1" />
                                <TranslateTransform x:Name="PressTranslate" Y="0" />
                            </TransformGroup>
                        </Grid.RenderTransform>
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Effect="{StaticResource ControlElevationEffect}" />
                        <Border x:Name="HoverOverlay"
                                Background="{DynamicResource ControlHoverOverlayBrush}"
                                Opacity="0" CornerRadius="5" />
                        <Border x:Name="PressedInset"
                                BorderBrush="{DynamicResource ShadowBrush}"
                                BorderThickness="0,2,0,0" Opacity="0" CornerRadius="5" />
                        <!-- click-point ripple host (behaviour-driven; see MotionAssist.Ripple) -->
                        <Border x:Name="RippleHost" CornerRadius="5" ClipToBounds="True" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- hover: a subtle lift (scale up) + faint wash -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0.08" Duration="0:0:0.11" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1.01" Duration="0:0:0.11" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1.01" Duration="0:0:0.11" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="PressTranslate" Storyboard.TargetProperty="Y" To="-1" Duration="0:0:0.11" EasingFunction="{StaticResource EaseOut}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.10" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.10" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.10" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="PressTranslate" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.10" EasingFunction="{StaticResource EaseOut}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- press: a quick, firm depress; release SPRINGS back with an overshoot -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0.17" Duration="0:0:0.09" />
                                        <DoubleAnimation Storyboard.TargetName="PressedInset" Storyboard.TargetProperty="Opacity" To="0.48" Duration="0:0:0.09" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="0.99" Duration="0:0:0.09" EasingFunction="{StaticResource EaseIn}" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="0.99" Duration="0:0:0.09" EasingFunction="{StaticResource EaseIn}" />
                                        <DoubleAnimation Storyboard.TargetName="PressTranslate" Storyboard.TargetProperty="Y" To="1" Duration="0:0:0.09" EasingFunction="{StaticResource EaseIn}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay" Storyboard.TargetProperty="Opacity" To="0.08" Duration="0:0:0.10" />
                                        <DoubleAnimation Storyboard.TargetName="PressedInset" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.10" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleX" To="1.01" Duration="0:0:0.18" EasingFunction="{StaticResource SpringOutSoft}" />
                                        <DoubleAnimation Storyboard.TargetName="PressScale" Storyboard.TargetProperty="ScaleY" To="1.01" Duration="0:0:0.18" EasingFunction="{StaticResource SpringOutSoft}" />
                                        <DoubleAnimation Storyboard.TargetName="PressTranslate" Storyboard.TargetProperty="Y" To="-1" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource OnAccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style x:Key="SubtleButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>
    <Style x:Key="SelectableSubtleButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="10,7" />
    </Style>
    <Style x:Key="RailNavButton" TargetType="Button" BasedOn="{StaticResource SelectableSubtleButton}">
        <Setter Property="Margin" Value="0,2" />
        <Setter Property="MinHeight" Value="38" />
    </Style>
    <!-- icon-only button (ux-round §4 consistent iconography): Segoe MDL2 glyph content.
         Every use MUST set ToolTip + AutomationProperties.Name — the glyph alone says nothing. -->
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="8,5" />
    </Style>
    <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="Content" Value="&#xE8BB;" />
        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="Background" Value="{DynamicResource ErrorDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="ToolTip" Value="Close" />
    </Style>
    <!-- ===== text box ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== combo box ===== -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Chrome" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SelectionBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="420" />
        <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Toggle" Focusable="False" ClickMode="Press"
                                      Background="{DynamicResource FieldBrush}"
                                      BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="ToggleChrome" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5"
                                            Effect="{StaticResource ControlElevationEffect}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="22" />
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Data="M0,0 L8,0 L4,5 Z" Fill="{DynamicResource TextMutedBrush}" />
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ToggleChrome" Property="BorderBrush" Value="{DynamicResource EdgeStrongBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="ToggleChrome" Property="Margin" Value="0,1,0,-1" />
                                            <Setter TargetName="ToggleChrome" Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ToggleChrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          TextElement.Foreground="{DynamicResource TextBrush}"
                                          Margin="10,0,26,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                        <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False" PopupAnimation="Fade">
                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource EdgeBrush}"
                                    BorderThickness="1" CornerRadius="5" Margin="0,2,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Toggle" Property="BorderBrush" Value="{DynamicResource EdgeStrongBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Toggle" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Toggle" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ===== list box ===== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
    </Style>
    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="420" />
        <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid Margin="0,1">
                        <Border x:Name="Chrome" Background="Transparent" CornerRadius="4" />
                        <!-- hover paints an overlay so it can fade ~150ms (ux-round §4);
                             selection stays instant on the Chrome underneath -->
                        <Border x:Name="HoverOverlay" Background="{DynamicResource SurfaceAltBrush}"
                                Opacity="0" CornerRadius="4" />
                        <Border x:Name="SelectionEdge" Width="3" HorizontalAlignment="Left"
                                Background="{DynamicResource AccentBrush}" Opacity="0" CornerRadius="2" />
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SelectionBrush}" />
                            <Setter TargetName="HoverOverlay" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="SelectionEdge" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== tabs ===== -->
    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="0,0,0,1">
                            <TabPanel IsItemsHost="True" Background="Transparent" />
                        </Border>
                        <ContentPresenter ContentSource="SelectedContent" Margin="0,14,0,0" />
                    </DockPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Tab headers are keyboard peers of the mouse (locked decision 8): a TabItem is
         Focusable/IsTabStop so Tab, the arrow keys and Ctrl+Tab reach and switch tabs, with a
         keyboard-focus highlight drawn on the header itself. (A prior build set
         Focusable=False, which silently killed keyboard tab switching on the standings screen —
         the Drivers, Constructors and Round-matrix tabs could only be reached with the mouse.) -->
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="420" />
        <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Chrome" Background="Transparent" BorderBrush="Transparent"
                            BorderThickness="0,0,0,2" Padding="14,8" Cursor="Hand">
                        <ContentPresenter ContentSource="Header"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          TextBlock.FontSize="15" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                        </Trigger>
                        <!-- keyboard focus highlight: only paints for Tab/arrow focus, never for
                             the mouse, so keyboard users can always see which tab is active -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource AccentDimBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== check box ===== -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="420" />
        <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent" Margin="{TemplateBinding Padding}">
                        <Border x:Name="Box" Width="17" Height="17" CornerRadius="3"
                                Background="{DynamicResource FieldBrush}"
                                BorderBrush="{DynamicResource EdgeBrush}" BorderThickness="1"
                                VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BoxScale" ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <!-- the tick starts collapsed to a point and POPS in on check -->
                            <Path x:Name="Check" Data="M 3 8 L 7 12 L 13 4"
                                  Stroke="{DynamicResource OnAccentBrush}"
                                  StrokeThickness="2" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="CheckScale" ScaleX="0" ScaleY="0" />
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.32" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.32" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="BoxScale" Storyboard.TargetProperty="ScaleX" From="0.8" To="1" Duration="0:0:0.3" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="BoxScale" Storyboard.TargetProperty="ScaleY" From="0.8" To="1" Duration="0:0:0.3" EasingFunction="{StaticResource SpringOut}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="0:0:0.12" EasingFunction="{StaticResource EaseIn}" />
                                        <DoubleAnimation Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.12" EasingFunction="{StaticResource EaseIn}" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentDimBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Radio options share the checkbox hit target but use a physical circular well. -->
    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="ToolTipService.InitialShowDelay" Value="420" />
        <Setter Property="ToolTipService.ShowDuration" Value="12000" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
        <Setter Property="Padding" Value="3" />
        <Setter Property="MinHeight" Value="26" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal" Background="Transparent" Margin="{TemplateBinding Padding}">
                        <Border x:Name="Well" Width="18" Height="18" CornerRadius="9"
                                Background="{DynamicResource FieldBrush}"
                                BorderBrush="{DynamicResource EdgeStrongBrush}" BorderThickness="1"
                                VerticalAlignment="Center">
                            <Ellipse x:Name="Dot" Width="8" Height="8" Fill="{DynamicResource AccentBrush}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0" />
                        </Border>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Well" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter TargetName="Well" Property="Background" Value="{DynamicResource AccentDimBrush}" />
                            <Setter TargetName="Dot" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Well" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Dot" Property="Width" Value="6" />
                            <Setter TargetName="Dot" Property="Height" Value="6" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== tooltip ===== -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Placement" Value="Mouse" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="5" Padding="{TemplateBinding Padding}"
                            Effect="{StaticResource ControlElevationEffect}">
                        <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== rating bar (wizard seat pick: skills as bars, raw numbers on hover) ===== -->
    <Style x:Key="RatingBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Minimum" Value="0" />
        <Setter Property="Maximum" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource FieldBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Grid>
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}" CornerRadius="3" />
                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}"
                                CornerRadius="3" HorizontalAlignment="Left" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== context menus (right-click parity: MRU, standings column chooser) ===== -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Template">
            <Setter.Value>
                <!-- flat items only (no submenus in this app's context menus) -->
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="CheckGlyph" Text="✓" Margin="4,0,0,0" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentTextBrush}" Visibility="Hidden" />
                            <ContentPresenter Grid.Column="1" ContentSource="Header"
                                              Margin="{TemplateBinding Padding}" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource SelectionBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Separator">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="6,4" />
        <Setter Property="Background" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== slider (settings: font scale, default difficulty) ===== -->
    <Style x:Key="SliderRepeatFill" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="4" CornerRadius="2" Background="{DynamicResource AccentBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SliderRepeatTrack" TargetType="RepeatButton">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="4" CornerRadius="2" Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SliderThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <!-- the thumb grows under the finger and lights a soft accent halo while
                         grabbed — a dial you can feel take hold. -->
                    <Grid RenderTransformOrigin="0.5,0.5" Background="Transparent">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="ThumbScale" ScaleX="1" ScaleY="1" />
                        </Grid.RenderTransform>
                        <Ellipse x:Name="Glow" Width="26" Height="26" Fill="{DynamicResource AccentBrush}" Opacity="0" />
                        <Ellipse Width="14" Height="14" Fill="{DynamicResource AccentBrush}"
                                 Stroke="{DynamicResource OnAccentBrush}" StrokeThickness="1" Cursor="Hand" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleX" To="1.18" Duration="0:0:0.15" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleY" To="1.18" Duration="0:0:0.15" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.16" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2" EasingFunction="{StaticResource EaseOut}" />
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleX" To="1.4" Duration="0:0:0.3" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleY" To="1.4" Duration="0:0:0.3" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0.28" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.35" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="ThumbScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.35" EasingFunction="{StaticResource SpringOut}" />
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.25" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusRing}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Border Height="4" CornerRadius="2" Background="{DynamicResource EdgeBrush}"
                                VerticalAlignment="Center" />
                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderRepeatFill}"
                                              Command="{x:Static Slider.DecreaseLarge}" />
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderRepeatTrack}"
                                              Command="{x:Static Slider.IncreaseLarge}" />
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SliderThumbStyle}" />
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== virtualized flat list (ux-round §4: big grids) =====
         ItemsControl does NOT virtualize by default; this style gives it a virtualizing
         panel and its own item-scrolling ScrollViewer. Use for long flat tables (standings
         rows, round points) — NOT for lists whose row template depends on AlternationIndex
         (virtualization renumbers realized containers). -->
    <!-- ===== scroll bars ===== -->
    <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="MinWidth" Value="8" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbChrome" Background="{DynamicResource EdgeStrongBrush}"
                            CornerRadius="4" Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track" Orientation="Vertical" IsDirectionReversed="True"
                   Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                   Value="{TemplateBinding Value}" ViewportSize="{TemplateBinding ViewportSize}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButton}"
                                  Command="{x:Static ScrollBar.PageUpCommand}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButton}"
                                  Command="{x:Static ScrollBar.PageDownCommand}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>
    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Background="{TemplateBinding Background}">
            <Track x:Name="PART_Track" Orientation="Horizontal"
                   Minimum="{TemplateBinding Minimum}" Maximum="{TemplateBinding Maximum}"
                   Value="{TemplateBinding Value}" ViewportSize="{TemplateBinding ViewportSize}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButton}"
                                  Command="{x:Static ScrollBar.PageLeftCommand}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumb}" MinWidth="24" MinHeight="8" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButton}"
                                  Command="{x:Static ScrollBar.PageRightCommand}" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="12" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="12" />
                <Setter Property="MinHeight" Value="12" />
                <Setter Property="Width" Value="Auto" />
                <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="VirtualizedList" TargetType="ItemsControl">
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ItemsControl">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False"
                                  CanContentScroll="True">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== first-run coach mark (ux-round §4): a dismissable accent callout =====
         Views put an info glyph + text + a "Got it" button inside; visibility binds to
         HomeViewModel.CoachMarks with FallbackValue=Collapsed (never shows where the
         coach-mark state is out of reach, e.g. the compact checklist window). -->
    <Style x:Key="CoachMark" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,9" />
    </Style>
    <Style x:Key="CoachMarkGlyph" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{StaticResource IconFont}" />
        <Setter Property="Text" Value="&#xE946;" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Margin" Value="0,2,10,0" />
    </Style>

</ResourceDictionary>
