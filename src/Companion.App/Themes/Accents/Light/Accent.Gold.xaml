<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Gold · light-base accessible preset. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#7A5600" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#624500" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#7A5600" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="#247A5600" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#337A5600" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF" />
</ResourceDictionary>
