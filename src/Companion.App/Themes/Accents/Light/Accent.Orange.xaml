<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Orange · light-base accessible preset. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#A84700" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#8A3A00" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#A84700" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="#24A84700" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#33A84700" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF" />
</ResourceDictionary>
