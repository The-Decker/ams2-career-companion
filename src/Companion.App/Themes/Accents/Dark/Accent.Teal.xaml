<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Teal · dark-base accessible preset. -->
    <SolidColorBrush x:Key="AccentBrush" Color="#2CC7B5" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#4BD6C5" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#42CEBD" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="#332CC7B5" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#4D2CC7B5" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="#101318" />
</ResourceDictionary>
