<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Companion.App.Converters"
                    xmlns:career="clr-namespace:Companion.Core.Career;assembly=Companion.Core"
                    xmlns:views="clr-namespace:Companion.App.Views">

    <!-- ======================================================================
         ERA MEDIUM: EMAIL (season years 1994+)
         The clean inbox skin: dark ink on white, a light sender row with an
         accent bar and an envelope glyph. PaperTextureKey is "" for this medium
         (a clean, texture-less surface), so the paper brush is a flat solid.
         Tokens are MEDIUM-PREFIXED so all three era dictionaries merge together
         without a key collision; the shared document contract at the bottom keys
         its swap on EraMedium via DataTrigger ("immersive docs, legible tools":
         only document surfaces take this skin).

         Typography: the contract font stack (Segoe UI, Arial, sans-serif) is an
         OS stack, every supported Windows box carries at least one face, so no
         era-doc font is bundled (see Assets/Era/README.md for the licensing
         call).
         ====================================================================== -->

    <!-- ===== email tokens ===== -->
    <Color x:Key="EraEmailPaperColor">#FAFBFD</Color>
    <Color x:Key="EraEmailInkColor">#1E2A38</Color>

    <!-- A clean, texture-less surface: PaperTextureKey "" maps to a flat paper brush. -->
    <SolidColorBrush x:Key="EraEmailPaperBrush" Color="#FAFBFD" />
    <SolidColorBrush x:Key="EraEmailPaperSolidBrush" Color="#FAFBFD" />
    <SolidColorBrush x:Key="EraEmailBandBrush" Color="#EEF3FA" />
    <SolidColorBrush x:Key="EraEmailInkBrush" Color="#1E2A38" />
    <SolidColorBrush x:Key="EraEmailInkFaintBrush" Color="#5A6B7E" />
    <SolidColorBrush x:Key="EraEmailAccentBrush" Color="#3B7DD8" />
    <SolidColorBrush x:Key="EraEmailAccentDimBrush" Color="#333B7DD8" />
    <SolidColorBrush x:Key="EraEmailChromeBrush" Color="#C9D6E6" />
    <FontFamily x:Key="EraEmailDocFont">Segoe UI, Arial, sans-serif</FontFamily>

    <!-- The inbox letterhead: a light sender row with the accent bar and an
         envelope glyph, the letterhead line in the clean sans and the medium
         label at the right. Binds the document view-model (Letterhead +
         EraSkin.Label). -->
    <DataTemplate x:Key="EraEmailLetterhead">
        <Border Background="{DynamicResource EraEmailBandBrush}"
                BorderBrush="{DynamicResource EraEmailChromeBrush}" BorderThickness="0,0,0,1"
                Padding="12,8" CornerRadius="4,4,0,0">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Left" Width="4" CornerRadius="2" Margin="0,0,10,0"
                        Background="{DynamicResource EraEmailAccentBrush}" />
                <Canvas DockPanel.Dock="Left" Width="18" Height="14" Margin="0,1,10,0"
                        VerticalAlignment="Center">
                    <Rectangle Width="18" Height="14" RadiusX="1.5" RadiusY="1.5"
                               Stroke="{DynamicResource EraEmailAccentBrush}" StrokeThickness="1.6" />
                    <Line X1="1.5" Y1="2" X2="9" Y2="8"
                          Stroke="{DynamicResource EraEmailAccentBrush}" StrokeThickness="1.4" />
                    <Line X1="16.5" Y1="2" X2="9" Y2="8"
                          Stroke="{DynamicResource EraEmailAccentBrush}" StrokeThickness="1.4" />
                </Canvas>
                <TextBlock DockPanel.Dock="Right" Text="{Binding EraSkin.Label}" Margin="12,0,0,0"
                           FontFamily="{DynamicResource EraEmailDocFont}" FontSize="10" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource EraEmailAccentBrush}" />
                <TextBlock Text="{Binding Letterhead}" FontFamily="{DynamicResource EraEmailDocFont}"
                           FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"
                           Foreground="{DynamicResource EraEmailInkBrush}"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- ======================================================================
         SHARED ERA-DOCUMENT CONTRACT (identical block in Era.Telegram.xaml,
         Era.Fax.xaml and Era.Email.xaml): merge any one dictionary and the full
         swap is present; merging all three is a no-op for these keys (the last
         identical definition wins). Document surfaces key on the flattened
         EraMedium via DataTrigger; typography and accent bind EraSkin directly
         so a data/rules/era-themes.json decade override still restyles them.
         Every trigger pair ends with the EraThemingEnabled gate trigger LAST,
         so the master switch restores neutral chrome when off.
         ====================================================================== -->
    <conv:EraThemingGateConverter x:Key="EraThemingGate" />

    <!-- The plain letterhead (gate off, or a surface with no medium). -->
    <DataTemplate x:Key="EraNeutralLetterhead">
        <TextBlock Text="{Binding Letterhead}" FontWeight="SemiBold" FontSize="13"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
    </DataTemplate>

    <!-- The document surface: neutral panel by default, period paper per medium. -->
    <Style x:Key="EraDocumentSurface" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Background" Value="{DynamicResource EraTelegramPaperBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EraTelegramChromeBrush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius" Value="2" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Background" Value="{DynamicResource EraFaxPaperBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EraFaxChromeBrush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius" Value="2" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Background" Value="{DynamicResource EraEmailPaperBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EraEmailChromeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The letterhead band: swaps the whole per-medium DataTemplate. -->
    <Style x:Key="EraDocumentLetterhead" TargetType="ContentControl">
        <Setter Property="Content" Value="{Binding}" />
        <Setter Property="ContentTemplate" Value="{DynamicResource EraNeutralLetterhead}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="ContentTemplate" Value="{DynamicResource EraTelegramLetterhead}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="ContentTemplate" Value="{DynamicResource EraFaxLetterhead}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="ContentTemplate" Value="{DynamicResource EraEmailLetterhead}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="ContentTemplate" Value="{DynamicResource EraNeutralLetterhead}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Document headline: the era document face + ink on paper. -->
    <Style x:Key="EraDocumentHeadline" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{Binding EraSkin.DocumentFontStack}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Foreground" Value="{DynamicResource EraTelegramInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Foreground" Value="{DynamicResource EraFaxInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Foreground" Value="{DynamicResource EraEmailInkBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Document body copy: the era document face + ink on paper. -->
    <Style x:Key="EraDocumentBody" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{Binding EraSkin.DocumentFontStack}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Foreground" Value="{DynamicResource EraTelegramInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Foreground" Value="{DynamicResource EraFaxInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Foreground" Value="{DynamicResource EraEmailInkBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The dateline: small era face, faint ink. -->
    <Style x:Key="EraDocumentDateline" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{Binding EraSkin.DocumentFontStack}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Foreground" Value="{DynamicResource EraTelegramInkFaintBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Foreground" Value="{DynamicResource EraFaxInkFaintBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Foreground" Value="{DynamicResource EraEmailInkFaintBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The section rule inside a document. -->
    <Style x:Key="EraDocumentRule" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="Margin" Value="0,12,0,12" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Height" Value="2" />
                <Setter Property="Background" Value="{DynamicResource EraTelegramChromeBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Background" Value="{DynamicResource EraFaxChromeBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Background" Value="{DynamicResource EraEmailChromeBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Height" Value="1" />
                <Setter Property="Background" Value="{DynamicResource EdgeBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- An accent frame inside a document (quote/callout edge): era accent hex, so a
         decade override restamps it; neutral edge when the gate is off. -->
    <Style x:Key="EraDocumentAccentFrame" TargetType="Border">
        <Setter Property="BorderBrush" Value="{Binding EraSkin.AccentHex, Converter={StaticResource HexBrush}}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Style.Triggers>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The reusable period offer letter (era-theming-assets-brief.md A4 shape): the
         offer's facts composed as the era document, wherever offers appear. The
         accept action stays with the hosting screen; this is the document only. -->
    <DataTemplate x:Key="EraOfferDocumentTemplate">
        <Border Style="{StaticResource EraDocumentSurface}" Padding="0" Margin="0,4">
            <StackPanel>
                <ContentControl Style="{StaticResource EraDocumentLetterhead}" />
                <StackPanel Margin="16,10,16,14">
                    <TextBlock Text="{Binding Dateline}" Style="{StaticResource EraDocumentDateline}" />
                    <Border Style="{StaticResource EraDocumentRule}" />
                    <TextBlock Text="{Binding BodyText}" Style="{StaticResource EraDocumentBody}"
                               FontSize="13.5" LineHeight="20" />
                    <WrapPanel Margin="0,12,0,0">
                        <Border Style="{StaticResource CompactChip}" Margin="0,0,6,0">
                            <TextBlock Text="{Binding TierText}" Style="{StaticResource Mono}" FontSize="10.5" />
                        </Border>
                        <Border Style="{StaticResource CompactChip}">
                            <TextBlock Text="{Binding SalaryText}" Style="{StaticResource Mono}" FontSize="10.5" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
