<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- A purpose-built light hierarchy: white elevated cards over a cool neutral canvas,
         dark field text, explicit borders, and readable muted tones. -->
    <SolidColorBrush x:Key="BgBrush" Color="#F4F6FA" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#E9EDF4" />
    <SolidColorBrush x:Key="FieldBrush" Color="#F9FAFC" />
    <SolidColorBrush x:Key="EdgeBrush" Color="#CCD3DE" />
    <SolidColorBrush x:Key="EdgeStrongBrush" Color="#98A3B3" />

    <SolidColorBrush x:Key="TextBrush" Color="#151922" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#343B47" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#596373" />
    <SolidColorBrush x:Key="TextFaintBrush" Color="#697486" />

    <SolidColorBrush x:Key="AccentBrush" Color="#285CC4" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#214DA7" />
    <SolidColorBrush x:Key="AccentTextBrush" Color="#285CC4" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="#24285CC4" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#33285CC4" />
    <SolidColorBrush x:Key="OnAccentBrush" Color="#FFFFFF" />

    <SolidColorBrush x:Key="SuccessBrush" Color="#267A45" />
    <SolidColorBrush x:Key="SuccessDimBrush" Color="#E2F3E8" />
    <SolidColorBrush x:Key="WarningBrush" Color="#8A5B00" />
    <SolidColorBrush x:Key="WarningDimBrush" Color="#FFF1CF" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#B42332" />
    <SolidColorBrush x:Key="ErrorDimBrush" Color="#FBE4E7" />

    <SolidColorBrush x:Key="ControlHoverOverlayBrush" Color="#0B0D12" />
    <SolidColorBrush x:Key="OverlaySurfaceBrush" Color="#F2FFFFFF" />
    <SolidColorBrush x:Key="OverlaySurfaceAltBrush" Color="#EEF4F6FA" />
    <SolidColorBrush x:Key="ScrimBrush" Color="#730B0D12" />
    <SolidColorBrush x:Key="ShadowBrush" Color="#330B0D12" />

    <LinearGradientBrush x:Key="MediaCaptionGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Offset="0" Color="#00000000" />
        <GradientStop Offset="1" Color="#CC000000" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="OnMediaBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="OnMediaMutedBrush" Color="#E6FFFFFF" />
    <SolidColorBrush x:Key="TeamColorScrimBrush" Color="#73000000" />
    <SolidColorBrush x:Key="OnTeamColorBrush" Color="#FFFFFF" />
</ResourceDictionary>
