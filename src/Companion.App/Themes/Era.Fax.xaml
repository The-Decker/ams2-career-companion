<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:Companion.App.Converters"
                    xmlns:career="clr-namespace:Companion.Core.Career;assembly=Companion.Core"
                    xmlns:views="clr-namespace:Companion.App.Views">

    <!-- ======================================================================
         ERA MEDIUM: FAX (season years 1980-1993)
         The slate thermal-paper skin: blue-gray ink on warm white, a dark sender
         band letterhead and fine thermal banding. Tokens are MEDIUM-PREFIXED so
         all three era dictionaries merge together without a key collision; the
         shared document contract at the bottom keys its swap on EraMedium via
         DataTrigger ("immersive docs, legible tools": only document surfaces
         take this skin).

         Typography: the contract font stack (Cascadia Mono, Consolas, monospace)
         is an OS stack, every supported Windows box carries at least one face,
         so no era-doc font is bundled (see Assets/Era/README.md for the
         licensing call). The thermal grain is a vector DrawingBrush tile (lean,
         packaging-free); the matching raster master lives at
         Assets/Era/thermal-grain.png.
         ====================================================================== -->

    <!-- ===== fax tokens ===== -->
    <Color x:Key="EraFaxPaperColor">#F1EEE4</Color>
    <Color x:Key="EraFaxInkColor">#222B33</Color>

    <SolidColorBrush x:Key="EraFaxPaperSolidBrush" Color="#F1EEE4" />
    <SolidColorBrush x:Key="EraFaxBandBrush" Color="#46586A" />
    <SolidColorBrush x:Key="EraFaxBandTextBrush" Color="#F1EEE4" />
    <SolidColorBrush x:Key="EraFaxInkBrush" Color="#222B33" />
    <SolidColorBrush x:Key="EraFaxInkFaintBrush" Color="#5C6B77" />
    <SolidColorBrush x:Key="EraFaxAccentBrush" Color="#5E7A8C" />
    <SolidColorBrush x:Key="EraFaxAccentDimBrush" Color="#335E7A8C" />
    <SolidColorBrush x:Key="EraFaxChromeBrush" Color="#46586A" />
    <FontFamily x:Key="EraFaxDocFont">Cascadia Mono, Consolas, monospace</FontFamily>

    <!-- The thermal roll itself: a tileable vector grain (twin of
         Assets/Era/thermal-grain.png) over the paper color, one Background brush. -->
    <DrawingBrush x:Key="EraFaxPaperBrush" TileMode="Tile"
                  Viewport="0,0,96,96" ViewportUnits="Absolute" Stretch="None"
                  AlignmentX="Left" AlignmentY="Top">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="#F1EEE4">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,96,96" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#0F46586A">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="0,0,96,1" />
                            <RectangleGeometry Rect="0,6,96,1" />
                            <RectangleGeometry Rect="0,12,96,1" />
                            <RectangleGeometry Rect="0,18,96,1" />
                            <RectangleGeometry Rect="0,24,96,1" />
                            <RectangleGeometry Rect="0,30,96,1" />
                            <RectangleGeometry Rect="0,36,96,1" />
                            <RectangleGeometry Rect="0,42,96,1" />
                            <RectangleGeometry Rect="0,48,96,1" />
                            <RectangleGeometry Rect="0,54,96,1" />
                            <RectangleGeometry Rect="0,60,96,1" />
                            <RectangleGeometry Rect="0,66,96,1" />
                            <RectangleGeometry Rect="0,72,96,1" />
                            <RectangleGeometry Rect="0,78,96,1" />
                            <RectangleGeometry Rect="0,84,96,1" />
                            <RectangleGeometry Rect="0,90,96,1" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#1646586A">
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <RectangleGeometry Rect="14,26,2,2" />
                            <RectangleGeometry Rect="52,8,2,2" />
                            <RectangleGeometry Rect="78,52,2,2" />
                            <RectangleGeometry Rect="30,70,2,2" />
                            <RectangleGeometry Rect="64,86,2,2" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <!-- The fax letterhead: the dark sender band with cut-out stripes at the left,
         the letterhead line in the memo face and the medium label at the right.
         Binds the document view-model (Letterhead + EraSkin.Label). -->
    <DataTemplate x:Key="EraFaxLetterhead">
        <Border Background="{DynamicResource EraFaxBandBrush}" Padding="14,9"
                CornerRadius="2,2,0,0">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Border Width="4" Height="18" Margin="0,0,4,0"
                            Background="{DynamicResource EraFaxBandTextBrush}" />
                    <Border Width="6" Height="18" Margin="0,0,4,0"
                            Background="{DynamicResource EraFaxBandTextBrush}" />
                    <Border Width="4" Height="18"
                            Background="{DynamicResource EraFaxBandTextBrush}" />
                </StackPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding EraSkin.Label}" Margin="12,0,0,0"
                           FontFamily="{DynamicResource EraFaxDocFont}" FontSize="10" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource EraFaxBandTextBrush}" />
                <TextBlock Text="{Binding Letterhead}" FontFamily="{DynamicResource EraFaxDocFont}"
                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center"
                           Foreground="{DynamicResource EraFaxBandTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- ======================================================================
         SHARED ERA-DOCUMENT CONTRACT (identical block in Era.Telegram.xaml,
         Era.Fax.xaml and Era.Email.xaml): merge any one dictionary and the full
         swap is present; merging all three is a no-op for these keys (the last
         identical definition wins). Document surfaces key on the flattened
         EraMedium via DataTrigger; typography and accent bind EraSkin directly
         so a data/rules/era-themes.json decade override still restyles them.
         Every trigger pair ends with the EraThemingEnabled gate trigger LAST,
         so the master switch restores neutral chrome when off.
         ====================================================================== -->
    <conv:EraThemingGateConverter x:Key="EraThemingGate" />

    <!-- The plain letterhead (gate off, or a surface with no medium). -->
    <DataTemplate x:Key="EraNeutralLetterhead">
        <TextBlock Text="{Binding Letterhead}" FontWeight="SemiBold" FontSize="13"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
    </DataTemplate>

    <!-- The document surface: neutral panel by default, period paper per medium. -->
    <Style x:Key="EraDocumentSurface" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Background" Value="{DynamicResource EraTelegramPaperBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EraTelegramChromeBrush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius" Value="2" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Background" Value="{DynamicResource EraFaxPaperBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EraFaxChromeBrush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius" Value="2" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Background" Value="{DynamicResource EraEmailPaperBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EraEmailChromeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource EdgeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The letterhead band: swaps the whole per-medium DataTemplate. -->
    <Style x:Key="EraDocumentLetterhead" TargetType="ContentControl">
        <Setter Property="Content" Value="{Binding}" />
        <Setter Property="ContentTemplate" Value="{DynamicResource EraNeutralLetterhead}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="ContentTemplate" Value="{DynamicResource EraTelegramLetterhead}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="ContentTemplate" Value="{DynamicResource EraFaxLetterhead}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="ContentTemplate" Value="{DynamicResource EraEmailLetterhead}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="ContentTemplate" Value="{DynamicResource EraNeutralLetterhead}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Document headline: the era document face + ink on paper. -->
    <Style x:Key="EraDocumentHeadline" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{Binding EraSkin.DocumentFontStack}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Foreground" Value="{DynamicResource EraTelegramInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Foreground" Value="{DynamicResource EraFaxInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Foreground" Value="{DynamicResource EraEmailInkBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="FontFamily" Value="{StaticResource DisplayFont}" />
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Document body copy: the era document face + ink on paper. -->
    <Style x:Key="EraDocumentBody" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{Binding EraSkin.DocumentFontStack}" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="TextTrimming" Value="None" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Foreground" Value="{DynamicResource EraTelegramInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Foreground" Value="{DynamicResource EraFaxInkBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Foreground" Value="{DynamicResource EraEmailInkBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The dateline: small era face, faint ink. -->
    <Style x:Key="EraDocumentDateline" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="FontFamily" Value="{Binding EraSkin.DocumentFontStack}" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Foreground" Value="{DynamicResource EraTelegramInkFaintBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Foreground" Value="{DynamicResource EraFaxInkFaintBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Foreground" Value="{DynamicResource EraEmailInkFaintBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The section rule inside a document. -->
    <Style x:Key="EraDocumentRule" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource EdgeBrush}" />
        <Setter Property="Margin" Value="0,12,0,12" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Telegram}">
                <Setter Property="Height" Value="2" />
                <Setter Property="Background" Value="{DynamicResource EraTelegramChromeBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Fax}">
                <Setter Property="Background" Value="{DynamicResource EraFaxChromeBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding EraMedium}" Value="{x:Static career:EraMedium.Email}">
                <Setter Property="Background" Value="{DynamicResource EraEmailChromeBrush}" />
            </DataTrigger>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Height" Value="1" />
                <Setter Property="Background" Value="{DynamicResource EdgeBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- An accent frame inside a document (quote/callout edge): era accent hex, so a
         decade override restamps it; neutral edge when the gate is off. -->
    <Style x:Key="EraDocumentAccentFrame" TargetType="Border">
        <Setter Property="BorderBrush" Value="{Binding EraSkin.AccentHex, Converter={StaticResource HexBrush}}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Style.Triggers>
            <DataTrigger Value="False">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EraThemingGate}">
                        <Binding Path="DataContext.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=views:HubView}" />
                        <Binding Path="Tag.EraThemingEnabled"
                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The reusable period offer letter (era-theming-assets-brief.md A4 shape): the
         offer's facts composed as the era document, wherever offers appear. The
         accept action stays with the hosting screen; this is the document only. -->
    <DataTemplate x:Key="EraOfferDocumentTemplate">
        <Border Style="{StaticResource EraDocumentSurface}" Padding="0" Margin="0,4">
            <StackPanel>
                <ContentControl Style="{StaticResource EraDocumentLetterhead}" />
                <StackPanel Margin="16,10,16,14">
                    <TextBlock Text="{Binding Dateline}" Style="{StaticResource EraDocumentDateline}" />
                    <Border Style="{StaticResource EraDocumentRule}" />
                    <TextBlock Text="{Binding BodyText}" Style="{StaticResource EraDocumentBody}"
                               FontSize="13.5" LineHeight="20" />
                    <WrapPanel Margin="0,12,0,0">
                        <Border Style="{StaticResource CompactChip}" Margin="0,0,6,0">
                            <TextBlock Text="{Binding TierText}" Style="{StaticResource Mono}" FontSize="10.5" />
                        </Border>
                        <Border Style="{StaticResource CompactChip}">
                            <TextBlock Text="{Binding SalaryText}" Style="{StaticResource Mono}" FontSize="10.5" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
