<Window x:Class="Companion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMS2 Career Companion"
        Width="1120" Height="740"
        MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI" FontSize="14"
        TextOptions.TextFormattingMode="Display">
    <DockPanel>
        <!-- shell-level failure banner (e.g. a career file that would not open) -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource ErrorDimBrush}"
                Visibility="{Binding StatusError, Converter={StaticResource NullCollapsed}}">
            <TextBlock Text="{Binding StatusError}" Foreground="{StaticResource ErrorBrush}"
                       Margin="16,8" TextWrapping="Wrap" />
        </Border>

        <!-- the conductor: Start / wizard / Home resolve through App.xaml's DataTemplates -->
        <ContentControl Content="{Binding Current}" Focusable="False" />
    </DockPanel>
</Window>
