<Window x:Class="Companion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Companion.App"
        Title="AMS2 Career Companion"
        Width="1120" Height="740"
        MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI" FontSize="{DynamicResource AppFontSize}"
        TextOptions.TextFormattingMode="Display"
        PreviewKeyDown="OnPreviewKeyDown">
    <DockPanel>
        <!-- shell header: app identity + the settings gear (ux-round contract section 3) -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource EdgeBrush}" BorderThickness="0,0,0,1">
            <DockPanel Margin="12,3">
                <Button DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                        FontFamily="Segoe MDL2 Assets" Content="&#xE713;" FontSize="15" Padding="8,5"
                        AutomationProperties.Name="Settings"
                        ToolTip="Settings — appearance, racing defaults, staging behavior, data folders (click again or press Esc to close)"
                        Command="{Binding ToggleSettingsCommand}" />
                <TextBlock Text="AMS2 CAREER COMPANION" Style="{StaticResource Faint}"
                           VerticalAlignment="Center" Margin="4,0,0,0" FontSize="11" />
            </DockPanel>
        </Border>

        <!-- shell-level failure banner (e.g. a career file that would not open) -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource ErrorDimBrush}"
                Visibility="{Binding StatusError, Converter={StaticResource NullCollapsed}}">
            <TextBlock Text="{Binding StatusError}" Foreground="{StaticResource ErrorBrush}"
                       Margin="16,8" TextWrapping="Wrap" />
        </Border>

        <!-- the conductor: Start / wizard / Home / Settings resolve through App.xaml's DataTemplates.
             Each screen fades + slides in on navigation (MotionAssist.Entrance). -->
        <ContentControl Content="{Binding Current}" Focusable="False"
                        RenderTransformOrigin="0.5,0.5" app:MotionAssist.Entrance="True" />
    </DockPanel>
</Window>
