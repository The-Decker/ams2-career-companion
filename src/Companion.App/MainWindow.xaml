<Window x:Class="Companion.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AMS2 Career Companion — dev preview"
        Width="720" Height="460"
        WindowStartupLocation="CenterScreen"
        Background="#1B1B1F">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AMS2 Career Companion"
                   FontSize="28" FontWeight="SemiBold" Foreground="#F2F2F5" />
        <TextBlock Grid.Row="1" x:Name="VersionText"
                   FontSize="13" Foreground="#9A9AA5" Margin="0,4,0,20" />

        <StackPanel Grid.Row="2">
            <TextBlock x:Name="InstallText" FontSize="15" Foreground="#D8D8DE"
                       TextWrapping="Wrap" Margin="0,0,0,10" />
            <TextBlock x:Name="LiveriesText" FontSize="15" Foreground="#D8D8DE"
                       TextWrapping="Wrap" Margin="0,0,0,10" />
            <TextBlock x:Name="CustomAiText" FontSize="15" Foreground="#D8D8DE"
                       TextWrapping="Wrap" Margin="0,0,0,10" />
        </StackPanel>

        <TextBlock Grid.Row="3" Foreground="#6E6E78" FontSize="12" TextWrapping="Wrap"
                   Text="Dev preview — the career UI (new-career wizard, race-day briefing, result entry, standings) is milestone M4 and lands next. Engine status: points engine oracle-verified against all 77 F1 seasons; 1967 + 1988 reference packs; grid generation proven against this machine's install." />
    </Grid>
</Window>
